# Standalone JSON assets exported for end-users to deploy by hand.
# `npm run build` does not consume these — the SPA reads JSON straight from `installer/`.
# Excluding ~10MB of duplicate JSON shaves the build context noticeably.
assets/

# Pre-rendered NDJSON dashboards, only used by the legacy CLI installer (index-legacy.mjs).
# The Vite build and the runtime SPA never read this directory.
installer/aws-custom-dashboards/ndjson/

# (aws-elastic-integration + aws-apm-integration are tiny; keeping them avoids any client quirks
# with patterns that start with installer/aws-* and accidentally skipping aws-custom-* trees.)
