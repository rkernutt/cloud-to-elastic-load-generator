{
  "name": "cloud-to-elastic-load-generator",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite-node scripts/verify-setup-bundles.mjs",
    "preview": "vite preview",
    "samples": "vite-node scripts/export-samples.mjs && vite-node scripts/export-gcp-samples.mjs && vite-node scripts/export-azure-samples.mjs",
    "samples:verify": "vite-node scripts/verify-samples.mjs && vite-node scripts/verify-gcp-samples.mjs && vite-node scripts/verify-azure-samples.mjs",
    "copy-icons": "vite-node scripts/sync-aws-icons.mjs",
    "icons:audit": "vite-node scripts/list-used-icons.mjs",
    "icons:vendor": "node scripts/build-vendor-icon-maps.mjs",
    "assets:export": "node scripts/export-standalone-assets.mjs && prettier --write --log-level=warn assets/",
    "postinstall": "npm run copy-icons",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run && npm run samples && npm run samples:verify",
    "test:watch": "vitest",
    "setup:aws-integration": "node installer/aws-elastic-integration/index.mjs",
    "setup:aws-pipelines": "node installer/aws-custom-pipelines/index.mjs",
    "setup:aws-dashboards": "node installer/aws-custom-dashboards/index.mjs",
    "setup:aws-dashboards:legacy": "node installer/aws-custom-dashboards/index-legacy.mjs",
    "generate:aws-dashboards:ndjson": "node installer/aws-custom-dashboards/generate-ndjson.mjs",
    "setup:aws-ml-jobs": "node installer/aws-custom-ml-jobs/index.mjs",
    "setup:aws-loadgen-packs": "node installer/aws-loadgen-packs/index.mjs",
    "setup:aws-apm-integration": "node installer/aws-apm-integration/index.mjs",
    "setup:gcp-integration": "node installer/gcp-elastic-integration/index.mjs",
    "setup:gcp-pipelines": "node installer/gcp-custom-pipelines/index.mjs",
    "setup:gcp-dashboards": "node installer/gcp-custom-dashboards/index.mjs",
    "setup:gcp-ml-jobs": "node installer/gcp-custom-ml-jobs/index.mjs",
    "setup:azure-integration": "node installer/azure-elastic-integration/index.mjs",
    "setup:azure-pipelines": "node installer/azure-custom-pipelines/index.mjs",
    "setup:azure-dashboards": "node installer/azure-custom-dashboards/index.mjs",
    "setup:azure-ml-jobs": "node installer/azure-custom-ml-jobs/index.mjs",
    "setup:alert-rules": "node installer/alert-rules-installer/index.mjs",
    "setup:workflow": "node installer/workflow-installer/index.mjs",
    "gen:gcp-pipelines": "vite-node scripts/generate-gcp-pipeline-registry.mjs",
    "gen:gcp-dashboards": "vite-node scripts/generate-gcp-dashboards.mjs",
    "gen:azure-pipelines": "vite-node scripts/generate-azure-pipeline-registry.mjs",
    "gen:azure-dashboards": "vite-node scripts/generate-azure-dashboards.mjs",
    "integrations:sync-official": "vite-node scripts/sync-elastic-official-integrations.mjs",
    "gen:minimal-installer-coverage": "vite-node scripts/generate-minimal-coverage-installer-assets.mjs",
    "docker:up": "sh docker-up",
    "docker:build": "sh scripts/docker-build-from-tar.sh",
    "docker:check-installer": "sh scripts/assert-installer-for-docker.sh"
  },
  "overrides": {
    "prismjs": "^1.30.0"
  },
  "dependencies": {
    "@elastic/datemath": "^5.0.3",
    "@elastic/eui": "^114.0.0",
    "@emotion/css": "^11.13.5",
    "@emotion/react": "^11.14.0",
    "moment": "^2.30.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "simple-icons": "^16.15.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.19.15",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.1",
    "aws-icons": "^3.3.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "js-yaml": "^4.1.1",
    "jsdom": "^25.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.10",
    "vite-node": "^6.0.0",
    "vitest": "^4.1.5"
  }
}
