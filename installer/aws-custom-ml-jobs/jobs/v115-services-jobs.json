  "jobs": [
    {
      "id": "aws-rdsproxy-connection-failure-spike",
      "description": "Detects spikes in RDS Proxy connection failures per proxy (authentication or target exhaustion issues)",
      "job": {
        "description": "Detects spikes in RDS Proxy connection failures per proxy (authentication or target exhaustion issues)",
        "groups": ["aws", "v115-services"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_count partitionfield=aws.rdsproxy.proxy_name",
              "function": "high_count",
              "partition_field_name": "aws.rdsproxy.proxy_name",
              "detector_index": 0
            }
          ],
          "influencers": ["aws.rdsproxy.proxy_name", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "32mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "aws-elastic-load-generator" }
      },
      "datafeed": {
        "indices": ["logs-aws.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              { "term": { "event.dataset": "aws.rdsproxy" } },
              { "term": { "event.outcome": "failure" } }
