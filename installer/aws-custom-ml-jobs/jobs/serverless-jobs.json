{
  "group": "serverless",
  "description": "Serverless & API anomaly detection — API Gateway errors, throttling, latency",
  "jobs": [
    {
      "id": "aws-apigateway-5xx-error-spike",
      "description": "Detects unusual spikes in API Gateway 5xx server errors per API — may indicate backend failures or misconfigurations",
      "job": {
        "description": "Detects unusual spikes in API Gateway 5xx server errors per API — may indicate backend failures or misconfigurations",
        "groups": ["aws", "serverless"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_count partitionfield=aws.apigateway.request_id",
              "function": "high_count",
              "partition_field_name": "aws.apigateway.stage",
              "detector_index": 0
            }
          ],
          "influencers": ["aws.apigateway.stage", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "32mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "aws-elastic-load-generator" }
      },
      "datafeed": {
        "indices": ["logs-aws.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              { "term": { "event.dataset": "aws.apigateway" } },
              { "term": { "event.outcome": "failure" } },
              { "range": { "http.response.status_code": { "gte": 500 } } }
            ]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "60s",
        "delayed_data_check_config": { "enabled": true }
      }
    },
    {
      "id": "aws-apigateway-throttle-spike",
      "description": "Detects unusual spikes in API Gateway throttled requests (429) — quota exhaustion or abuse",
      "job": {
        "description": "Detects unusual spikes in API Gateway throttled requests (429) — quota exhaustion or abuse",
        "groups": ["aws", "serverless"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_count",
              "function": "high_count",
              "detector_index": 0
            }
          ],
          "influencers": ["aws.apigateway.stage", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "16mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "aws-elastic-load-generator" }
      },
      "datafeed": {
        "indices": ["logs-aws.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              { "term": { "event.dataset": "aws.apigateway" } },
              { "term": { "http.response.status_code": 429 } }
            ]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "60s",
        "delayed_data_check_config": { "enabled": true }
      }
    },
    {
      "id": "aws-apigateway-latency-anomaly",
      "description": "Detects unusual API Gateway integration latency per stage — backend slowdowns or cold starts",
      "job": {
        "description": "Detects unusual API Gateway integration latency per stage — backend slowdowns or cold starts",
        "groups": ["aws", "serverless"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_mean(event.duration) partitionfield=aws.apigateway.stage",
              "function": "high_mean",
              "field_name": "event.duration",
              "partition_field_name": "aws.apigateway.stage",
              "detector_index": 0
            }
          ],
          "influencers": ["aws.apigateway.stage", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "32mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "aws-elastic-load-generator" }
      },
      "datafeed": {
        "indices": ["logs-aws.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [{ "term": { "event.dataset": "aws.apigateway" } }]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "60s",
        "delayed_data_check_config": { "enabled": true }
      }
    },
    {
      "id": "aws-lambda-cold-start-spike",
      "description": "Detects unusual spikes in Lambda cold start (init) events per function — scaling pressure or deployment issues",
      "job": {
        "description": "Detects unusual spikes in Lambda cold start (init) events per function — scaling pressure or deployment issues",
        "groups": ["aws", "serverless"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_count partitionfield=aws.lambda.function.name",
              "function": "high_count",
              "partition_field_name": "aws.lambda.function.name",
              "detector_index": 0
            }
          ],
          "influencers": ["aws.lambda.function.name", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "32mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "aws-elastic-load-generator" }
      },
      "datafeed": {
        "indices": ["logs-aws.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              { "term": { "event.dataset": "aws.lambda_logs" } },
              { "term": { "aws.lambda.cold_start": true } }
            ]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "60s",
        "delayed_data_check_config": { "enabled": true }
      }
    }
  ]
}
