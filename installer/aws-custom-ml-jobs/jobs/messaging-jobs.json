{
  "group": "messaging",
  "description": "Messaging & streaming anomaly detection — SNS delivery failures, MSK consumer lag, EventBridge failures, Step Functions execution failures",
  "jobs": [
    {
      "id": "aws-sns-delivery-failure-spike",
      "description": "Detects unusual spikes in SNS notification delivery failures",
      "job": {
        "description": "Detects unusual spikes in SNS notification delivery failures",
        "groups": ["aws", "messaging"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_mean(aws.sns.metrics.NumberOfNotificationsFailed.sum)",
              "function": "high_mean",
              "field_name": "aws.sns.metrics.NumberOfNotificationsFailed.sum",
              "detector_index": 0
            }
          ],
          "influencers": ["cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "16mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "aws-elastic-load-generator" }
      },
      "datafeed": {
        "indices": ["logs-aws.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [{ "term": { "event.dataset": "aws.sns" } }]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "60s",
        "delayed_data_check_config": { "enabled": true }
      }
    },
    {
      "id": "aws-msk-consumer-lag-anomaly",
      "description": "Detects unusual Kafka consumer lag in MSK — indicates consumers falling behind producers",
      "job": {
        "description": "Detects unusual Kafka consumer lag in MSK — indicates consumers falling behind producers",
        "groups": ["aws", "messaging"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_mean(aws.msk.lag) partitionfield=aws.msk.cluster.name",
              "function": "high_mean",
              "field_name": "aws.msk.lag",
              "partition_field_name": "aws.msk.cluster_name",
              "detector_index": 0
            }
          ],
          "influencers": ["aws.msk.cluster_name", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "32mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "aws-elastic-load-generator" }
      },
      "datafeed": {
        "indices": ["logs-aws.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [{ "term": { "event.dataset": "aws.msk" } }]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "60s",
        "delayed_data_check_config": { "enabled": true }
      }
    },
    {
      "id": "aws-msk-under-replicated-partitions",
