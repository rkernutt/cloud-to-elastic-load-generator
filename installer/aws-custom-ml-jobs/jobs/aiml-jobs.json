{
  "group": "aiml",
  "description": "AI & ML service anomaly detection — Bedrock model usage & latency",
  "jobs": [
    {
      "id": "aws-bedrock-token-usage-spike",
      "description": "Detects unusual spikes in Bedrock token consumption per model",
      "job": {
        "description": "Detects unusual spikes in Bedrock token consumption per model",
        "groups": ["aws", "aiml"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "High mean input token count by Bedrock model",
              "function": "high_mean",
              "field_name": "aws.bedrock.input_token_count",
              "partition_field_name": "aws.bedrock.model_id",
              "detector_index": 0
            }
          ],
          "influencers": ["aws.bedrock.model_id", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "32mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "aws-elastic-load-generator" }
      },
      "datafeed": {
        "indices": ["logs-aws.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [{ "term": { "event.dataset": "aws.bedrock" } }]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "60s",
        "delayed_data_check_config": { "enabled": true }
      }
    },
    {
      "id": "aws-bedrock-latency-anomaly",
      "description": "Detects unusual Bedrock model invocation latency per model",
      "job": {
        "description": "Detects unusual Bedrock model invocation latency per model",
        "groups": ["aws", "aiml"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "High mean invocation latency by Bedrock model",
              "function": "high_mean",
              "field_name": "aws.bedrock.invocation_latency_ms",
              "partition_field_name": "aws.bedrock.model_id",
              "detector_index": 0
            }
          ],
          "influencers": ["aws.bedrock.model_id", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "32mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "aws-elastic-load-generator" }
      },
      "datafeed": {
        "indices": ["logs-aws.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [{ "term": { "event.dataset": "aws.bedrock" } }]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "60s",
        "delayed_data_check_config": { "enabled": true }
      }
    },
    {
      "id": "aws-bedrock-error-spike",
      "description": "Detects spikes in Bedrock invocation errors and throttles per model",
      "job": {
        "description": "Detects spikes in Bedrock invocation errors and throttles per model",
        "groups": ["aws", "aiml"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "High count of failed Bedrock invocations by model",
              "function": "high_count",
              "partition_field_name": "aws.bedrock.model_id",
              "detector_index": 0
            }
          ],
          "influencers": ["aws.bedrock.model_id", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "32mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "aws-elastic-load-generator" }
      },
      "datafeed": {
        "indices": ["logs-aws.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              { "term": { "event.dataset": "aws.bedrock" } },
              { "term": { "event.outcome": "failure" } }
            ]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "60s",
        "delayed_data_check_config": { "enabled": true }
      }
    },
    {
      "id": "aws-bedrock-rare-model",
      "description": "Detects rare or unusual Bedrock model IDs being called, indicating misconfiguration or abuse",
      "job": {
        "description": "Detects rare or unusual Bedrock model IDs being called, indicating misconfiguration or abuse",
        "groups": ["aws", "aiml"],
        "analysis_config": {
          "bucket_span": "60m",
          "detectors": [
            {
              "detector_description": "Rare Bedrock model ID invocations",
              "function": "rare",
              "by_field_name": "aws.bedrock.model_id",
              "detector_index": 0
            }
          ],
          "influencers": ["aws.bedrock.model_id", "cloud.account.id"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "16mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "aws-elastic-load-generator" }
      },
      "datafeed": {
        "indices": ["logs-aws.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [{ "term": { "event.dataset": "aws.bedrock" } }]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "60s",
        "delayed_data_check_config": { "enabled": true }
      }
    }
  ]
}
