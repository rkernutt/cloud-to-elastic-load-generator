{
  "group": "devtools",
  "description": "Developer & CI/CD anomaly detection — CodeBuild failures, AWS CodePipeline stage failures, X-Ray trace errors",
  "jobs": [
    {
      "id": "aws-codebuild-failure-spike",
      "description": "Detects unusual spikes in AWS CodeBuild project failures — broken builds or environment regressions",
      "job": {
        "description": "Detects unusual spikes in CodeBuild project failures — broken builds or environment regressions",
        "groups": ["aws", "devtools", "cloudloadgen"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_count partitionfield=aws.codebuild.project_name",
              "function": "high_count",
              "partition_field_name": "aws.codebuild.project_name",
              "detector_index": 0
            }
          ],
          "influencers": ["aws.codebuild.project_name", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": {
          "model_memory_limit": "32mb"
        },
        "data_description": {
          "time_field": "@timestamp"
        },
        "custom_settings": {
          "created_by": "aws-elastic-load-generator",
          "tags": ["cloudloadgen"]
        }
      },
      "datafeed": {
        "indices": ["logs-aws.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              {
                "term": {
                  "event.dataset": "aws.codebuild"
                }
              },
              {
                "term": {
                  "event.outcome": "failure"
                }
              }
            ]
          }
        },
        "chunking_config": {
          "mode": "auto"
        },
        "query_delay": "60s",
        "delayed_data_check_config": {
          "enabled": true
        }
      }
    },
    {
      "id": "aws-codebuild-duration-anomaly",
      "description": "Detects unusual AWS CodeBuild build durations per project — slow builds indicating dependency or resource issues",
      "job": {
        "description": "Detects unusual CodeBuild build durations per project — slow builds indicating dependency or resource issues",
        "groups": ["aws", "devtools", "cloudloadgen"],
        "analysis_config": {
          "bucket_span": "60m",
          "detectors": [
            {
              "detector_description": "high_mean(event.duration) partitionfield=aws.codebuild.project_name",
              "function": "high_mean",
              "field_name": "event.duration",
              "partition_field_name": "aws.codebuild.project_name",
              "detector_index": 0
            }
          ],
          "influencers": ["aws.codebuild.project_name"]
        },
        "allow_lazy_open": true,
        "analysis_limits": {
          "model_memory_limit": "32mb"
        },
        "data_description": {
          "time_field": "@timestamp"
        },
        "custom_settings": {
          "created_by": "aws-elastic-load-generator",
          "tags": ["cloudloadgen"]
        }
      },
      "datafeed": {
        "indices": ["logs-aws.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              {
                "term": {
                  "event.dataset": "aws.codebuild"
                }
              }
            ]
          }
        },
        "chunking_config": {
          "mode": "auto"
        },
        "query_delay": "60s",
        "delayed_data_check_config": {
          "enabled": true
        }
      }
    },
