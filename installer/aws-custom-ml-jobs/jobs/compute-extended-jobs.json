      }
    },
    {
      "id": "aws-beanstalk-latency-p99-anomaly",
      "description": "Detects unusual p99 latency spikes in AWS Elastic Beanstalk \u2014 tail latency regression",
      "job": {
        "description": "Detects unusual p99 latency spikes in Elastic Beanstalk \u2014 tail latency regression",
        "groups": ["aws", "compute-extended", "cloudloadgen"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_mean(event.duration) partitionfield=aws.elasticbeanstalk.environment",
              "function": "high_mean",
              "field_name": "event.duration",
              "partition_field_name": "aws.elasticbeanstalk.environment",
              "detector_index": 0
            }
          ],
          "influencers": ["aws.elasticbeanstalk.environment"]
        },
        "allow_lazy_open": true,
        "analysis_limits": {
          "model_memory_limit": "32mb"
        },
        "data_description": {
          "time_field": "@timestamp"
        },
        "custom_settings": {
          "created_by": "aws-elastic-load-generator",
          "tags": ["cloudloadgen"]
        }
      },
      "datafeed": {
        "indices": ["logs-aws.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              {
                "term": {
                  "event.dataset": "aws.elasticbeanstalk"
                }
              }
            ]
          }
        },
        "chunking_config": {
          "mode": "auto"
        },
        "query_delay": "120s",
        "delayed_data_check_config": {
          "enabled": true
        }
      }
    }
  ]
}
