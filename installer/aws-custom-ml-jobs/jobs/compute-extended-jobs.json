{
  "group": "compute-extended",
  "description": "Extended compute anomaly detection \u2014 ECS container health, Amazon EC2 Auto Scaling thrashing, AWS Elastic Beanstalk errors & latency",
  "jobs": [
    {
      "id": "aws-ecs-memory-pressure",
      "description": "Detects unusual memory utilization spikes in Amazon ECS containers \u2014 early OOM warning",
      "job": {
        "description": "Detects unusual memory utilization spikes in ECS containers \u2014 early OOM warning",
        "groups": ["aws", "compute-extended", "cloudloadgen"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "High mean ECS MemoryUtilization by cluster",
              "function": "high_mean",
              "field_name": "aws.ecs.metrics.MemoryUtilization.avg",
              "partition_field_name": "aws.ecs.dimensions.ClusterName",
              "detector_index": 0
            }
          ],
          "influencers": [
            "aws.ecs.dimensions.ClusterName",
            "aws.ecs.dimensions.ServiceName",
            "cloud.region"
          ]
        },
        "allow_lazy_open": true,
        "analysis_limits": {
          "model_memory_limit": "32mb"
        },
        "data_description": {
          "time_field": "@timestamp"
        },
        "custom_settings": {
          "created_by": "aws-elastic-load-generator",
          "tags": ["cloudloadgen"]
        }
      },
      "datafeed": {
        "indices": ["metrics-aws.ecs_metrics*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              {
                "term": {
                  "event.dataset": "aws.ecs_metrics"
                }
              }
            ]
          }
        },
        "chunking_config": {
          "mode": "auto"
        },
        "query_delay": "120s",
        "delayed_data_check_config": {
          "enabled": true
        }
      }
    },
    {
      "id": "aws-ecs-task-failure-spike",
      "description": "Detects spikes in Amazon ECS task failures \u2014 container instability detection",
      "job": {
        "description": "Detects spikes in ECS task failures \u2014 container instability detection",
        "groups": ["aws", "compute-extended", "cloudloadgen"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "High count of ECS task failures by cluster",
              "function": "high_count",
              "partition_field_name": "aws.ecs.ecs_cluster",
              "detector_index": 0
            }
          ],
          "influencers": ["aws.ecs.ecs_cluster", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": {
          "model_memory_limit": "32mb"
        },
        "data_description": {
          "time_field": "@timestamp"
        },
        "custom_settings": {
          "created_by": "aws-elastic-load-generator",
          "tags": ["cloudloadgen"]
        }
      },
      "datafeed": {
        "indices": ["logs-aws.ecs*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              {
                "term": {
                  "event.dataset": "aws.ecs"
                }
              },
              {
                "term": {
                  "event.outcome": "failure"
                }
              }
            ]
          }
        },
        "chunking_config": {
          "mode": "auto"
        },
        "query_delay": "120s",
        "delayed_data_check_config": {
          "enabled": true
        }
      }
    },
    {
      "id": "aws-autoscaling-rapid-scaling",
      "description": "Detects unusually rapid Amazon EC2 Auto Scaling activity \u2014 flapping/thrashing detection",
      "job": {
        "description": "Detects unusually rapid Auto Scaling activity \u2014 flapping/thrashing detection",
        "groups": ["aws", "compute-extended", "cloudloadgen"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_count partitionfield=aws.autoscaling.group_name",
              "function": "high_count",
              "partition_field_name": "aws.autoscaling.group_name",
              "detector_index": 0
            }
          ],
          "influencers": ["aws.autoscaling.group_name", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": {
          "model_memory_limit": "32mb"
        },
        "data_description": {
          "time_field": "@timestamp"
        },
        "custom_settings": {
          "created_by": "aws-elastic-load-generator",
          "tags": ["cloudloadgen"]
        }
      },
      "datafeed": {
        "indices": ["logs-aws.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              {
                "term": {
                  "event.dataset": "aws.autoscaling"
                }
              }
            ]
          }
        },
        "chunking_config": {
          "mode": "auto"
        },
        "query_delay": "120s",
        "delayed_data_check_config": {
          "enabled": true
        }
      }
    },
    {
      "id": "aws-beanstalk-5xx-spike",
