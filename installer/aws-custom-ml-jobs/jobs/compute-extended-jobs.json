{
  "group": "compute-extended",
  "description": "Extended compute anomaly detection — ECS container health, Auto Scaling thrashing, Elastic Beanstalk errors & latency",
  "jobs": [
    {
      "id": "aws-ecs-memory-pressure",
      "description": "Detects unusual memory utilization spikes in ECS containers — early OOM warning",
      "job": {
        "description": "Detects unusual memory utilization spikes in ECS containers — early OOM warning",
        "groups": ["aws", "compute-extended"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_count partitionfield=aws.ecs.dimensions.ClusterName",
              "function": "high_count",
              "partition_field_name": "aws.ecs.dimensions.ClusterName",
              "detector_index": 0
            }
          ],
          "influencers": ["aws.ecs.dimensions.ClusterName", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "32mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "aws-elastic-load-generator" }
      },
      "datafeed": {
        "indices": ["metrics-aws.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [{ "term": { "event.dataset": "aws.ecs_metrics" } }]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "60s",
        "delayed_data_check_config": { "enabled": true }
      }
    },
    {
      "id": "aws-ecs-task-failure-spike",
