{
  "group": "analytics",
  "description": "Analytics anomaly detection — AWS Glue job failures, Athena cost & performance, Amazon EMR task failures, Spark stage/executor/GC/shuffle anomalies",
  "jobs": [
    {
      "id": "aws-glue-job-duration-anomaly",
      "description": "Detects unusual ETL job durations per AWS Glue job — catches jobs silently getting slower",
      "job": {
        "description": "Detects unusual ETL job durations per Glue job — catches jobs silently getting slower",
        "groups": ["aws", "analytics", "cloudloadgen"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_mean(aws.glue.metrics.driver.aggregate.elapsedTime) partitionfield=aws.glue.job.name",
              "function": "high_mean",
              "field_name": "aws.glue.metrics.driver.aggregate.elapsedTime",
              "partition_field_name": "aws.glue.dimensions.JobName",
              "detector_index": 0
            }
          ],
          "influencers": ["aws.glue.dimensions.JobName", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": {
          "model_memory_limit": "32mb"
        },
        "data_description": {
          "time_field": "@timestamp"
        },
        "custom_settings": {
          "created_by": "aws-elastic-load-generator",
          "tags": ["cloudloadgen"]
        }
      },
      "datafeed": {
        "indices": ["metrics-aws.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              {
                "term": {
                  "event.dataset": "aws.glue"
                }
              }
            ]
          }
        },
        "chunking_config": {
          "mode": "auto"
        },
        "query_delay": "60s",
        "delayed_data_check_config": {
          "enabled": true
        }
      }
    },
