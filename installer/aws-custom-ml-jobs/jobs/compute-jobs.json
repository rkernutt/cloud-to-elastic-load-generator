{
  "group": "compute",
  "description": "Compute & container anomaly detection — Lambda, EC2, EKS",
  "jobs": [
    {
      "id": "aws-lambda-error-spike",
      "description": "Detects spikes in AWS Lambda function errors per function name (application failures or regressions)",
      "job": {
        "description": "Detects spikes in Lambda function errors per function name (application failures or regressions)",
        "groups": ["aws", "compute", "cloudloadgen"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_count partitionfield=aws.lambda.function.name",
              "function": "high_count",
              "partition_field_name": "aws.lambda.function.name",
              "detector_index": 0
            }
          ],
          "influencers": ["aws.lambda.function.name", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": {
          "model_memory_limit": "32mb"
        },
        "data_description": {
          "time_field": "@timestamp"
        },
        "custom_settings": {
          "created_by": "aws-elastic-load-generator",
          "tags": ["cloudloadgen"]
        }
      },
      "datafeed": {
        "indices": ["logs-aws.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              {
                "term": {
                  "event.dataset": "aws.lambda_logs"
                }
              },
              {
                "term": {
                  "event.outcome": "failure"
                }
              }
            ]
          }
        },
        "chunking_config": {
          "mode": "auto"
        },
        "query_delay": "60s",
        "delayed_data_check_config": {
          "enabled": true
        }
      }
    },
