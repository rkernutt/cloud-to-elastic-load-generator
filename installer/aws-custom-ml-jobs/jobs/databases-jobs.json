{
  "group": "databases",
  "description": "Database anomaly detection — RDS, Aurora, ElastiCache",
  "jobs": [
    {
      "id": "aws-rds-latency-anomaly",
      "description": "Detects unusual RDS query latency per DB instance",
      "job": {
        "description": "Detects unusual RDS query latency per DB instance",
        "groups": ["aws", "databases"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "High mean RDS read latency by DB instance",
              "function": "high_mean",
              "field_name": "aws.rds.latency.read",
              "partition_field_name": "aws.rds.db_instance.identifier",
              "detector_index": 0
            }
          ],
          "influencers": ["aws.rds.db_instance.identifier", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "32mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "aws-elastic-load-generator" }
      },
      "datafeed": {
        "indices": ["logs-aws.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [{ "term": { "event.dataset": "aws.rds" } }]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "60s",
        "delayed_data_check_config": { "enabled": true }
      }
    },
    {
      "id": "aws-rds-connection-spike",
