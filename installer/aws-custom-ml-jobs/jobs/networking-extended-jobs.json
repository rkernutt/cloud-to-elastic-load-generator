{
  "group": "networking-extended",
  "description": "Extended networking anomaly detection — CloudFront error rates & cache misses, Route 53 NXDOMAIN spikes, Network Firewall drops",
  "jobs": [
    {
      "id": "aws-cloudfront-error-rate-spike",
      "description": "Detects unusual CDN error rates in CloudFront — origin failures and availability issues",
      "job": {
        "description": "Detects unusual CDN error rates in CloudFront — origin failures and availability issues",
        "groups": ["aws", "networking-extended"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "High count of CloudFront 5xx error responses",
              "function": "high_count",
              "detector_index": 0
            }
          ],
          "influencers": ["cloud.region", "source.ip"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "16mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "aws-elastic-load-generator" }
      },
      "datafeed": {
        "indices": ["logs-aws.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              { "term": { "event.dataset": "aws.cloudfront_logs" } },
              { "range": { "http.response.status_code": { "gte": 500 } } }
            ]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "60s",
        "delayed_data_check_config": { "enabled": true }
      }
    },
    {
      "id": "aws-cloudfront-cache-miss-spike",
      "description": "Detects unusual CloudFront cache miss rate spikes — cache invalidation storms and origin overload",
      "job": {
        "description": "Detects unusual CloudFront cache miss rate spikes — cache invalidation storms and origin overload",
        "groups": ["aws", "networking-extended"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "High count of CloudFront cache misses",
              "function": "high_count",
              "detector_index": 0
            }
          ],
          "influencers": ["cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "16mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "aws-elastic-load-generator" }
      },
      "datafeed": {
        "indices": ["logs-aws.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              { "term": { "event.dataset": "aws.cloudfront_logs" } },
              { "term": { "aws.cloudfront.edge_result_type": "Miss" } }
            ]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "60s",
        "delayed_data_check_config": { "enabled": true }
      }
    },
    {
      "id": "aws-route53-nxdomain-spike",
      "description": "Detects unusual NXDOMAIN response rate spikes — DNS-based attack or misconfiguration detection",
      "job": {
        "description": "Detects unusual NXDOMAIN response rate spikes — DNS-based attack or misconfiguration detection",
        "groups": ["aws", "networking-extended"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "High count of Route 53 NXDOMAIN responses",
              "function": "high_count",
              "detector_index": 0
            }
          ],
          "influencers": ["source.ip", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "16mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "aws-elastic-load-generator" }
      },
      "datafeed": {
        "indices": ["logs-aws.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              { "term": { "event.dataset": "aws.route53" } },
              { "term": { "aws.route53.response_code": "NXDOMAIN" } }
            ]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "60s",
        "delayed_data_check_config": { "enabled": true }
      }
    },
    {
      "id": "aws-networkfirewall-drop-spike",
      "description": "Detects unusual Network Firewall packet drop spikes — network perimeter anomaly detection",
      "job": {
        "description": "Detects unusual Network Firewall packet drop spikes — network perimeter anomaly detection",
        "groups": ["aws", "networking-extended"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "High count of Network Firewall dropped packets",
              "function": "high_count",
              "detector_index": 0
            }
          ],
          "influencers": ["source.ip", "destination.port"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "16mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "aws-elastic-load-generator" }
      },
      "datafeed": {
        "indices": ["logs-aws.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              { "term": { "event.dataset": "aws.firewall_logs" } },
              { "term": { "event.action": "drop" } }
            ]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "60s",
        "delayed_data_check_config": { "enabled": true }
      }
    }
  ]
}
