      "id": "aws-vpcipam-allocation-failure-spike",
      "description": "Detects spikes in VPC IPAM allocation failures per pool (CIDR exhaustion or overlap conflict)",
      "job": {
        "description": "Detects spikes in VPC IPAM allocation failures per pool (CIDR exhaustion or overlap conflict)",
        "groups": ["aws", "aws-ml-platform-wide-coverage"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_count partitionfield=aws.vpcipam.pool_id",
              "function": "high_count",
              "partition_field_name": "aws.vpcipam.pool_id",
              "detector_index": 0
            }
          ],
          "influencers": ["aws.vpcipam.pool_id", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "32mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "aws-elastic-load-generator" }
      },
      "datafeed": {
        "indices": ["logs-aws.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              { "term": { "event.dataset": "aws.vpcipam" } },
              { "term": { "event.outcome": "failure" } }
            ]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "60s",
        "delayed_data_check_config": { "enabled": true }
