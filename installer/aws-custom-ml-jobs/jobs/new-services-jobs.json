  "jobs": [
    {
      "id": "aws-kendra-query-failure-spike",
      "description": "Detects spikes in Amazon Kendra query failures per index (degraded search service or misconfiguration)",
      "job": {
        "description": "Detects spikes in Kendra query failures per index (degraded search service or misconfiguration)",
        "groups": ["aws", "new-services", "cloudloadgen"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_count partitionfield=aws.kendra.index_name",
              "function": "high_count",
              "partition_field_name": "aws.kendra.index_name",
              "detector_index": 0
            }
          ],
          "influencers": ["aws.kendra.index_name", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": {
          "model_memory_limit": "32mb"
        },
        "data_description": {
          "time_field": "@timestamp"
        },
        "custom_settings": {
          "created_by": "aws-elastic-load-generator",
          "tags": ["cloudloadgen"]
        }
      },
      "datafeed": {
        "indices": ["logs-aws.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              {
                "term": {
                  "event.dataset": "aws.kendra"
                }
              },
              {
                "term": {
                  "event.outcome": "failure"
                }
              }
            ]
          }
        },
        "chunking_config": {
          "mode": "auto"
        },
        "query_delay": "60s",
        "delayed_data_check_config": {
          "enabled": true
        }
      }
    },
