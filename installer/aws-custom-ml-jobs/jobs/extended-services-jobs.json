{
  "group": "extended-services",
  "description": "Extended AWS integrations — anomaly detection for Guardrails, EMR Serverless, GWLB, Classic ELB, media/IVS, search, identity, PCA, MGN, Synthetics, and AMP",
  "jobs": [
    {
      "id": "aws-bedrockguardrails-failure-spike",
      "description": "Spikes in Bedrock Guardrails failures by region",
      "job": {
        "description": "Unusual failure count for Bedrock Guardrails partitioned by AWS Region",
        "groups": ["aws", "extended-services", "cloudloadgen"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_count partitionfield=cloud.region",
              "function": "high_count",
              "partition_field_name": "cloud.region",
              "detector_index": 0
            }
          ],
          "influencers": ["cloud.region", "aws.bedrockguardrails.guardrail_id"]
        },
        "allow_lazy_open": true,
        "analysis_limits": {
          "model_memory_limit": "32mb"
        },
        "data_description": {
          "time_field": "@timestamp"
        },
        "custom_settings": {
          "created_by": "aws-elastic-load-generator",
          "tags": ["cloudloadgen"]
        }
      },
      "datafeed": {
        "indices": ["logs-aws.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              {
                "term": {
                  "event.dataset": "aws.bedrockguardrails"
                }
              },
              {
                "term": {
                  "event.outcome": "failure"
                }
              }
            ]
          }
        },
        "chunking_config": {
          "mode": "auto"
        },
        "query_delay": "60s",
        "delayed_data_check_config": {
          "enabled": true
        }
      }
    },
