      "id": "aws-appmesh-5xx-spike",
      "description": "Detects spikes in App Mesh Envoy proxy failures per virtual node (upstream service errors or misconfigured routing)",
      "job": {
        "description": "Detects spikes in App Mesh Envoy proxy failures per virtual node (upstream service errors or misconfigured routing)",
        "groups": ["aws", "v11-services"],
        "analysis_config": {
          "bucket_span": "5m",
          "detectors": [
            {
              "detector_description": "high_count by event.outcome=failure partitionfield=aws.appmesh.virtual_node",
              "function": "high_count",
              "by_field_name": "event.outcome",
              "partition_field_name": "aws.appmesh.virtual_node",
              "detector_index": 0
            }
          ],
          "influencers": ["aws.appmesh.virtual_node", "cloud.account.id", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "32mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "aws-elastic-load-generator" }
      },
      "datafeed": {
        "indices": ["logs-aws.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              { "term": { "event.dataset": "aws.appmesh" } },
              { "term": { "event.outcome": "failure" } }
            ]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "60s",
