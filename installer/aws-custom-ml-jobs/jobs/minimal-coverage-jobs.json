{
  "group": "minimal-coverage",
  "description": "Auto-generated baseline ML jobs (failure count by region) for services that received minimal dashboards",
  "jobs": [
    {
      "id": "aws-auroradsql-failure-spike",
      "description": "Unusual spike in failure events for aws.auroradsql (load generator baseline)",
      "job": {
        "description": "Unusual spike in failure events for aws.auroradsql",
        "groups": ["aws", "minimal-coverage"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_count partitionfield=cloud.region aws.auroradsql",
              "function": "high_count",
              "partition_field_name": "cloud.region",
              "detector_index": 0
            }
          ],
          "influencers": ["cloud.region", "event.outcome"]
        },
        "allow_lazy_open": true,
        "analysis_limits": {
          "model_memory_limit": "32mb"
        },
        "data_description": {
          "time_field": "@timestamp"
        },
        "custom_settings": {
          "created_by": "aws-load-generator-minimal-coverage"
        }
      },
      "datafeed": {
        "indices": ["logs-aws.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              {
                "term": {
                  "event.dataset": "aws.auroradsql"
                }
              },
              {
                "term": {
                  "event.outcome": "failure"
                }
              }
            ]
          }
        },
        "chunking_config": {
          "mode": "auto"
        },
        "query_delay": "60s",
        "delayed_data_check_config": {
          "enabled": true
        }
      }
    },
