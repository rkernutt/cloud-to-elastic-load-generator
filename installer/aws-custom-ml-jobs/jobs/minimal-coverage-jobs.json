{
  "group": "minimal-coverage",
  "description": "Minimal-coverage ML jobs — service-specific failure and metric detectors for lightly covered services",
  "jobs": [
    {
      "id": "aws-auroradsql-failure-spike",
      "description": "Detects spikes in Aurora DSQL failures per resource",
      "job": {
        "description": "Detects spikes in Aurora DSQL failures partitioned by aws.auroradsql.cluster_id",
        "groups": ["aws", "minimal-coverage", "cloudloadgen"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "High count of Aurora DSQL failures",
              "function": "high_count",
              "detector_index": 0,
              "partition_field_name": "aws.auroradsql.cluster_id"
            }
          ],
          "influencers": ["aws.auroradsql.cluster_id", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": {
          "model_memory_limit": "16mb"
        },
        "data_description": {
          "time_field": "@timestamp"
        },
        "custom_settings": {
          "created_by": "aws-load-generator-minimal-coverage",
          "tags": ["cloudloadgen"]
        }
      },
      "datafeed": {
        "indices": ["logs-aws.auroradsql*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              {
                "term": {
                  "event.dataset": "aws.auroradsql"
                }
              },
              {
                "term": {
                  "event.outcome": "failure"
                }
              }
            ]
          }
        },
        "chunking_config": {
          "mode": "auto"
        },
        "query_delay": "60s",
        "delayed_data_check_config": {
          "enabled": true
        }
      }
    },
