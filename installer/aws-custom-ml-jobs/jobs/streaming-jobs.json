{
  "group": "streaming",
  "description": "Streaming & messaging anomaly detection — Kinesis Streams, Kinesis Analytics, SQS",
  "jobs": [
    {
      "id": "aws-kinesisanalytics-kpu-spike",
      "description": "Detects unusual spikes in Kinesis Analytics KPU utilization by application",
      "job": {
        "description": "Detects unusual spikes in Kinesis Analytics KPU utilization by application",
        "groups": ["aws", "streaming"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "High mean KPU utilization by application",
              "function": "high_mean",
              "field_name": "aws.kinesisanalytics.metrics.kpu_utilization_pct",
              "partition_field_name": "aws.kinesisanalytics.application_name",
              "detector_index": 0
            }
          ],
          "influencers": ["aws.kinesisanalytics.application_name", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "32mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "aws-elastic-load-generator" }
      },
      "datafeed": {
        "indices": ["logs-aws.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [{ "term": { "event.dataset": "aws.kinesisanalytics" } }]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "60s",
        "delayed_data_check_config": { "enabled": true }
      }
    },
