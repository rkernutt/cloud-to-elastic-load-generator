{
  "title": "AWS CloudFront — CDN Traffic & Cache",
  "time_range": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "type": "lens",
      "uid": "cf-k1",
      "grid": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.cloudfront_logs* | STATS Requests = COUNT()"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Requests"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "cf-k2",
      "grid": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.cloudfront_logs* | EVAL e = CASE(`http.response.status_code` >= 400, 1, 0) | STATS m = AVG(e) | EVAL `Error %` = ROUND(m * 100, 1)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Error %"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "cf-k3",
      "grid": {
        "x": 24,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.cloudfront_logs* | EVAL hit = CASE(`aws.cloudfront.edge_result_type` == \"Hit\" OR `aws.cloudfront.edge_result_type` == \"RefreshHit\", 1, 0) | STATS m = AVG(hit) | EVAL `Hit %` = ROUND(m * 100, 1)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Cache hit %"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "cf-k4",
      "grid": {
        "x": 36,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.cloudfront_logs* | STATS `Bytes served` = SUM(`http.response.bytes`)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Bytes served"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "cf-d1",
      "grid": {
        "x": 0,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Edge result",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.cloudfront_logs* | STATS c = COUNT() BY r = `aws.cloudfront.edge_result_type` | SORT c DESC | LIMIT 8"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "r"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "cf-d2",
      "grid": {
        "x": 16,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "HTTP status",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.cloudfront_logs* | STATS c = COUNT() BY s = `http.response.status_code` | SORT c DESC | LIMIT 10"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "s"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "cf-d3",
      "grid": {
        "x": 32,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Top distributions",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.cloudfront_logs* | STATS c = COUNT() BY d = `aws.dimensions.DistributionId` | SORT c DESC | LIMIT 8"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "d"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "cf-l1",
      "grid": {
        "x": 0,
        "y": 15,
        "w": 48,
        "h": 10
      },
      "config": {
        "title": "Requests over time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.cloudfront_logs* | STATS c = COUNT() BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
                "column": "b"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "c",
                  "label": "Requests"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "cf-l2",
      "grid": {
        "x": 0,
        "y": 25,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Bytes & time-to-first-byte",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.cloudfront_logs* | STATS bytes = SUM(`http.response.bytes`), ttfb = AVG(`aws.cloudfront.time_to_first_byte`) BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
                "column": "b"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "bytes",
                  "label": "Bytes"
                },
                {
                  "operation": "value",
                  "column": "ttfb",
                  "label": "TTFB (s)"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "cf-l3",
      "grid": {
        "x": 24,
        "y": 25,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Errors over time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.cloudfront_logs* | STATS err = SUM(CASE(`http.response.status_code` >= 400, 1, 0)) BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
                "column": "b"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "err",
                  "label": "Errors"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "cf-b1",
      "grid": {
        "x": 0,
        "y": 35,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Top edge locations",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "bar_horizontal",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.cloudfront_logs* | STATS c = COUNT() BY e = `aws.cloudfront.edge_location` | SORT c DESC | LIMIT 10"
              },
              "x": {
                "operation": "value",
                "column": "e"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "c",
                  "label": "Requests"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "cf-t1",
      "grid": {
        "x": 0,
        "y": 45,
        "w": 48,
        "h": 12
      },
      "config": {
        "title": "Recent requests",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.cloudfront_logs* | KEEP `@timestamp`, `aws.dimensions.DistributionId`, `aws.cloudfront.edge_location`, `http.response.status_code`, `aws.cloudfront.edge_result_type`, `http.response.bytes`, `url.path` | SORT `@timestamp` DESC | LIMIT 100"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "`@timestamp`",
              "label": "Time"
            },
            {
              "operation": "value",
              "column": "aws.dimensions.DistributionId",
              "label": "Distribution"
            },
            {
              "operation": "value",
              "column": "aws.cloudfront.edge_location",
              "label": "Edge"
            },
            {
              "operation": "value",
              "column": "http.response.status_code",
              "label": "Status"
            },
            {
              "operation": "value",
              "column": "aws.cloudfront.edge_result_type",
              "label": "Result"
            },
            {
              "operation": "value",
              "column": "http.response.bytes",
              "label": "Bytes"
            },
            {
              "operation": "value",
              "column": "url.path",
              "label": "Path"
            }
          ],
          "rows": []
        }
      }
    }
  ]
}
