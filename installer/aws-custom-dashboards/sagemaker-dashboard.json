{
  "title": "AWS SageMaker — Endpoints & Training",
  "time_range": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "type": "lens",
      "uid": "sm-kpi-invocations",
      "grid": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.sagemaker* | STATS `Total Invocations` = SUM(`aws.sagemaker.cloudwatch_metrics.Invocations.sum`)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Total Invocations"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "sm-kpi-latency",
      "grid": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.sagemaker* | STATS `Avg Latency (ms)` = AVG(`aws.sagemaker.cloudwatch_metrics.ModelLatency.avg`)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Avg Latency (ms)"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "sm-kpi-4xx",
      "grid": {
        "x": 24,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.sagemaker* | STATS `Total 4xx Errors` = SUM(`aws.sagemaker.cloudwatch_metrics.Invocations4XXError.sum`)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Total 4xx Errors"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "sm-kpi-5xx",
      "grid": {
        "x": 36,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.sagemaker* | STATS `Total 5xx Errors` = SUM(`aws.sagemaker.cloudwatch_metrics.Invocations5XXError.sum`)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Total 5xx Errors"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "sm-invocations",
      "grid": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Invocations Over Time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "area",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.sagemaker* | STATS invocations = SUM(`aws.sagemaker.cloudwatch_metrics.Invocations.sum`) BY bucket = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT bucket"
              },
              "x": {
                "operation": "value",
                "column": "bucket"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "invocations",
                  "label": "Invocations"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "sm-latency",
      "grid": {
        "x": 24,
        "y": 5,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Model Latency (avg ms)",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.sagemaker* | STATS avg_latency = AVG(`aws.sagemaker.cloudwatch_metrics.ModelLatency.avg`) BY bucket = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT bucket"
              },
              "x": {
                "operation": "value",
                "column": "bucket"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "avg_latency",
                  "label": "Latency (ms)"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "sm-errors",
      "grid": {
        "x": 0,
        "y": 15,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "4xx / 5xx Errors Over Time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.sagemaker* | STATS errors_4xx = SUM(`aws.sagemaker.cloudwatch_metrics.Invocations4XXError.sum`), errors_5xx = SUM(`aws.sagemaker.cloudwatch_metrics.Invocations5XXError.sum`) BY bucket = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT bucket"
              },
              "x": {
                "operation": "value",
                "column": "bucket"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "errors_4xx",
                  "label": "4xx Errors"
                },
                {
                  "operation": "value",
                  "column": "errors_5xx",
                  "label": "5xx Errors"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "sm-utilization",
      "grid": {
        "x": 24,
        "y": 15,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "GPU / CPU Utilization (%)",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.sagemaker* | STATS gpu = AVG(`aws.sagemaker.cloudwatch_metrics.GPUUtilization.avg`), cpu = AVG(`aws.sagemaker.cloudwatch_metrics.CPUUtilization.avg`) BY bucket = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT bucket"
              },
              "x": {
                "operation": "value",
                "column": "bucket"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "gpu",
                  "label": "GPU %"
                },
                {
                  "operation": "value",
                  "column": "cpu",
                  "label": "CPU %"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "sm-outcomes",
      "grid": {
        "x": 0,
        "y": 25,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Job Outcomes",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.sagemaker* | STATS count = COUNT() BY outcome = log.level"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "count"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "outcome"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "sm-job-type",
      "grid": {
        "x": 16,
        "y": 25,
        "w": 32,
        "h": 10
      },
      "config": {
        "title": "Events by Job Type",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "bar_horizontal",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.sagemaker* | STATS count = COUNT() BY job_type = `aws.sagemaker.job.type` | SORT count DESC"
              },
              "x": {
                "operation": "value",
                "column": "job_type"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "count",
                  "label": "Events"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "sm-event-action",
      "grid": {
        "x": 0,
        "y": 35,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Events by Action",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "bar_horizontal",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.sagemaker* | STATS count = COUNT() BY action = event.action | SORT count DESC | LIMIT 10"
              },
              "x": {
                "operation": "value",
                "column": "action"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "count",
                  "label": "Events"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "sm-training-metrics",
      "grid": {
        "x": 24,
        "y": 35,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Training Loss & Accuracy",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.sagemaker* | WHERE `aws.sagemaker.job.type` == \"Training\" | STATS avg_loss = AVG(`aws.sagemaker.metrics.training_loss`), avg_acc = AVG(`aws.sagemaker.metrics.accuracy`) BY bucket = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT bucket"
              },
              "x": {
                "operation": "value",
                "column": "bucket"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "avg_loss",
                  "label": "Avg Loss"
                },
                {
                  "operation": "value",
                  "column": "avg_acc",
                  "label": "Avg Accuracy"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "sm-log-table",
      "grid": {
        "x": 0,
        "y": 45,
        "w": 48,
        "h": 12
      },
      "config": {
        "title": "Recent SageMaker Events",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.sagemaker* | KEEP `@timestamp`, `aws.sagemaker.job.name`, `aws.sagemaker.job.type`, event.action, log.level, event.duration | SORT `@timestamp` DESC | LIMIT 100"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "`@timestamp`",
              "label": "Timestamp"
            },
            {
              "operation": "value",
              "column": "aws.sagemaker.job.name",
              "label": "Job Name"
            },
            {
              "operation": "value",
              "column": "aws.sagemaker.job.type",
              "label": "Job Type"
            },
            {
              "operation": "value",
              "column": "event.action",
              "label": "Action"
            },
            {
              "operation": "value",
              "column": "log.level",
              "label": "Log level"
            },
            {
              "operation": "value",
              "column": "event.duration",
              "label": "Duration (ns)"
            }
          ],
          "rows": []
        }
      }
    }
  ]
}
