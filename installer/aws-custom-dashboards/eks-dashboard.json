              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.eks* | STATS rx = SUM(`aws.eks.metrics.pod_network_rx_bytes.sum`), tx = SUM(`aws.eks.metrics.pod_network_tx_bytes.sum`) BY bucket = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT bucket"
              },
              "x": {
                "operation": "value",
                "column": "bucket"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "rx",
                  "label": "RX Bytes"
                },
                {
                  "operation": "value",
                  "column": "tx",
                  "label": "TX Bytes"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "eks-node-cpu-by-node",
      "grid": {
        "x": 0,
        "y": 35,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Node CPU by Node",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "bar_horizontal",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.eks* | STATS avg_cpu = AVG(`aws.eks.metrics.node_cpu_utilization.avg`) BY node = `aws.eks.node.name` | SORT avg_cpu DESC | LIMIT 10"
              },
              "x": {
                "operation": "value",
                "column": "node"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "avg_cpu",
                  "label": "Avg CPU %"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "eks-failed-node-count-over-time",
      "grid": {
        "x": 24,
        "y": 35,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Failed Node Count Over Time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.eks* | STATS failed = MAX(`aws.eks.metrics.cluster_failed_node_count.avg`) BY bucket = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT bucket"
              },
              "x": {
                "operation": "value",
                "column": "bucket"
              },
              "y": [
                {
                  "operation": "value",
