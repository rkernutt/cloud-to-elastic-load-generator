    },
    {
      "type": "lens",
      "uid": "eks-log-table",
      "grid": {
        "x": 0,
        "y": 45,
        "w": 48,
        "h": 12
      },
      "config": {
        "title": "Recent Events",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.eks* | KEEP `@timestamp`, `aws.eks.cluster.name`, `aws.eks.node.name`, log.level, `aws.eks.metrics.node_cpu_utilization.avg`, `aws.eks.metrics.node_memory_utilization.avg`, `aws.eks.metrics.pod_count.avg` | SORT `@timestamp` DESC | LIMIT 100"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "`@timestamp`",
              "label": "Timestamp"
            },
            {
              "operation": "value",
              "column": "aws.eks.cluster.name",
              "label": "Cluster"
            },
            {
              "operation": "value",
              "column": "aws.eks.node.name",
              "label": "Node"
            },
            {
              "operation": "value",
              "column": "log.level",
              "label": "Log level"
            },
            {
              "operation": "value",
              "column": "aws.eks.metrics.node_cpu_utilization.avg",
              "label": "Node CPU %"
            },
            {
              "operation": "value",
              "column": "aws.eks.metrics.node_memory_utilization.avg",
              "label": "Node Memory %"
            },
            {
              "operation": "value",
              "column": "aws.eks.metrics.pod_count.avg",
              "label": "Pod Count"
            }
          ],
          "rows": []
        }
      }
    }
  ]
}
