{
  "title": "Amazon S3 — Access & Errors",
  "time_range": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "type": "lens",
      "uid": "s3-k1",
      "grid": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.s3access* | STATS Requests = COUNT()"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Requests"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "s3-k2",
      "grid": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.s3access* | EVAL s5 = CASE(`aws.s3access.http_status` >= 500, 1, 0) | STATS m = AVG(s5) | EVAL `5xx %` = ROUND(m * 100, 1)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "5xx %"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "s3-k3",
      "grid": {
        "x": 24,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.s3access* | EVAL s4 = CASE(`aws.s3access.http_status` >= 400 AND `aws.s3access.http_status` < 500, 1, 0) | STATS m = AVG(s4) | EVAL `4xx %` = ROUND(m * 100, 1)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "4xx %"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "s3-k4",
      "grid": {
        "x": 36,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.s3access* | STATS `Bytes sent` = SUM(`aws.s3access.bytes_sent`)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Bytes sent"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "s3-d1",
      "grid": {
        "x": 0,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "HTTP status",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.s3access* | STATS c = COUNT() BY s = `aws.s3access.http_status` | SORT c DESC | LIMIT 10"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "s"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "s3-d2",
      "grid": {
        "x": 16,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Operation",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.s3access* | STATS c = COUNT() BY o = `aws.s3access.operation` | SORT c DESC | LIMIT 10"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "o"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "s3-d3",
      "grid": {
        "x": 32,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Outcome",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.s3access* | STATS c = COUNT() BY out = event.outcome"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "out"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "s3-l1",
      "grid": {
        "x": 0,
        "y": 15,
        "w": 48,
        "h": 10
      },
      "config": {
        "title": "Requests over time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.s3access* | STATS c = COUNT() BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
                "column": "b"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "c",
                  "label": "Requests"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "s3-l2",
      "grid": {
        "x": 0,
        "y": 25,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Errors over time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.s3access* | STATS e4 = SUM(CASE(`aws.s3access.http_status` >= 400 AND `aws.s3access.http_status` < 500, 1, 0)), e5 = SUM(CASE(`aws.s3access.http_status` >= 500, 1, 0)) BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
                "column": "b"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "e4",
                  "label": "4xx"
                },
                {
                  "operation": "value",
                  "column": "e5",
                  "label": "5xx"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "s3-l3",
      "grid": {
        "x": 24,
        "y": 25,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Bytes transferred",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.s3access* | STATS bts = SUM(`aws.s3access.bytes_sent`) BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
                "column": "b"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "bts",
                  "label": "Bytes"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "s3-b1",
      "grid": {
        "x": 0,
        "y": 35,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Top buckets",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "bar_horizontal",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.s3access* | STATS c = COUNT() BY bk = `aws.s3access.bucket` | SORT c DESC | LIMIT 10"
              },
              "x": {
                "operation": "value",
                "column": "bk"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "c",
                  "label": "Requests"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "s3-t1",
      "grid": {
        "x": 0,
        "y": 45,
        "w": 48,
        "h": 12
      },
      "config": {
        "title": "Recent access",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.s3access* | KEEP `@timestamp`, `aws.s3access.bucket`, `aws.s3access.operation`, `aws.s3access.http_status`, `aws.s3access.bytes_sent`, `aws.s3access.error_code`, `aws.s3access.remote_ip`, event.outcome | SORT `@timestamp` DESC | LIMIT 100"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "`@timestamp`",
              "label": "Time"
            },
            {
              "operation": "value",
              "column": "aws.s3access.bucket",
              "label": "Bucket"
            },
            {
              "operation": "value",
              "column": "aws.s3access.operation",
              "label": "Operation"
            },
            {
              "operation": "value",
              "column": "aws.s3access.http_status",
              "label": "Status"
            },
            {
              "operation": "value",
              "column": "aws.s3access.bytes_sent",
              "label": "Bytes"
            },
            {
              "operation": "value",
              "column": "aws.s3access.error_code",
              "label": "Error"
            },
            {
              "operation": "value",
              "column": "aws.s3access.remote_ip",
              "label": "Client"
            },
            {
              "operation": "value",
              "column": "event.outcome",
              "label": "Outcome"
            }
          ],
          "rows": []
        }
      }
    }
  ]
}
