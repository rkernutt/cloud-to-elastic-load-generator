{
  "title": "AWS Audit Manager — Compliance Assessments",
  "time_range": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "type": "lens",
      "uid": "auditmanager-kpi-total-evidence",
      "grid": { "x": 0, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.auditmanager* | STATS `Total Evidence Items` = COUNT()"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Total Evidence Items" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "auditmanager-kpi-non-compliant-controls",
      "grid": { "x": 12, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.auditmanager* | WHERE `aws.auditmanager.compliance_check` == \"NON_COMPLIANT\" | STATS `Non-Compliant Controls` = COUNT_DISTINCT(`aws.auditmanager.control_id`)"
          },
          "metrics": [
            { "type": "primary", "operation": "value", "column": "Non-Compliant Controls" }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "auditmanager-kpi-active-assessments",
      "grid": { "x": 24, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.auditmanager* | STATS `Active Assessments` = COUNT_DISTINCT(`aws.auditmanager.assessment_name`)"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Active Assessments" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "auditmanager-kpi-evidence-count",
      "grid": { "x": 36, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.auditmanager* | STATS `Evidence Count` = SUM(`aws.auditmanager.evidence_count`)"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Evidence Count" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "auditmanager-donut-evidence-status",
      "grid": { "x": 0, "y": 5, "w": 24, "h": 10 },
      "config": {
        "title": "Evidence Status",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.auditmanager* | STATS count = COUNT() BY status = `aws.auditmanager.evidence_status` | SORT count DESC | LIMIT 10"
          },
          "metrics": [{ "operation": "value", "column": "count" }],
          "group_by": [{ "operation": "value", "column": "status" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "auditmanager-donut-data-source",
      "grid": { "x": 24, "y": 5, "w": 24, "h": 10 },
      "config": {
        "title": "Data Source",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.auditmanager* | STATS count = COUNT() BY source = `aws.auditmanager.data_source` | SORT count DESC | LIMIT 10"
          },
          "metrics": [{ "operation": "value", "column": "count" }],
          "group_by": [{ "operation": "value", "column": "source" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "auditmanager-compliance-checks-over-time",
      "grid": { "x": 0, "y": 15, "w": 48, "h": 10 },
      "config": {
        "title": "Compliance Checks Over Time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": { "title": { "visible": false } },
            "left": { "title": { "visible": false } }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.auditmanager* | STATS count = COUNT() BY bucket = BUCKET(@timestamp, 75, ?_tstart, ?_tend) | SORT bucket"
              },
              "x": { "operation": "value", "column": "bucket" },
              "y": [{ "operation": "value", "column": "count", "label": "Compliance Checks" }]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "auditmanager-recent-evidence",
      "grid": { "x": 0, "y": 25, "w": 48, "h": 10 },
      "config": {
        "title": "Recent Evidence",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.auditmanager* | KEEP @timestamp, `aws.auditmanager.assessment_name`, `aws.auditmanager.control_id`, `aws.auditmanager.evidence_status`, `aws.auditmanager.compliance_check` | SORT @timestamp DESC | LIMIT 100"
          },
          "metrics": [
            { "operation": "value", "column": "@timestamp", "label": "Timestamp" },
            {
              "operation": "value",
              "column": "aws.auditmanager.assessment_name",
              "label": "Assessment Name"
            },
            {
              "operation": "value",
              "column": "aws.auditmanager.control_id",
              "label": "Control ID"
            },
            {
              "operation": "value",
              "column": "aws.auditmanager.evidence_status",
              "label": "Evidence Status"
            },
            {
              "operation": "value",
              "column": "aws.auditmanager.compliance_check",
              "label": "Compliance Check"
            }
          ],
          "rows": []
        }
      }
    }
  ]
}
