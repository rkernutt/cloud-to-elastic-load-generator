{
  "title": "AWS AppConfig — Configuration Deployments",
  "time_range": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "type": "lens",
      "uid": "appconfig-kpi-total-deployments",
      "grid": { "x": 0, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.appconfig* | STATS `Total Deployments` = COUNT()"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Total Deployments" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "appconfig-kpi-rolled-back",
      "grid": { "x": 12, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.appconfig* | WHERE `aws.appconfig.state` == \"ROLLED_BACK\" | STATS `Rolled-Back Deployments` = COUNT()"
          },
          "metrics": [
            { "type": "primary", "operation": "value", "column": "Rolled-Back Deployments" }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "appconfig-kpi-applications",
      "grid": { "x": 24, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.appconfig* | STATS `Applications Configured` = COUNT_DISTINCT(`aws.appconfig.application_name`)"
          },
          "metrics": [
            { "type": "primary", "operation": "value", "column": "Applications Configured" }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "appconfig-kpi-avg-completion",
      "grid": { "x": 36, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.appconfig* | STATS avg_c = AVG(`aws.appconfig.percentage_complete`) | EVAL `Avg Completion (%)` = ROUND(avg_c, 1)"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Avg Completion (%)" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "appconfig-donut-deployment-state",
      "grid": { "x": 0, "y": 5, "w": 24, "h": 10 },
      "config": {
        "title": "Deployment State",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.appconfig* | STATS count = COUNT() BY state = `aws.appconfig.state` | SORT count DESC | LIMIT 10"
          },
          "metrics": [{ "operation": "value", "column": "count" }],
          "group_by": [{ "operation": "value", "column": "state" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "appconfig-donut-deployment-strategy",
      "grid": { "x": 24, "y": 5, "w": 24, "h": 10 },
      "config": {
        "title": "Deployment Strategy",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.appconfig* | STATS count = COUNT() BY strategy = `aws.appconfig.deployment_strategy` | SORT count DESC | LIMIT 10"
          },
          "metrics": [{ "operation": "value", "column": "count" }],
          "group_by": [{ "operation": "value", "column": "strategy" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "appconfig-deployments-over-time",
      "grid": { "x": 0, "y": 15, "w": 48, "h": 10 },
      "config": {
        "title": "Configuration Deployments Over Time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": { "title": { "visible": false } },
            "left": { "title": { "visible": false } }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.appconfig* | STATS count = COUNT() BY bucket = BUCKET(@timestamp, 75, ?_tstart, ?_tend) | SORT bucket"
              },
              "x": { "operation": "value", "column": "bucket" },
              "y": [{ "operation": "value", "column": "count", "label": "Deployments" }]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "appconfig-recent-deployments",
      "grid": { "x": 0, "y": 25, "w": 48, "h": 10 },
      "config": {
        "title": "Recent Deployments",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.appconfig* | KEEP @timestamp, `aws.appconfig.application_name`, `aws.appconfig.environment_name`, `aws.appconfig.state`, `aws.appconfig.percentage_complete` | SORT @timestamp DESC | LIMIT 100"
          },
          "metrics": [
            { "operation": "value", "column": "@timestamp", "label": "Timestamp" },
            {
              "operation": "value",
              "column": "aws.appconfig.application_name",
              "label": "Application"
            },
            {
              "operation": "value",
              "column": "aws.appconfig.environment_name",
              "label": "Environment"
            },
            { "operation": "value", "column": "aws.appconfig.state", "label": "State" },
            {
              "operation": "value",
              "column": "aws.appconfig.percentage_complete",
              "label": "Completion (%)"
            }
          ],
          "rows": []
        }
      }
    }
  ]
}
