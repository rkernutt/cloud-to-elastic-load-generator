{
  "title": "AWS Network Access Analyzer — Network Findings & Scopes",
  "time_range": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "type": "lens",
      "uid": "networkaccessanalyzer-kpi-total-events",
      "grid": { "x": 0, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.networkaccessanalyzer* | STATS `Total Events` = COUNT()"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Total Events" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "networkaccessanalyzer-kpi-errors",
      "grid": { "x": 12, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.networkaccessanalyzer* | WHERE event.outcome == \"failure\" | STATS `Errors` = COUNT()"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Errors" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "networkaccessanalyzer-kpi-unique-resources",
      "grid": { "x": 24, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.networkaccessanalyzer* | STATS `Unique Scopes` = COUNT_DISTINCT(`aws.networkaccessanalyzer.scope_name`)"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Unique Scopes" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "networkaccessanalyzer-kpi-findings",
      "grid": { "x": 36, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.networkaccessanalyzer* | STATS `Total Findings` = SUM(`aws.networkaccessanalyzer.finding_count`)"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Total Findings" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "networkaccessanalyzer-donut-outcome",
      "grid": { "x": 0, "y": 5, "w": 24, "h": 10 },
      "config": {
        "title": "Event Outcome",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.networkaccessanalyzer* | STATS count = COUNT() BY outcome = event.outcome | SORT count DESC | LIMIT 10"
          },
          "dimensions": [{ "column": "outcome", "type": "category" }],
          "metrics": [{ "type": "size", "operation": "value", "column": "count" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "networkaccessanalyzer-bar-timeline",
      "grid": { "x": 0, "y": 15, "w": 48, "h": 12 },
      "config": {
        "title": "Events Over Time",
        "attributes": {
          "type": "bar_stacked",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.networkaccessanalyzer* | EVAL bucket = DATE_TRUNC(15 minutes, @timestamp) | STATS count = COUNT() BY bucket, outcome = event.outcome | SORT bucket"
          },
          "xAxis": { "column": "bucket", "type": "date" },
          "breakdown": { "column": "outcome", "type": "category" },
          "metrics": [{ "type": "bar", "operation": "value", "column": "count" }]
        }
      }
    }
  ]
}
