{
  "title": "Amazon EMR — Clusters & Job Performance",
  "time_range": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "type": "lens",
      "uid": "emr-kpi-total",
      "grid": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.emr* | STATS `Total Jobs` = COUNT()"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Total Jobs"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "emr-kpi-success-rate",
      "grid": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.emr* | EVAL is_success = CASE(log.level == \"info\", 1, 0) | STATS avg_rate = AVG(is_success) | EVAL `Success Rate %` = ROUND(avg_rate * 100, 1)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Success Rate %"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "emr-kpi-avg-duration",
      "grid": {
        "x": 24,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.emr* | STATS avg_ns = AVG(event.duration) | EVAL `Avg Duration (s)` = ROUND(avg_ns / 1000000000.0, 2)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Avg Duration (s)"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "emr-kpi-failed",
      "grid": {
        "x": 36,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.emr* | WHERE log.level == \"error\" | STATS `Failed Jobs` = COUNT()"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Failed Jobs"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "emr-outcomes",
      "grid": {
        "x": 0,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Job Outcomes",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.emr* | STATS count = COUNT() BY outcome = log.level"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "count"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "outcome"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "emr-by-application",
      "grid": {
        "x": 16,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Jobs by Application",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.emr* | STATS count = COUNT() BY application = `aws.emr.application`"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "count"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "application"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "emr-run-state",
      "grid": {
        "x": 32,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Jobs by Run State",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.emr* | STATS count = COUNT() BY state = `aws.emr.job.run_state`"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "count"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "state"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "emr-jobs-over-time",
      "grid": {
        "x": 0,
        "y": 15,
        "w": 48,
        "h": 10
      },
      "config": {
        "title": "Job Runs Over Time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.emr* | STATS count = COUNT() BY bucket = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT bucket"
              },
              "x": {
                "operation": "value",
                "column": "bucket"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "count",
                  "label": "Job Runs"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "emr-log-table",
      "grid": {
        "x": 0,
        "y": 45,
        "w": 48,
        "h": 12
      },
      "config": {
        "title": "Recent Job Runs",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.emr* | KEEP `@timestamp`, `aws.emr.cluster_name`, `aws.emr.application`, `aws.emr.job.name`, `aws.emr.job.run_state`, log.level, event.duration | SORT `@timestamp` DESC | LIMIT 100"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "`@timestamp`",
              "label": "Timestamp"
            },
            {
              "operation": "value",
              "column": "aws.emr.cluster_name",
              "label": "Cluster"
            },
            {
              "operation": "value",
              "column": "aws.emr.application",
              "label": "Application"
            },
            {
              "operation": "value",
              "column": "aws.emr.job.name",
              "label": "Job Name"
            },
            {
              "operation": "value",
              "column": "aws.emr.job.run_state",
              "label": "Run State"
            },
            {
              "operation": "value",
              "column": "log.level",
              "label": "Log level"
            },
            {
              "operation": "value",
              "column": "event.duration",
              "label": "Duration (ns)"
            }
          ],
          "rows": []
        }
      }
    }
  ]
}
