{
  "title": "AWS Batch — Overview",
  "time_range": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "type": "lens",
      "uid": "batch-kpi-events",
      "grid": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.batch* | STATS Events = COUNT()"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Events"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "batch-kpi-failures",
      "grid": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.batch* | STATS Failures = SUM(CASE(`event.outcome` == \"failure\", 1, 0))"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Failures"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "batch-kpi-metric3",
      "grid": {
        "x": 24,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM metrics-aws.batch* | STATS avg_m = AVG(`aws.batch.metrics.PendingJobCount.avg`) | EVAL `Avg metric` = ROUND(avg_m, 1)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Avg metric"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "batch-kpi-metric4",
      "grid": {
        "x": 36,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM metrics-aws.batch* | STATS `Metric sum` = ROUND(SUM(`aws.batch.metrics.PendingJobCount.avg`), 0)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Metric sum"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "batch-donut-outcome",
      "grid": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 8
      },
      "config": {
        "title": "Event Outcome",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.batch* | STATS count = COUNT() BY outcome = `event.outcome` | SORT ``count DESC"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "count"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "outcome"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "batch-bar-dimension",
      "grid": {
        "x": 24,
        "y": 5,
        "w": 24,
        "h": 8
      },
      "config": {
        "title": "Events by status",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "bar_horizontal",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.batch* | STATS count = COUNT() BY dim = `aws.batch.job.status` | SORT ``count DESC | LIMIT 10"
              },
              "x": {
                "operation": "value",
                "column": "dim"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "count",
                  "label": "Events"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "batch-line-volume",
      "grid": {
        "x": 0,
        "y": 13,
        "w": 24,
        "h": 8
      },
      "config": {
        "title": "Event Volume Over Time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.batch* | STATS count = COUNT() BY bucket = BUCKET(`@timestamp````@timestamp`, 75, ?_tstart, ?_tend) | SORT ``bucket"
              },
              "x": {
                "operation": "value",
                "column": "bucket"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "count",
                  "label": "Events"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "batch-line-metric",
      "grid": {
        "x": 24,
        "y": 13,
        "w": 24,
        "h": 8
      },
      "config": {
        "title": "Key metric over time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM metrics-aws.batch* | STATS avg_m = AVG(`aws.batch.metrics.PendingJobCount.avg`) BY bucket = BUCKET(`@timestamp````@timestamp`, 75, ?_tstart, ?_tend) | SORT ``bucket"
              },
              "x": {
                "operation": "value",
                "column": "bucket"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "avg_m",
                  "label": "Avg metric"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "batch-bar-region",
      "grid": {
        "x": 0,
        "y": 21,
        "w": 16,
        "h": 8
      },
      "config": {
        "title": "Events by Region",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "bar_horizontal",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.batch* | STATS count = COUNT() BY region = COALESCE(cloud.region, \"unknown\") | SORT ``count DESC | LIMIT 10"
              },
              "x": {
                "operation": "value",
                "column": "region"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "count",
                  "label": "Events"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "batch-bar-resource",
      "grid": {
        "x": 16,
        "y": 21,
        "w": 16,
        "h": 8
      },
      "config": {
        "title": "Events by id",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "bar_horizontal",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.batch* | STATS count = COUNT() BY res = `aws.batch.job.id` | SORT ``count DESC | LIMIT 10"
              },
              "x": {
                "operation": "value",
                "column": "res"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "count",
                  "label": "Events"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "batch-donut-log-level",
      "grid": {
        "x": 32,
        "y": 21,
        "w": 16,
        "h": 8
      },
      "config": {
        "title": "Log Level",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.batch* | STATS count = COUNT() BY lvl = log.level | SORT ``count DESC"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "count"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "lvl"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "batch-table-recent",
      "grid": {
        "x": 0,
        "y": 29,
        "w": 48,
        "h": 10
      },
      "config": {
        "title": "Recent Events",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.batch* | KEEP `@timestamp``@timestamp`, `aws.batch.job.status`, `aws.batch.job.id`, `log.level`, `event.outcome`, message | SORT `@timestamp` DESC | LIMIT 100"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "`@timestamp`",
              "label": "Timestamp"
            },
            {
              "operation": "value",
              "column": "aws.batch.job.status",
              "label": "Status"
            },
            {
              "operation": "value",
              "column": "aws.batch.job.id",
              "label": "Id"
            },
            {
              "operation": "value",
              "column": "aws.batch.metrics.PendingJobCount.avg",
              "label": "Avg"
            },
            {
              "operation": "value",
              "column": "log.level",
              "label": "Level"
            },
            {
              "operation": "value",
              "column": "event.outcome",
              "label": "Outcome"
            },
            {
              "operation": "value",
              "column": "message",
              "label": "Message"
            }
          ],
          "rows": []
        }
      }
    }
  ]
}
