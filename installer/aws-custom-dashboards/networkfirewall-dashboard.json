{
  "title": "AWS Network Firewall — Flows",
  "time_range": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "type": "lens",
      "uid": "nfw-k1",
      "grid": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.firewall_logs* | STATS Flows = COUNT()"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Flows"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "nfw-k2",
      "grid": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.firewall_logs* | EVAL d = CASE(`aws.firewall_logs.action` == \"DROP\", 1, 0) | STATS m = AVG(d) | EVAL `Dropped %` = ROUND(m * 100, 1)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Dropped %"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "nfw-k3",
      "grid": {
        "x": 24,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM metrics-aws.firewall_metrics* | STATS `Dropped pkts` = SUM(`aws.firewall.metrics.DroppedPackets.sum`)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Dropped pkts"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "nfw-k4",
      "grid": {
        "x": 36,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM metrics-aws.firewall_metrics* | STATS `Passed pkts` = SUM(`aws.firewall.metrics.PassedPackets.sum`)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Passed pkts"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "nfw-d1",
      "grid": {
        "x": 0,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Action",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.firewall_logs* | STATS c = COUNT() BY a = `aws.firewall_logs.action` | SORT c DESC"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "a"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "nfw-d2",
      "grid": {
        "x": 16,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Protocol",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.firewall_logs* | STATS c = COUNT() BY p = `aws.firewall_logs.protocol` | SORT c DESC | LIMIT 8"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "p"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "nfw-d3",
      "grid": {
        "x": 32,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Firewalls",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.firewall_logs* | STATS c = COUNT() BY f = `aws.firewall_logs.firewall_name` | SORT c DESC | LIMIT 8"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "f"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "nfw-l1",
      "grid": {
        "x": 0,
        "y": 15,
        "w": 48,
        "h": 10
      },
      "config": {
        "title": "Events over time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.firewall_logs* | STATS c = COUNT() BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
                "column": "b"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "c",
                  "label": "Events"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "nfw-l3",
      "grid": {
        "x": 24,
        "y": 25,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Drop events",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.firewall_logs* | STATS drops = SUM(CASE(`aws.firewall_logs.action` == \"DROP\", 1, 0)) BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
                "column": "b"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "drops",
                  "label": "Drops"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "nfw-b1",
      "grid": {
        "x": 0,
        "y": 35,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Top destination ports",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "bar_horizontal",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.firewall_logs* | STATS c = COUNT() BY p = `aws.firewall_logs.dest_port` | SORT c DESC | LIMIT 10"
              },
              "x": {
                "operation": "value",
                "column": "p"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "c",
                  "label": "Flows"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "nfw-t1",
      "grid": {
        "x": 0,
        "y": 45,
        "w": 48,
        "h": 12
      },
      "config": {
        "title": "Recent flows",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.firewall_logs* | KEEP `@timestamp`, `aws.firewall_logs.firewall_name`, `aws.firewall_logs.action`, `aws.firewall_logs.protocol`, `source.ip`, `destination.ip`, `aws.firewall_logs.dest_port`, event.outcome | SORT `@timestamp` DESC | LIMIT 100"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "`@timestamp`",
              "label": "Time"
            },
            {
              "operation": "value",
              "column": "aws.firewall_logs.firewall_name",
              "label": "Firewall"
            },
            {
              "operation": "value",
              "column": "aws.firewall_logs.action",
              "label": "Action"
            },
            {
              "operation": "value",
              "column": "aws.firewall_logs.protocol",
              "label": "Proto"
            },
            {
              "operation": "value",
              "column": "source.ip",
              "label": "Src"
            },
            {
              "operation": "value",
              "column": "destination.ip",
              "label": "Dst"
            },
            {
              "operation": "value",
              "column": "aws.firewall_logs.dest_port",
              "label": "Dport"
            },
            {
              "operation": "value",
              "column": "event.outcome",
              "label": "Outcome"
            }
          ],
          "rows": []
        }
      }
    }
  ]
}
