{
  "title": "Amazon CodeCatalyst — Dev Workflows",
  "time_range": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "type": "lens",
      "uid": "codecatalyst-kpi-total-runs",
      "grid": { "x": 0, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.codecatalyst* | STATS `Total Runs` = COUNT()"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Total Runs" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "codecatalyst-kpi-failed-runs",
      "grid": { "x": 12, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.codecatalyst* | WHERE `aws.codecatalyst.workflow_run_status` == \"FAILED\" | STATS `Failed Runs` = COUNT()"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Failed Runs" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "codecatalyst-kpi-succeeded-runs",
      "grid": { "x": 24, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.codecatalyst* | WHERE `aws.codecatalyst.workflow_run_status` == \"SUCCEEDED\" | STATS `Succeeded Runs` = COUNT()"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Succeeded Runs" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "codecatalyst-kpi-active-dev-envs",
      "grid": { "x": 36, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.codecatalyst* | WHERE `aws.codecatalyst.dev_environment_status` == \"RUNNING\" | STATS `Active Dev Environments` = COUNT()"
          },
          "metrics": [
            { "type": "primary", "operation": "value", "column": "Active Dev Environments" }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "codecatalyst-donut-by-project",
      "grid": { "x": 0, "y": 5, "w": 24, "h": 10 },
      "config": {
        "title": "Runs by Project",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.codecatalyst* | STATS count = COUNT() BY project = `aws.codecatalyst.project_name` | SORT count DESC | LIMIT 10"
          },
          "metrics": [{ "operation": "value", "column": "count" }],
          "group_by": [{ "operation": "value", "column": "project" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "codecatalyst-donut-by-run-status",
      "grid": { "x": 24, "y": 5, "w": 24, "h": 10 },
      "config": {
        "title": "Runs by Status",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.codecatalyst* | STATS count = COUNT() BY status = `aws.codecatalyst.workflow_run_status` | SORT count DESC | LIMIT 10"
          },
          "metrics": [{ "operation": "value", "column": "count" }],
          "group_by": [{ "operation": "value", "column": "status" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "codecatalyst-runs-over-time",
      "grid": { "x": 0, "y": 15, "w": 48, "h": 10 },
      "config": {
        "title": "Workflow Runs Over Time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": { "title": { "visible": false } },
            "left": { "title": { "visible": false } }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.codecatalyst* | STATS count = COUNT() BY bucket = BUCKET(@timestamp, 75, ?_tstart, ?_tend) | SORT bucket"
              },
              "x": { "operation": "value", "column": "bucket" },
              "y": [{ "operation": "value", "column": "count", "label": "Runs" }]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "codecatalyst-recent-runs",
      "grid": { "x": 0, "y": 25, "w": 48, "h": 10 },
      "config": {
        "title": "Recent Workflow Runs",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.codecatalyst* | KEEP @timestamp, `aws.codecatalyst.space_name`, `aws.codecatalyst.project_name`, `aws.codecatalyst.workflow_run_status` | SORT @timestamp DESC | LIMIT 100"
          },
          "metrics": [
            { "operation": "value", "column": "@timestamp", "label": "Timestamp" },
            {
              "operation": "value",
              "column": "aws.codecatalyst.space_name",
              "label": "Space Name"
            },
            {
              "operation": "value",
              "column": "aws.codecatalyst.project_name",
              "label": "Project Name"
            },
            {
              "operation": "value",
              "column": "aws.codecatalyst.workflow_run_status",
              "label": "Run Status"
            }
          ],
          "rows": []
        }
      }
    }
  ]
}
