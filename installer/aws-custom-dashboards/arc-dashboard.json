{
  "title": "Amazon App Recovery Controller — Zonal Shifts",
  "time_range": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "type": "lens",
      "uid": "arc-kpi-total-shifts",
      "grid": { "x": 0, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.arc* | STATS `Total Shifts` = COUNT()"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Total Shifts" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "arc-kpi-active-shifts",
      "grid": { "x": 12, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.arc* | WHERE `aws.arc.zonal_shift_status` == \"ACTIVE\" | STATS `Active Shifts` = COUNT()"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Active Shifts" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "arc-kpi-failed-operations",
      "grid": { "x": 24, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.arc* | WHERE event.outcome == \"failure\" | STATS `Failed Operations` = COUNT()"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Failed Operations" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "arc-kpi-impaired-azs",
      "grid": { "x": 36, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.arc* | WHERE `aws.arc.zonal_shift_status` == \"ACTIVE\" | STATS `Impaired AZs` = COUNT_DISTINCT(`aws.arc.away_from`)"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Impaired AZs" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "arc-donut-by-shift-status",
      "grid": { "x": 0, "y": 5, "w": 24, "h": 10 },
      "config": {
        "title": "Shifts by Status",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.arc* | STATS count = COUNT() BY status = `aws.arc.zonal_shift_status` | SORT count DESC | LIMIT 10"
          },
          "metrics": [{ "operation": "value", "column": "count" }],
          "group_by": [{ "operation": "value", "column": "status" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "arc-donut-by-az",
      "grid": { "x": 24, "y": 5, "w": 24, "h": 10 },
      "config": {
        "title": "Shifts by Availability Zone",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.arc* | STATS count = COUNT() BY az = `aws.arc.away_from` | SORT count DESC | LIMIT 10"
          },
          "metrics": [{ "operation": "value", "column": "count" }],
          "group_by": [{ "operation": "value", "column": "az" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "arc-shifts-over-time",
      "grid": { "x": 0, "y": 15, "w": 48, "h": 10 },
      "config": {
        "title": "Zonal Shifts Over Time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": { "title": { "visible": false } },
            "left": { "title": { "visible": false } }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.arc* | STATS count = COUNT() BY bucket = BUCKET(@timestamp, 75, ?_tstart, ?_tend) | SORT bucket"
              },
              "x": { "operation": "value", "column": "bucket" },
              "y": [{ "operation": "value", "column": "count", "label": "Shifts" }]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "arc-recent-shifts",
      "grid": { "x": 0, "y": 25, "w": 48, "h": 10 },
      "config": {
        "title": "Recent Zonal Shifts",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.arc* | KEEP @timestamp, `aws.arc.zonal_shift_status`, `aws.arc.away_from`, `aws.arc.comment`, event.outcome | SORT @timestamp DESC | LIMIT 100"
          },
          "metrics": [
            { "operation": "value", "column": "@timestamp", "label": "Timestamp" },
            {
              "operation": "value",
              "column": "aws.arc.zonal_shift_status",
              "label": "Shift Status"
            },
            { "operation": "value", "column": "aws.arc.away_from", "label": "Away From AZ" },
            { "operation": "value", "column": "aws.arc.comment", "label": "Comment" },
            { "operation": "value", "column": "event.outcome", "label": "Outcome" }
          ],
          "rows": []
        }
      }
    }
  ]
}
