{
  "title": "AWS Connect — Overview",
  "time_range": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "type": "lens",
      "uid": "connect-kpi-events",
      "grid": { "x": 0, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": { "type": "esql", "query": "FROM logs-aws.connect* | STATS Events = COUNT()" },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Events" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "connect-kpi-failures",
      "grid": { "x": 12, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.connect* | STATS Failures = SUM(CASE(`event.outcome` == \"failure\", 1, 0))"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Failures" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "connect-kpi-metric3",
      "grid": { "x": 24, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM metrics-aws.connect* | STATS avg_m = AVG(`aws.connect.metrics.ContactsQueued.sum`) | EVAL `Avg metric` = ROUND(avg_m, 1)"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Avg metric" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "connect-kpi-metric4",
      "grid": { "x": 36, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM metrics-aws.connect* | STATS `Metric sum` = ROUND(SUM(`aws.connect.metrics.ContactsQueued.sum`), 0)"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Metric sum" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "connect-donut-outcome",
      "grid": { "x": 0, "y": 5, "w": 24, "h": 8 },
      "config": {
        "title": "Event Outcome",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.connect* | STATS count = COUNT() BY outcome = `event.outcome` | SORT count DESC"
          },
          "metrics": [{ "operation": "value", "column": "count" }],
          "group_by": [{ "operation": "value", "column": "outcome" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "connect-bar-dimension",
      "grid": { "x": 24, "y": 5, "w": 24, "h": 8 },
      "config": {
        "title": "Events by queue name",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": { "title": { "visible": false } },
            "left": { "title": { "visible": false } }
          },
          "layers": [
            {
              "type": "bar_horizontal",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.connect* | STATS count = COUNT() BY dim = `aws.connect.queue_name` | SORT count DESC | LIMIT 10"
              },
              "x": { "operation": "value", "column": "dim" },
              "y": [{ "operation": "value", "column": "count", "label": "Events" }]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "connect-line-volume",
      "grid": { "x": 0, "y": 13, "w": 24, "h": 8 },
      "config": {
        "title": "Event Volume Over Time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": { "title": { "visible": false } },
            "left": { "title": { "visible": false } }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.connect* | STATS count = COUNT() BY bucket = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT bucket"
              },
              "x": { "operation": "value", "column": "bucket" },
              "y": [{ "operation": "value", "column": "count", "label": "Events" }]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "connect-line-metric",
      "grid": { "x": 24, "y": 13, "w": 24, "h": 8 },
      "config": {
        "title": "Key metric over time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": { "title": { "visible": false } },
            "left": { "title": { "visible": false } }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM metrics-aws.connect* | STATS avg_m = AVG(`aws.connect.metrics.ContactsQueued.sum`) BY bucket = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT bucket"
              },
              "x": { "operation": "value", "column": "bucket" },
              "y": [{ "operation": "value", "column": "avg_m", "label": "Avg metric" }]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "connect-bar-region",
      "grid": { "x": 0, "y": 21, "w": 16, "h": 8 },
      "config": {
        "title": "Events by Region",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": { "title": { "visible": false } },
            "left": { "title": { "visible": false } }
          },
          "layers": [
            {
              "type": "bar_horizontal",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.connect* | STATS count = COUNT() BY region = cloud.region | SORT count DESC | LIMIT 10"
              },
              "x": { "operation": "value", "column": "region" },
              "y": [{ "operation": "value", "column": "count", "label": "Events" }]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "connect-bar-resource",
      "grid": { "x": 16, "y": 21, "w": 16, "h": 8 },
      "config": {
        "title": "Events by instance id",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": { "title": { "visible": false } },
            "left": { "title": { "visible": false } }
          },
          "layers": [
            {
              "type": "bar_horizontal",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.connect* | STATS count = COUNT() BY res = `aws.connect.instance_id` | SORT count DESC | LIMIT 10"
              },
              "x": { "operation": "value", "column": "res" },
              "y": [{ "operation": "value", "column": "count", "label": "Events" }]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "connect-donut-log-level",
      "grid": { "x": 32, "y": 21, "w": 16, "h": 8 },
      "config": {
        "title": "Log Level",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.connect* | STATS count = COUNT() BY lvl = log.level | SORT count DESC"
          },
          "metrics": [{ "operation": "value", "column": "count" }],
          "group_by": [{ "operation": "value", "column": "lvl" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "connect-table-recent",
      "grid": { "x": 0, "y": 29, "w": 48, "h": 10 },
      "config": {
        "title": "Recent Events",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.connect* | KEEP `@timestamp`, `aws.connect.queue_name`, `aws.connect.instance_id`, `log.level`, `event.outcome`, message | SORT `@timestamp` DESC | LIMIT 100"
          },
          "metrics": [
            { "operation": "value", "column": "`@timestamp`", "label": "Timestamp" },
            { "operation": "value", "column": "aws.connect.queue_name", "label": "Queue name" },
            { "operation": "value", "column": "aws.connect.instance_id", "label": "Instance id" },
            { "operation": "value", "column": "log.level", "label": "Level" },
            { "operation": "value", "column": "event.outcome", "label": "Outcome" },
            { "operation": "value", "column": "message", "label": "Message" }
          ],
          "rows": []
        }
      }
    }
  ]
}
