{
  "title": "AWS API Gateway — Requests & Latency",
  "time_range": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "type": "lens",
      "uid": "apigw-k1",
      "grid": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.apigateway_logs* | STATS `Requests` = COUNT()"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Requests"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "apigw-k2",
      "grid": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.apigateway_logs* | EVAL s5 = CASE(`aws.apigateway.status` >= 500, 1, 0) | STATS m = AVG(s5) | EVAL `5xx %` = ROUND(m * 100, 1)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "5xx %"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "apigw-k3",
      "grid": {
        "x": 24,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.apigateway_logs* | STATS a = AVG(event.duration) | EVAL `Avg latency (ms)` = ROUND(a / 1000000.0, 1)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Avg latency (ms)"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "apigw-k4",
      "grid": {
        "x": 36,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.apigateway_logs* | STATS a = AVG(`aws.apigateway.integration_latency`) | EVAL `Avg integ (ms)` = ROUND(a, 1)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Avg integration (ms)"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "apigw-d1",
      "grid": {
        "x": 0,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "HTTP status",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.apigateway_logs* | STATS c = COUNT() BY st = `aws.apigateway.status` | SORT c DESC | LIMIT 10"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "st"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "apigw-d2",
      "grid": {
        "x": 16,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "API stages",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.apigateway_logs* | STATS c = COUNT() BY stg = `aws.apigateway.stage` | SORT c DESC | LIMIT 10"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "stg"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "apigw-d3",
      "grid": {
        "x": 32,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "API type",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.apigateway_logs* | STATS c = COUNT() BY t = `aws.apigateway.api_type` | SORT c DESC | LIMIT 8"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "t"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "apigw-l1",
      "grid": {
        "x": 0,
        "y": 15,
        "w": 48,
        "h": 10
      },
      "config": {
        "title": "Requests over time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.apigateway_logs* | STATS c = COUNT() BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
                "column": "b"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "c",
                  "label": "Requests"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "apigw-l2",
      "grid": {
        "x": 0,
        "y": 25,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Latency vs integration",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.apigateway_logs* | STATS lat = AVG(event.duration) / 1000000.0, integ = AVG(`aws.apigateway.integration_latency`) BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
                "column": "b"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "lat",
                  "label": "Latency (ms)"
                },
                {
                  "operation": "value",
                  "column": "integ",
                  "label": "Integration (ms)"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "apigw-l3",
      "grid": {
        "x": 24,
        "y": 25,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "4xx vs 5xx",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.apigateway_logs* | STATS e4 = SUM(`aws.apigateway.metrics.4XXError.sum`), e5 = SUM(`aws.apigateway.metrics.5XXError.sum`) BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
                "column": "b"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "e4",
                  "label": "4XX"
                },
                {
                  "operation": "value",
                  "column": "e5",
                  "label": "5XX"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "apigw-b1",
      "grid": {
        "x": 0,
        "y": 35,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Top APIs by volume",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "bar_horizontal",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.apigateway_logs* | STATS c = COUNT() BY api = `aws.apigateway.api_id` | SORT c DESC | LIMIT 10"
              },
              "x": {
                "operation": "value",
                "column": "api"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "c",
                  "label": "Requests"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "apigw-t1",
      "grid": {
        "x": 0,
        "y": 45,
        "w": 48,
        "h": 12
      },
      "config": {
        "title": "Recent requests",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.apigateway_logs* | KEEP `@timestamp`, `aws.apigateway.api_id`, `aws.apigateway.stage`, `aws.apigateway.http_method`, `aws.apigateway.resource_path`, `aws.apigateway.status`, `aws.apigateway.integration_latency`, `aws.apigateway.request_id` | SORT `@timestamp` DESC | LIMIT 100"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "`@timestamp`",
              "label": "Time"
            },
            {
              "operation": "value",
              "column": "aws.apigateway.api_id",
              "label": "API"
            },
            {
              "operation": "value",
              "column": "aws.apigateway.stage",
              "label": "Stage"
            },
            {
              "operation": "value",
              "column": "aws.apigateway.http_method",
              "label": "Method"
            },
            {
              "operation": "value",
              "column": "aws.apigateway.resource_path",
              "label": "Path"
            },
            {
              "operation": "value",
              "column": "aws.apigateway.status",
              "label": "Status"
            },
            {
              "operation": "value",
              "column": "aws.apigateway.integration_latency",
              "label": "Integ ms"
            },
            {
              "operation": "value",
              "column": "aws.apigateway.request_id",
              "label": "Request ID"
            }
          ],
          "rows": []
        }
      }
    }
  ]
}
