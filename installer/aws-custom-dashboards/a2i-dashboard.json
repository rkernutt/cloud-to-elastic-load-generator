{
  "title": "Amazon Augmented AI — Human Review",
  "time_range": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "type": "lens",
      "uid": "a2i-kpi-total-loops",
      "grid": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.a2i* | STATS `Total Loops` = COUNT()"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Total Loops"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "a2i-kpi-failed-loops",
      "grid": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.a2i* | WHERE `aws.a2i.human_loop_status` == \"Failed\" | STATS `Failed Loops` = COUNT()"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Failed Loops"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "a2i-kpi-completed-loops",
      "grid": {
        "x": 24,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.a2i* | WHERE `aws.a2i.task_completed` == true | STATS `Completed Loops` = COUNT()"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Completed Loops"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "a2i-kpi-review-required",
      "grid": {
        "x": 36,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.a2i* | WHERE `aws.a2i.human_review_required` == true | STATS `Review Required Count` = COUNT()"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Review Required Count"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "a2i-donut-by-loop-status",
      "grid": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Loops by Status",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.a2i* | STATS count = COUNT() BY status = `aws.a2i.human_loop_status` | SORT count DESC | LIMIT 10"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "count"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "status"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "a2i-donut-by-flow-definition",
      "grid": {
        "x": 24,
        "y": 5,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Loops by Flow Definition",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.a2i* | STATS count = COUNT() BY flow = `aws.a2i.flow_definition_name` | SORT count DESC | LIMIT 10"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "count"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "flow"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "a2i-loops-over-time",
      "grid": {
        "x": 0,
        "y": 15,
        "w": 48,
        "h": 10
      },
      "config": {
        "title": "Human Review Loops Over Time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.a2i* | STATS count = COUNT() BY bucket = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT bucket"
              },
              "x": {
                "operation": "value",
                "column": "bucket"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "count",
                  "label": "Loops"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "a2i-recent-loops",
      "grid": {
        "x": 0,
        "y": 25,
        "w": 48,
        "h": 10
      },
      "config": {
        "title": "Recent Human Review Loops",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.a2i* | KEEP `@timestamp`, `aws.a2i.human_loop_status`, `aws.a2i.human_review_required`, `aws.a2i.task_completed`, `aws.a2i.flow_definition_name` | SORT `@timestamp` DESC | LIMIT 100"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "`@timestamp`",
              "label": "Timestamp"
            },
            {
              "operation": "value",
              "column": "aws.a2i.human_loop_status",
              "label": "Loop Status"
            },
            {
              "operation": "value",
              "column": "aws.a2i.human_review_required",
              "label": "Review Required"
            },
            {
              "operation": "value",
              "column": "aws.a2i.task_completed",
              "label": "Task Completed"
            },
            {
              "operation": "value",
              "column": "aws.a2i.flow_definition_name",
              "label": "Flow Definition"
            }
          ],
          "rows": []
        }
      }
    }
  ]
}
