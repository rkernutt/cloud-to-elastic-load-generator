{
  "title": "AWS B2B Data Interchange — EDI Processing",
  "time_range": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "type": "lens",
      "uid": "b2bi-kpi-total-transactions",
      "grid": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.b2bi* | STATS `Total Transactions` = COUNT()"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Total Transactions"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "b2bi-kpi-failed-transformations",
      "grid": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.b2bi* | WHERE `aws.b2bi.processing_status` == \"FAILED\" | STATS `Failed Transformations` = COUNT()"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Failed Transformations"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "b2bi-kpi-total-transaction-count",
      "grid": {
        "x": 24,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.b2bi* | STATS `Total Transaction Count` = SUM(`aws.b2bi.transaction_count`)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Total Transaction Count"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "b2bi-kpi-unique-partners",
      "grid": {
        "x": 36,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.b2bi* | STATS `Unique Partners` = COUNT_DISTINCT(`aws.b2bi.partner_name`)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Unique Partners"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "b2bi-donut-processing-status",
      "grid": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Processing Status",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.b2bi* | STATS count = COUNT() BY status = `aws.b2bi.processing_status` | SORT count DESC | LIMIT 10"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "count"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "status"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "b2bi-donut-document-type",
      "grid": {
        "x": 24,
        "y": 5,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Document Type",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.b2bi* | STATS count = COUNT() BY doc_type = `aws.b2bi.document_type` | SORT count DESC | LIMIT 10"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "count"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "doc_type"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "b2bi-transactions-over-time",
      "grid": {
        "x": 0,
        "y": 15,
        "w": 48,
        "h": 10
      },
      "config": {
        "title": "EDI Transactions Over Time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.b2bi* | STATS count = COUNT() BY bucket = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT bucket"
              },
              "x": {
                "operation": "value",
                "column": "bucket"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "count",
                  "label": "Transactions"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "b2bi-recent-transactions",
      "grid": {
        "x": 0,
        "y": 25,
        "w": 48,
        "h": 10
      },
      "config": {
        "title": "Recent Transactions",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.b2bi* | KEEP `@timestamp`, `aws.b2bi.partner_name`, `aws.b2bi.document_type`, `aws.b2bi.processing_status`, `aws.b2bi.transaction_count` | SORT `@timestamp` DESC | LIMIT 100"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "`@timestamp`",
              "label": "Timestamp"
            },
            {
              "operation": "value",
              "column": "aws.b2bi.partner_name",
              "label": "Partner Name"
            },
            {
              "operation": "value",
              "column": "aws.b2bi.document_type",
              "label": "Document Type"
            },
            {
              "operation": "value",
              "column": "aws.b2bi.processing_status",
              "label": "Processing Status"
            },
            {
              "operation": "value",
              "column": "aws.b2bi.transaction_count",
              "label": "Transaction Count"
            }
          ],
          "rows": []
        }
      }
    }
  ]
}
