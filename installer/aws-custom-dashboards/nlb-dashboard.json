{
  "title": "AWS Network Load Balancer — TCP/UDP",
  "time_range": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "type": "lens",
      "uid": "nlb-k1",
      "grid": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.elb_logs* | WHERE `cloud.service.name` == \"nlb\" | STATS Events = COUNT()"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Events"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "nlb-k2",
      "grid": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.elb_logs* | WHERE `cloud.service.name` == \"nlb\" | EVAL f = CASE(event.outcome == \"failure\", 1, 0) | STATS m = AVG(f) | EVAL `Failure %` = ROUND(m * 100, 1)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Failure %"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "nlb-k3",
      "grid": {
        "x": 24,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.elb_logs* | WHERE `cloud.service.name` == \"nlb\" | STATS `Conn ms` = ROUND(AVG(`aws.elb.connection_time.ms`), 1)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Avg conn (ms)"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "nlb-k4",
      "grid": {
        "x": 36,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.elb_logs* | WHERE `cloud.service.name` == \"nlb\" | STATS bytes = SUM(`aws.elb.received_bytes`) + SUM(`aws.elb.sent_bytes`) | EVAL `Bytes` = bytes"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Bytes transferred"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "nlb-d1",
      "grid": {
        "x": 0,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Protocol",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.elb_logs* | WHERE `cloud.service.name` == \"nlb\" | STATS c = COUNT() BY p = `aws.elb.protocol` | SORT c DESC"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "p"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "nlb-d2",
      "grid": {
        "x": 16,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Outcome",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.elb_logs* | WHERE `cloud.service.name` == \"nlb\" | STATS c = COUNT() BY o = event.outcome"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "o"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "nlb-d3",
      "grid": {
        "x": 32,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Load balancers",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.elb_logs* | WHERE `cloud.service.name` == \"nlb\" | STATS c = COUNT() BY lb = `aws.elb.name` | SORT c DESC | LIMIT 8"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "lb"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "nlb-l1",
      "grid": {
        "x": 0,
        "y": 15,
        "w": 48,
        "h": 10
      },
      "config": {
        "title": "Connections over time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.elb_logs* | WHERE `cloud.service.name` == \"nlb\" | STATS c = COUNT() BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
                "column": "b"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "c",
                  "label": "Events"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "nlb-l2",
      "grid": {
        "x": 0,
        "y": 25,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Received vs sent bytes",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.elb_logs* | WHERE `cloud.service.name` == \"nlb\" | STATS rx = SUM(`aws.elb.received_bytes`), tx = SUM(`aws.elb.sent_bytes`) BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
                "column": "b"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "rx",
                  "label": "Received"
                },
                {
                  "operation": "value",
                  "column": "tx",
                  "label": "Sent"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "nlb-l3",
      "grid": {
        "x": 24,
        "y": 25,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Connection duration (ms)",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.elb_logs* | WHERE `cloud.service.name` == \"nlb\" | STATS d = AVG(`aws.elb.connection_time.ms`) BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
                "column": "b"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "d",
                  "label": "Conn ms"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "nlb-b1",
      "grid": {
        "x": 0,
        "y": 35,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Top backend IPs",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "bar_horizontal",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.elb_logs* | WHERE `cloud.service.name` == \"nlb\" | STATS c = COUNT() BY ip = `aws.elb.backend.ip` | SORT c DESC | LIMIT 10"
              },
              "x": {
                "operation": "value",
                "column": "ip"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "c",
                  "label": "Flows"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "nlb-t1",
      "grid": {
        "x": 0,
        "y": 45,
        "w": 48,
        "h": 12
      },
      "config": {
        "title": "Recent flows",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.elb_logs* | WHERE `cloud.service.name` == \"nlb\" | KEEP `@timestamp`, `aws.elb.name`, `aws.elb.protocol`, event.outcome, `source.ip`, `aws.elb.backend.ip`, `aws.elb.connection_time.ms`, `network.bytes` | SORT `@timestamp` DESC | LIMIT 100"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "`@timestamp`",
              "label": "Time"
            },
            {
              "operation": "value",
              "column": "aws.elb.name",
              "label": "NLB"
            },
            {
              "operation": "value",
              "column": "aws.elb.protocol",
              "label": "Proto"
            },
            {
              "operation": "value",
              "column": "event.outcome",
              "label": "Outcome"
            },
            {
              "operation": "value",
              "column": "source.ip",
              "label": "Client"
            },
            {
              "operation": "value",
              "column": "aws.elb.backend.ip",
              "label": "Backend"
            },
            {
              "operation": "value",
              "column": "aws.elb.connection_time.ms",
              "label": "Conn ms"
            },
            {
              "operation": "value",
              "column": "network.bytes",
              "label": "Bytes"
            }
          ],
          "rows": []
        }
      }
    }
  ]
}
