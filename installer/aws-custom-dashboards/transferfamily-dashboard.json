{
  "title": "AWS Transferfamily — Overview",
  "time_range": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "type": "lens",
      "uid": "transferfamily-kpi-events",
      "grid": { "x": 0, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.transferfamily* | STATS Events = COUNT()"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Events" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "transferfamily-kpi-failures",
      "grid": { "x": 12, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.transferfamily* | STATS Failures = SUM(CASE(`event.outcome` == \"failure\", 1, 0))"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Failures" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "transferfamily-kpi-actions",
      "grid": { "x": 24, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.transferfamily* | STATS `Distinct actions` = COUNT_DISTINCT(`event.action`)"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Distinct actions" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "transferfamily-kpi-resources",
      "grid": { "x": 36, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.transferfamily* | STATS Resources = COUNT_DISTINCT(`aws.transferfamily.server_id`)"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Resources" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "transferfamily-donut-outcome",
      "grid": { "x": 0, "y": 5, "w": 24, "h": 8 },
      "config": {
        "title": "Event Outcome",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.transferfamily* | STATS count = COUNT() BY outcome = `event.outcome` | SORT count DESC"
          },
          "metrics": [{ "operation": "value", "column": "count" }],
          "group_by": [{ "operation": "value", "column": "outcome" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "transferfamily-bar-dimension",
      "grid": { "x": 24, "y": 5, "w": 24, "h": 8 },
      "config": {
        "title": "Events by operation",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": { "title": { "visible": false } },
            "left": { "title": { "visible": false } }
          },
          "layers": [
            {
              "type": "bar_horizontal",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.transferfamily* | STATS count = COUNT() BY dim = `aws.transferfamily.operation` | SORT count DESC | LIMIT 10"
              },
              "x": { "operation": "value", "column": "dim" },
              "y": [{ "operation": "value", "column": "count", "label": "Events" }]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "transferfamily-line-volume",
      "grid": { "x": 0, "y": 13, "w": 24, "h": 8 },
      "config": {
        "title": "Event Volume Over Time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": { "title": { "visible": false } },
            "left": { "title": { "visible": false } }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.transferfamily* | STATS count = COUNT() BY bucket = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT bucket"
              },
              "x": { "operation": "value", "column": "bucket" },
              "y": [{ "operation": "value", "column": "count", "label": "Events" }]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "transferfamily-line-failures",
      "grid": { "x": 24, "y": 13, "w": 24, "h": 8 },
      "config": {
        "title": "Failures over time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": { "title": { "visible": false } },
            "left": { "title": { "visible": false } }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.transferfamily* | STATS failures = SUM(CASE(`event.outcome` == \"failure\", 1, 0)) BY bucket = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT bucket"
              },
              "x": { "operation": "value", "column": "bucket" },
              "y": [{ "operation": "value", "column": "failures", "label": "Failures" }]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "transferfamily-bar-region",
      "grid": { "x": 0, "y": 21, "w": 16, "h": 8 },
      "config": {
        "title": "Events by Region",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": { "title": { "visible": false } },
            "left": { "title": { "visible": false } }
          },
          "layers": [
            {
              "type": "bar_horizontal",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.transferfamily* | STATS count = COUNT() BY region = cloud.region | SORT count DESC | LIMIT 10"
              },
              "x": { "operation": "value", "column": "region" },
              "y": [{ "operation": "value", "column": "count", "label": "Events" }]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "transferfamily-bar-resource",
      "grid": { "x": 16, "y": 21, "w": 16, "h": 8 },
      "config": {
        "title": "Events by server id",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": { "title": { "visible": false } },
            "left": { "title": { "visible": false } }
          },
          "layers": [
            {
              "type": "bar_horizontal",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.transferfamily* | STATS count = COUNT() BY res = `aws.transferfamily.server_id` | SORT count DESC | LIMIT 10"
              },
              "x": { "operation": "value", "column": "res" },
              "y": [{ "operation": "value", "column": "count", "label": "Events" }]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "transferfamily-donut-log-level",
      "grid": { "x": 32, "y": 21, "w": 16, "h": 8 },
      "config": {
        "title": "Log Level",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.transferfamily* | STATS count = COUNT() BY lvl = log.level | SORT count DESC"
          },
          "metrics": [{ "operation": "value", "column": "count" }],
          "group_by": [{ "operation": "value", "column": "lvl" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "transferfamily-table-recent",
      "grid": { "x": 0, "y": 29, "w": 48, "h": 10 },
      "config": {
        "title": "Recent Events",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.transferfamily* | KEEP `@timestamp`, `aws.transferfamily.operation`, `aws.transferfamily.server_id`, `log.level`, `event.outcome`, message | SORT `@timestamp` DESC | LIMIT 100"
          },
          "metrics": [
            { "operation": "value", "column": "`@timestamp`", "label": "Timestamp" },
            {
              "operation": "value",
              "column": "aws.transferfamily.operation",
              "label": "Operation"
            },
            {
              "operation": "value",
              "column": "aws.transferfamily.server_id",
              "label": "Server id"
            },
            { "operation": "value", "column": "log.level", "label": "Level" },
            { "operation": "value", "column": "event.outcome", "label": "Outcome" },
            { "operation": "value", "column": "message", "label": "Message" }
          ],
          "rows": []
        }
      }
    }
  ]
}
