{
  "title": "Amazon Kinesis — Overview",
  "time_range": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "type": "lens",
      "uid": "kin-kpi-events",
      "grid": { "x": 0, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.kinesis* | STATS `Events` = COUNT()"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Events" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "kin-kpi-failures",
      "grid": { "x": 12, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.kinesis* | STATS `Failures` = SUM(CASE(`event.outcome` == \"failure\", 1, 0))"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Failures" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "kin-kpi-records",
      "grid": { "x": 24, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM metrics-aws.kinesis* | STATS `Incoming Records` = SUM(`aws.kinesis.metrics.IncomingRecords.sum`)"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Incoming Records" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "kin-kpi-bytes",
      "grid": { "x": 36, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM metrics-aws.kinesis* | STATS `Incoming Bytes` = SUM(`aws.kinesis.metrics.IncomingBytes.sum`)"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Incoming Bytes" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "kin-donut-outcome",
      "grid": { "x": 0, "y": 5, "w": 24, "h": 8 },
      "config": {
        "title": "Event Outcome",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.kinesis* | STATS count = COUNT() BY outcome = `event.outcome` | SORT count DESC"
          },
          "metrics": [{ "operation": "value", "column": "count" }],
          "group_by": [{ "operation": "value", "column": "outcome" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "kin-bar-operation",
      "grid": { "x": 24, "y": 5, "w": 24, "h": 8 },
      "config": {
        "title": "Events by Operation",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": { "title": { "visible": false } },
            "left": { "title": { "visible": false } }
          },
          "layers": [
            {
              "type": "bar_horizontal",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.kinesis* | STATS count = COUNT() BY op = `aws.kinesis.operation` | SORT count DESC | LIMIT 10"
              },
              "x": { "operation": "value", "column": "op" },
              "y": [{ "operation": "value", "column": "count", "label": "Events" }]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "kin-line-volume",
      "grid": { "x": 0, "y": 13, "w": 24, "h": 8 },
      "config": {
        "title": "Event Volume Over Time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": { "title": { "visible": false } },
            "left": { "title": { "visible": false } }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.kinesis* | STATS count = COUNT() BY bucket = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT bucket"
              },
              "x": { "operation": "value", "column": "bucket" },
              "y": [{ "operation": "value", "column": "count", "label": "Events" }]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "kin-line-latency",
      "grid": { "x": 24, "y": 13, "w": 24, "h": 8 },
      "config": {
        "title": "Get/Put Latency Over Time (ms)",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": { "title": { "visible": false } },
            "left": { "title": { "visible": false } }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM metrics-aws.kinesis* | STATS get_lat = AVG(`aws.kinesis.metrics.GetRecords.Latency.avg`), put_lat = AVG(`aws.kinesis.metrics.PutRecords.Latency.avg`) BY bucket = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT bucket"
              },
              "x": { "operation": "value", "column": "bucket" },
              "y": [
                { "operation": "value", "column": "get_lat", "label": "GetRecords" },
                { "operation": "value", "column": "put_lat", "label": "PutRecords" }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "kin-bar-region",
      "grid": { "x": 0, "y": 21, "w": 16, "h": 8 },
      "config": {
        "title": "Events by Region",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": { "title": { "visible": false } },
            "left": { "title": { "visible": false } }
          },
          "layers": [
            {
              "type": "bar_horizontal",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.kinesis* | STATS count = COUNT() BY region = cloud.region | SORT count DESC | LIMIT 10"
              },
              "x": { "operation": "value", "column": "region" },
              "y": [{ "operation": "value", "column": "count", "label": "Events" }]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "kin-bar-stream",
      "grid": { "x": 16, "y": 21, "w": 16, "h": 8 },
      "config": {
        "title": "Top Streams",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": { "title": { "visible": false } },
            "left": { "title": { "visible": false } }
          },
          "layers": [
            {
              "type": "bar_horizontal",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.kinesis* | STATS count = COUNT() BY stream = `aws.kinesis.stream_name` | SORT count DESC | LIMIT 10"
              },
              "x": { "operation": "value", "column": "stream" },
              "y": [{ "operation": "value", "column": "count", "label": "Events" }]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "kin-donut-log-level",
      "grid": { "x": 32, "y": 21, "w": 16, "h": 8 },
      "config": {
        "title": "Log Level",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.kinesis* | STATS count = COUNT() BY lvl = log.level | SORT count DESC"
          },
          "metrics": [{ "operation": "value", "column": "count" }],
          "group_by": [{ "operation": "value", "column": "lvl" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "kin-table-recent",
      "grid": { "x": 0, "y": 29, "w": 48, "h": 10 },
      "config": {
        "title": "Recent Events",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.kinesis* | KEEP `@timestamp`, `aws.kinesis.stream_name`, `aws.kinesis.shard_id`, `aws.kinesis.operation`, log.level, `event.outcome` | SORT `@timestamp` DESC | LIMIT 100"
          },
          "metrics": [
            { "operation": "value", "column": "`@timestamp`", "label": "Timestamp" },
            { "operation": "value", "column": "aws.kinesis.stream_name", "label": "Stream" },
            { "operation": "value", "column": "aws.kinesis.shard_id", "label": "Shard" },
            { "operation": "value", "column": "aws.kinesis.operation", "label": "Operation" },
            { "operation": "value", "column": "log.level", "label": "Log level" },
            { "operation": "value", "column": "event.outcome", "label": "Outcome" }
          ],
          "rows": []
        }
      }
    }
  ]
}
