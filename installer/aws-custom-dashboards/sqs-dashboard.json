{
  "title": "Amazon SQS — Overview",
  "time_range": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "type": "lens",
      "uid": "sqs-kpi-events",
      "grid": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.sqs* | STATS `Events` = COUNT()"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Events"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "sqs-kpi-failures",
      "grid": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.sqs* | STATS `Failures` = SUM(CASE(`event.outcome` == \"failure\", 1, 0))"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Failures"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "sqs-kpi-visible",
      "grid": {
        "x": 24,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM metrics-aws.sqs* | STATS avg_v = AVG(`aws.sqs.metrics.ApproximateNumberOfMessagesVisible.avg`) | EVAL `Avg Visible Msgs` = ROUND(avg_v, 0)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Avg Visible Msgs"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "sqs-kpi-sent",
      "grid": {
        "x": 36,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM metrics-aws.sqs* | STATS `Messages Sent` = SUM(`aws.sqs.metrics.NumberOfMessagesSent.sum`)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Messages Sent"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "sqs-donut-outcome",
      "grid": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 8
      },
      "config": {
        "title": "Event Outcome",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.sqs* | STATS count = COUNT() BY outcome = `event.outcome` | SORT count DESC"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "count"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "outcome"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "sqs-bar-operation",
      "grid": {
        "x": 24,
        "y": 5,
        "w": 24,
        "h": 8
      },
      "config": {
        "title": "Events by Operation",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "bar_horizontal",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.sqs* | STATS count = COUNT() BY op = `aws.sqs.operation` | SORT count DESC | LIMIT 10"
              },
              "x": {
                "operation": "value",
                "column": "op"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "count",
                  "label": "Events"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "sqs-line-volume",
      "grid": {
        "x": 0,
        "y": 13,
        "w": 24,
        "h": 8
      },
      "config": {
        "title": "Event Volume Over Time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.sqs* | STATS count = COUNT() BY bucket = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT bucket"
              },
              "x": {
                "operation": "value",
                "column": "bucket"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "count",
                  "label": "Events"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "sqs-line-throughput",
      "grid": {
        "x": 24,
        "y": 13,
        "w": 24,
        "h": 8
      },
      "config": {
        "title": "Message Throughput Over Time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM metrics-aws.sqs* | STATS sent = SUM(`aws.sqs.metrics.NumberOfMessagesSent.sum`), received = SUM(`aws.sqs.metrics.NumberOfMessagesReceived.sum`) BY bucket = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT bucket"
              },
              "x": {
                "operation": "value",
                "column": "bucket"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "sent",
                  "label": "Sent"
                },
                {
                  "operation": "value",
                  "column": "received",
                  "label": "Received"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "sqs-bar-region",
      "grid": {
        "x": 0,
        "y": 21,
        "w": 16,
        "h": 8
      },
      "config": {
        "title": "Events by Region",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "bar_horizontal",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.sqs* | STATS count = COUNT() BY region = COALESCE(cloud.region, \"unknown\") | SORT count DESC | LIMIT 10"
              },
              "x": {
                "operation": "value",
                "column": "region"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "count",
                  "label": "Events"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "sqs-bar-queue",
      "grid": {
        "x": 16,
        "y": 21,
        "w": 16,
        "h": 8
      },
      "config": {
        "title": "Top Queues",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "bar_horizontal",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.sqs* | STATS count = COUNT() BY queue = `aws.sqs.queue_name` | SORT count DESC | LIMIT 10"
              },
              "x": {
                "operation": "value",
                "column": "queue"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "count",
                  "label": "Events"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "sqs-donut-log-level",
      "grid": {
        "x": 32,
        "y": 21,
        "w": 16,
        "h": 8
      },
      "config": {
        "title": "Log Level",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.sqs* | STATS count = COUNT() BY lvl = log.level | SORT count DESC"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "count"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "lvl"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "sqs-table-recent",
      "grid": {
        "x": 0,
        "y": 29,
        "w": 48,
        "h": 10
      },
      "config": {
        "title": "Recent Events",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.sqs* | KEEP `@timestamp`, `aws.sqs.queue_name`, `aws.sqs.operation`, log.level, `event.outcome` | SORT `@timestamp` DESC | LIMIT 100"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "`@timestamp`",
              "label": "Timestamp"
            },
            {
              "operation": "value",
              "column": "aws.sqs.queue_name",
              "label": "Queue"
            },
            {
              "operation": "value",
              "column": "aws.sqs.operation",
              "label": "Operation"
            },
            {
              "operation": "value",
              "column": "aws.sqs.metrics.ApproximateNumberOfMessagesVisible.avg",
              "label": "Visible"
            },
            {
              "operation": "value",
              "column": "aws.sqs.metrics.NumberOfMessagesSent.sum",
              "label": "Sent"
            },
            {
              "operation": "value",
              "column": "log.level",
              "label": "Log level"
            },
            {
              "operation": "value",
              "column": "event.outcome",
              "label": "Outcome"
            }
          ],
          "rows": []
        }
      }
    }
  ]
}
