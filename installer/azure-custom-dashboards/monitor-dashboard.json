{
  "title": "Azure Monitor — Alerts & Diagnostics",
  "time_range": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "type": "lens",
      "uid": "azmon-k1",
      "grid": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.monitor* | STATS Events = COUNT()"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Events"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "azmon-k2",
      "grid": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.monitor* | EVAL f = CASE(event.outcome == \"failure\", 1, 0) | STATS m = AVG(f) | EVAL `Failure %` = ROUND(m * 100, 1)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Failure %"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "azmon-k3",
      "grid": {
        "x": 24,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.monitor* | STATS `Resources` = COUNT_DISTINCT(`azure.monitor.resource_name`)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Distinct resources"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "azmon-k4",
      "grid": {
        "x": 36,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.monitor* | STATS `Avg ms` = ROUND(AVG(`azure.monitor.duration_ms`), 0)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Avg duration (ms)"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "azmon-d1",
      "grid": {
        "x": 0,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Category",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.monitor* | STATS c = COUNT() BY cat = `azure.monitor.category` | SORT c DESC | LIMIT 10"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "cat"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "azmon-d2",
      "grid": {
        "x": 16,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Result",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.monitor* | STATS c = COUNT() BY r = `azure.monitor.status` | SORT c DESC"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "r"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "azmon-d3",
      "grid": {
        "x": 32,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Outcome",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.monitor* | STATS c = COUNT() BY o = event.outcome | SORT c DESC"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "o"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "azmon-l1",
      "grid": {
        "x": 0,
        "y": 15,
        "w": 48,
        "h": 10
      },
      "config": {
        "title": "Events over time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-azure.monitor* | STATS c = COUNT() BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
                "column": "b"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "c",
                  "label": "Events"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "azmon-l2",
      "grid": {
        "x": 0,
        "y": 25,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "HTTP status mix",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-azure.monitor* | STATS s2 = SUM(CASE(`azure.monitor.http_status` >= 200 AND `azure.monitor.http_status` < 300, 1, 0)), s4 = SUM(CASE(`azure.monitor.http_status` >= 400, 1, 0)) BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
                "column": "b"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "s2",
                  "label": "2xx"
                },
                {
                  "operation": "value",
                  "column": "s4",
                  "label": "4xx+"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "azmon-l3",
      "grid": {
        "x": 24,
        "y": 25,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Alert category",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-azure.monitor* | STATS d = SUM(CASE(category == \"Alert\", 1, 0)) BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
                "column": "b"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "d",
                  "label": "Alerts"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "azmon-b1",
      "grid": {
        "x": 0,
        "y": 35,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Top operations",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "bar_horizontal",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-azure.monitor* | STATS c = COUNT() BY op = operationName | SORT c DESC | LIMIT 10"
              },
              "x": {
                "operation": "value",
                "column": "op"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "c",
                  "label": "Count"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "azmon-t1",
      "grid": {
        "x": 0,
        "y": 45,
        "w": 48,
        "h": 12
      },
      "config": {
        "title": "Recent",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.monitor* | KEEP `@timestamp`, operationName, `azure.monitor.category`, `azure.monitor.status`, `azure.monitor.http_status`, `azure.monitor.duration_ms`, correlationId | SORT `@timestamp` DESC | LIMIT 100"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "`@timestamp`",
              "label": "Time"
            },
            {
              "operation": "value",
              "column": "operationName",
              "label": "Operation"
            },
            {
              "operation": "value",
              "column": "azure.monitor.category",
              "label": "Category"
            },
            {
              "operation": "value",
              "column": "azure.monitor.status",
              "label": "Status"
            },
            {
              "operation": "value",
              "column": "azure.monitor.http_status",
              "label": "HTTP"
            },
            {
              "operation": "value",
              "column": "azure.monitor.duration_ms",
              "label": "Ms"
            },
            {
              "operation": "value",
              "column": "correlationId",
              "label": "Correlation"
            }
          ],
          "rows": []
        }
      }
    }
  ]
}
