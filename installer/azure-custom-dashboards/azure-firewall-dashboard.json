{
  "title": "Azure Firewall — Allow vs Deny",
  "time_range": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "type": "lens",
      "uid": "azfw-k1",
      "grid": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.firewall* | STATS Events = COUNT()"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Events"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "azfw-k2",
      "grid": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.firewall* | EVAL d = CASE(to_lower(`azure.firewall.action`) == \"deny\", 1, 0) | STATS m = AVG(d) | EVAL `Denied %` = ROUND(m * 100, 1)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Denied %"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "azfw-k3",
      "grid": {
        "x": 24,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.firewall* | STATS `Firewalls` = COUNT_DISTINCT(`azure.firewall.name`)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Distinct firewalls"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "azfw-k4",
      "grid": {
        "x": 36,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.firewall* | STATS `DNS` = SUM(CASE(category == \"AzureFirewallDnsProxy\", 1, 0))"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "DNS proxy events"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "azfw-d1",
      "grid": {
        "x": 0,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Action",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.firewall* | STATS c = COUNT() BY a = `azure.firewall.action` | SORT c DESC"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "a"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "azfw-d2",
      "grid": {
        "x": 16,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Log category",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.firewall* | STATS c = COUNT() BY cat = category | SORT c DESC | LIMIT 10"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "cat"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "azfw-d3",
      "grid": {
        "x": 32,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Rule collection",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.firewall* | STATS c = COUNT() BY rc = `azure.firewall.rule_collection` | SORT c DESC | LIMIT 8"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "rc"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "azfw-l1",
      "grid": {
        "x": 0,
        "y": 15,
        "w": 48,
        "h": 10
      },
      "config": {
        "title": "Events over time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-azure.firewall* | STATS c = COUNT() BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
                "column": "b"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "c",
                  "label": "Events"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "azfw-l2",
      "grid": {
        "x": 0,
        "y": 25,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Allow vs deny",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-azure.firewall* | STATS al = SUM(CASE(to_lower(`azure.firewall.action`) == \"allow\", 1, 0)), dn = SUM(CASE(to_lower(`azure.firewall.action`) == \"deny\", 1, 0)) BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
                "column": "b"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "al",
                  "label": "Allow"
                },
                {
                  "operation": "value",
                  "column": "dn",
                  "label": "Deny"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "azfw-l3",
      "grid": {
        "x": 24,
        "y": 25,
        "w": 24,
        "h": 10
      },
