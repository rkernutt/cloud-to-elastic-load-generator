      "grid": {
        "x": 0,
        "y": 35,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Top destination ports",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "bar_horizontal",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-azure.firewall* | STATS c = COUNT() BY p = `azure.firewall.dest_port` | SORT c DESC | LIMIT 10"
              },
              "x": {
                "operation": "value",
                "column": "p"
              },
              "y": [
                {
                  "operation": "value",
