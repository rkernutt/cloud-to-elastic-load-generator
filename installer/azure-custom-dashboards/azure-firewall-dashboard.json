    },
    {
      "type": "lens",
      "uid": "azfw-t1",
      "grid": {
        "x": 0,
        "y": 45,
        "w": 48,
        "h": 12
      },
      "config": {
        "title": "Recent",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.firewall* | KEEP `@timestamp`, `azure.firewall.name`, category, `azure.firewall.action`, `azure.firewall.source_ip`, `azure.firewall.dest_ip`, `azure.firewall.dest_port` | SORT `@timestamp` DESC | LIMIT 100"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "`@timestamp`",
              "label": "Time"
            },
            {
              "operation": "value",
              "column": "azure.firewall.name",
              "label": "Firewall"
            },
            {
              "operation": "value",
              "column": "category",
              "label": "Category"
            },
            {
              "operation": "value",
              "column": "azure.firewall.action",
              "label": "Action"
            },
            {
              "operation": "value",
              "column": "azure.firewall.source_ip",
              "label": "Src"
            },
            {
              "operation": "value",
              "column": "azure.firewall.dest_ip",
              "label": "Dst"
            },
            {
              "operation": "value",
              "column": "azure.firewall.dest_port",
              "label": "Dport"
            }
          ],
          "rows": []
        }
      }
    }
  ]
}
