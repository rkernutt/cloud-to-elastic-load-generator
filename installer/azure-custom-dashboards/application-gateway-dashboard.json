      },
      "config": {
        "title": "Recent",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.application_gateway* | KEEP `@timestamp`, `azure.application_gateway.name`, category, operationName, `azure.application_gateway.http_status`, `azure.application_gateway.latency_ms`, event.outcome | SORT `@timestamp` DESC | LIMIT 100"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "`@timestamp`",
              "label": "Time"
            },
            {
              "operation": "value",
              "column": "azure.application_gateway.name",
