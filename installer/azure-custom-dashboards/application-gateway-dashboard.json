              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-azure.application_gateway* | STATS lat = AVG(`azure.application_gateway.latency_ms`) BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
                "column": "b"
              },
              "y": [
