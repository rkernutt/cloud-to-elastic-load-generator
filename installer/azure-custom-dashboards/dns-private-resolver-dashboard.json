{
  "title": "Azure DNS Private Resolver — overview",
  "time_range": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "type": "lens",
      "uid": "adprk1",
      "grid": { "x": 0, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.dns_private_resolver* | STATS `Log events` = COUNT()"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Log events" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "adprd1",
      "grid": { "x": 0, "y": 5, "w": 16, "h": 10 },
      "config": {
        "title": "Event outcome",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.dns_private_resolver* | STATS c = COUNT() BY o = event.outcome"
          },
          "metrics": [{ "operation": "value", "column": "c" }],
          "group_by": [{ "operation": "value", "column": "o" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "adprb1",
      "grid": { "x": 16, "y": 5, "w": 32, "h": 10 },
      "config": {
        "title": "Events over time",
        "attributes": {
          "type": "xy",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.dns_private_resolver* | STATS count = COUNT() BY bucket = DATE_TRUNC(30 minutes, `@timestamp`), o = COALESCE(event.outcome, \"unknown\")"
          },
          "layers": [
            {
              "seriesType": "bar_stacked",
              "xAccessor": "bucket",
              "yAccessor": "count",
              "splitAccessor": "o"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "adprb2",
      "grid": { "x": 0, "y": 15, "w": 24, "h": 10 },
      "config": {
        "title": "Errors over time",
        "attributes": {
          "type": "xy",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.dns_private_resolver* | WHERE event.outcome == \"failure\" | STATS count = COUNT() BY bucket = DATE_TRUNC(30 minutes, `@timestamp`), op = COALESCE(operationName, \"unknown\")"
          },
          "layers": [
            {
              "seriesType": "bar_stacked",
              "xAccessor": "bucket",
              "yAccessor": "count",
              "splitAccessor": "op"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "adprb3",
      "grid": { "x": 24, "y": 15, "w": 24, "h": 10 },
      "config": {
        "title": "Events by region",
        "attributes": {
          "type": "xy",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.dns_private_resolver* | STATS count = COUNT() BY bucket = DATE_TRUNC(30 minutes, `@timestamp`), region = cloud.region"
          },
          "layers": [
            {
              "seriesType": "bar_stacked",
              "xAccessor": "bucket",
              "yAccessor": "count",
              "splitAccessor": "region"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "adprt1",
      "grid": { "x": 0, "y": 25, "w": 48, "h": 12 },
      "config": {
        "title": "Top operations",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.dns_private_resolver* | STATS c = COUNT() BY op = COALESCE(operationName, \"unknown\") | SORT c DESC | LIMIT 15"
          },
          "metrics": [
            { "operation": "value", "column": "op", "label": "Operation" },
            { "operation": "value", "column": "c", "label": "Count" }
          ],
          "rows": []
        }
      }
    },
    {
      "type": "lens",
      "uid": "adprp1",
      "grid": { "x": 0, "y": 37, "w": 24, "h": 10 },
      "config": {
        "title": "Events by resolver category",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.dns_private_resolver* | STATS c = COUNT() BY cat = COALESCE(`azure.dns_private_resolver.category`, \"unknown\")"
          },
          "metrics": [{ "operation": "value", "column": "c" }],
          "group_by": [{ "operation": "value", "column": "cat" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "adprp2",
      "grid": { "x": 24, "y": 37, "w": 24, "h": 10 },
      "config": {
        "title": "Forwarding audits by resolver",
        "attributes": {
          "type": "xy",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.dns_private_resolver* | WHERE operationName == \"DnsResolver.Forwarding/Audit\" | STATS count = COUNT() BY bucket = DATE_TRUNC(30 minutes, `@timestamp`), resolver = COALESCE(`azure.dns_private_resolver.resolver`, \"unknown\")"
          },
          "layers": [
            {
              "seriesType": "bar_stacked",
              "xAccessor": "bucket",
              "yAccessor": "count",
              "splitAccessor": "resolver"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "azure-mx-k1-dns-private-resolver",
      "grid": { "x": 0, "y": 48, "w": 24, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM metrics-azure.dns_private_resolver_metrics* | STATS `Metric Dns Resolver Outbound Endpoint Health Pe` = ROUND(AVG(`azure.dns_private_resolver.metrics.DnsResolverOutboundEndpointHealthPercentage.avg`), 2)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Metric Dns Resolver Outbound Endpoint Health Pe"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "azure-mx-k2-dns-private-resolver",
      "grid": { "x": 24, "y": 48, "w": 24, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM metrics-azure.dns_private_resolver_metrics* | STATS `Metric DNSQuery Inbound Count Per Second Averag` = ROUND(AVG(`azure.dns_private_resolver.metrics.DNSQueryInboundCountPerSecondAverage.avg`), 2)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Metric DNSQuery Inbound Count Per Second Averag"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "azure-mx-ts-dns-private-resolver",
      "grid": { "x": 0, "y": 53, "w": 48, "h": 10 },
      "config": {
        "title": "Dns Resolver Outbound Endpoint Health Pe over time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": { "title": { "visible": false } },
            "left": { "title": { "visible": false } }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM metrics-azure.dns_private_resolver_metrics* | STATS m = AVG(`azure.dns_private_resolver.metrics.DnsResolverOutboundEndpointHealthPercentage.avg`) BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": { "operation": "value", "column": "b" },
              "y": [
                {
                  "operation": "value",
                  "column": "m",
                  "label": "Dns Resolver Outbound Endpoint Health Pe"
                }
              ]
            }
          ]
        }
      }
    }
  ]
}
