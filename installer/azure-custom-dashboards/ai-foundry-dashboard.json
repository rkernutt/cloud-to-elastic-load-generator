{
  "title": "Azure AI Foundry — overview",
  "time_range": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "type": "lens",
      "uid": "aaifk1",
      "grid": { "x": 0, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.ai_foundry* | STATS `Log events` = COUNT()"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Log events" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "aaifd1",
      "grid": { "x": 0, "y": 5, "w": 16, "h": 10 },
      "config": {
        "title": "Event outcome",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.ai_foundry* | STATS c = COUNT() BY o = event.outcome"
          },
          "metrics": [{ "operation": "value", "column": "c" }],
          "group_by": [{ "operation": "value", "column": "o" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "aaifb1",
      "grid": { "x": 16, "y": 5, "w": 32, "h": 10 },
      "config": {
        "title": "Events over time",
        "attributes": {
          "type": "xy",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.ai_foundry* | STATS count = COUNT() BY bucket = DATE_TRUNC(30 minutes, `@timestamp`), o = COALESCE(event.outcome, \"unknown\")"
          },
          "layers": [
            {
              "seriesType": "bar_stacked",
              "xAccessor": "bucket",
              "yAccessor": "count",
              "splitAccessor": "o"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "aaifb2",
      "grid": { "x": 0, "y": 15, "w": 24, "h": 10 },
      "config": {
        "title": "Errors over time",
        "attributes": {
          "type": "xy",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.ai_foundry* | WHERE event.outcome == \"failure\" | STATS count = COUNT() BY bucket = DATE_TRUNC(30 minutes, `@timestamp`), op = COALESCE(operationName, \"unknown\")"
          },
          "layers": [
            {
              "seriesType": "bar_stacked",
              "xAccessor": "bucket",
              "yAccessor": "count",
              "splitAccessor": "op"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "aaifb3",
      "grid": { "x": 24, "y": 15, "w": 24, "h": 10 },
      "config": {
        "title": "Events by region",
        "attributes": {
          "type": "xy",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.ai_foundry* | STATS count = COUNT() BY bucket = DATE_TRUNC(30 minutes, `@timestamp`), region = cloud.region"
          },
          "layers": [
            {
              "seriesType": "bar_stacked",
              "xAccessor": "bucket",
              "yAccessor": "count",
              "splitAccessor": "region"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "aaift1",
      "grid": { "x": 0, "y": 25, "w": 48, "h": 12 },
      "config": {
        "title": "Top operations",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.ai_foundry* | STATS c = COUNT() BY op = COALESCE(operationName, \"unknown\") | SORT c DESC | LIMIT 15"
          },
          "metrics": [
            { "operation": "value", "column": "op", "label": "Operation" },
            { "operation": "value", "column": "c", "label": "Count" }
          ],
          "rows": []
        }
      }
    },
    {
      "type": "lens",
      "uid": "aaifp1",
      "grid": { "x": 0, "y": 37, "w": 24, "h": 10 },
      "config": {
        "title": "Events by catalog category",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.ai_foundry* | STATS c = COUNT() BY cat = COALESCE(`azure.ai_foundry.category`, \"unknown\")"
          },
          "metrics": [{ "operation": "value", "column": "c" }],
          "group_by": [{ "operation": "value", "column": "cat" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "aaifp2",
      "grid": { "x": 24, "y": 37, "w": 24, "h": 10 },
      "config": {
        "title": "Volume by category over time",
        "attributes": {
          "type": "xy",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.ai_foundry* | STATS count = COUNT() BY bucket = DATE_TRUNC(30 minutes, `@timestamp`), cat = COALESCE(`azure.ai_foundry.category`, \"unknown\")"
          },
          "layers": [
            {
              "seriesType": "bar_stacked",
              "xAccessor": "bucket",
              "yAccessor": "count",
              "splitAccessor": "cat"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "azure-mx-k1-ai-foundry",
      "grid": { "x": 0, "y": 48, "w": 24, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM metrics-azure.ai_foundry_metrics* | STATS `Metric Batch Inference Throughput` = ROUND(SUM(`azure.ai_foundry.metrics.BatchInferenceThroughput.sum`), 2)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Metric Batch Inference Throughput"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "azure-mx-k2-ai-foundry",
      "grid": { "x": 24, "y": 48, "w": 24, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM metrics-azure.ai_foundry_metrics* | STATS `Metric Gpu Memory Usage Percent` = ROUND(AVG(`azure.ai_foundry.metrics.GpuMemoryUsagePercent.avg`), 2)"
          },
          "metrics": [
            { "type": "primary", "operation": "value", "column": "Metric Gpu Memory Usage Percent" }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "azure-mx-ts-ai-foundry",
      "grid": { "x": 0, "y": 53, "w": 48, "h": 10 },
      "config": {
        "title": "Gpu Memory Usage Percent over time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": { "title": { "visible": false } },
            "left": { "title": { "visible": false } }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM metrics-azure.ai_foundry_metrics* | STATS m = AVG(`azure.ai_foundry.metrics.GpuMemoryUsagePercent.avg`) BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": { "operation": "value", "column": "b" },
              "y": [{ "operation": "value", "column": "m", "label": "Gpu Memory Usage Percent" }]
            }
          ]
        }
      }
    }
  ]
}
