{
  "title": "Azure Event Hubs \u2014 overview",
  "time_range": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "type": "lens",
      "uid": "zaevthubk1",
      "grid": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.event_hubs* | STATS `Log events` = COUNT()"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Log events"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "zaevthubd1",
      "grid": {
        "x": 0,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Event outcome",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.event_hubs* | STATS c = COUNT() BY o = event.outcome"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "o"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "zaevthubl1",
      "grid": {
        "x": 0,
        "y": 15,
        "w": 48,
        "h": 10
      },
      "config": {
        "title": "Event volume",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-azure.event_hubs* | STATS c = COUNT() BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
                "column": "b"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "c",
                  "label": "Events"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "zaevthubt1",
      "grid": {
        "x": 0,
        "y": 25,
        "w": 48,
        "h": 12
      },
      "config": {
        "title": "By resource group",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.event_hubs* | STATS c = COUNT() BY region = COALESCE(`azure.event_hubs.resource_group`, \"unknown\") | SORT c DESC | LIMIT 15"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "region",
              "label": "Resource group"
            },
            {
              "operation": "value",
              "column": "c",
              "label": "Count"
            }
          ],
          "rows": []
        }
      }
    },
    {
      "type": "lens",
      "uid": "zaevthubt2",
      "grid": {
        "x": 0,
        "y": 37,
        "w": 48,
        "h": 12
      },
      "config": {
        "title": "Top Event Hubs by event count",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.event_hubs* | STATS c = COUNT() BY hub = COALESCE(azure.event_hubs.namespace, \"unknown\") | SORT c DESC | LIMIT 15"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "hub",
              "label": "Namespace"
            },
            {
              "operation": "value",
              "column": "c",
              "label": "Count"
            }
          ],
          "rows": []
        }
      }
    }
  ]
}
