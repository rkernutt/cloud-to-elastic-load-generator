          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.microsoft_365* | STATS c = COUNT() BY t = `azure.microsoft_365.record_type` | SORT c DESC | LIMIT 10"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
