{
  "title": "Microsoft 365 — Audit & Workloads",
  "time_range": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "type": "lens",
      "uid": "azm365-k1",
      "grid": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.microsoft_365* | STATS Events = COUNT()"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Events"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "azm365-k2",
      "grid": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.microsoft_365* | EVAL f = CASE(event.outcome == \"failure\", 1, 0) | STATS m = AVG(f) | EVAL `Failed %` = ROUND(m * 100, 1)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Failed %"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "azm365-k3",
      "grid": {
        "x": 24,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.microsoft_365* | STATS `Workloads` = COUNT_DISTINCT(`azure.microsoft_365.workload`)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Workloads"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
