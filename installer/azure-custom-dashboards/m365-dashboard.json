        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.microsoft_365* | STATS `Types` = COUNT_DISTINCT(`azure.microsoft_365.record_type`)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Record types"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
