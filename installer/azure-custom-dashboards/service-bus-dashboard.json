{
  "title": "Azure Service Bus — Messages",
  "time_range": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "type": "lens",
      "uid": "az-sb-k1",
      "grid": { "x": 0, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.service_bus* | STATS `Log events` = COUNT()"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Log events" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "az-sb-t1",
      "grid": { "x": 0, "y": 5, "w": 48, "h": 12 },
      "config": {
        "title": "Recent",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.service_bus* | KEEP `@timestamp`, `azure.service_bus.namespace`, `azure.service_bus.entity`, `azure.service_bus.operation`, event.outcome, message | SORT `@timestamp` DESC | LIMIT 100"
          },
          "metrics": [
            { "operation": "value", "column": "`@timestamp`", "label": "Time" },
            { "operation": "value", "column": "azure.service_bus.namespace", "label": "Namespace" },
            { "operation": "value", "column": "azure.service_bus.entity", "label": "Entity" },
            { "operation": "value", "column": "azure.service_bus.operation", "label": "Op" },
            { "operation": "value", "column": "event.outcome", "label": "Outcome" },
            { "operation": "value", "column": "message", "label": "Message" }
          ],
          "rows": []
        }
      }
    },
    {
      "type": "lens",
      "uid": "azure-mx-k1-service-bus",
      "grid": { "x": 0, "y": 18, "w": 24, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM metrics-azure.service_bus_metrics* | STATS `Metric Incoming Requests` = ROUND(AVG(`azure.service_bus.metrics.IncomingRequests.avg`), 2)"
          },
          "metrics": [
            { "type": "primary", "operation": "value", "column": "Metric Incoming Requests" }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "azure-mx-k2-service-bus",
      "grid": { "x": 24, "y": 18, "w": 24, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM metrics-azure.service_bus_metrics* | STATS `Metric Incoming Messages` = ROUND(AVG(`azure.service_bus.metrics.IncomingMessages.avg`), 2)"
          },
          "metrics": [
            { "type": "primary", "operation": "value", "column": "Metric Incoming Messages" }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "azure-mx-ts-service-bus",
      "grid": { "x": 0, "y": 23, "w": 48, "h": 10 },
      "config": {
        "title": "Incoming Requests over time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": { "title": { "visible": false } },
            "left": { "title": { "visible": false } }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM metrics-azure.service_bus_metrics* | STATS m = AVG(`azure.service_bus.metrics.IncomingRequests.avg`) BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": { "operation": "value", "column": "b" },
              "y": [{ "operation": "value", "column": "m", "label": "Incoming Requests" }]
            }
          ]
        }
      }
    }
  ]
}
