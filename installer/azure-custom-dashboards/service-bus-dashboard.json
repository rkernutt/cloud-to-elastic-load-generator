            },
            {
              "operation": "value",
              "column": "azure.service_bus.namespace",
              "label": "Namespace"
            },
            {
              "operation": "value",
              "column": "azure.service_bus.entity",
              "label": "Entity"
            },
            {
              "operation": "value",
              "column": "azure.service_bus.operation",
              "label": "Op"
            },
            {
              "operation": "value",
              "column": "log.level",
              "label": "Log level"
            },
            {
              "operation": "value",
              "column": "message",
              "label": "Message"
            }
          ],
          "rows": []
        }
