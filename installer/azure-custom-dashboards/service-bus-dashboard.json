        "h": 12
      },
      "config": {
        "title": "Recent",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.service_bus* | KEEP `@timestamp`, `azure.service_bus.namespace`, `azure.service_bus.entity`, `azure.service_bus.operation`, log.level, message | SORT `@timestamp` DESC | LIMIT 100"
