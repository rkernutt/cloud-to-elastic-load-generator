{
  "group": "gcp-streaming",
  "description": "GCP streaming \u2014 Pub/Sub, Dataflow",
  "jobs": [
    {
      "id": "gcp-pubsub-failure-spike",
      "description": "Spikes in Pub/Sub failures per subscription",
      "job": {
        "description": "Spikes in Pub/Sub failures per subscription",
        "groups": ["gcp", "streaming", "cloudloadgen"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_count partitionfield=gcp.pubsub.subscription_name",
              "function": "high_count",
              "partition_field_name": "gcp.pubsub.subscription_name",
              "detector_index": 0
            }
          ],
          "influencers": ["gcp.pubsub.subscription_name", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": {
          "model_memory_limit": "32mb"
        },
        "data_description": {
          "time_field": "@timestamp"
        },
        "custom_settings": {
          "created_by": "gcp-elastic-load-generator",
          "tags": ["cloudloadgen"]
        }
      },
      "datafeed": {
        "indices": ["logs-gcp.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              {
                "term": {
                  "cloud.provider": "gcp"
                }
              },
              {
                "wildcard": {
                  "cloud.service.name": "*pubsub*"
                }
              },
              {
                "term": {
                  "event.outcome": "failure"
                }
              }
            ]
          }
        },
        "chunking_config": {
          "mode": "auto"
        },
        "query_delay": "120s",
        "delayed_data_check_config": {
          "enabled": true
        }
      }
    },
    {
      "id": "gcp-dataflow-watermark-lag",
      "description": "Unusual Dataflow watermark lag",
      "job": {
        "description": "Unusual Dataflow watermark lag",
        "groups": ["gcp", "streaming", "cloudloadgen"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_mean(gcp.dataflow.metrics.dataflow.googleapis.com/job/data_watermark_age.avg) partitionfield=gcp.dataflow.labels.job_name",
              "function": "high_mean",
              "field_name": "gcp.dataflow.metrics.dataflow.googleapis.com/job/data_watermark_age.avg",
              "partition_field_name": "gcp.dataflow.labels.job_name",
              "detector_index": 0
            }
          ],
          "influencers": ["gcp.dataflow.labels.job_name", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": {
          "model_memory_limit": "32mb"
        },
        "data_description": {
          "time_field": "@timestamp"
        },
        "custom_settings": {
          "created_by": "gcp-elastic-load-generator",
          "tags": ["cloudloadgen"]
        }
      },
      "datafeed": {
        "indices": ["metrics-gcp.dataflow_metrics*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              {
                "term": {
                  "event.dataset": "gcp.dataflow_metrics"
                }
              },
              {
                "exists": {
                  "field": "gcp.dataflow.metrics.dataflow.googleapis.com/job/data_watermark_age.avg"
                }
              }
            ]
          }
        },
        "chunking_config": {
          "mode": "auto"
        },
        "query_delay": "120s",
        "delayed_data_check_config": {
          "enabled": true
        }
      }
    },
    {
      "id": "gcp-dataflow-elements-throughput",
      "description": "Unusual Dataflow elements produced",
      "job": {
        "description": "Unusual Dataflow elements produced",
        "groups": ["gcp", "streaming", "cloudloadgen"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_sum(gcp.dataflow.metrics.dataflow.googleapis.com/job/elements_produced_count.sum) partitionfield=gcp.dataflow.labels.job_name",
              "function": "high_sum",
              "field_name": "gcp.dataflow.metrics.dataflow.googleapis.com/job/elements_produced_count.sum",
              "partition_field_name": "gcp.dataflow.labels.job_name",
              "detector_index": 0
            }
          ],
          "influencers": ["gcp.dataflow.labels.job_name", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": {
          "model_memory_limit": "32mb"
        },
        "data_description": {
          "time_field": "@timestamp"
        },
        "custom_settings": {
          "created_by": "gcp-elastic-load-generator",
          "tags": ["cloudloadgen"]
        }
      },
      "datafeed": {
        "indices": ["metrics-gcp.dataflow_metrics*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              {
                "term": {
                  "event.dataset": "gcp.dataflow_metrics"
                }
              },
              {
                "exists": {
                  "field": "gcp.dataflow.metrics.dataflow.googleapis.com/job/elements_produced_count.sum"
                }
              }
            ]
          }
        },
        "chunking_config": {
          "mode": "auto"
        },
        "query_delay": "120s",
        "delayed_data_check_config": {
          "enabled": true
        }
      }
    },
    {
      "id": "gcp-pubsub-unacked-message-anomaly",
      "description": "Detects unusual Pub/Sub unacknowledged message backlog per subscription (subscriber lag, push endpoint failures)",
      "job": {
        "description": "Detects unusual Pub/Sub unacknowledged message backlog per subscription",
        "groups": ["gcp", "streaming", "cloudloadgen"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_count partitionfield=gcp.pubsub.subscription_name",
              "function": "high_count",
              "partition_field_name": "gcp.pubsub.subscription_name",
              "detector_index": 0
            }
          ],
          "influencers": ["gcp.pubsub.subscription_name", "gcp.pubsub.topic_name", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": {
          "model_memory_limit": "32mb"
        },
        "data_description": {
          "time_field": "@timestamp"
        },
        "custom_settings": {
          "created_by": "gcp-elastic-load-generator",
          "tags": ["cloudloadgen"]
        }
      },
      "datafeed": {
        "indices": ["logs-gcp.pubsub*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              {
                "term": {
                  "cloud.provider": "gcp"
                }
              }
            ],
            "should": [
              {
                "wildcard": {
                  "message": "*num_undelivered_messages*"
                }
              },
              {
                "wildcard": {
                  "message": "*oldest_unacked_message_age*"
                }
              }
            ],
            "minimum_should_match": 1
          }
        },
        "chunking_config": {
          "mode": "auto"
        },
        "query_delay": "120s",
        "delayed_data_check_config": {
          "enabled": true
        }
      }
    },
    {
      "id": "gcp-dataflow-backlog-anomaly",
      "description": "Detects unusual Dataflow system lag per job (processing backlog, watermark delay, autoscaling stalls)",
      "job": {
        "description": "Detects unusual Dataflow system lag per job",
        "groups": ["gcp", "streaming", "cloudloadgen"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_mean(gcp.dataflow.metrics.dataflow.googleapis.com/job/data_watermark_age.avg) partitionfield=gcp.dataflow.labels.job_name",
              "function": "high_mean",
              "field_name": "gcp.dataflow.metrics.dataflow.googleapis.com/job/data_watermark_age.avg",
              "partition_field_name": "gcp.dataflow.labels.job_name",
              "detector_index": 0
            }
          ],
          "influencers": ["gcp.dataflow.labels.job_name", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": {
          "model_memory_limit": "32mb"
        },
        "data_description": {
          "time_field": "@timestamp"
        },
        "custom_settings": {
          "created_by": "gcp-elastic-load-generator",
          "tags": ["cloudloadgen"]
        }
      },
      "datafeed": {
        "indices": ["metrics-gcp.dataflow_metrics*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              {
                "term": {
                  "event.dataset": "gcp.dataflow_metrics"
                }
              },
              {
                "exists": {
                  "field": "gcp.dataflow.metrics.dataflow.googleapis.com/job/data_watermark_age.avg"
                }
              }
            ]
          }
        },
        "chunking_config": {
          "mode": "auto"
        },
        "query_delay": "120s",
        "delayed_data_check_config": {
          "enabled": true
        }
      }
    }
  ]
}
