{
  "group": "gcp-analytics",
  "description": "GCP analytics — BigQuery, Dataproc",
  "jobs": [
    {
      "id": "gcp-bigquery-bytes-scanned-anomaly",
      "description": "Unusual BigQuery bytes processed per job",
      "job": {
        "description": "Unusual BigQuery bytes processed per job",
        "groups": ["gcp", "analytics"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_sum(gcp.bigquery.total_bytes_processed) partitionfield=gcp.bigquery.job_id",
              "function": "high_sum",
              "field_name": "gcp.bigquery.total_bytes_processed",
              "partition_field_name": "gcp.bigquery.job_id",
              "detector_index": 0
            }
          ],
          "influencers": ["gcp.bigquery.dataset", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "48mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "gcp-elastic-load-generator" }
      },
      "datafeed": {
        "indices": ["logs-gcp.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              { "term": { "cloud.provider": "gcp" } },
              { "wildcard": { "cloud.service.name": "*bigquery*" } }
            ]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "60s",
        "delayed_data_check_config": { "enabled": true }
      }
    },
    {
      "id": "gcp-bigquery-job-failures",
      "description": "Spikes in failed BigQuery jobs",
      "job": {
        "description": "Spikes in failed BigQuery jobs",
        "groups": ["gcp", "analytics"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_count partitionfield=gcp.bigquery.job_type",
              "function": "high_count",
              "partition_field_name": "gcp.bigquery.job_type",
              "detector_index": 0
            }
          ],
          "influencers": ["gcp.bigquery.job_type", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "32mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "gcp-elastic-load-generator" }
      },
      "datafeed": {
        "indices": ["logs-gcp.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              { "term": { "cloud.provider": "gcp" } },
              { "wildcard": { "cloud.service.name": "*bigquery*" } },
              { "term": { "event.outcome": "failure" } }
            ]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "60s",
        "delayed_data_check_config": { "enabled": true }
      }
    },
    {
      "id": "gcp-dataproc-job-duration",
      "description": "Unusual Dataproc job duration",
      "job": {
        "description": "Unusual Dataproc job duration",
        "groups": ["gcp", "analytics"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_mean(event.duration) partitionfield=gcp.dataproc.job_id",
              "function": "high_mean",
              "field_name": "event.duration",
              "partition_field_name": "gcp.dataproc.job_id",
              "detector_index": 0
            }
          ],
          "influencers": ["gcp.dataproc.cluster_name", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "32mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "gcp-elastic-load-generator" }
      },
      "datafeed": {
        "indices": ["logs-gcp.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              { "term": { "cloud.provider": "gcp" } },
              { "wildcard": { "cloud.service.name": "*dataproc*" } }
            ]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "60s",
        "delayed_data_check_config": { "enabled": true }
      }
    }
  ]
}
