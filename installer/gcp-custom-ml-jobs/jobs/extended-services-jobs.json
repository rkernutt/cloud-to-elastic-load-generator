        "custom_settings": {
          "created_by": "gcp-load-generator-extended-services",
          "tags": ["cloudloadgen"]
        }
      },
      "datafeed": {
        "indices": ["logs-gcp.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              { "term": { "event.dataset": "gcp.vertex_ai_agent_builder" } },
              { "term": { "event.outcome": "failure" } }
