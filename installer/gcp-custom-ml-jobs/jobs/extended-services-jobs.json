        "groups": ["gcp", "extended-services", "cloudloadgen"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_count partitionfield=cloud.region gcp.vertex_ai_agent_builder",
              "function": "high_count",
              "partition_field_name": "cloud.region",
              "detector_index": 0
