{
  "group": "gcp-aiml",
  "description": "GCP AI/ML — Vertex AI",
  "jobs": [
    {
      "id": "gcp-vertex-ai-latency-anomaly",
      "description": "Unusual Vertex AI prediction latency per model",
      "job": {
        "description": "Unusual Vertex AI prediction latency per model",
        "groups": ["gcp", "aiml", "cloudloadgen"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_mean(gcp.vertex-ai-search.metrics.discoveryengine.googleapis.com/search_requests_regional.avg)",
              "function": "high_mean",
              "field_name": "gcp.vertex-ai-search.metrics.discoveryengine.googleapis.com/search_requests_regional.avg",
              "detector_index": 0
            }
          ],
          "influencers": ["gcp.vertex_ai.model_name", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "32mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "gcp-elastic-load-generator", "tags": ["cloudloadgen"] }
      },
      "datafeed": {
        "indices": ["metrics-gcp.vertexai_metrics*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              { "term": { "event.dataset": "gcp.vertexai_metrics" } },
              {
                "exists": {
                  "field": "gcp.vertex-ai-search.metrics.discoveryengine.googleapis.com/search_requests_regional.avg"
                }
              }
            ]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "120s",
        "delayed_data_check_config": { "enabled": true }
      }
    },
    {
      "id": "gcp-vertex-ai-failure-spike",
      "description": "Spikes in Vertex AI failures per endpoint",
      "job": {
        "description": "Spikes in Vertex AI failures per endpoint",
        "groups": ["gcp", "aiml", "cloudloadgen"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_count partitionfield=gcp.vertex_ai.endpoint_id",
              "function": "high_count",
              "partition_field_name": "gcp.vertex_ai.endpoint_id",
              "detector_index": 0
            }
          ],
          "influencers": ["gcp.vertex_ai.endpoint_id", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "32mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "gcp-elastic-load-generator", "tags": ["cloudloadgen"] }
      },
      "datafeed": {
        "indices": ["logs-gcp.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              { "term": { "cloud.provider": "gcp" } },
              { "wildcard": { "cloud.service.name": "*aiplatform*" } },
              { "term": { "event.outcome": "failure" } }
            ]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "120s",
        "delayed_data_check_config": { "enabled": true }
      }
    }
  ]
}
