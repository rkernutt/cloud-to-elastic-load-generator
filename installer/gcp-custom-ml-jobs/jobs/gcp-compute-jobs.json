{
  "group": "gcp-compute",
  "description": "GCP serverless & compute \u2014 Cloud Functions, Cloud Run, Compute Engine, GKE",
  "jobs": [
    {
      "id": "gcp-cloud-functions-error-spike",
      "description": "Spikes in Cloud Functions failures per function name",
      "job": {
        "description": "Spikes in Cloud Functions failures per function name",
        "groups": ["gcp", "compute", "cloudloadgen"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_count partitionfield=gcp.cloud_functions.function_name",
              "function": "high_count",
              "partition_field_name": "gcp.cloud_functions.function_name",
              "detector_index": 0
            }
          ],
          "influencers": ["gcp.cloud_functions.function_name", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": {
          "model_memory_limit": "32mb"
        },
        "data_description": {
          "time_field": "@timestamp"
        },
        "custom_settings": {
          "created_by": "gcp-elastic-load-generator",
          "tags": ["cloudloadgen"]
        }
      },
      "datafeed": {
        "indices": ["logs-gcp.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              {
                "term": {
                  "cloud.provider": "gcp"
                }
              },
              {
                "wildcard": {
                  "cloud.service.name": "*cloudfunctions*"
                }
              },
              {
                "term": {
                  "event.outcome": "failure"
                }
              }
            ]
          }
        },
        "chunking_config": {
          "mode": "auto"
        },
        "query_delay": "120s",
        "delayed_data_check_config": {
          "enabled": true
        }
      }
    },
    {
