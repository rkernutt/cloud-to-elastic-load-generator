    {
      "id": "gcp-gke-pod-restart-anomaly",
      "description": "Detects spikes in GKE pod restart and crash-loop events per pod (OOMKilled, unhealthy, back-off restarting)",
      "job": {
        "description": "Detects spikes in GKE pod restart and crash-loop events per pod",
        "groups": ["gcp", "compute", "cloudloadgen"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_count partitionfield=gcp.gke.pod",
              "function": "high_count",
              "partition_field_name": "gcp.gke.pod",
              "detector_index": 0
            }
          ],
          "influencers": ["gcp.gke.pod", "gcp.gke.namespace", "gcp.gke.cluster", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": {
          "model_memory_limit": "32mb"
        },
        "data_description": {
          "time_field": "@timestamp"
        },
        "custom_settings": {
          "created_by": "gcp-elastic-load-generator",
          "tags": ["cloudloadgen"]
        }
      },
      "datafeed": {
        "indices": ["logs-gcp.gke*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              {
                "term": {
                  "cloud.provider": "gcp"
                }
              },
              {
                "term": {
                  "gcp.gke.event_type": "KUBERNETES_EVENT"
                }
              },
              {
                "term": {
                  "event.outcome": "failure"
                }
              }
            ],
            "should": [
              {
                "wildcard": {
                  "message": "*OOMKilled*"
                }
              },
              {
                "wildcard": {
                  "message": "*Back-off restarting*"
                }
              },
              {
                "wildcard": {
                  "message": "*Unhealthy*"
                }
              }
            ],
            "minimum_should_match": 1
          }
        },
        "chunking_config": {
          "mode": "auto"
        },
        "query_delay": "120s",
        "delayed_data_check_config": {
          "enabled": true
        }
      }
    },
