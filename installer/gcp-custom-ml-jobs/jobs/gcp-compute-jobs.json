      "datafeed": {
        "indices": ["metrics-gcp.cloudrun_metrics*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              {
                "term": {
                  "event.dataset": "gcp.cloudrun_metrics"
                }
              },
              {
                "exists": {
                  "field": "gcp.cloud-run.metrics.run.googleapis.com/request_latencies.avg"
                }
