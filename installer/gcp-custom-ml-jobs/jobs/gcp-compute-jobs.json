{
  "group": "gcp-compute",
  "description": "GCP serverless & compute — Cloud Functions, Cloud Run, Compute Engine, GKE",
  "jobs": [
    {
      "id": "gcp-cloud-functions-error-spike",
      "description": "Spikes in Cloud Functions failures per function name",
      "job": {
        "description": "Spikes in Cloud Functions failures per function name",
        "groups": ["gcp", "compute"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_count partitionfield=gcp.cloud_functions.function_name",
              "function": "high_count",
              "partition_field_name": "gcp.cloud_functions.function_name",
              "detector_index": 0
            }
          ],
          "influencers": ["gcp.cloud_functions.function_name", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "32mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "gcp-elastic-load-generator" }
      },
      "datafeed": {
        "indices": ["logs-gcp.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              { "term": { "cloud.provider": "gcp" } },
              { "wildcard": { "cloud.service.name": "*cloudfunctions*" } },
              { "term": { "event.outcome": "failure" } }
            ]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "60s",
        "delayed_data_check_config": { "enabled": true }
      }
    },
    {
      "id": "gcp-cloud-run-latency-anomaly",
      "description": "Unusual Cloud Run request duration per service",
      "job": {
        "description": "Unusual Cloud Run request duration per service",
        "groups": ["gcp", "compute"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_mean(event.duration) partitionfield=gcp.cloud_run.service_name",
              "function": "high_mean",
              "field_name": "event.duration",
              "partition_field_name": "gcp.cloud_run.service_name",
              "detector_index": 0
            }
          ],
          "influencers": ["gcp.cloud_run.service_name", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "32mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "gcp-elastic-load-generator" }
      },
      "datafeed": {
        "indices": ["logs-gcp.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              { "term": { "cloud.provider": "gcp" } },
              { "wildcard": { "cloud.service.name": "*run.googleapis.com*" } }
            ]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "60s",
        "delayed_data_check_config": { "enabled": true }
      }
    },
    {
      "id": "gcp-gke-pod-event-spike",
      "description": "Spikes in GKE pod events per cluster",
      "job": {
        "description": "Spikes in GKE pod events per cluster",
        "groups": ["gcp", "compute"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_count partitionfield=gcp.gke.cluster",
              "function": "high_count",
              "partition_field_name": "gcp.gke.cluster",
              "detector_index": 0
            }
          ],
          "influencers": ["gcp.gke.cluster", "gcp.gke.namespace", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "32mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "gcp-elastic-load-generator" }
      },
      "datafeed": {
        "indices": ["logs-gcp.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              { "term": { "cloud.provider": "gcp" } },
              { "wildcard": { "cloud.service.name": "*container.googleapis.com*" } }
            ]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "60s",
        "delayed_data_check_config": { "enabled": true }
      }
    },
    {
      "id": "gcp-compute-engine-failures",
      "description": "Spikes in Compute Engine failure outcomes per instance",
      "job": {
        "description": "Spikes in Compute Engine failure outcomes",
        "groups": ["gcp", "compute"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_count partitionfield=gcp.compute_engine.instance_name",
              "function": "high_count",
              "partition_field_name": "gcp.compute_engine.instance_name",
              "detector_index": 0
            }
          ],
          "influencers": ["gcp.compute_engine.instance_name", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "32mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "gcp-elastic-load-generator" }
      },
      "datafeed": {
        "indices": ["logs-gcp.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              { "term": { "cloud.provider": "gcp" } },
              { "term": { "event.outcome": "failure" } },
              { "wildcard": { "cloud.service.name": "*compute.googleapis.com*" } }
            ]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "60s",
        "delayed_data_check_config": { "enabled": true }
      }
    }
  ]
}
