              "function": "high_mean",
              "field_name": "event.duration",
              "partition_field_name": "gcp.cloud_spanner.database",
              "detector_index": 0
            }
          ],
          "influencers": ["gcp.cloud_spanner.database", "gcp.cloud_spanner.instance_id", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": {
          "model_memory_limit": "32mb"
        },
        "data_description": {
          "time_field": "@timestamp"
        },
        "custom_settings": {
          "created_by": "gcp-elastic-load-generator",
          "tags": ["cloudloadgen"]
        }
      },
      "datafeed": {
        "indices": ["logs-gcp.spanner*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              {
                "term": {
                  "cloud.provider": "gcp"
                }
