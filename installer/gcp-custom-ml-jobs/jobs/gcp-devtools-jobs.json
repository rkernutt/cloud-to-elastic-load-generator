{
  "group": "gcp-devtools",
  "description": "GCP developer tools — Cloud Build",
  "jobs": [
    {
      "id": "gcp-cloud-build-failure-spike",
      "description": "Spikes in failed Cloud Build steps per trigger",
      "job": {
        "description": "Spikes in failed Cloud Build steps per trigger",
        "groups": ["gcp", "devtools", "cloudloadgen"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_count partitionfield=gcp.cloud_build.trigger_name",
              "function": "high_count",
              "partition_field_name": "gcp.cloud_build.trigger_name",
              "detector_index": 0
            }
          ],
          "influencers": ["gcp.cloud_build.trigger_name", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "32mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "gcp-elastic-load-generator", "tags": ["cloudloadgen"] }
      },
      "datafeed": {
        "indices": ["logs-gcp.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              { "term": { "cloud.provider": "gcp" } },
              { "wildcard": { "cloud.service.name": "*cloudbuild*" } },
              { "term": { "event.outcome": "failure" } }
            ]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "120s",
        "delayed_data_check_config": { "enabled": true }
      }
    },
    {
      "id": "gcp-cloud-build-duration",
      "description": "Unusual Cloud Build duration per build",
      "job": {
        "description": "Unusual Cloud Build duration per build",
        "groups": ["gcp", "devtools", "cloudloadgen"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_mean(gcp.source-repositories.metrics.serviceruntime.googleapis.com/api/request_count.avg)",
              "function": "high_mean",
              "field_name": "gcp.source-repositories.metrics.serviceruntime.googleapis.com/api/request_count.avg",
              "detector_index": 0
            }
          ],
          "influencers": ["gcp.cloud_build.trigger_name", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "32mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "gcp-elastic-load-generator", "tags": ["cloudloadgen"] }
      },
      "datafeed": {
        "indices": ["metrics-gcp.cloudbuild_metrics*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              { "term": { "event.dataset": "gcp.cloudbuild_metrics" } },
              {
                "exists": {
                  "field": "gcp.source-repositories.metrics.serviceruntime.googleapis.com/api/request_count.avg"
                }
              }
            ]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "120s",
        "delayed_data_check_config": { "enabled": true }
      }
    },
    {
      "id": "gcp-apigee-error-spike",
      "description": "Detects spikes in Apigee API failures by proxy",
      "job": {
        "description": "Detects spikes in Apigee API failures by proxy",
        "groups": ["gcp", "networking", "cloudloadgen"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_count partitionfield=gcp.apigee.proxy_name",
              "function": "high_count",
              "partition_field_name": "gcp.apigee.proxy_name",
              "detector_index": 0
            }
          ],
          "influencers": ["gcp.apigee.proxy_name", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "32mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "gcp-elastic-load-generator", "tags": ["cloudloadgen"] }
      },
      "datafeed": {
        "indices": ["logs-gcp.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              { "term": { "cloud.provider": "gcp" } },
              { "wildcard": { "cloud.service.name": "*apigee.googleapis.com*" } },
              { "term": { "event.outcome": "failure" } }
            ]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "120s",
        "delayed_data_check_config": { "enabled": true }
      }
    },
    {
      "id": "gcp-apigee-latency-anomaly",
      "description": "Detects unusual Apigee API latency",
      "job": {
        "description": "Detects unusual Apigee API latency",
        "groups": ["gcp", "networking", "cloudloadgen"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_mean(gcp.apigee.metrics.apigee.googleapis.com/proxy/request_count.avg)",
              "function": "high_mean",
              "field_name": "gcp.apigee.metrics.apigee.googleapis.com/proxy/request_count.avg",
              "detector_index": 0
            }
          ],
          "influencers": ["cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "32mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "gcp-elastic-load-generator", "tags": ["cloudloadgen"] }
      },
      "datafeed": {
        "indices": ["metrics-gcp.apigee_metrics*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              { "term": { "event.dataset": "gcp.apigee_metrics" } },
              {
                "exists": {
                  "field": "gcp.apigee.metrics.apigee.googleapis.com/proxy/request_count.avg"
                }
              }
            ]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "120s",
        "delayed_data_check_config": { "enabled": true }
      }
    }
  ]
}
