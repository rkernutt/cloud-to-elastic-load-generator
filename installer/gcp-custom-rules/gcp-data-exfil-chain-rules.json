{
  "group": "gcp-data-exfil-chain",
  "description": "Alerting rules for the GCP Data Exfiltration Chain scenario (DLP, VPC Flow, GCS)",
  "rules": [
    {
      "id": "cloudloadgen-gcp-exfil-dlp-alert",
      "name": "[CloudLoadGen] GCP Data Exfil Chain — DLP Finding Alert",
      "rule_type_id": ".es-query",
      "consumer": "stackAlerts",
      "schedule": { "interval": "5m" },
      "tags": ["cloudloadgen", "gcp-data-exfil-chain"],
      "enabled": false,
      "params": {
        "searchType": "esQuery",
        "timeWindowSize": 15,
        "timeWindowUnit": "m",
        "threshold": [1],
        "thresholdComparator": ">=",
        "size": 100,
        "esQuery": "{\"bool\":{\"filter\":[{\"term\":{\"event.kind\":\"alert\"}},{\"bool\":{\"should\":[{\"term\":{\"event.dataset\":\"gcp.dlp\"}},{\"term\":{\"data_stream.dataset\":\"gcp.dlp\"}}],\"minimum_should_match\":1}}]}}",
        "index": ["logs-gcp.dlp*"],
        "timeField": "@timestamp",
        "aggType": "count"
      },
      "actions": [],
      "notify_when": "onActiveAlert"
    },
    {
      "id": "cloudloadgen-gcp-exfil-high-egress",
      "name": "[CloudLoadGen] GCP Data Exfil Chain — VPC High Bytes Sent",
      "rule_type_id": ".es-query",
      "consumer": "stackAlerts",
      "schedule": { "interval": "5m" },
      "tags": ["cloudloadgen", "gcp-data-exfil-chain"],
      "enabled": false,
      "params": {
        "searchType": "esQuery",
        "timeWindowSize": 15,
        "timeWindowUnit": "m",
        "threshold": [1],
        "thresholdComparator": ">=",
        "size": 100,
        "esQuery": "{\"bool\":{\"filter\":[{\"bool\":{\"should\":[{\"term\":{\"event.dataset\":\"gcp.vpcflow\"}},{\"term\":{\"data_stream.dataset\":\"gcp.vpcflow\"}}],\"minimum_should_match\":1}},{\"term\":{\"gcp.vpc_flow.direction\":\"egress\"}},{\"range\":{\"gcp.vpc_flow.bytes_sent\":{\"gt\":52428800}}}]}}",
        "index": ["logs-gcp.vpcflow*"],
        "timeField": "@timestamp",
        "aggType": "count"
      },
      "actions": [],
      "notify_when": "onActiveAlert"
    },
    {
      "id": "cloudloadgen-gcp-exfil-gcs-suspicious",
      "name": "[CloudLoadGen] GCP Data Exfil Chain — Large GCS Object Get",
      "rule_type_id": ".es-query",
      "consumer": "stackAlerts",
      "schedule": { "interval": "5m" },
      "tags": ["cloudloadgen", "gcp-data-exfil-chain"],
      "enabled": false,
      "params": {
        "searchType": "esQuery",
        "timeWindowSize": 15,
        "timeWindowUnit": "m",
        "threshold": [1],
        "thresholdComparator": ">=",
        "size": 100,
        "esQuery": "{\"bool\":{\"filter\":[{\"bool\":{\"should\":[{\"term\":{\"event.dataset\":\"gcp.gcs\"}},{\"term\":{\"data_stream.dataset\":\"gcp.gcs\"}}],\"minimum_should_match\":1}},{\"term\":{\"gcp.cloud_storage.operation\":\"storage.objects.get\"}},{\"range\":{\"gcp.cloud_storage.object_size\":{\"gt\":52428800}}}]}}",
        "index": ["logs-gcp.gcs*"],
        "timeField": "@timestamp",
        "aggType": "count"
      },
      "actions": [],
      "notify_when": "onActiveAlert"
    },
    {
      "id": "cloudloadgen-gcp-exfil-full-chain",
      "name": "[CloudLoadGen] GCP Data Exfil Chain — Full Chain Correlation",
      "rule_type_id": ".es-query",
      "consumer": "stackAlerts",
      "schedule": { "interval": "5m" },
      "tags": ["cloudloadgen", "gcp-data-exfil-chain"],
      "enabled": false,
      "params": {
        "searchType": "esQuery",
        "timeWindowSize": 15,
        "timeWindowUnit": "m",
        "threshold": [2],
        "thresholdComparator": ">",
        "size": 100,
        "esQuery": "{\"bool\":{\"filter\":[{\"bool\":{\"should\":[{\"bool\":{\"filter\":[{\"term\":{\"event.kind\":\"alert\"}},{\"bool\":{\"should\":[{\"term\":{\"event.dataset\":\"gcp.dlp\"}},{\"term\":{\"data_stream.dataset\":\"gcp.dlp\"}}],\"minimum_should_match\":1}}]}},{\"bool\":{\"filter\":[{\"bool\":{\"should\":[{\"term\":{\"event.dataset\":\"gcp.vpcflow\"}},{\"term\":{\"data_stream.dataset\":\"gcp.vpcflow\"}}],\"minimum_should_match\":1}},{\"term\":{\"gcp.vpc_flow.direction\":\"egress\"}},{\"range\":{\"gcp.vpc_flow.bytes_sent\":{\"gt\":52428800}}}]}},{\"bool\":{\"filter\":[{\"bool\":{\"should\":[{\"term\":{\"event.dataset\":\"gcp.gcs\"}},{\"term\":{\"data_stream.dataset\":\"gcp.gcs\"}}],\"minimum_should_match\":1}},{\"term\":{\"gcp.cloud_storage.operation\":\"storage.objects.get\"}},{\"range\":{\"gcp.cloud_storage.object_size\":{\"gt\":52428800}}}]}}],\"minimum_should_match\":1}}]}}",
        "index": ["logs-gcp.dlp*", "logs-gcp.vpcflow*", "logs-gcp.gcs*"],
        "timeField": "@timestamp",
        "aggType": "count"
      },
      "actions": [],
      "notify_when": "onActiveAlert"
    }
  ]
}
