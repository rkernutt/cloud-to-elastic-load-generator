{
  "group": "gcp-security-chain",
  "description": "Alerting rules for the GCP Security Finding Chain scenario (SCC, Chronicle, SecOps)",
  "rules": [
    {
      "id": "cloudloadgen-gcp-security-scc-high-severity",
      "name": "[CloudLoadGen] GCP Security Finding Chain — SCC HIGH/CRITICAL",
      "rule_type_id": ".es-query",
      "consumer": "stackAlerts",
      "schedule": {
        "interval": "5m"
      },
      "tags": ["cloudloadgen", "gcp-security-chain"],
      "enabled": false,
      "params": {
        "searchType": "esQuery",
        "timeWindowSize": 15,
        "timeWindowUnit": "m",
        "threshold": [1],
        "thresholdComparator": ">=",
        "size": 100,
        "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"bool\":{\"should\":[{\"term\":{\"gcp.security_command_center.severity\":\"HIGH\"}},{\"term\":{\"gcp.security_command_center.severity\":\"CRITICAL\"}}],\"minimum_should_match\":1}}]}}}",
        "index": ["logs-gcp.scc*"],
        "timeField": "@timestamp",
        "aggType": "count"
      },
      "actions": [],
      "notify_when": "onActiveAlert"
    },
    {
      "id": "cloudloadgen-gcp-security-chain-burst",
      "name": "[CloudLoadGen] GCP Security Finding Chain — Multi-Stage Chain Burst",
      "rule_type_id": ".es-query",
      "consumer": "stackAlerts",
      "schedule": {
        "interval": "5m"
      },
      "tags": ["cloudloadgen", "gcp-security-chain"],
      "enabled": false,
      "params": {
        "searchType": "esQuery",
        "timeWindowSize": 15,
        "timeWindowUnit": "m",
        "threshold": [2],
        "thresholdComparator": ">",
        "size": 100,
        "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"bool\":{\"should\":[{\"bool\":{\"filter\":[{\"bool\":{\"should\":[{\"term\":{\"event.dataset\":\"gcp.scc\"}},{\"term\":{\"data_stream.dataset\":\"gcp.scc\"}}],\"minimum_should_match\":1}},{\"term\":{\"event.kind\":\"alert\"}}]}},{\"bool\":{\"filter\":[{\"bool\":{\"should\":[{\"term\":{\"event.dataset\":\"gcp.chronicle\"}},{\"term\":{\"data_stream.dataset\":\"gcp.chronicle\"}}],\"minimum_should_match\":1}},{\"exists\":{\"field\":\"gcp.chronicle.detection_type\"}}]}},{\"bool\":{\"filter\":[{\"bool\":{\"should\":[{\"term\":{\"event.dataset\":\"gcp.secops\"}},{\"term\":{\"data_stream.dataset\":\"gcp.secops\"}}],\"minimum_should_match\":1}},{\"exists\":{\"field\":\"gcp.security_operations.action_type\"}}]}}],\"minimum_should_match\":1}}]}}}",
        "index": ["logs-gcp.scc*", "logs-gcp.chronicle*", "logs-gcp.secops*"],
        "timeField": "@timestamp",
        "aggType": "count"
      },
      "actions": [],
      "notify_when": "onActiveAlert"
    },
    {
      "id": "cloudloadgen-gcp-security-secops-case-created",
      "name": "[CloudLoadGen] GCP Security Finding Chain — SecOps Case Created",
      "rule_type_id": ".es-query",
      "consumer": "stackAlerts",
      "schedule": {
        "interval": "5m"
      },
      "tags": ["cloudloadgen", "gcp-security-chain"],
      "enabled": false,
      "params": {
        "searchType": "esQuery",
        "timeWindowSize": 15,
        "timeWindowUnit": "m",
        "threshold": [1],
        "thresholdComparator": ">=",
        "size": 100,
        "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"term\":{\"gcp.security_operations.action_type\":\"CASE_CREATED\"}}]}}}",
        "index": ["logs-gcp.secops*"],
        "timeField": "@timestamp",
        "aggType": "count"
      },
      "actions": [],
      "notify_when": "onActiveAlert"
    },
    {
      "id": "cloudloadgen-gcp-security-chronicle-high-match",
      "name": "[CloudLoadGen] GCP Security Finding Chain — Chronicle High Match Volume",
      "rule_type_id": ".es-query",
      "consumer": "stackAlerts",
      "schedule": {
        "interval": "5m"
      },
      "tags": ["cloudloadgen", "gcp-security-chain"],
      "enabled": false,
      "params": {
        "searchType": "esQuery",
        "timeWindowSize": 15,
        "timeWindowUnit": "m",
        "threshold": [1],
        "thresholdComparator": ">=",
        "size": 100,
        "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"range\":{\"gcp.chronicle.matched_events_count\":{\"gt\":100}}}]}}}",
        "index": ["logs-gcp.chronicle*"],
        "timeField": "@timestamp",
        "aggType": "count"
      },
      "actions": [],
      "notify_when": "onActiveAlert"
    }
  ]
}
