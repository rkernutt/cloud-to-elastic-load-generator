{
  "title": "GCP Cloud SQL \u2014 Queries & Connections",
  "time_range": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "type": "lens",
      "uid": "gcp-sql-k1",
      "grid": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.cloudsql* | STATS `Queries` = COUNT()"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Queries"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-sql-k2",
      "grid": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.cloudsql* | EVAL is_err = CASE(event.outcome == \"failure\", 1, 0) | STATS e = AVG(is_err) | EVAL `Fail %` = ROUND(e * 100, 1)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Fail %"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-sql-k3",
      "grid": {
        "x": 24,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.cloudsql* | STATS m = AVG(`gcp.cloud_sql.query_duration_ms`) | EVAL `Avg query (ms)` = ROUND(m, 2)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Avg query (ms)"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-sql-d1",
      "grid": {
        "x": 0,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Engine",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.cloudsql* | STATS c = COUNT() BY e = `gcp.cloud_sql.database_engine`"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "e"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-sql-d2",
      "grid": {
        "x": 16,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Query type",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.cloudsql* | STATS c = COUNT() BY t = `gcp.cloud_sql.query_type` | SORT c DESC | LIMIT 8"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "t"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-sql-l1",
      "grid": {
        "x": 0,
        "y": 15,
        "w": 48,
        "h": 10
      },
      "config": {
        "title": "Volume",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-gcp.cloudsql* | STATS c = COUNT() BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
                "column": "b"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "c",
                  "label": "Queries"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-sql-t1",
      "grid": {
        "x": 0,
        "y": 25,
        "w": 48,
        "h": 12
      },
      "config": {
        "title": "Recent",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.cloudsql* | KEEP `@timestamp`, `gcp.cloud_sql.instance_name`, `gcp.cloud_sql.database_engine`, `gcp.cloud_sql.query_type`, `gcp.cloud_sql.query_duration_ms`, event.outcome, message | SORT `@timestamp` DESC | LIMIT 100"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "`@timestamp`",
              "label": "Time"
            },
            {
              "operation": "value",
              "column": "gcp.cloud_sql.instance_name",
              "label": "Instance"
            },
            {
              "operation": "value",
              "column": "gcp.cloud_sql.database_engine",
              "label": "Engine"
            },
            {
              "operation": "value",
              "column": "gcp.cloud_sql.query_type",
              "label": "Query"
            },
            {
              "operation": "value",
              "column": "gcp.cloud_sql.query_duration_ms",
              "label": "Dur ms"
            },
            {
              "operation": "value",
              "column": "event.outcome",
              "label": "Outcome"
            },
            {
              "operation": "value",
              "column": "message",
              "label": "Message"
            }
          ],
          "rows": []
        }
      }
    }
  ]
}
