{
  "title": "GCP Vertex AI Agent Builder — overview",
  "time_range": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "type": "lens",
      "uid": "gvaabk1",
      "grid": { "x": 0, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.vertex_ai_agent_builder* | STATS `Log events` = COUNT()"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Log events" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gvaabd1",
      "grid": { "x": 0, "y": 5, "w": 16, "h": 10 },
      "config": {
        "title": "Event outcome",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.vertex_ai_agent_builder* | STATS c = COUNT() BY o = event.outcome"
          },
          "metrics": [{ "operation": "value", "column": "c" }],
          "group_by": [{ "operation": "value", "column": "o" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gvaabb1",
      "grid": { "x": 16, "y": 5, "w": 32, "h": 10 },
      "config": {
        "title": "Events over time",
        "attributes": {
          "type": "xy",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.vertex_ai_agent_builder* | STATS count = COUNT() BY bucket = DATE_TRUNC(30 minutes, `@timestamp`)"
          },
          "layers": [{ "seriesType": "bar_stacked", "xAccessor": "bucket", "yAccessor": "count" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gvaabb2",
      "grid": { "x": 0, "y": 15, "w": 24, "h": 10 },
      "config": {
        "title": "Errors over time",
        "attributes": {
          "type": "xy",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.vertex_ai_agent_builder* | WHERE event.outcome == \"failure\" | STATS count = COUNT() BY scenario = COALESCE(`gcp.vertex_ai_agent_builder.scenario`, \"unknown\"), bucket = DATE_TRUNC(30 minutes, `@timestamp`)"
          },
          "layers": [
            {
              "seriesType": "bar_stacked",
              "xAccessor": "bucket",
              "yAccessor": "count",
              "splitAccessor": "scenario"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gvaabb3",
      "grid": { "x": 24, "y": 15, "w": 24, "h": 10 },
      "config": {
        "title": "Events by region",
        "attributes": {
          "type": "xy",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.vertex_ai_agent_builder* | STATS count = COUNT() BY region = cloud.region, bucket = DATE_TRUNC(30 minutes, `@timestamp`)"
          },
          "layers": [
            {
              "seriesType": "bar_stacked",
              "xAccessor": "bucket",
              "yAccessor": "count",
              "splitAccessor": "region"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gvaabt1",
      "grid": { "x": 0, "y": 25, "w": 48, "h": 12 },
      "config": {
        "title": "Top operations",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.vertex_ai_agent_builder* | STATS c = COUNT() BY op = COALESCE(event.action, `gcp.vertex_ai_agent_builder.scenario`, \"unknown\") | SORT c DESC | LIMIT 15"
          },
          "metrics": [
            { "operation": "value", "column": "op", "label": "Operation" },
            { "operation": "value", "column": "c", "label": "Count" }
          ],
          "rows": []
        }
      }
    },
    {
      "type": "lens",
      "uid": "gvaabx1",
      "grid": { "x": 0, "y": 37, "w": 24, "h": 10 },
      "config": {
        "title": "By scenario",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.vertex_ai_agent_builder* | STATS c = COUNT() BY s = `gcp.vertex_ai_agent_builder.scenario`"
          },
          "metrics": [{ "operation": "value", "column": "c" }],
          "group_by": [{ "operation": "value", "column": "s" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gvaabx2",
      "grid": { "x": 24, "y": 37, "w": 24, "h": 10 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.vertex_ai_agent_builder* | WHERE `gcp.vertex_ai_agent_builder.latency_ms` IS NOT NULL | STATS m = AVG(`gcp.vertex_ai_agent_builder.latency_ms`) | EVAL `Avg latency (ms)` = ROUND(m, 1)"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Avg latency (ms)" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-mx-k1-vertex-ai-agent-builder",
      "grid": { "x": 0, "y": 48, "w": 24, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM metrics-gcp.vertex_ai_agent_builder_metrics* | STATS `Metric Request Count` = ROUND(SUM(`gcp.vertex-ai-agent-builder.metrics.aiplatform.googleapis.com/reasoning_engine/request_count.sum`), 2)"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Metric Request Count" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-mx-k2-vertex-ai-agent-builder",
      "grid": { "x": 24, "y": 48, "w": 24, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM metrics-gcp.vertex_ai_agent_builder_metrics* | STATS `Metric Approx Logical Size Bytes` = ROUND(AVG(`gcp.vertex-ai-agent-builder.metrics.aiplatform.googleapis.com/reasoning_engine/memory_bank/approx_logical_size_bytes.avg`), 2)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Metric Approx Logical Size Bytes"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-mx-ts-vertex-ai-agent-builder",
      "grid": { "x": 0, "y": 53, "w": 48, "h": 10 },
      "config": {
        "title": "Approx Logical Size Bytes over time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": { "title": { "visible": false } },
            "left": { "title": { "visible": false } }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM metrics-gcp.vertex_ai_agent_builder_metrics* | STATS m = AVG(`gcp.vertex-ai-agent-builder.metrics.aiplatform.googleapis.com/reasoning_engine/memory_bank/approx_logical_size_bytes.avg`) BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": { "operation": "value", "column": "b" },
              "y": [{ "operation": "value", "column": "m", "label": "Approx Logical Size Bytes" }]
            }
          ]
        }
      }
    }
  ]
}
