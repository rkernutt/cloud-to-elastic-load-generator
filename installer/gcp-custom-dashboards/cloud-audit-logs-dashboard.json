{
  "title": "GCP Cloud Audit Logs — API Activity",
  "time_range": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "type": "lens",
      "uid": "gcpal-k1",
      "grid": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.audit* | STATS Events = COUNT()"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Events"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcpal-k2",
      "grid": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.audit* | EVAL d = CASE(`gcp.cloud_audit.authorization_decision` == \"DENIED\", 1, 0) | STATS m = AVG(d) | EVAL `Denied %` = ROUND(m * 100, 1)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Denied %"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcpal-k3",
      "grid": {
        "x": 24,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.audit* | STATS `Methods` = COUNT_DISTINCT(`gcp.cloud_audit.method_name`)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Distinct methods"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcpal-k4",
      "grid": {
        "x": 36,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.audit* | STATS `Services` = COUNT_DISTINCT(`gcp.cloud_audit.service_name`)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Distinct services"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcpal-d1",
      "grid": {
        "x": 0,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Authorization",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.audit* | STATS c = COUNT() BY a = `gcp.cloud_audit.authorization_decision` | SORT c DESC"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "a"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcpal-d2",
      "grid": {
        "x": 16,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Caller type",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.audit* | STATS c = COUNT() BY t = `gcp.cloud_audit.caller_type` | SORT c DESC"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "t"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcpal-d3",
      "grid": {
        "x": 32,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Top methods",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.audit* | STATS c = COUNT() BY m = `gcp.cloud_audit.method_name` | SORT c DESC | LIMIT 8"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "m"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcpal-l1",
      "grid": {
        "x": 0,
        "y": 15,
        "w": 48,
        "h": 10
      },
      "config": {
        "title": "API calls over time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-gcp.audit* | STATS c = COUNT() BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
                "column": "b"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "c",
                  "label": "Events"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcpal-l2",
      "grid": {
        "x": 0,
        "y": 25,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Denied vs allowed",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-gcp.audit* | STATS den = SUM(CASE(`gcp.cloud_audit.authorization_decision` == \"DENIED\", 1, 0)), ok = SUM(CASE(`gcp.cloud_audit.authorization_decision` == \"ALLOWED\", 1, 0)) BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
                "column": "b"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "den",
                  "label": "Denied"
                },
                {
                  "operation": "value",
                  "column": "ok",
                  "label": "Allowed"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcpal-l3",
      "grid": {
        "x": 24,
        "y": 25,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Failure outcome",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-gcp.audit* | STATS bad = SUM(CASE(event.outcome == \"failure\", 1, 0)) BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
                "column": "b"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "bad",
                  "label": "Failures"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcpal-b1",
      "grid": {
        "x": 0,
        "y": 35,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Top principals",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "bar_horizontal",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-gcp.audit* | STATS c = COUNT() BY u = `user.name` | SORT c DESC | LIMIT 10"
              },
              "x": {
                "operation": "value",
                "column": "u"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "c",
                  "label": "Calls"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcpal-t1",
      "grid": {
        "x": 0,
        "y": 45,
        "w": 48,
        "h": 12
      },
      "config": {
        "title": "Recent audit events",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.audit* | KEEP `@timestamp`, `gcp.cloud_audit.service_name`, `gcp.cloud_audit.method_name`, `gcp.cloud_audit.resource_name`, `gcp.cloud_audit.authorization_decision`, `user.name`, `gcp.cloud_audit.caller_ip`, event.outcome | SORT `@timestamp` DESC | LIMIT 100"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "`@timestamp`",
              "label": "Time"
            },
            {
              "operation": "value",
              "column": "gcp.cloud_audit.service_name",
              "label": "Service"
            },
            {
              "operation": "value",
              "column": "gcp.cloud_audit.method_name",
              "label": "Method"
            },
            {
              "operation": "value",
              "column": "gcp.cloud_audit.resource_name",
              "label": "Resource"
            },
            {
              "operation": "value",
              "column": "gcp.cloud_audit.authorization_decision",
              "label": "Authz"
            },
            {
              "operation": "value",
              "column": "user.name",
              "label": "Principal"
            },
            {
              "operation": "value",
              "column": "gcp.cloud_audit.caller_ip",
              "label": "IP"
            },
            {
              "operation": "value",
              "column": "event.outcome",
              "label": "Outcome"
            }
          ],
          "rows": []
        }
      }
    }
  ]
}
