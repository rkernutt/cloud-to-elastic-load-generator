{
  "title": "GCP BigQuery — Jobs & Slot Usage",
  "time_range": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "type": "lens",
      "uid": "gcp-bq-k1",
      "grid": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.bigquery* | STATS `Jobs` = COUNT()"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Jobs"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-bq-k2",
      "grid": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.bigquery* | EVAL is_err = CASE(event.outcome == \"failure\", 1, 0) | STATS e = AVG(is_err) | EVAL `Fail %` = ROUND(e * 100, 1)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Fail %"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-bq-k3",
      "grid": {
        "x": 24,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.bigquery* | STATS tb = SUM(`gcp.bigquery.total_bytes_processed`) | EVAL `TB scanned` = ROUND(tb / 1099511627776.0, 2)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "TB scanned"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-bq-d1",
      "grid": {
        "x": 0,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Job type",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.bigquery* | STATS c = COUNT() BY j = `gcp.bigquery.job_type`"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "j"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-bq-d2",
      "grid": {
        "x": 16,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Statement",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.bigquery* | STATS c = COUNT() BY s = `gcp.bigquery.statement_type` | SORT c DESC | LIMIT 10"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "s"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-bq-l1",
      "grid": {
        "x": 0,
        "y": 15,
        "w": 48,
        "h": 10
      },
      "config": {
        "title": "Jobs over time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-gcp.bigquery* | STATS c = COUNT() BY b = BUCKET(@timestamp, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
                "column": "b"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "c",
                  "label": "Jobs"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-bq-t1",
      "grid": {
        "x": 0,
        "y": 25,
        "w": 48,
        "h": 12
      },
      "config": {
        "title": "Recent jobs",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.bigquery* | KEEP @timestamp, `gcp.bigquery.job_id`, `gcp.bigquery.job_type`, `gcp.bigquery.dataset`, `gcp.bigquery.statement_type`, `gcp.bigquery.total_bytes_processed`, event.outcome, message | SORT @timestamp DESC | LIMIT 100"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "@timestamp",
              "label": "Time"
            },
            {
              "operation": "value",
              "column": "gcp.bigquery.job_id",
              "label": "Job"
            },
            {
              "operation": "value",
              "column": "gcp.bigquery.job_type",
              "label": "Type"
            },
            {
              "operation": "value",
              "column": "gcp.bigquery.dataset",
              "label": "Dataset"
            },
            {
              "operation": "value",
              "column": "gcp.bigquery.statement_type",
              "label": "Statement"
            },
            {
              "operation": "value",
              "column": "gcp.bigquery.total_bytes_processed",
              "label": "Bytes"
            },
            {
              "operation": "value",
              "column": "event.outcome",
              "label": "Outcome"
            },
            {
              "operation": "value",
              "column": "message",
              "label": "Message"
            }
          ],
          "rows": []
        }
      }
    }
  ]
}
