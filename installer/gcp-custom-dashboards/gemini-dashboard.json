{
  "title": "GCP Gemini — overview",
  "time_range": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "type": "lens",
      "uid": "ggeminik1",
      "grid": { "x": 0, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.gemini* | STATS `Log events` = COUNT()"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Log events" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "ggeminid1",
      "grid": { "x": 0, "y": 5, "w": 16, "h": 10 },
      "config": {
        "title": "Event outcome",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.gemini* | STATS c = COUNT() BY o = event.outcome"
          },
          "metrics": [{ "operation": "value", "column": "c" }],
          "group_by": [{ "operation": "value", "column": "o" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "ggeminil1",
      "grid": { "x": 0, "y": 15, "w": 48, "h": 10 },
      "config": {
        "title": "Event volume",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": { "title": { "visible": false } },
            "left": { "title": { "visible": false } }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-gcp.gemini* | STATS c = COUNT() BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": { "operation": "value", "column": "b" },
              "y": [{ "operation": "value", "column": "c", "label": "Events" }]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "ggeminit1",
      "grid": { "x": 0, "y": 25, "w": 48, "h": 12 },
      "config": {
        "title": "By project",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.gemini* | STATS c = COUNT() BY region = `cloud.project.id` | SORT c DESC | LIMIT 15"
          },
          "metrics": [
            { "operation": "value", "column": "region", "label": "Project" },
            { "operation": "value", "column": "c", "label": "Count" }
          ],
          "rows": []
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-mx-k1-gemini",
      "grid": { "x": 0, "y": 38, "w": 24, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM metrics-gcp.gemini_metrics* | STATS `Metric Generate Content Usage Output Token Coun` = ROUND(SUM(`gcp.gemini.metrics.generativelanguage.googleapis.com/generate_content_usage_output_token_count.sum`), 2)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Metric Generate Content Usage Output Token Coun"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-mx-k2-gemini",
      "grid": { "x": 24, "y": 38, "w": 24, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM metrics-gcp.gemini_metrics* | STATS `Metric Usage` = ROUND(AVG(`gcp.gemini.metrics.generativelanguage.googleapis.com/quota/generate_content_free_tier_input_token_count/usage.avg`), 2)"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Metric Usage" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-mx-ts-gemini",
      "grid": { "x": 0, "y": 43, "w": 48, "h": 10 },
      "config": {
        "title": "Usage over time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": { "title": { "visible": false } },
            "left": { "title": { "visible": false } }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM metrics-gcp.gemini_metrics* | STATS m = AVG(`gcp.gemini.metrics.generativelanguage.googleapis.com/quota/generate_content_free_tier_input_token_count/usage.avg`) BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": { "operation": "value", "column": "b" },
              "y": [{ "operation": "value", "column": "m", "label": "Usage" }]
            }
          ]
        }
      }
    }
  ]
}
