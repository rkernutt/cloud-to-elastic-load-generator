{
  "title": "GCP VPC Flow — Traffic & Denials",
  "time_range": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "type": "lens",
      "uid": "gcp-vpc-k1",
      "grid": { "x": 0, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.vpcflow* | STATS `Log events` = COUNT()"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Log events" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-vpc-k2",
      "grid": { "x": 12, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.vpcflow* | EVAL is_deny = CASE(`gcp.vpc_flow.action` == \"DENY\", 1, 0) | STATS d = AVG(is_deny) | EVAL `Deny %` = ROUND(d * 100, 1)"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Deny %" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-vpc-d1",
      "grid": { "x": 0, "y": 5, "w": 16, "h": 10 },
      "config": {
        "title": "Action",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.vpcflow* | STATS c = COUNT() BY a = `gcp.vpc_flow.action`"
          },
          "metrics": [{ "operation": "value", "column": "c" }],
          "group_by": [{ "operation": "value", "column": "a" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-vpc-d2",
      "grid": { "x": 16, "y": 5, "w": 16, "h": 10 },
      "config": {
        "title": "Direction",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.vpcflow* | STATS c = COUNT() BY d = `gcp.vpc_flow.direction`"
          },
          "metrics": [{ "operation": "value", "column": "c" }],
          "group_by": [{ "operation": "value", "column": "d" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-vpc-l1",
      "grid": { "x": 0, "y": 15, "w": 48, "h": 10 },
      "config": {
        "title": "Flows",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": { "title": { "visible": false } },
            "left": { "title": { "visible": false } }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-gcp.vpcflow* | STATS c = COUNT() BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": { "operation": "value", "column": "b" },
              "y": [{ "operation": "value", "column": "c", "label": "Flows" }]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-vpc-t1",
      "grid": { "x": 0, "y": 25, "w": 48, "h": 12 },
      "config": {
        "title": "Recent",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.vpcflow* | KEEP `@timestamp`, `gcp.vpc_flow.src_ip`, `gcp.vpc_flow.dst_ip`, `gcp.vpc_flow.dst_port`, `gcp.vpc_flow.protocol`, `gcp.vpc_flow.action`, event.outcome, message | SORT `@timestamp` DESC | LIMIT 100"
          },
          "metrics": [
            { "operation": "value", "column": "`@timestamp`", "label": "Time" },
            { "operation": "value", "column": "gcp.vpc_flow.src_ip", "label": "Src" },
            { "operation": "value", "column": "gcp.vpc_flow.dst_ip", "label": "Dst" },
            { "operation": "value", "column": "gcp.vpc_flow.dst_port", "label": "Port" },
            { "operation": "value", "column": "gcp.vpc_flow.protocol", "label": "Proto" },
            { "operation": "value", "column": "gcp.vpc_flow.action", "label": "Action" },
            { "operation": "value", "column": "event.outcome", "label": "Outcome" },
            { "operation": "value", "column": "message", "label": "Message" }
          ],
          "rows": []
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-mx-k1-vpc-flow",
      "grid": { "x": 0, "y": 38, "w": 24, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM metrics-gcp.vpcflow_metrics* | STATS `Metric Egress Bytes Count` = ROUND(SUM(COALESCE(`gcp.network-service-tiers.metrics.networking.googleapis.com/vm_flow/egress_bytes_count.sum`, `gcp.vpc-flow.metrics.networking.googleapis.com/vm_flow/egress_bytes_count.sum`)), 2)"
          },
          "metrics": [
            { "type": "primary", "operation": "value", "column": "Metric Egress Bytes Count" }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-mx-k2-vpc-flow",
      "grid": { "x": 24, "y": 38, "w": 24, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM metrics-gcp.vpcflow_metrics* | STATS `Metric Ingress Bytes Count` = ROUND(SUM(`gcp.vpc-flow.metrics.networking.googleapis.com/vm_flow/ingress_bytes_count.sum`), 2)"
          },
          "metrics": [
            { "type": "primary", "operation": "value", "column": "Metric Ingress Bytes Count" }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-mx-ts-vpc-flow",
      "grid": { "x": 0, "y": 43, "w": 48, "h": 10 },
      "config": {
        "title": "Egress Bytes Count over time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": { "title": { "visible": false } },
            "left": { "title": { "visible": false } }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM metrics-gcp.vpcflow_metrics* | STATS m = SUM(COALESCE(`gcp.network-service-tiers.metrics.networking.googleapis.com/vm_flow/egress_bytes_count.sum`, `gcp.vpc-flow.metrics.networking.googleapis.com/vm_flow/egress_bytes_count.sum`)) BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": { "operation": "value", "column": "b" },
              "y": [{ "operation": "value", "column": "m", "label": "Egress Bytes Count" }]
            }
          ]
        }
      }
    }
  ]
}
