{
  "title": "GCP GKE — Pod & Cluster Events",
  "time_range": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "type": "lens",
      "uid": "gcp-gke-k1",
      "grid": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.gke* | STATS `Events` = COUNT()"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Events"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-gke-k2",
      "grid": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.gke* | EVAL is_err = CASE(event.outcome == \"failure\", 1, 0) | STATS e = AVG(is_err) | EVAL `Fail %` = ROUND(e * 100, 1)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Fail %"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-gke-d1",
      "grid": {
        "x": 0,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Event type",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.gke* | STATS c = COUNT() BY t = `gcp.gke.event_type` | SORT c DESC | LIMIT 12"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "t"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-gke-d2",
      "grid": {
        "x": 16,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Namespace",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.gke* | STATS c = COUNT() BY n = `gcp.gke.namespace` | SORT c DESC | LIMIT 10"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "n"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-gke-l1",
      "grid": {
        "x": 0,
        "y": 15,
        "w": 48,
        "h": 10
      },
      "config": {
        "title": "Events over time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-gcp.gke* | STATS c = COUNT() BY b = BUCKET(@timestamp, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
                "column": "b"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "c",
                  "label": "Events"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-gke-t1",
      "grid": {
        "x": 0,
        "y": 25,
        "w": 48,
        "h": 12
      },
      "config": {
        "title": "Recent pod events",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.gke* | KEEP @timestamp, `gcp.gke.cluster`, `gcp.gke.namespace`, `gcp.gke.pod`, `gcp.gke.event_type`, `gcp.gke.severity`, event.outcome, message | SORT @timestamp DESC | LIMIT 100"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "@timestamp",
              "label": "Time"
            },
            {
              "operation": "value",
              "column": "gcp.gke.cluster",
              "label": "Cluster"
            },
            {
              "operation": "value",
              "column": "gcp.gke.namespace",
              "label": "Namespace"
            },
            {
              "operation": "value",
              "column": "gcp.gke.pod",
              "label": "Pod"
            },
            {
              "operation": "value",
              "column": "gcp.gke.event_type",
              "label": "Event"
            },
            {
              "operation": "value",
              "column": "gcp.gke.severity",
              "label": "Severity"
            },
            {
              "operation": "value",
              "column": "event.outcome",
              "label": "Outcome"
            },
            {
              "operation": "value",
              "column": "message",
              "label": "Message"
            }
          ],
          "rows": []
        }
      }
    }
  ]
}
