{
  "title": "GCP Cloud Build — Pipeline Steps",
  "time_range": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "type": "lens",
      "uid": "gcp-cb-k1",
      "grid": { "x": 0, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.cloudbuild* | STATS `Log events` = COUNT()"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Log events" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-cb-k2",
      "grid": { "x": 12, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.cloudbuild* | EVAL is_err = CASE(event.outcome == \"failure\", 1, 0) | STATS e = AVG(is_err) | EVAL `Fail %` = ROUND(e * 100, 1)"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Fail %" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-cb-d1",
      "grid": { "x": 0, "y": 5, "w": 16, "h": 10 },
      "config": {
        "title": "Status",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.cloudbuild* | STATS c = COUNT() BY s = `gcp.cloud_build.status` | SORT c DESC | LIMIT 10"
          },
          "metrics": [{ "operation": "value", "column": "c" }],
          "group_by": [{ "operation": "value", "column": "s" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-cb-l1",
      "grid": { "x": 0, "y": 15, "w": 48, "h": 10 },
      "config": {
        "title": "Builds",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": { "title": { "visible": false } },
            "left": { "title": { "visible": false } }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-gcp.cloudbuild* | STATS c = COUNT() BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": { "operation": "value", "column": "b" },
              "y": [{ "operation": "value", "column": "c", "label": "Builds" }]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-cb-t1",
      "grid": { "x": 0, "y": 25, "w": 48, "h": 12 },
      "config": {
        "title": "Recent",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.cloudbuild* | KEEP `@timestamp`, `gcp.cloud_build.build_id`, `gcp.cloud_build.trigger_name`, `gcp.cloud_build.step_name`, `gcp.cloud_build.status`, `gcp.cloud_build.build_duration_seconds`, event.outcome, message | SORT `@timestamp` DESC | LIMIT 100"
          },
          "metrics": [
            { "operation": "value", "column": "`@timestamp`", "label": "Time" },
            { "operation": "value", "column": "gcp.cloud_build.build_id", "label": "Build" },
            { "operation": "value", "column": "gcp.cloud_build.trigger_name", "label": "Trigger" },
            { "operation": "value", "column": "gcp.cloud_build.step_name", "label": "Step" },
            { "operation": "value", "column": "gcp.cloud_build.status", "label": "Status" },
            {
              "operation": "value",
              "column": "gcp.cloud_build.build_duration_seconds",
              "label": "Sec"
            },
            { "operation": "value", "column": "event.outcome", "label": "Outcome" },
            { "operation": "value", "column": "message", "label": "Message" }
          ],
          "rows": []
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-mx-k1-cloud-build",
      "grid": { "x": 0, "y": 38, "w": 24, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM metrics-gcp.cloudbuild_metrics* | STATS `Metric Request Count` = ROUND(SUM(COALESCE(`gcp.cloud-build.metrics.serviceruntime.googleapis.com/api/request_count.sum`, `gcp.source-repositories.metrics.serviceruntime.googleapis.com/api/request_count.sum`)), 2)"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Metric Request Count" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-mx-k2-cloud-build",
      "grid": { "x": 24, "y": 38, "w": 24, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM metrics-gcp.cloudbuild_metrics* | STATS `Metric Usage` = ROUND(AVG(`gcp.cloud-build.metrics.cloudbuild.googleapis.com/quota/concurrent_public_pool_build_cpus/usage.avg`), 2)"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Metric Usage" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-mx-ts-cloud-build",
      "grid": { "x": 0, "y": 43, "w": 48, "h": 10 },
      "config": {
        "title": "Usage over time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": { "title": { "visible": false } },
            "left": { "title": { "visible": false } }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM metrics-gcp.cloudbuild_metrics* | STATS m = AVG(`gcp.cloud-build.metrics.cloudbuild.googleapis.com/quota/concurrent_public_pool_build_cpus/usage.avg`) BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": { "operation": "value", "column": "b" },
              "y": [{ "operation": "value", "column": "m", "label": "Usage" }]
            }
          ]
        }
      }
    }
  ]
}
