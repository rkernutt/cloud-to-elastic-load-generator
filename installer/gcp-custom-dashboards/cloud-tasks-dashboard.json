{
  "title": "GCP Cloud Tasks — Queues & Execution",
  "time_range": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "type": "lens",
      "uid": "gcp-ct-k1",
      "grid": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.cloudtasks* | STATS `Task attempts` = COUNT()"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Task attempts"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-ct-k2",
      "grid": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.cloudtasks* | STATS `Avg queue depth` = ROUND(AVG(`gcp.cloud_tasks.metrics.queue_depth.avg`), 0)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Avg queue depth"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-ct-k3",
      "grid": {
        "x": 24,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.cloudtasks* | STATS total = COUNT(), retries = SUM(CASE(`gcp.cloud_tasks.dispatch_count` > 1, 1, 0)) | EVAL `Retry %` = ROUND(retries * 100.0 / total, 1)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Retry %"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-ct-k4",
      "grid": {
        "x": 36,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.cloudtasks* | EVAL is_err = CASE(event.outcome == \"failure\", 1, 0) | STATS e = AVG(is_err) | EVAL `Error %` = ROUND(e * 100, 1)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Error %"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-ct-d1",
      "grid": {
        "x": 0,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Queue",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.cloudtasks* | STATS c = COUNT() BY q = `gcp.cloud_tasks.queue_name` | SORT c DESC | LIMIT 10"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "q"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-ct-d2",
      "grid": {
        "x": 16,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Response code",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.cloudtasks* | STATS c = COUNT() BY rc = TO_STRING(`gcp.cloud_tasks.response_code`) | SORT c DESC | LIMIT 10"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "rc"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-ct-d3",
      "grid": {
        "x": 32,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Outcome",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.cloudtasks* | STATS c = COUNT() BY o = event.outcome | SORT c DESC"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "o"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-ct-l1",
      "grid": {
        "x": 0,
        "y": 15,
        "w": 48,
        "h": 10
      },
      "config": {
        "title": "Executions over time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-gcp.cloudtasks* | STATS c = COUNT() BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
                "column": "b"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "c",
                  "label": "Attempts"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-ct-l2",
      "grid": {
        "x": 0,
        "y": 25,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Queue depth over time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-gcp.cloudtasks* | STATS depth = AVG(`gcp.cloud_tasks.metrics.queue_depth.avg`) BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
                "column": "b"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "depth",
                  "label": "Depth"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-ct-b1",
      "grid": {
        "x": 24,
        "y": 25,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Latency by queue (ms)",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "bar_horizontal",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-gcp.cloudtasks* | STATS lat = ROUND(AVG(`gcp.cloud_tasks.attempt_latency_ms`), 0) BY q = `gcp.cloud_tasks.queue_name` | SORT lat DESC | LIMIT 10"
              },
              "x": {
                "operation": "value",
                "column": "q"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "lat",
                  "label": "Avg ms"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-ct-t1",
      "grid": {
        "x": 0,
        "y": 35,
        "w": 48,
        "h": 12
      },
      "config": {
        "title": "Recent tasks",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.cloudtasks* | KEEP `@timestamp`, `gcp.cloud_tasks.queue_name`, `gcp.cloud_tasks.task_name`, `gcp.cloud_tasks.dispatch_count`, `gcp.cloud_tasks.response_code`, `gcp.cloud_tasks.attempt_latency_ms`, event.outcome, message | SORT `@timestamp` DESC | LIMIT 100"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "`@timestamp`",
              "label": "Time"
            },
            {
              "operation": "value",
              "column": "gcp.cloud_tasks.queue_name",
              "label": "Queue"
            },
            {
              "operation": "value",
              "column": "gcp.cloud_tasks.task_name",
              "label": "Task"
            },
            {
              "operation": "value",
              "column": "gcp.cloud_tasks.dispatch_count",
              "label": "Dispatch"
            },
            {
              "operation": "value",
              "column": "gcp.cloud_tasks.response_code",
              "label": "HTTP"
            },
            {
              "operation": "value",
              "column": "gcp.cloud_tasks.attempt_latency_ms",
              "label": "Latency ms"
            },
            {
              "operation": "value",
              "column": "event.outcome",
              "label": "Outcome"
            },
            {
              "operation": "value",
              "column": "message",
              "label": "Message"
            }
          ],
          "rows": []
        }
      }
    }
  ]
}
