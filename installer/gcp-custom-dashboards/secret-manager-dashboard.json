{
  "title": "GCP Secret Manager — Access & Rotation",
  "time_range": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "type": "lens",
      "uid": "gcp-sm-k1",
      "grid": { "x": 0, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.secretmanager* | STATS `Access events` = COUNT()"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Access events" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-sm-k2",
      "grid": { "x": 12, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.secretmanager* | STATS Secrets = COUNT_DISTINCT(`gcp.secret_manager.secret_name`)"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Secrets" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-sm-k3",
      "grid": { "x": 24, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.secretmanager* | STATS Rotations = SUM(CASE(`gcp.secret_manager.action` == \"AddSecretVersion\", 1, 0))"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Rotations" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-sm-k4",
      "grid": { "x": 36, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.secretmanager* | EVAL is_err = CASE(event.outcome == \"failure\", 1, 0) | STATS e = AVG(is_err) | EVAL `Error %` = ROUND(e * 100, 1)"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Error %" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-sm-d1",
      "grid": { "x": 0, "y": 5, "w": 16, "h": 10 },
      "config": {
        "title": "Action",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.secretmanager* | STATS c = COUNT() BY a = `gcp.secret_manager.action` | SORT c DESC"
          },
          "metrics": [{ "operation": "value", "column": "c" }],
          "group_by": [{ "operation": "value", "column": "a" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-sm-d2",
      "grid": { "x": 16, "y": 5, "w": 16, "h": 10 },
      "config": {
        "title": "Top secrets",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.secretmanager* | STATS c = COUNT() BY s = `gcp.secret_manager.secret_name` | SORT c DESC | LIMIT 10"
          },
          "metrics": [{ "operation": "value", "column": "c" }],
          "group_by": [{ "operation": "value", "column": "s" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-sm-d3",
      "grid": { "x": 32, "y": 5, "w": 16, "h": 10 },
      "config": {
        "title": "Outcome",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.secretmanager* | STATS c = COUNT() BY o = event.outcome | SORT c DESC"
          },
          "metrics": [{ "operation": "value", "column": "c" }],
          "group_by": [{ "operation": "value", "column": "o" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-sm-l1",
      "grid": { "x": 0, "y": 15, "w": 48, "h": 10 },
      "config": {
        "title": "Access rate over time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": { "title": { "visible": false } },
            "left": { "title": { "visible": false } }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-gcp.secretmanager* | STATS c = COUNT() BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": { "operation": "value", "column": "b" },
              "y": [{ "operation": "value", "column": "c", "label": "Access" }]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-sm-l2",
      "grid": { "x": 0, "y": 25, "w": 24, "h": 10 },
      "config": {
        "title": "Rotation events over time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": { "title": { "visible": false } },
            "left": { "title": { "visible": false } }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-gcp.secretmanager* | STATS r = SUM(CASE(`gcp.secret_manager.action` == \"AddSecretVersion\", 1, 0)) BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": { "operation": "value", "column": "b" },
              "y": [{ "operation": "value", "column": "r", "label": "Rotations" }]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-sm-b1",
      "grid": { "x": 24, "y": 25, "w": 24, "h": 10 },
      "config": {
        "title": "Access by secret",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": { "title": { "visible": false } },
            "left": { "title": { "visible": false } }
          },
          "layers": [
            {
              "type": "bar_horizontal",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-gcp.secretmanager* | STATS c = COUNT() BY s = `gcp.secret_manager.secret_name` | SORT c DESC | LIMIT 10"
              },
              "x": { "operation": "value", "column": "s" },
              "y": [{ "operation": "value", "column": "c", "label": "Access" }]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-sm-t1",
      "grid": { "x": 0, "y": 35, "w": 48, "h": 12 },
      "config": {
        "title": "Recent access",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.secretmanager* | KEEP `@timestamp`, `gcp.secret_manager.secret_name`, `gcp.secret_manager.version`, `gcp.secret_manager.action`, `gcp.secret_manager.accessor`, `gcp.secret_manager.replication`, event.outcome | SORT `@timestamp` DESC | LIMIT 100"
          },
          "metrics": [
            { "operation": "value", "column": "`@timestamp`", "label": "Time" },
            { "operation": "value", "column": "gcp.secret_manager.secret_name", "label": "Secret" },
            { "operation": "value", "column": "gcp.secret_manager.version", "label": "Version" },
            { "operation": "value", "column": "gcp.secret_manager.action", "label": "Action" },
            { "operation": "value", "column": "gcp.secret_manager.accessor", "label": "Accessor" },
            {
              "operation": "value",
              "column": "gcp.secret_manager.replication",
              "label": "Replication"
            },
            { "operation": "value", "column": "event.outcome", "label": "Outcome" }
          ],
          "rows": []
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-mx-k1-secret-manager",
      "grid": { "x": 0, "y": 48, "w": 24, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM metrics-gcp.secretmanager_metrics* | STATS `Metric Access Count` = ROUND(SUM(`gcp.secret-manager.metrics.secretmanager.googleapis.com/secret/version/access_count.sum`), 2)"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Metric Access Count" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-mx-k2-secret-manager",
      "grid": { "x": 24, "y": 48, "w": 24, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM metrics-gcp.secretmanager_metrics* | STATS `Metric Request Count` = ROUND(SUM(`gcp.secret-manager.metrics.serviceruntime.googleapis.com/api/request_count.sum`), 2)"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Metric Request Count" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-mx-ts-secret-manager",
      "grid": { "x": 0, "y": 53, "w": 48, "h": 10 },
      "config": {
        "title": "Access Count over time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": { "title": { "visible": false } },
            "left": { "title": { "visible": false } }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM metrics-gcp.secretmanager_metrics* | STATS m = SUM(`gcp.secret-manager.metrics.secretmanager.googleapis.com/secret/version/access_count.sum`) BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": { "operation": "value", "column": "b" },
              "y": [{ "operation": "value", "column": "m", "label": "Access Count" }]
            }
          ]
        }
      }
    }
  ]
}
