{
  "title": "GCP Parallelstore — overview",
  "time_range": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "type": "lens",
      "uid": "gprk1",
      "grid": { "x": 0, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.parallelstore* | STATS `Log events` = COUNT()"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Log events" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gprd1",
      "grid": { "x": 0, "y": 5, "w": 16, "h": 10 },
      "config": {
        "title": "Event outcome",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.parallelstore* | STATS c = COUNT() BY o = event.outcome"
          },
          "metrics": [{ "operation": "value", "column": "c" }],
          "group_by": [{ "operation": "value", "column": "o" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gprb1",
      "grid": { "x": 16, "y": 5, "w": 32, "h": 10 },
      "config": {
        "title": "Events over time",
        "attributes": {
          "type": "xy",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.parallelstore* | STATS count = COUNT() BY bucket = DATE_TRUNC(30 minutes, `@timestamp`)"
          },
          "layers": [{ "seriesType": "bar_stacked", "xAccessor": "bucket", "yAccessor": "count" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gprb2",
      "grid": { "x": 0, "y": 15, "w": 24, "h": 10 },
      "config": {
        "title": "Errors over time",
        "attributes": {
          "type": "xy",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.parallelstore* | WHERE event.outcome == \"failure\" | STATS count = COUNT() BY scenario = COALESCE(`gcp.parallelstore.scenario`, \"unknown\"), bucket = DATE_TRUNC(30 minutes, `@timestamp`)"
          },
          "layers": [
            {
              "seriesType": "bar_stacked",
              "xAccessor": "bucket",
              "yAccessor": "count",
              "splitAccessor": "scenario"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gprb3",
      "grid": { "x": 24, "y": 15, "w": 24, "h": 10 },
      "config": {
        "title": "Events by region",
        "attributes": {
          "type": "xy",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.parallelstore* | STATS count = COUNT() BY region = cloud.region, bucket = DATE_TRUNC(30 minutes, `@timestamp`)"
          },
          "layers": [
            {
              "seriesType": "bar_stacked",
              "xAccessor": "bucket",
              "yAccessor": "count",
              "splitAccessor": "region"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gprt1",
      "grid": { "x": 0, "y": 25, "w": 48, "h": 12 },
      "config": {
        "title": "Top operations",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.parallelstore* | STATS c = COUNT() BY op = COALESCE(event.action, `gcp.parallelstore.scenario`, \"unknown\") | SORT c DESC | LIMIT 15"
          },
          "metrics": [
            { "operation": "value", "column": "op", "label": "Operation" },
            { "operation": "value", "column": "c", "label": "Count" }
          ],
          "rows": []
        }
      }
    },
    {
      "type": "lens",
      "uid": "gprx1",
      "grid": { "x": 0, "y": 37, "w": 24, "h": 10 },
      "config": {
        "title": "By scenario",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.parallelstore* | STATS c = COUNT() BY s = `gcp.parallelstore.scenario`"
          },
          "metrics": [{ "operation": "value", "column": "c" }],
          "group_by": [{ "operation": "value", "column": "s" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gprx2",
      "grid": { "x": 24, "y": 37, "w": 24, "h": 10 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.parallelstore* | WHERE `gcp.parallelstore.throughput_mib_per_sec` IS NOT NULL | STATS m = AVG(`gcp.parallelstore.throughput_mib_per_sec`) | EVAL `Avg MiB/s` = ROUND(m, 1)"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Avg MiB/s" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-mx-k1-parallelstore",
      "grid": { "x": 0, "y": 48, "w": 24, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM metrics-gcp.parallelstore_metrics* | STATS `Metric Read Bytes Count` = ROUND(SUM(`gcp.parallelstore.metrics.parallelstore.googleapis.com/instance/read_bytes_count.sum`), 2)"
          },
          "metrics": [
            { "type": "primary", "operation": "value", "column": "Metric Read Bytes Count" }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-mx-k2-parallelstore",
      "grid": { "x": 24, "y": 48, "w": 24, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM metrics-gcp.parallelstore_metrics* | STATS `Metric Metadata Latency Ms` = ROUND(AVG(`gcp.parallelstore.metrics.parallelstore.googleapis.com/instance/metadata_latency_ms.avg`), 2)"
          },
          "metrics": [
            { "type": "primary", "operation": "value", "column": "Metric Metadata Latency Ms" }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-mx-ts-parallelstore",
      "grid": { "x": 0, "y": 53, "w": 48, "h": 10 },
      "config": {
        "title": "Metadata Latency Ms over time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": { "title": { "visible": false } },
            "left": { "title": { "visible": false } }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM metrics-gcp.parallelstore_metrics* | STATS m = AVG(`gcp.parallelstore.metrics.parallelstore.googleapis.com/instance/metadata_latency_ms.avg`) BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": { "operation": "value", "column": "b" },
              "y": [{ "operation": "value", "column": "m", "label": "Metadata Latency Ms" }]
            }
          ]
        }
      }
    }
  ]
}
