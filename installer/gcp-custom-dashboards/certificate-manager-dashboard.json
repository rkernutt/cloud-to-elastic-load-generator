{
  "title": "GCP Certificate Manager — overview",
  "time_range": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "type": "lens",
      "uid": "gcertmk1",
      "grid": { "x": 0, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.certificate_manager* | STATS `Log events` = COUNT()"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Log events" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcertmd1",
      "grid": { "x": 0, "y": 5, "w": 16, "h": 10 },
      "config": {
        "title": "Event outcome",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.certificate_manager* | STATS c = COUNT() BY o = event.outcome"
          },
          "metrics": [{ "operation": "value", "column": "c" }],
          "group_by": [{ "operation": "value", "column": "o" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcertmb1",
      "grid": { "x": 16, "y": 5, "w": 32, "h": 10 },
      "config": {
        "title": "Events over time",
        "attributes": {
          "type": "xy",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.certificate_manager* | STATS count = COUNT() BY bucket = DATE_TRUNC(30 minutes, `@timestamp`)"
          },
          "layers": [{ "seriesType": "bar_stacked", "xAccessor": "bucket", "yAccessor": "count" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcertmb2",
      "grid": { "x": 0, "y": 15, "w": 24, "h": 10 },
      "config": {
        "title": "Errors over time",
        "attributes": {
          "type": "xy",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.certificate_manager* | WHERE event.outcome == \"failure\" | STATS count = COUNT() BY scenario = COALESCE(`gcp.certificate_manager.scenario`, \"unknown\"), bucket = DATE_TRUNC(30 minutes, `@timestamp`)"
          },
          "layers": [
            {
              "seriesType": "bar_stacked",
              "xAccessor": "bucket",
              "yAccessor": "count",
              "splitAccessor": "scenario"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcertmb3",
      "grid": { "x": 24, "y": 15, "w": 24, "h": 10 },
      "config": {
        "title": "Events by region",
        "attributes": {
          "type": "xy",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.certificate_manager* | STATS count = COUNT() BY region = cloud.region, bucket = DATE_TRUNC(30 minutes, `@timestamp`)"
          },
          "layers": [
            {
              "seriesType": "bar_stacked",
              "xAccessor": "bucket",
              "yAccessor": "count",
              "splitAccessor": "region"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcertmt1",
      "grid": { "x": 0, "y": 25, "w": 48, "h": 12 },
      "config": {
        "title": "Top operations",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.certificate_manager* | STATS c = COUNT() BY op = COALESCE(event.action, `gcp.certificate_manager.scenario`, \"unknown\") | SORT c DESC | LIMIT 15"
          },
          "metrics": [
            { "operation": "value", "column": "op", "label": "Operation" },
            { "operation": "value", "column": "c", "label": "Count" }
          ],
          "rows": []
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcertmx1",
      "grid": { "x": 0, "y": 37, "w": 24, "h": 10 },
      "config": {
        "title": "By scenario",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.certificate_manager* | STATS c = COUNT() BY s = `gcp.certificate_manager.scenario`"
          },
          "metrics": [{ "operation": "value", "column": "c" }],
          "group_by": [{ "operation": "value", "column": "s" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcertmx2",
      "grid": { "x": 24, "y": 37, "w": 24, "h": 10 },
      "config": {
        "title": "Certificate maps",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.certificate_manager* | STATS c = COUNT() BY m = `gcp.certificate_manager.certificate_map_id` | SORT c DESC | LIMIT 10"
          },
          "metrics": [{ "operation": "value", "column": "c" }],
          "group_by": [{ "operation": "value", "column": "m" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-mx-k1-certificate-manager",
      "grid": { "x": 0, "y": 48, "w": 24, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM metrics-gcp.certificate_manager_metrics* | STATS `Metric Certificate Observance Event Count` = ROUND(SUM(`gcp.certificate-manager.metrics.certificatemanager.googleapis.com/project/v2/certificate_observance_event_count.sum`), 2)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Metric Certificate Observance Event Count"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-mx-k2-certificate-manager",
      "grid": { "x": 24, "y": 48, "w": 24, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM metrics-gcp.certificate_manager_metrics* | STATS `Metric Entries` = ROUND(AVG(`gcp.certificate-manager.metrics.certificatemanager.googleapis.com/map/entries.avg`), 2)"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Metric Entries" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-mx-ts-certificate-manager",
      "grid": { "x": 0, "y": 53, "w": 48, "h": 10 },
      "config": {
        "title": "Entries over time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": { "title": { "visible": false } },
            "left": { "title": { "visible": false } }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM metrics-gcp.certificate_manager_metrics* | STATS m = AVG(`gcp.certificate-manager.metrics.certificatemanager.googleapis.com/map/entries.avg`) BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": { "operation": "value", "column": "b" },
              "y": [{ "operation": "value", "column": "m", "label": "Entries" }]
            }
          ]
        }
      }
    }
  ]
}
