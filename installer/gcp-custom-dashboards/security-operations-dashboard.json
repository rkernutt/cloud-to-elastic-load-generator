{
  "title": "GCP Security Operations (SecOps) — overview",
  "time_range": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "type": "lens",
      "uid": "gsecurityoperk1",
      "grid": { "x": 0, "y": 0, "w": 12, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.secops* | STATS `Log events` = COUNT()"
          },
          "metrics": [{ "type": "primary", "operation": "value", "column": "Log events" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gsecurityoperd1",
      "grid": { "x": 0, "y": 5, "w": 16, "h": 10 },
      "config": {
        "title": "Event outcome",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.secops* | STATS c = COUNT() BY o = event.outcome"
          },
          "metrics": [{ "operation": "value", "column": "c" }],
          "group_by": [{ "operation": "value", "column": "o" }]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gsecurityoperl1",
      "grid": { "x": 0, "y": 15, "w": 48, "h": 10 },
      "config": {
        "title": "Event volume",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": { "title": { "visible": false } },
            "left": { "title": { "visible": false } }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-gcp.secops* | STATS c = COUNT() BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": { "operation": "value", "column": "b" },
              "y": [{ "operation": "value", "column": "c", "label": "Events" }]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gsecurityopert1",
      "grid": { "x": 0, "y": 25, "w": 48, "h": 12 },
      "config": {
        "title": "By project",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.secops* | STATS c = COUNT() BY region = `cloud.project.id` | SORT c DESC | LIMIT 15"
          },
          "metrics": [
            { "operation": "value", "column": "region", "label": "Project" },
            { "operation": "value", "column": "c", "label": "Count" }
          ],
          "rows": []
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-mx-k1-security-operations",
      "grid": { "x": 0, "y": 38, "w": 24, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM metrics-gcp.secops_metrics* | STATS `Metric Detection Count` = ROUND(SUM(`gcp.security-operations.metrics.chronicle.googleapis.com/rule/detection_count.sum`), 2)"
          },
          "metrics": [
            { "type": "primary", "operation": "value", "column": "Metric Detection Count" }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-mx-k2-security-operations",
      "grid": { "x": 24, "y": 38, "w": 24, "h": 5 },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM metrics-gcp.secops_metrics* | STATS `Metric Log Ingestion Bytes` = ROUND(AVG(`gcp.security-operations.metrics.chronicle.googleapis.com/log_ingestion_bytes.avg`), 2)"
          },
          "metrics": [
            { "type": "primary", "operation": "value", "column": "Metric Log Ingestion Bytes" }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-mx-ts-security-operations",
      "grid": { "x": 0, "y": 43, "w": 48, "h": 10 },
      "config": {
        "title": "Log Ingestion Bytes over time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": { "title": { "visible": false } },
            "left": { "title": { "visible": false } }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM metrics-gcp.secops_metrics* | STATS m = AVG(`gcp.security-operations.metrics.chronicle.googleapis.com/log_ingestion_bytes.avg`) BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": { "operation": "value", "column": "b" },
              "y": [{ "operation": "value", "column": "m", "label": "Log Ingestion Bytes" }]
            }
          ]
        }
      }
    }
  ]
}
