{
  "title": "GCP Cloud Armor — WAF & Edge Protection",
  "time_range": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "type": "lens",
      "uid": "gcp-armor-k1",
      "grid": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.cloudarmor* | STATS Requests = COUNT()"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Requests"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-armor-k2",
      "grid": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.cloudarmor* | STATS Blocked = SUM(CASE(`gcp.cloud_armor.action` IN (\"DENY\", \"DENY_403\", \"RATE_LIMITED\"), 1, 0))"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Blocked"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-armor-k3",
      "grid": {
        "x": 24,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.cloudarmor* | STATS total = COUNT(), blocked = SUM(CASE(`gcp.cloud_armor.action` IN (\"DENY\", \"DENY_403\", \"RATE_LIMITED\"), 1, 0)) | EVAL `Block %` = ROUND(blocked * 100.0 / total, 1)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Block %"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-armor-k4",
      "grid": {
        "x": 36,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.cloudarmor* | STATS `Source IPs` = COUNT_DISTINCT(`gcp.cloud_armor.source_ip`)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Source IPs"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-armor-d1",
      "grid": {
        "x": 0,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Action",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.cloudarmor* | STATS c = COUNT() BY a = `gcp.cloud_armor.action` | SORT c DESC"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "a"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-armor-d2",
      "grid": {
        "x": 16,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Rule",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.cloudarmor* | STATS c = COUNT() BY r = `gcp.cloud_armor.rule_name` | SORT c DESC | LIMIT 10"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "r"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "gcp-armor-d3",
      "grid": {
        "x": 32,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Region",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.cloudarmor* | STATS c = COUNT() BY reg = cloud.region | SORT c DESC | LIMIT 10"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "reg"
            }
          ]
        }
      }
    },
