    {
      "type": "lens",
      "uid": "gcp-armor-t1",
      "grid": {
        "x": 0,
        "y": 35,
        "w": 48,
        "h": 12
      },
      "config": {
        "title": "Recent WAF events",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-gcp.cloudarmor* | KEEP `@timestamp`, `gcp.cloud_armor.source_ip`, `gcp.cloud_armor.action`, `gcp.cloud_armor.rule_name`, `gcp.cloud_armor.policy_name`, `gcp.cloud_armor.matched_expression`, cloud.region, event.outcome | SORT `@timestamp` DESC | LIMIT 100"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "`@timestamp`",
              "label": "Time"
            },
            {
              "operation": "value",
              "column": "gcp.cloud_armor.source_ip",
              "label": "Source IP"
            },
            {
              "operation": "value",
              "column": "gcp.cloud_armor.action",
              "label": "Action"
            },
            {
              "operation": "value",
              "column": "gcp.cloud_armor.rule_name",
              "label": "Rule"
            },
            {
              "operation": "value",
              "column": "gcp.cloud_armor.policy_name",
              "label": "Policy"
            },
            {
              "operation": "value",
              "column": "gcp.cloud_armor.matched_expression",
              "label": "Expression"
            },
            {
              "operation": "value",
              "column": "cloud.region",
              "label": "Region"
            },
            {
              "operation": "value",
              "column": "event.outcome",
              "label": "Outcome"
            }
          ],
          "rows": []
        }
      }
