          "layers": [
            {
              "type": "bar_horizontal",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-gcp.cloudarmor* | WHERE `gcp.cloud_armor.action` IN (\"DENY\", \"DENY_403\", \"RATE_LIMITED\") | STATS c = COUNT() BY ip = `gcp.cloud_armor.source_ip` | SORT c DESC | LIMIT 15"
