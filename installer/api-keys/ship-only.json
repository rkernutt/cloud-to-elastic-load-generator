{
  "name": "cloudloadgen-ship",
  "metadata": {
    "application": "cloud-to-elastic-load-generator",
    "tags": ["cloudloadgen"],
    "purpose": "Ship synthetic logs, metrics, and traces only — no setup or asset management"
  },
  "role_descriptors": {
    "cloudloadgen_ship": {
      "cluster": ["monitor"],
      "indices": [
        {
          "names": [
            "logs-aws.*",
            "logs-gcp.*",
            "logs-azure.*",
            "logs-cloud_security_posture.findings*",
            "logs-servicenow.event-*",
            "metrics-aws.*",
            "metrics-gcp.*",
            "metrics-azure.*",
            "metrics-o365_metrics.*",
            "traces-apm*",
            "traces-aws.*"
          ],
          "privileges": ["auto_configure", "create_doc", "create_index", "view_index_metadata"]
        }
      ]
    }
  }
}
