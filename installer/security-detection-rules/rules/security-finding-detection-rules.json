{
  "description": "Elastic Security detection rules for security finding chain and general threat detection. Generates alerts for Attack Discovery.",
  "rules": [
    {
      "rule_id": "cloudloadgen-guardduty-high-critical",
      "name": "[CloudLoadGen] GuardDuty HIGH or CRITICAL Finding",
      "description": "Detects GuardDuty findings with HIGH or CRITICAL severity — immediate SOC attention required.",
      "type": "query",
      "language": "kuery",
      "query": "event.dataset:aws.guardduty AND (event.severity >= 7 OR message:*HIGH* OR message:*CRITICAL*)",
      "index": ["logs-aws.guardduty*"],
      "severity": "high",
      "risk_score": 73,
      "threat": [
        {
          "framework": "MITRE ATT&CK",
          "tactic": {
            "id": "TA0040",
            "name": "Impact",
            "reference": "https://attack.mitre.org/tactics/TA0040/"
          },
          "technique": [
            {
              "id": "T1496",
              "name": "Resource Hijacking",
              "reference": "https://attack.mitre.org/techniques/T1496/"
            }
          ]
        }
      ],
      "tags": ["Cloud", "AWS", "GuardDuty", "Threat Detection", "Attack Discovery"],
      "false_positives": ["Known penetration testing activities"],
      "interval": "5m",
      "from": "now-6m",
      "enabled": true,
      "max_signals": 100
    },
    {
      "rule_id": "cloudloadgen-guardduty-crypto-mining",
      "name": "[CloudLoadGen] GuardDuty Cryptocurrency Mining Detection",
      "description": "Detects GuardDuty findings related to cryptocurrency mining — indicates compromised compute resources.",
      "type": "query",
      "language": "kuery",
      "query": "event.dataset:aws.guardduty AND (message:*CryptoCurrency* OR message:*BitcoinTool* OR message:*crypto*)",
      "index": ["logs-aws.guardduty*"],
      "severity": "high",
      "risk_score": 73,
      "threat": [
        {
          "framework": "MITRE ATT&CK",
          "tactic": {
            "id": "TA0040",
            "name": "Impact",
            "reference": "https://attack.mitre.org/tactics/TA0040/"
          },
          "technique": [
            {
              "id": "T1496",
              "name": "Resource Hijacking",
              "reference": "https://attack.mitre.org/techniques/T1496/"
            }
          ]
        }
      ],
      "tags": ["Cloud", "AWS", "GuardDuty", "Crypto Mining", "Attack Discovery"],
      "false_positives": ["Legitimate blockchain infrastructure"],
      "interval": "5m",
      "from": "now-6m",
      "enabled": true,
      "max_signals": 100
    },
    {
      "rule_id": "cloudloadgen-securityhub-compliance-fail",
      "name": "[CloudLoadGen] Security Hub Compliance Check Failed",
      "description": "Detects failed Security Hub compliance checks — posture degradation indicator.",
      "type": "query",
      "language": "kuery",
      "query": "event.dataset:aws.securityhub AND event.outcome:failure",
      "index": ["logs-aws.securityhub*"],
      "severity": "medium",
      "risk_score": 47,
      "threat": [
        {
          "framework": "MITRE ATT&CK",
          "tactic": {
            "id": "TA0005",
            "name": "Defense Evasion",
            "reference": "https://attack.mitre.org/tactics/TA0005/"
          },
          "technique": [
            {
              "id": "T1562.001",
              "name": "Disable or Modify Tools",
              "reference": "https://attack.mitre.org/techniques/T1562/001/"
            }
          ]
        }
      ],
      "tags": ["Cloud", "AWS", "Security Hub", "Compliance", "Attack Discovery"],
      "false_positives": ["Known exceptions during infrastructure changes"],
      "interval": "5m",
      "from": "now-6m",
      "enabled": true,
      "max_signals": 100
    },
    {
      "rule_id": "cloudloadgen-securitylake-ocsf-alert",
      "name": "[CloudLoadGen] Security Lake OCSF Security Finding",
      "description": "Detects high-severity OCSF security findings in AWS Security Lake — normalized cross-source threat signal.",
      "type": "query",
      "language": "kuery",
      "query": "event.dataset:aws.securitylake AND (event.severity >= 7 OR log.level:error OR log.level:warn)",
      "index": ["logs-aws.securitylake*"],
      "severity": "high",
      "risk_score": 73,
      "tags": ["Cloud", "AWS", "Security Lake", "OCSF", "Attack Discovery"],
      "false_positives": ["Known security scanner findings"],
      "interval": "5m",
      "from": "now-6m",
      "enabled": true,
      "max_signals": 100
    },
    {
      "rule_id": "cloudloadgen-cloudtrail-root-activity",
      "name": "[CloudLoadGen] AWS Root Account API Activity",
      "description": "Detects API calls made by the AWS root account — should be near-zero in well-managed accounts.",
      "type": "query",
      "language": "kuery",
      "query": "event.dataset:aws.cloudtrail AND (user.name:root OR message:*Root*)",
      "index": ["logs-aws.cloudtrail*"],
      "severity": "critical",
      "risk_score": 99,
      "threat": [
        {
          "framework": "MITRE ATT&CK",
          "tactic": {
            "id": "TA0004",
            "name": "Privilege Escalation",
            "reference": "https://attack.mitre.org/tactics/TA0004/"
          },
          "technique": [
            {
              "id": "T1078.004",
              "name": "Cloud Accounts",
              "reference": "https://attack.mitre.org/techniques/T1078/004/"
            }
          ]
        }
      ],
      "tags": ["Cloud", "AWS", "Root Account", "Privilege Escalation", "Attack Discovery"],
      "false_positives": ["Initial account setup", "Emergency break-glass procedures"],
      "interval": "5m",
      "from": "now-6m",
      "enabled": true,
      "max_signals": 100
    },
    {
      "rule_id": "cloudloadgen-cloudtrail-logging-disabled",
      "name": "[CloudLoadGen] CloudTrail Logging Stopped or Deleted",
      "description": "Detects attempts to stop or delete CloudTrail trails — critical defense evasion technique.",
      "type": "query",
      "language": "kuery",
      "query": "event.dataset:aws.cloudtrail AND (event.action:StopLogging OR event.action:DeleteTrail)",
      "index": ["logs-aws.cloudtrail*"],
      "severity": "critical",
      "risk_score": 99,
      "threat": [
        {
          "framework": "MITRE ATT&CK",
          "tactic": {
            "id": "TA0005",
            "name": "Defense Evasion",
            "reference": "https://attack.mitre.org/tactics/TA0005/"
          },
          "technique": [
            {
              "id": "T1562.008",
              "name": "Disable Cloud Logs",
              "reference": "https://attack.mitre.org/techniques/T1562/008/"
            }
          ]
        }
      ],
      "tags": ["Cloud", "AWS", "CloudTrail", "Defense Evasion", "Attack Discovery"],
      "false_positives": ["Trail consolidation during migration"],
      "interval": "5m",
      "from": "now-6m",
      "enabled": true,
      "max_signals": 100
    }
  ]
}
