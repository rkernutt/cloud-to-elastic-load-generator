    {
      "id": "azure-aks-pod-restart-anomaly",
      "description": "Detects spikes in AKS pod failure and restart events per namespace (crash loops, OOM, probe failures)",
      "job": {
        "description": "Detects spikes in AKS pod failure and restart events per namespace",
        "groups": ["azure", "compute", "cloudloadgen"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_count partitionfield=kubernetes.namespace",
              "function": "high_count",
              "partition_field_name": "kubernetes.namespace",
              "detector_index": 0
            }
          ],
          "influencers": [
            "kubernetes.namespace",
            "kubernetes.pod.name",
            "azure.kubernetes.cluster_name",
            "cloud.region"
          ]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "32mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": {
          "created_by": "azure-elastic-load-generator",
          "tags": ["cloudloadgen"]
        }
      },
      "datafeed": {
        "indices": ["logs-azure.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              { "term": { "cloud.provider": "azure" } },
              { "term": { "cloud.service.name": "Microsoft.ContainerService/managedClusters" } },
              { "term": { "event.outcome": "failure" } }
            ],
            "should": [
              { "wildcard": { "message": "*Back-off restarting*" } },
              { "wildcard": { "message": "*OOMKilled*" } },
              { "wildcard": { "message": "*CrashLoopBackOff*" } }
            ],
            "minimum_should_match": 1
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "120s",
        "delayed_data_check_config": { "enabled": true }
      }
