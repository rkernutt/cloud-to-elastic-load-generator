          "bool": {
            "filter": [
              { "term": { "event.dataset": "azure.app_service_metrics" } },
              { "exists": { "field": "azure.app_service.metrics.AverageResponseTime.avg" } }
            ]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "120s",
        "delayed_data_check_config": { "enabled": true }
      }
    },
