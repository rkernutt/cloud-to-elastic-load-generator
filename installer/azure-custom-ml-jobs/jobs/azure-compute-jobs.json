{
  "group": "azure-compute",
  "description": "Azure compute & serverless — Functions, App Service, AKS, VMs",
  "jobs": [
    {
      "id": "azure-functions-error-spike",
      "description": "Spikes in Function App failures per function name",
      "job": {
        "description": "Spikes in Function App failures per function name",
        "groups": ["azure", "compute"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_count partitionfield=azure.functions.function_name",
              "function": "high_count",
              "partition_field_name": "azure.functions.function_name",
              "detector_index": 0
            }
          ],
          "influencers": ["azure.functions.function_name", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "32mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "azure-elastic-load-generator" }
      },
      "datafeed": {
        "indices": ["logs-azure.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              { "term": { "cloud.provider": "azure" } },
              { "exists": { "field": "azure.functions.function_name" } },
              { "term": { "event.outcome": "failure" } }
            ]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "60s",
        "delayed_data_check_config": { "enabled": true }
      }
    },
    {
      "id": "azure-app-service-latency-anomaly",
      "description": "Unusual App Service request duration per app",
      "job": {
        "description": "Unusual App Service request duration per app",
        "groups": ["azure", "compute"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_mean(event.duration) partitionfield=azure.app_service.app_name",
              "function": "high_mean",
              "field_name": "event.duration",
              "partition_field_name": "azure.app_service.app_name",
              "detector_index": 0
            }
          ],
          "influencers": ["azure.app_service.app_name", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "32mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "azure-elastic-load-generator" }
      },
      "datafeed": {
        "indices": ["logs-azure.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              { "term": { "cloud.provider": "azure" } },
              { "exists": { "field": "azure.app_service.app_name" } }
            ]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "60s",
        "delayed_data_check_config": { "enabled": true }
      }
    },
    {
      "id": "azure-aks-event-spike",
      "description": "Spikes in AKS control plane / node events per cluster",
      "job": {
        "description": "Spikes in AKS events per cluster",
        "groups": ["azure", "compute"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_count partitionfield=azure.kubernetes.cluster_name",
              "function": "high_count",
              "partition_field_name": "azure.kubernetes.cluster_name",
              "detector_index": 0
            }
          ],
          "influencers": ["azure.kubernetes.cluster_name", "azure.kubernetes.namespace", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "32mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "azure-elastic-load-generator" }
      },
      "datafeed": {
        "indices": ["logs-azure.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              { "term": { "cloud.provider": "azure" } },
              {
                "term": {
                  "cloud.service.name": "Microsoft.ContainerService/managedClusters"
                }
              }
            ]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "60s",
        "delayed_data_check_config": { "enabled": true }
      }
    },
    {
      "id": "azure-vm-failure-spike",
      "description": "Spikes in Virtual Machine failure outcomes per VM",
      "job": {
        "description": "Spikes in Virtual Machine failure outcomes per VM",
        "groups": ["azure", "compute"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_count partitionfield=azure.virtual_machines.vm_name",
              "function": "high_count",
              "partition_field_name": "azure.virtual_machines.vm_name",
              "detector_index": 0
            }
          ],
          "influencers": ["azure.virtual_machines.vm_name", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "32mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "azure-elastic-load-generator" }
      },
      "datafeed": {
        "indices": ["logs-azure.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              { "term": { "cloud.provider": "azure" } },
              { "term": { "event.outcome": "failure" } },
              {
                "term": {
                  "cloud.service.name": "Microsoft.Compute/virtualMachines"
                }
              }
            ]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "60s",
        "delayed_data_check_config": { "enabled": true }
      }
    }
  ]
}
