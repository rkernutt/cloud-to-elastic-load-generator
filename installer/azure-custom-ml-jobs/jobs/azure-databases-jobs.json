{
  "group": "azure-databases",
  "description": "Azure databases — SQL Database, Cosmos DB",
  "jobs": [
    {
      "id": "azure-sql-dtu-anomaly",
      "description": "Unusual SQL Database DTU utilization per database",
      "job": {
        "description": "Unusual SQL Database DTU utilization per database",
        "groups": ["azure", "databases"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_mean(azure.sql_database.dtu_percent) partitionfield=azure.sql_database.database",
              "function": "high_mean",
              "field_name": "azure.sql_database.dtu_percent",
              "partition_field_name": "azure.sql_database.database",
              "detector_index": 0
            }
          ],
          "influencers": ["azure.sql_database.server", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "32mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "azure-elastic-load-generator" }
      },
      "datafeed": {
        "indices": ["logs-azure.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              { "term": { "cloud.provider": "azure" } },
              { "term": { "cloud.service.name": "Microsoft.Sql/servers" } }
            ]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "60s",
        "delayed_data_check_config": { "enabled": true }
      }
    },
    {
      "id": "azure-sql-connection-spike",
      "description": "Unusual failed SQL connection counts per server",
      "job": {
        "description": "Unusual failed SQL connection counts per server",
        "groups": ["azure", "databases"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_mean(azure.sql_database.failed_connections) partitionfield=azure.sql_database.server",
              "function": "high_mean",
              "field_name": "azure.sql_database.failed_connections",
              "partition_field_name": "azure.sql_database.server",
              "detector_index": 0
            }
          ],
          "influencers": ["azure.sql_database.server", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "32mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "azure-elastic-load-generator" }
      },
      "datafeed": {
        "indices": ["logs-azure.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              { "term": { "cloud.provider": "azure" } },
              { "term": { "cloud.service.name": "Microsoft.Sql/servers" } }
            ]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "60s",
        "delayed_data_check_config": { "enabled": true }
      }
    },
    {
      "id": "azure-cosmos-failure-spike",
      "description": "Spikes in Cosmos DB failures per account",
      "job": {
        "description": "Spikes in Cosmos DB failures per account",
        "groups": ["azure", "databases"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_count partitionfield=azure.cosmos_db.account",
              "function": "high_count",
              "partition_field_name": "azure.cosmos_db.account",
              "detector_index": 0
            }
          ],
          "influencers": ["azure.cosmos_db.account", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "32mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "azure-elastic-load-generator" }
      },
      "datafeed": {
        "indices": ["logs-azure.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              { "term": { "cloud.provider": "azure" } },
              {
                "term": {
                  "cloud.service.name": "Microsoft.DocumentDB/databaseAccounts"
                }
              },
              { "term": { "event.outcome": "failure" } }
            ]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "60s",
        "delayed_data_check_config": { "enabled": true }
      }
    }
  ]
}
