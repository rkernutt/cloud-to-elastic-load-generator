{
  "group": "azure-databases",
  "description": "Azure databases \u2014 SQL Database, Cosmos DB",
  "jobs": [
    {
      "id": "azure-sql-dtu-anomaly",
      "description": "Unusual SQL Database DTU utilization per database",
      "job": {
        "description": "Unusual SQL Database DTU utilization per database",
        "groups": ["azure", "databases", "cloudloadgen"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_mean(azure.sql_database.metrics.dtu_consumption_percent.avg)",
              "function": "high_mean",
              "field_name": "azure.sql_database.metrics.dtu_consumption_percent.avg",
              "detector_index": 0
            }
          ],
          "influencers": ["azure.sql_database.server", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": {
          "model_memory_limit": "32mb"
        },
        "data_description": {
          "time_field": "@timestamp"
        },
        "custom_settings": {
          "created_by": "azure-elastic-load-generator",
          "tags": ["cloudloadgen"]
        }
      },
      "datafeed": {
        "indices": ["metrics-azure.sql_database_metrics*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              {
                "term": {
                  "event.dataset": "azure.sql_database_metrics"
                }
              },
              {
                "exists": {
                  "field": "azure.sql_database.metrics.dtu_consumption_percent.avg"
                }
              }
            ]
          }
        },
        "chunking_config": {
          "mode": "auto"
        },
        "query_delay": "120s",
        "delayed_data_check_config": {
          "enabled": true
        }
      }
    },
    {
      "id": "azure-sql-connection-spike",
      "description": "Unusual failed SQL connection counts per server",
      "job": {
        "description": "Unusual failed SQL connection counts per server",
        "groups": ["azure", "databases", "cloudloadgen"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_sum(azure.sql_database.metrics.connection_failed.sum)",
              "function": "high_sum",
              "field_name": "azure.sql_database.metrics.connection_failed.sum",
              "detector_index": 0
            }
          ],
          "influencers": ["azure.sql_database.server", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": {
          "model_memory_limit": "32mb"
        },
        "data_description": {
          "time_field": "@timestamp"
        },
        "custom_settings": {
          "created_by": "azure-elastic-load-generator",
          "tags": ["cloudloadgen"]
        }
      },
      "datafeed": {
        "indices": ["metrics-azure.sql_database_metrics*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              {
                "term": {
                  "event.dataset": "azure.sql_database_metrics"
                }
              },
              {
                "exists": {
                  "field": "azure.sql_database.metrics.connection_failed.sum"
                }
              }
            ]
          }
        },
        "chunking_config": {
          "mode": "auto"
        },
        "query_delay": "120s",
        "delayed_data_check_config": {
          "enabled": true
        }
      }
    },
    {
      "id": "azure-cosmos-failure-spike",
      "description": "Spikes in Cosmos DB failures per account",
      "job": {
        "description": "Spikes in Cosmos DB failures per account",
        "groups": ["azure", "databases", "cloudloadgen"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_count partitionfield=azure.cosmos_db.account",
              "function": "high_count",
              "partition_field_name": "azure.cosmos_db.account",
              "detector_index": 0
            }
          ],
          "influencers": ["azure.cosmos_db.account", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": {
          "model_memory_limit": "32mb"
        },
        "data_description": {
          "time_field": "@timestamp"
        },
        "custom_settings": {
          "created_by": "azure-elastic-load-generator",
          "tags": ["cloudloadgen"]
        }
      },
      "datafeed": {
        "indices": ["logs-azure.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              {
                "term": {
                  "cloud.provider": "azure"
                }
              },
              {
                "term": {
                  "cloud.service.name": "Microsoft.DocumentDB/databaseAccounts"
                }
              },
              {
                "term": {
                  "event.outcome": "failure"
                }
              }
            ]
          }
        },
        "chunking_config": {
          "mode": "auto"
        },
        "query_delay": "120s",
        "delayed_data_check_config": {
          "enabled": true
        }
      }
    },
    {
      "id": "azure-cosmos-db-ru-consumption-anomaly",
      "description": "Detects unusual Cosmos DB request unit consumption per account (hot partitions, 429 throttling, query fan-out)",
      "job": {
        "description": "Detects unusual Cosmos DB request unit consumption per account",
        "groups": ["azure", "databases", "cloudloadgen"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_sum(azure.cosmos_db.metrics.TotalRequestUnits.sum)",
              "function": "high_sum",
              "field_name": "azure.cosmos_db.metrics.TotalRequestUnits.sum",
              "detector_index": 0
            }
          ],
          "influencers": ["azure.cosmos_db.account", "azure.cosmos_db.database", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": {
          "model_memory_limit": "32mb"
        },
        "data_description": {
          "time_field": "@timestamp"
        },
        "custom_settings": {
          "created_by": "azure-elastic-load-generator",
          "tags": ["cloudloadgen"]
        }
      },
      "datafeed": {
        "indices": ["metrics-azure.cosmos_db_metrics*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              {
                "term": {
                  "event.dataset": "azure.cosmos_db_metrics"
                }
              },
              {
                "exists": {
                  "field": "azure.cosmos_db.metrics.TotalRequestUnits.sum"
                }
              }
            ]
          }
        },
        "chunking_config": {
          "mode": "auto"
        },
        "query_delay": "120s",
        "delayed_data_check_config": {
          "enabled": true
        }
      }
    },
    {
      "id": "azure-postgresql-connection-spike",
      "description": "Detects spikes in failed PostgreSQL connection attempts per server (auth failures, max connections, network blocks)",
      "job": {
        "description": "Detects spikes in failed PostgreSQL connection attempts per server",
        "groups": ["azure", "databases", "cloudloadgen"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_count partitionfield=azure.database_for_postgresql.server",
              "function": "high_count",
              "partition_field_name": "azure.database_for_postgresql.server",
              "detector_index": 0
            }
          ],
          "influencers": ["azure.database_for_postgresql.server", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": {
          "model_memory_limit": "32mb"
        },
        "data_description": {
          "time_field": "@timestamp"
        },
        "custom_settings": {
          "created_by": "azure-elastic-load-generator",
          "tags": ["cloudloadgen"]
        }
      },
      "datafeed": {
        "indices": ["logs-azure.postgresql*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              {
                "term": {
                  "cloud.provider": "azure"
                }
              },
              {
                "term": {
                  "event.outcome": "failure"
                }
              }
            ],
            "should": [
              {
                "wildcard": {
                  "message": "*connection_failed*"
                }
              },
              {
                "wildcard": {
                  "message": "*authentication failed*"
                }
              }
            ],
            "minimum_should_match": 1
          }
        },
        "chunking_config": {
          "mode": "auto"
        },
        "query_delay": "120s",
        "delayed_data_check_config": {
          "enabled": true
        }
      }
    }
  ]
}
