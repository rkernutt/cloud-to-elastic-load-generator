        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "azure-elastic-load-generator" }
      },
      "datafeed": {
        "indices": ["logs-azure.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              { "term": { "cloud.provider": "azure" } },
