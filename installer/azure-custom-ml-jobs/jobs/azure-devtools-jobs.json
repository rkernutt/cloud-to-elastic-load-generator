        "description": "Unusual pipeline run duration",
        "groups": ["azure", "devtools"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_mean(azure.devops_pipeline.duration_ms) partitionfield=azure.devops_pipeline.resource_name",
              "function": "high_mean",
              "field_name": "azure.devops_pipeline.duration_ms",
              "partition_field_name": "azure.devops_pipeline.resource_name",
              "detector_index": 0
