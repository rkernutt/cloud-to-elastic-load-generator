{
  "group": "extended-services",
  "description": "Azure extended services — failure spikes and latency anomalies for AI Foundry, data platforms, observability, networking, and security workloads",
  "jobs": [
    {
      "id": "azure-ai-foundry-failure-spike",
      "description": "Spikes in azure.ai_foundry failures by region",
      "job": {
        "description": "Unusual failure count for azure.ai_foundry partitioned by Azure Region",
        "groups": ["azure", "extended-services", "cloudloadgen"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_count partitionfield=cloud.region",
              "function": "high_count",
              "partition_field_name": "cloud.region",
              "detector_index": 0
            }
          ],
          "influencers": ["cloud.region", "cloud.account.id"]
        },
        "allow_lazy_open": true,
        "analysis_limits": {
          "model_memory_limit": "32mb"
        },
        "data_description": {
          "time_field": "@timestamp"
        },
        "custom_settings": {
          "created_by": "azure-elastic-load-generator",
          "tags": ["cloudloadgen"]
        }
      },
      "datafeed": {
        "indices": ["logs-azure.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              {
                "term": {
                  "event.dataset": "azure.ai_foundry"
                }
              },
              {
                "term": {
                  "event.outcome": "failure"
                }
              }
            ]
          }
        },
        "chunking_config": {
          "mode": "auto"
        },
        "query_delay": "60s",
        "delayed_data_check_config": {
          "enabled": true
        }
      }
    },
