            "filter": [
              { "term": { "cloud.provider": "azure" } },
              { "term": { "event.dataset": "azure.entra_id" } },
              {
                "bool": {
                  "should": [
                    { "term": { "azure.entra_id.category": "SignInLogs" } },
                    { "term": { "azure.entra_id.category": "SignIn" } }
                  ],
                  "minimum_should_match": 1
                }
              },
              { "exists": { "field": "azure.entra_id.properties.location.countryOrRegion" } }
