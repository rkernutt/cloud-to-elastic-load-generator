{
  "group": "azure-networking",
  "description": "Azure networking — Firewall, Application Gateway",
  "jobs": [
    {
      "id": "azure-firewall-deny-spike",
      "description": "Spikes in Firewall deny events per rule collection",
      "job": {
        "description": "Spikes in Azure Firewall deny events per rule collection",
        "groups": ["azure", "networking"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_count partitionfield=azure.firewall.rule_collection",
              "function": "high_count",
              "partition_field_name": "azure.firewall.rule_collection",
              "detector_index": 0
            }
          ],
          "influencers": ["azure.firewall.rule_collection", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "32mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "azure-elastic-load-generator" }
      },
      "datafeed": {
        "indices": ["logs-azure.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              { "term": { "cloud.provider": "azure" } },
              {
                "term": {
                  "cloud.service.name": "Microsoft.Network/azureFirewalls"
                }
              },
              { "term": { "azure.firewall.action": "Deny" } }
            ]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "60s",
        "delayed_data_check_config": { "enabled": true }
      }
    },
    {
      "id": "azure-application-gateway-latency",
      "description": "Unusual Application Gateway backend latency per gateway",
      "job": {
        "description": "Unusual Application Gateway latency per gateway",
        "groups": ["azure", "networking"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_mean(azure.application_gateway.latency_ms) partitionfield=azure.application_gateway.name",
              "function": "high_mean",
              "field_name": "azure.application_gateway.latency_ms",
              "partition_field_name": "azure.application_gateway.name",
              "detector_index": 0
            }
          ],
          "influencers": ["azure.application_gateway.name", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": { "model_memory_limit": "32mb" },
        "data_description": { "time_field": "@timestamp" },
        "custom_settings": { "created_by": "azure-elastic-load-generator" }
      },
      "datafeed": {
        "indices": ["logs-azure.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              { "term": { "cloud.provider": "azure" } },
              {
                "term": {
                  "cloud.service.name": "Microsoft.Network/applicationGateways"
                }
              }
            ]
          }
        },
        "chunking_config": { "mode": "auto" },
        "query_delay": "60s",
        "delayed_data_check_config": { "enabled": true }
      }
    }
  ]
}
