{
  "group": "azure-networking",
  "description": "Azure networking \u2014 Firewall, Application Gateway",
  "jobs": [
    {
      "id": "azure-firewall-deny-spike",
      "description": "Spikes in Firewall deny events per rule collection",
      "job": {
        "description": "Spikes in Azure Firewall deny events per rule collection",
        "groups": ["azure", "networking", "cloudloadgen"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_count partitionfield=azure.firewall.rule_collection",
              "function": "high_count",
              "partition_field_name": "azure.firewall.rule_collection",
              "detector_index": 0
            }
          ],
          "influencers": ["azure.firewall.rule_collection", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": {
          "model_memory_limit": "32mb"
        },
        "data_description": {
          "time_field": "@timestamp"
        },
        "custom_settings": {
          "created_by": "azure-elastic-load-generator",
          "tags": ["cloudloadgen"]
        }
      },
      "datafeed": {
        "indices": ["logs-azure.*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              {
                "term": {
                  "cloud.provider": "azure"
                }
              },
              {
                "term": {
                  "cloud.service.name": "Microsoft.Network/azureFirewalls"
                }
              },
              {
                "term": {
                  "azure.firewall.action": "Deny"
                }
              }
            ]
          }
        },
        "chunking_config": {
          "mode": "auto"
        },
        "query_delay": "120s",
        "delayed_data_check_config": {
          "enabled": true
        }
      }
    },
    {
      "id": "azure-application-gateway-latency",
      "description": "Unusual Application Gateway backend latency per gateway",
      "job": {
        "description": "Unusual Application Gateway latency per gateway",
        "groups": ["azure", "networking", "cloudloadgen"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_mean(azure.application_gateway.metrics.TotalLatency.avg)",
              "function": "high_mean",
              "field_name": "azure.application_gateway.metrics.TotalLatency.avg",
              "detector_index": 0
            }
          ],
          "influencers": ["azure.application_gateway.name", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": {
          "model_memory_limit": "32mb"
        },
        "data_description": {
          "time_field": "@timestamp"
        },
        "custom_settings": {
          "created_by": "azure-elastic-load-generator",
          "tags": ["cloudloadgen"]
        }
      },
      "datafeed": {
        "indices": ["metrics-azure.application_gateway_metrics*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              {
                "term": {
                  "event.dataset": "azure.application_gateway_metrics"
                }
              },
              {
                "exists": {
                  "field": "azure.application_gateway.metrics.TotalLatency.avg"
                }
              }
            ]
          }
        },
        "chunking_config": {
          "mode": "auto"
        },
        "query_delay": "120s",
        "delayed_data_check_config": {
          "enabled": true
        }
      }
    },
    {
      "id": "azure-application-gateway-5xx-rate-spike",
      "description": "Detects spikes in Application Gateway HTTP 5xx responses per gateway (backend pool unhealthy, TLS issues)",
      "job": {
        "description": "Detects spikes in Application Gateway HTTP 5xx responses per gateway",
        "groups": ["azure", "networking", "cloudloadgen"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_count partitionfield=azure.application_gateway.name",
              "function": "high_count",
              "partition_field_name": "azure.application_gateway.name",
              "detector_index": 0
            }
          ],
          "influencers": [
            "azure.application_gateway.name",
            "azure.application_gateway.backend_host",
            "cloud.region"
          ]
        },
        "allow_lazy_open": true,
        "analysis_limits": {
          "model_memory_limit": "32mb"
        },
        "data_description": {
          "time_field": "@timestamp"
        },
        "custom_settings": {
          "created_by": "azure-elastic-load-generator",
          "tags": ["cloudloadgen"]
        }
      },
      "datafeed": {
        "indices": ["logs-azure.application_gateway*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              {
                "term": {
                  "cloud.provider": "azure"
                }
              },
              {
                "range": {
                  "azure.application_gateway.http_status": {
                    "gte": 500
                  }
                }
              }
            ]
          }
        },
        "chunking_config": {
          "mode": "auto"
        },
        "query_delay": "120s",
        "delayed_data_check_config": {
          "enabled": true
        }
      }
    },
    {
      "id": "azure-load-balancer-health-probe-failure-spike",
      "description": "Detects spikes in Azure Load Balancer backend health probe failures per load balancer",
      "job": {
        "description": "Detects spikes in Load Balancer backend health probe failures per load balancer",
        "groups": ["azure", "networking", "cloudloadgen"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_count partitionfield=azure.load_balancer.name",
              "function": "high_count",
              "partition_field_name": "azure.load_balancer.name",
              "detector_index": 0
            }
          ],
          "influencers": ["azure.load_balancer.name", "cloud.region"]
        },
        "allow_lazy_open": true,
        "analysis_limits": {
          "model_memory_limit": "32mb"
        },
        "data_description": {
          "time_field": "@timestamp"
        },
        "custom_settings": {
          "created_by": "azure-elastic-load-generator",
          "tags": ["cloudloadgen"]
        }
      },
      "datafeed": {
        "indices": ["logs-azure.load_balancer*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              {
                "term": {
                  "cloud.provider": "azure"
                }
              }
            ],
            "should": [
              {
                "term": {
                  "operationName": "UnhealthyBackendPool"
                }
              },
              {
                "wildcard": {
                  "message": "*health probe failed*"
                }
              },
              {
                "term": {
                  "properties.healthState": "Unhealthy"
                }
              }
            ],
            "minimum_should_match": 1
          }
        },
        "chunking_config": {
          "mode": "auto"
        },
        "query_delay": "120s",
        "delayed_data_check_config": {
          "enabled": true
        }
      }
    },
    {
      "id": "azure-front-door-latency-anomaly",
      "description": "Detects unusual Azure Front Door edge response latency per profile (origin slowness, POP congestion, TLS overhead)",
      "job": {
        "description": "Detects unusual Azure Front Door edge response latency per profile",
        "groups": ["azure", "networking", "cloudloadgen"],
        "analysis_config": {
          "bucket_span": "15m",
          "detectors": [
            {
              "detector_description": "high_mean(azure.front_door.metrics.TotalLatency.avg)",
              "function": "high_mean",
              "field_name": "azure.front_door.metrics.TotalLatency.avg",
              "detector_index": 0
            }
          ],
          "influencers": [
            "azure.front_door.profile_name",
            "azure.front_door.endpoint",
            "cloud.region"
          ]
        },
        "allow_lazy_open": true,
        "analysis_limits": {
          "model_memory_limit": "32mb"
        },
        "data_description": {
          "time_field": "@timestamp"
        },
        "custom_settings": {
          "created_by": "azure-elastic-load-generator",
          "tags": ["cloudloadgen"]
        }
      },
      "datafeed": {
        "indices": ["metrics-azure.front_door_metrics*"],
        "max_empty_searches": 10,
        "query": {
          "bool": {
            "filter": [
              {
                "term": {
                  "event.dataset": "azure.front_door_metrics"
                }
              },
              {
                "exists": {
                  "field": "azure.front_door.metrics.TotalLatency.avg"
                }
              }
            ]
          }
        },
        "chunking_config": {
          "mode": "auto"
        },
        "query_delay": "120s",
        "delayed_data_check_config": {
          "enabled": true
        }
      }
    }
  ]
}
