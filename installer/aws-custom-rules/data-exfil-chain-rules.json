{
  "group": "data-exfil-chain",
  "description": "Alerting rules for the Data Exfiltration Chain scenario (GuardDuty, VPC Flow, CloudTrail S3)",
  "rules": [
    {
      "id": "cloudloadgen-aws-exfil-guardduty-alert",
      "name": "[CloudLoadGen] Data Exfil Chain — GuardDuty Exfiltration Finding",
      "rule_type_id": ".es-query",
      "consumer": "alerts",
      "schedule": {
        "interval": "5m"
      },
      "tags": ["cloudloadgen", "data-exfil-chain"],
      "enabled": false,
      "params": {
        "searchType": "esQuery",
        "timeWindowSize": 15,
        "timeWindowUnit": "m",
        "threshold": [1],
        "thresholdComparator": ">=",
        "size": 100,
        "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"term\":{\"event.dataset\":\"aws.guardduty\"}},{\"wildcard\":{\"aws.guardduty.type\":\"Exfiltration*\"}}]}}}",
        "index": ["logs-aws.guardduty*"],
        "timeField": "@timestamp",
        "aggType": "count"
      },
      "actions": [],
      "notify_when": "onActiveAlert"
    },
    {
      "id": "cloudloadgen-aws-exfil-high-egress",
      "name": "[CloudLoadGen] Data Exfil Chain — VPC Flow High Egress Bytes",
      "rule_type_id": ".es-query",
      "consumer": "alerts",
      "schedule": {
        "interval": "5m"
      },
      "tags": ["cloudloadgen", "data-exfil-chain"],
      "enabled": false,
      "params": {
        "searchType": "esQuery",
        "timeWindowSize": 15,
        "timeWindowUnit": "m",
        "threshold": [1],
        "thresholdComparator": ">=",
        "size": 100,
        "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"term\":{\"event.dataset\":\"aws.vpcflow\"}},{\"term\":{\"network.direction\":\"egress\"}},{\"range\":{\"aws.vpcflow.bytes\":{\"gt\":52428800}}}]}}}",
        "index": ["logs-aws.vpcflow*"],
        "timeField": "@timestamp",
        "aggType": "count"
      },
      "actions": [],
      "notify_when": "onActiveAlert"
    },
    {
      "id": "cloudloadgen-aws-exfil-s3-mass-access",
      "name": "[CloudLoadGen] Data Exfil Chain — S3 GetObject With High Additional Event Count",
      "rule_type_id": ".es-query",
      "consumer": "alerts",
      "schedule": {
        "interval": "5m"
      },
      "tags": ["cloudloadgen", "data-exfil-chain"],
      "enabled": false,
      "params": {
        "searchType": "esQuery",
        "timeWindowSize": 15,
        "timeWindowUnit": "m",
        "threshold": [1],
        "thresholdComparator": ">=",
        "size": 100,
        "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"term\":{\"event.dataset\":\"aws.cloudtrail\"}},{\"term\":{\"event.action\":\"GetObject\"}},{\"range\":{\"aws.cloudtrail.additional_event_count\":{\"gt\":100}}}]}}}",
        "index": ["logs-aws.cloudtrail*"],
        "timeField": "@timestamp",
        "aggType": "count"
      },
      "actions": [],
      "notify_when": "onActiveAlert"
    },
    {
      "id": "cloudloadgen-aws-exfil-full-chain",
      "name": "[CloudLoadGen] Data Exfil Chain — Full Chain Correlation",
      "rule_type_id": ".es-query",
      "consumer": "alerts",
      "schedule": {
        "interval": "5m"
      },
      "tags": ["cloudloadgen", "data-exfil-chain"],
      "enabled": false,
      "params": {
        "searchType": "esQuery",
        "timeWindowSize": 15,
        "timeWindowUnit": "m",
        "threshold": [2],
        "thresholdComparator": ">",
        "size": 100,
        "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"bool\":{\"should\":[{\"bool\":{\"filter\":[{\"term\":{\"event.dataset\":\"aws.guardduty\"}},{\"wildcard\":{\"aws.guardduty.type\":\"Exfiltration*\"}}]}},{\"bool\":{\"filter\":[{\"term\":{\"event.dataset\":\"aws.cloudtrail\"}},{\"term\":{\"event.action\":\"GetObject\"}},{\"range\":{\"aws.cloudtrail.additional_event_count\":{\"gt\":100}}}]}},{\"bool\":{\"filter\":[{\"term\":{\"event.dataset\":\"aws.vpcflow\"}},{\"term\":{\"network.direction\":\"egress\"}},{\"range\":{\"aws.vpcflow.bytes\":{\"gt\":52428800}}}]}}],\"minimum_should_match\":1}}]}}}",
        "index": ["logs-aws.guardduty*", "logs-aws.vpcflow*", "logs-aws.cloudtrail*"],
        "timeField": "@timestamp",
        "aggType": "count"
      },
      "actions": [],
      "notify_when": "onActiveAlert"
    }
  ]
}
