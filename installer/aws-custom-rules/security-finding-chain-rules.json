{
  "group": "security-chain",
  "description": "Alerting rules for the Security Finding Chain scenario (GuardDuty, Security Hub, Security Lake)",
  "rules": [
    {
      "id": "cloudloadgen-aws-security-high-severity-finding",
      "name": "[CloudLoadGen] Security Finding Chain — GuardDuty HIGH/CRITICAL Findings",
      "rule_type_id": ".es-query",
      "consumer": "alerts",
      "schedule": {
        "interval": "5m"
      },
      "tags": ["cloudloadgen", "security-chain"],
      "enabled": false,
      "params": {
        "searchType": "esQuery",
        "timeWindowSize": 15,
        "timeWindowUnit": "m",
        "threshold": [0],
        "thresholdComparator": ">",
        "size": 100,
        "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"term\":{\"event.dataset\":\"aws.guardduty\"}},{\"bool\":{\"should\":[{\"term\":{\"aws.guardduty.severity.value\":\"High\"}},{\"term\":{\"aws.guardduty.severity.value\":\"Critical\"}}],\"minimum_should_match\":1}}]}}}",
        "index": ["logs-aws.guardduty*"],
        "timeField": "@timestamp",
        "aggType": "count"
      },
      "actions": [],
      "notify_when": "onActiveAlert"
    },
    {
      "id": "cloudloadgen-aws-security-finding-chain-burst",
      "name": "[CloudLoadGen] Security Finding Chain — Multi-Stage Chain Burst",
      "rule_type_id": ".es-query",
      "consumer": "alerts",
      "schedule": {
        "interval": "5m"
      },
      "tags": ["cloudloadgen", "security-chain"],
      "enabled": false,
      "params": {
        "searchType": "esQuery",
        "timeWindowSize": 15,
        "timeWindowUnit": "m",
        "threshold": [2],
        "thresholdComparator": ">",
        "size": 100,
        "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"term\":{\"event.kind\":\"alert\"}},{\"bool\":{\"should\":[{\"term\":{\"event.dataset\":\"aws.guardduty\"}},{\"term\":{\"event.dataset\":\"aws.securityhub_findings\"}},{\"term\":{\"event.dataset\":\"aws.securitylake\"}}],\"minimum_should_match\":1}}]}}}",
        "index": [
          "logs-aws.guardduty*",
          "logs-aws.securityhub_findings*",
          "logs-aws.securitylake*"
        ],
        "timeField": "@timestamp",
        "aggType": "count"
      },
      "actions": [],
      "notify_when": "onActiveAlert"
    },
    {
      "id": "cloudloadgen-aws-securityhub-compliance-failed",
      "name": "[CloudLoadGen] Security Finding Chain — Security Hub Compliance FAILED",
      "rule_type_id": ".es-query",
      "consumer": "alerts",
      "schedule": {
        "interval": "5m"
      },
      "tags": ["cloudloadgen", "security-chain"],
      "enabled": false,
      "params": {
        "searchType": "esQuery",
        "timeWindowSize": 30,
        "timeWindowUnit": "m",
        "threshold": [3],
        "thresholdComparator": ">",
        "size": 100,
        "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"term\":{\"event.dataset\":\"aws.securityhub_findings\"}},{\"term\":{\"aws.securityhub_findings.Compliance.Status\":\"FAILED\"}}]}}}",
        "index": ["logs-aws.securityhub_findings*"],
        "timeField": "@timestamp",
        "aggType": "count"
      },
      "actions": [],
      "notify_when": "onActiveAlert"
    },
    {
      "id": "cloudloadgen-aws-security-unique-source-ips",
      "name": "[CloudLoadGen] Security Finding Chain — Multiple GuardDuty Alerts With Source IP",
      "rule_type_id": ".es-query",
      "consumer": "alerts",
      "schedule": {
        "interval": "5m"
      },
      "tags": ["cloudloadgen", "security-chain"],
      "enabled": false,
      "params": {
        "searchType": "esQuery",
        "timeWindowSize": 30,
        "timeWindowUnit": "m",
        "threshold": [5],
        "thresholdComparator": ">",
        "size": 100,
        "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"term\":{\"event.dataset\":\"aws.guardduty\"}},{\"term\":{\"event.kind\":\"alert\"}},{\"exists\":{\"field\":\"source.ip\"}}]}}}",
        "index": ["logs-aws.guardduty*"],
        "timeField": "@timestamp",
        "aggType": "count"
      },
      "actions": [],
      "notify_when": "onActiveAlert"
    }
  ]
}
