{
  "group": "azure-security-chain",
  "description": "Alerting rules for the Azure Security Finding Chain scenario (Defender, Sentinel, Activity Log)",
  "rules": [
    {
      "id": "cloudloadgen-azure-security-defender-alert",
      "name": "[CloudLoadGen] Azure Security Finding Chain — Defender Alert",
      "rule_type_id": ".es-query",
      "consumer": "stackAlerts",
      "schedule": {
        "interval": "5m"
      },
      "tags": ["cloudloadgen", "azure-security-chain"],
      "enabled": false,
      "params": {
        "searchType": "esQuery",
        "timeWindowSize": 15,
        "timeWindowUnit": "m",
        "threshold": [1],
        "thresholdComparator": ">=",
        "size": 100,
        "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"term\":{\"event.dataset\":\"azure.defender\"}},{\"term\":{\"event.kind\":\"alert\"}}]}}}",
        "index": ["logs-azure.defender*"],
        "timeField": "@timestamp",
        "aggType": "count"
      },
      "actions": [],
      "notify_when": "onActiveAlert"
    },
    {
      "id": "cloudloadgen-azure-security-chain-burst",
      "name": "[CloudLoadGen] Azure Security Finding Chain — Multi-Stage Chain Burst",
      "rule_type_id": ".es-query",
      "consumer": "stackAlerts",
      "schedule": {
        "interval": "5m"
      },
      "tags": ["cloudloadgen", "azure-security-chain"],
      "enabled": false,
      "params": {
        "searchType": "esQuery",
        "timeWindowSize": 15,
        "timeWindowUnit": "m",
        "threshold": [2],
        "thresholdComparator": ">",
        "size": 100,
        "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"term\":{\"event.kind\":\"alert\"}},{\"bool\":{\"should\":[{\"term\":{\"event.dataset\":\"azure.defender\"}},{\"term\":{\"event.dataset\":\"azure.sentinel\"}},{\"term\":{\"event.dataset\":\"azure.activity_log\"}}],\"minimum_should_match\":1}}]}}}",
        "index": ["logs-azure.defender*", "logs-azure.sentinel*", "logs-azure.activity_log*"],
        "timeField": "@timestamp",
        "aggType": "count"
      },
      "actions": [],
      "notify_when": "onActiveAlert"
    },
    {
      "id": "cloudloadgen-azure-security-sentinel-incident",
      "name": "[CloudLoadGen] Azure Security Finding Chain — Sentinel Incident Created",
      "rule_type_id": ".es-query",
      "consumer": "stackAlerts",
      "schedule": {
        "interval": "5m"
      },
      "tags": ["cloudloadgen", "azure-security-chain"],
      "enabled": false,
      "params": {
        "searchType": "esQuery",
        "timeWindowSize": 15,
        "timeWindowUnit": "m",
        "threshold": [1],
        "thresholdComparator": ">=",
        "size": 100,
        "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"term\":{\"event.dataset\":\"azure.sentinel\"}},{\"term\":{\"event.kind\":\"alert\"}}]}}}",
        "index": ["logs-azure.sentinel*"],
        "timeField": "@timestamp",
        "aggType": "count"
      },
      "actions": [],
      "notify_when": "onActiveAlert"
    },
    {
      "id": "cloudloadgen-azure-security-high-severity",
      "name": "[CloudLoadGen] Azure Security Finding Chain — Defender High Severity",
      "rule_type_id": ".es-query",
      "consumer": "stackAlerts",
      "schedule": {
        "interval": "5m"
      },
      "tags": ["cloudloadgen", "azure-security-chain"],
      "enabled": false,
      "params": {
        "searchType": "esQuery",
        "timeWindowSize": 30,
        "timeWindowUnit": "m",
        "threshold": [3],
        "thresholdComparator": ">",
        "size": 100,
        "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"term\":{\"event.dataset\":\"azure.defender\"}},{\"term\":{\"azure.defender.severity\":\"High\"}}]}}}",
        "index": ["logs-azure.defender*"],
        "timeField": "@timestamp",
        "aggType": "count"
      },
      "actions": [],
      "notify_when": "onActiveAlert"
    }
  ]
}
