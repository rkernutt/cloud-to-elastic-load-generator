{
  "_meta": {
    "rule_id": "cloudloadgen-azure-data-pipeline-databricks-error",
    "group": "data-pipeline",
    "api": "POST /api/alerting/rule"
  },
  "name": "[CloudLoadGen] Azure Data Pipeline — Databricks/Spark Processing Error",
  "rule_type_id": ".es-query",
  "consumer": "alerts",
  "schedule": {
    "interval": "5m"
  },
  "tags": ["cloudloadgen", "data-pipeline"],
  "enabled": false,
  "params": {
    "searchType": "esQuery",
    "timeWindowSize": 15,
    "timeWindowUnit": "m",
    "threshold": [1],
    "thresholdComparator": ">=",
    "size": 100,
    "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"term\":{\"event.dataset\":\"azure.databricks\"}},{\"exists\":{\"field\":\"error.type\"}}]}}}",
    "index": ["logs-azure.databricks*"],
    "timeField": "@timestamp",
    "aggType": "count"
  },
  "actions": [],
  "notify_when": "onActiveAlert",
  "artifacts": {
    "dashboards": [
      {
        "id": "c4295ae5-0d27-4fb5-9caa-b340d9298ea3"
      },
      {
        "id": "b5dc7c38-01dc-454c-96c1-1893904dba7c"
      }
    ]
  }
}
