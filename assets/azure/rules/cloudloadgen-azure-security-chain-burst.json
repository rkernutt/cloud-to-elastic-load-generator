{
  "_meta": {
    "rule_id": "cloudloadgen-azure-security-chain-burst",
    "group": "azure-security-chain",
    "api": "POST /api/alerting/rule"
  },
  "name": "[CloudLoadGen] Azure Security Finding Chain — Multi-Stage Chain Burst",
  "rule_type_id": ".es-query",
  "consumer": "alerts",
  "schedule": {
    "interval": "5m"
  },
  "tags": ["cloudloadgen", "azure-security-chain"],
  "enabled": false,
  "params": {
    "searchType": "esQuery",
    "timeWindowSize": 15,
    "timeWindowUnit": "m",
    "threshold": [2],
    "thresholdComparator": ">",
    "size": 100,
    "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"term\":{\"event.kind\":\"alert\"}},{\"bool\":{\"should\":[{\"term\":{\"event.dataset\":\"azure.defender\"}},{\"term\":{\"event.dataset\":\"azure.sentinel\"}},{\"term\":{\"event.dataset\":\"azure.activity_log\"}}],\"minimum_should_match\":1}}]}}}",
    "index": ["logs-azure.defender*", "logs-azure.sentinel*", "logs-azure.activity_log*"],
    "timeField": "@timestamp",
    "aggType": "count"
  },
  "actions": [],
  "notify_when": "onActiveAlert"
}
