{
  "_meta": {
    "rule_id": "cloudloadgen-azure-security-sentinel-incident",
    "group": "azure-security-chain",
    "api": "POST /api/alerting/rule"
  },
  "name": "[CloudLoadGen] Azure Security Finding Chain — Sentinel Incident Created",
  "rule_type_id": ".es-query",
  "consumer": "alerts",
  "schedule": {
    "interval": "5m"
  },
  "tags": ["cloudloadgen", "azure-security-chain"],
  "enabled": false,
  "params": {
    "searchType": "esQuery",
    "timeWindowSize": 15,
    "timeWindowUnit": "m",
    "threshold": [1],
    "thresholdComparator": ">=",
    "size": 100,
    "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"term\":{\"event.dataset\":\"azure.sentinel\"}},{\"term\":{\"event.kind\":\"alert\"}}]}}}",
    "index": ["logs-azure.sentinel*"],
    "timeField": "@timestamp",
    "aggType": "count"
  },
  "actions": [],
  "notify_when": "onActiveAlert",
  "artifacts": {
    "dashboards": [
      {
        "id": "5fc20838-fcf5-4ccd-81a4-bec647461e6d"
      },
      {
        "id": "7ebaad1c-21b2-4979-86b5-3253bf7e4b73"
      }
    ]
  }
}
