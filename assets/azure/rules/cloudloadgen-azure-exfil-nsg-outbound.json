{
  "_meta": {
    "rule_id": "cloudloadgen-azure-exfil-nsg-outbound",
    "group": "azure-data-exfil-chain",
    "api": "POST /api/alerting/rule"
  },
  "name": "[CloudLoadGen] Azure Data Exfil Chain — NSG Outbound Flow",
  "rule_type_id": ".es-query",
  "consumer": "alerts",
  "schedule": {
    "interval": "5m"
  },
  "tags": [
    "cloudloadgen",
    "azure-data-exfil-chain"
  ],
  "enabled": false,
  "params": {
    "searchType": "esQuery",
    "timeWindowSize": 15,
    "timeWindowUnit": "m",
    "threshold": [
      1
    ],
    "thresholdComparator": ">=",
    "size": 100,
    "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"term\":{\"event.dataset\":\"azure.network_security_groups\"}},{\"term\":{\"azure.network_security_groups.direction\":\"Outbound\"}}]}}}",
    "index": [
      "logs-azure.network_security_groups*"
    ],
    "timeField": "@timestamp",
    "aggType": "count"
  },
  "actions": [],
  "notify_when": "onActiveAlert"
}
