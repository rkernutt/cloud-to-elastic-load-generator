{
  "_meta": {
    "rule_id": "cloudloadgen-azure-exfil-defender-alert",
    "group": "azure-data-exfil-chain",
    "api": "POST /api/alerting/rule"
  },
  "name": "[CloudLoadGen] Azure Data Exfil Chain — Defender Exfiltration Alert",
  "rule_type_id": ".es-query",
  "consumer": "alerts",
  "schedule": {
    "interval": "5m"
  },
  "tags": ["cloudloadgen", "azure-data-exfil-chain"],
  "enabled": false,
  "params": {
    "searchType": "esQuery",
    "timeWindowSize": 15,
    "timeWindowUnit": "m",
    "threshold": [1],
    "thresholdComparator": ">=",
    "size": 100,
    "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"term\":{\"event.dataset\":\"azure.defender\"}},{\"wildcard\":{\"azure.defender.alert_type\":\"*Exfiltration*\"}}]}}}",
    "index": ["logs-azure.defender*"],
    "timeField": "@timestamp",
    "aggType": "count"
  },
  "actions": [],
  "notify_when": "onActiveAlert",
  "artifacts": {
    "dashboards": [
      {
        "id": "784c87c8-e5e9-4275-8312-01ebc9ac7485"
      },
      {
        "id": "19180f71-836b-41b0-993d-a53604b8b626"
      }
    ]
  }
}
