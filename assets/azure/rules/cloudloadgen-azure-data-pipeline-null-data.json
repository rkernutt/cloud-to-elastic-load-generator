{
  "_meta": {
    "rule_id": "cloudloadgen-azure-data-pipeline-null-data",
    "group": "data-pipeline",
    "api": "POST /api/alerting/rule"
  },
  "name": "[CloudLoadGen] Azure Data Pipeline — Null/Empty Data Detected",
  "rule_type_id": ".es-query",
  "consumer": "alerts",
  "schedule": {
    "interval": "5m"
  },
  "tags": ["cloudloadgen", "data-pipeline"],
  "enabled": false,
  "params": {
    "searchType": "esQuery",
    "timeWindowSize": 15,
    "timeWindowUnit": "m",
    "threshold": [1],
    "thresholdComparator": ">=",
    "size": 100,
    "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"term\":{\"event.dataset\":\"azure.synapse\"}},{\"term\":{\"azure.synapse.rows_returned\":0}}]}}}",
    "index": ["logs-azure.synapse*"],
    "timeField": "@timestamp",
    "aggType": "count"
  },
  "actions": [],
  "notify_when": "onActiveAlert",
  "artifacts": {
    "dashboards": [
      {
        "id": "c4295ae5-0d27-4fb5-9caa-b340d9298ea3"
      },
      {
        "id": "113e35dc-7c75-44fb-bb53-19f5313153b9"
      }
    ]
  }
}
