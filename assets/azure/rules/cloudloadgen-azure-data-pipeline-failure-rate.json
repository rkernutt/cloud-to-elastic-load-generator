{
  "_meta": {
    "rule_id": "cloudloadgen-azure-data-pipeline-failure-rate",
    "group": "data-pipeline",
    "api": "POST /api/alerting/rule"
  },
  "name": "[CloudLoadGen] Azure Data Pipeline — High Failure Rate",
  "rule_type_id": ".es-query",
  "consumer": "alerts",
  "schedule": {
    "interval": "5m"
  },
  "tags": ["cloudloadgen", "data-pipeline"],
  "enabled": false,
  "params": {
    "searchType": "esQuery",
    "timeWindowSize": 15,
    "timeWindowUnit": "m",
    "threshold": [3],
    "thresholdComparator": ">",
    "size": 100,
    "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"term\":{\"event.dataset\":\"azure.data_factory\"}},{\"term\":{\"event.outcome\":\"failure\"}}]}}}",
    "index": ["logs-azure.data_factory*"],
    "timeField": "@timestamp",
    "aggType": "count"
  },
  "actions": [],
  "notify_when": "onActiveAlert",
  "artifacts": {
    "dashboards": [
      {
        "id": "c4295ae5-0d27-4fb5-9caa-b340d9298ea3"
      },
      {
        "id": "72ce58a7-3175-4f40-8abb-eb408bc1460e"
      }
    ]
  }
}
