{
  "_meta": {
    "rule_id": "cloudloadgen-azure-iam-subscription-enum",
    "group": "azure-iam-privesc-chain",
    "api": "POST /api/alerting/rule"
  },
  "name": "[CloudLoadGen] Azure IAM PrivEsc Chain — Subscription Enumeration",
  "rule_type_id": ".es-query",
  "consumer": "alerts",
  "schedule": {
    "interval": "5m"
  },
  "tags": ["cloudloadgen", "azure-iam-privesc-chain"],
  "enabled": false,
  "params": {
    "searchType": "esQuery",
    "timeWindowSize": 15,
    "timeWindowUnit": "m",
    "threshold": [1],
    "thresholdComparator": ">=",
    "size": 100,
    "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"term\":{\"event.dataset\":\"azure.activity_log\"}},{\"wildcard\":{\"azure.activity_log.operation_name\":\"*subscriptions/read*\"}}]}}}",
    "index": ["logs-azure.activity_log*"],
    "timeField": "@timestamp",
    "aggType": "count"
  },
  "actions": [],
  "notify_when": "onActiveAlert",
  "artifacts": {
    "dashboards": [
      {
        "id": "b107335c-9966-4b92-91c0-de3cd38f4ee8"
      },
      {
        "id": "2ce5fbdd-942d-4785-a907-f7c1a4048440"
      }
    ]
  }
}
