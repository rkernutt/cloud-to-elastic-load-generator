{
  "_meta": {
    "job_id": "azure-sql-connection-spike",
    "group": "azure-databases",
    "api_job": "PUT _ml/anomaly_detectors/azure-sql-connection-spike",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-azure-sql-connection-spike",
    "api_open": "POST _ml/anomaly_detectors/azure-sql-connection-spike/_open",
    "api_start": "POST _ml/datafeeds/datafeed-azure-sql-connection-spike/_start"
  },
  "job": {
    "description": "Unusual failed SQL connection counts per server",
    "groups": ["azure", "databases"],
    "analysis_config": {
      "bucket_span": "15m",
      "detectors": [
        {
          "detector_description": "high_mean(azure.sql_database.failed_connections) partitionfield=azure.sql_database.server",
          "function": "high_mean",
          "field_name": "azure.sql_database.failed_connections",
          "partition_field_name": "azure.sql_database.server",
          "detector_index": 0
        }
      ],
      "influencers": ["azure.sql_database.server", "cloud.region"]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "32mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "azure-elastic-load-generator"
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-azure-sql-connection-spike",
    "job_id": "azure-sql-connection-spike",
    "indices": ["logs-azure.*"],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "cloud.provider": "azure"
            }
          },
          {
            "term": {
              "cloud.service.name": "Microsoft.Sql/servers"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
