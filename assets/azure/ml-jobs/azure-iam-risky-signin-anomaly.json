{
  "_meta": {
    "job_id": "azure-iam-risky-signin-anomaly",
    "group": "azure-iam-privesc-chain",
    "api_job": "PUT _ml/anomaly_detectors/azure-iam-risky-signin-anomaly",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-azure-iam-risky-signin-anomaly",
    "api_open": "POST _ml/anomaly_detectors/azure-iam-risky-signin-anomaly/_open",
    "api_start": "POST _ml/datafeeds/datafeed-azure-iam-risky-signin-anomaly/_start"
  },
  "job": {
    "description": "Detects unusual volume of at-risk Entra ID sign-ins",
    "groups": ["azure", "azure-iam-privesc-chain", "cloudloadgen"],
    "analysis_config": {
      "bucket_span": "15m",
      "detectors": [
        {
          "detector_description": "high_count partitionfield=azure.entra_id.riskLevel",
          "function": "high_count",
          "partition_field_name": "azure.entra_id.riskLevel",
          "detector_index": 0
        }
      ],
      "influencers": ["azure.entra_id.riskLevel", "source.ip", "azure.entra_id.user_principal_name"]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "64mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "azure-load-generator-azure-iam-privesc-chain",
      "tags": ["cloudloadgen"]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-azure-iam-risky-signin-anomaly",
    "job_id": "azure-iam-risky-signin-anomaly",
    "indices": ["logs-azure.entra_id*"],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "azure.entra_id.riskState": "AtRisk"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
