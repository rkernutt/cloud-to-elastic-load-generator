{
  "_meta": {
    "job_id": "azure-data-pipeline-error-spike",
    "group": "azure-data-pipeline",
    "api_job": "PUT _ml/anomaly_detectors/azure-data-pipeline-error-spike",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-azure-data-pipeline-error-spike",
    "api_open": "POST _ml/anomaly_detectors/azure-data-pipeline-error-spike/_open",
    "api_start": "POST _ml/datafeeds/datafeed-azure-data-pipeline-error-spike/_start"
  },
  "job": {
    "description": "Detects spikes in data pipeline failures",
    "groups": [
      "azure",
      "data-pipeline",
      "cloudloadgen"
    ],
    "analysis_config": {
      "bucket_span": "15m",
      "detectors": [
        {
          "detector_description": "high_count on event.outcome=failure partitionfield=cloud.region",
          "function": "high_count",
          "partition_field_name": "cloud.region",
          "detector_index": 0
        }
      ],
      "influencers": [
        "cloud.region",
        "event.dataset",
        "error.type"
      ]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "64mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "azure-load-generator-data-pipeline",
      "tags": [
        "cloudloadgen"
      ]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-azure-data-pipeline-error-spike",
    "job_id": "azure-data-pipeline-error-spike",
    "indices": [
      "logs-azure.data_factory*",
      "logs-azure.databricks*",
      "logs-azure.purview*",
      "logs-azure.synapse*"
    ],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "event.outcome": "failure"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
