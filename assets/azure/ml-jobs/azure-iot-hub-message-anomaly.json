{
  "_meta": {
    "job_id": "azure-iot-hub-message-anomaly",
    "group": "azure-compute",
    "api_job": "PUT _ml/anomaly_detectors/azure-iot-hub-message-anomaly",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-azure-iot-hub-message-anomaly",
    "api_open": "POST _ml/anomaly_detectors/azure-iot-hub-message-anomaly/_open",
    "api_start": "POST _ml/datafeeds/datafeed-azure-iot-hub-message-anomaly/_start"
  },
  "job": {
    "description": "Unusual IoT Hub message volume per device",
    "groups": ["azure", "iot"],
    "analysis_config": {
      "bucket_span": "15m",
      "detectors": [
        {
          "detector_description": "high_count partitionfield=azure.iot_hub.device_id",
          "function": "high_count",
          "partition_field_name": "azure.iot_hub.device_id",
          "detector_index": 0
        }
      ],
      "influencers": ["azure.iot_hub.device_id", "cloud.region"]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "32mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "azure-elastic-load-generator"
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-azure-iot-hub-message-anomaly",
    "job_id": "azure-iot-hub-message-anomaly",
    "indices": ["logs-azure.*"],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "cloud.provider": "azure"
            }
          },
          {
            "term": {
              "cloud.service.name": "Microsoft.Devices/IotHubs"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
