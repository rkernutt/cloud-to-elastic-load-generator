{
  "_meta": {
    "job_id": "azure-security-chain-rate",
    "group": "azure-security-chain",
    "api_job": "PUT _ml/anomaly_detectors/azure-security-chain-rate",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-azure-security-chain-rate",
    "api_open": "POST _ml/anomaly_detectors/azure-security-chain-rate/_open",
    "api_start": "POST _ml/datafeeds/datafeed-azure-security-chain-rate/_start"
  },
  "job": {
    "description": "Detects anomalous rate of finding chains",
    "groups": [
      "azure",
      "azure-security-chain",
      "cloudloadgen"
    ],
    "analysis_config": {
      "bucket_span": "30m",
      "detectors": [
        {
          "detector_description": "high_count partitionfield=event.dataset",
          "function": "high_count",
          "partition_field_name": "event.dataset",
          "detector_index": 0
        }
      ],
      "influencers": [
        "event.dataset",
        "cloud.account.id"
      ]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "64mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "azure-load-generator-azure-security-finding-chain",
      "tags": [
        "cloudloadgen"
      ]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-azure-security-chain-rate",
    "job_id": "azure-security-chain-rate",
    "indices": [
      "logs-azure.defender*",
      "logs-azure.sentinel*",
      "logs-azure.activity_log*"
    ],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "event.kind": "alert"
            }
          },
          {
            "bool": {
              "should": [
                {
                  "term": {
                    "event.dataset": "azure.defender"
                  }
                },
                {
                  "term": {
                    "event.dataset": "azure.sentinel"
                  }
                },
                {
                  "term": {
                    "event.dataset": "azure.activity_log"
                  }
                }
              ],
              "minimum_should_match": 1
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
