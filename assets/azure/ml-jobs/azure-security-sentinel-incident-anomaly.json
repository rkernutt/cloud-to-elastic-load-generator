{
  "_meta": {
    "job_id": "azure-security-sentinel-incident-anomaly",
    "group": "azure-security-chain",
    "api_job": "PUT _ml/anomaly_detectors/azure-security-sentinel-incident-anomaly",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-azure-security-sentinel-incident-anomaly",
    "api_open": "POST _ml/anomaly_detectors/azure-security-sentinel-incident-anomaly/_open",
    "api_start": "POST _ml/datafeeds/datafeed-azure-security-sentinel-incident-anomaly/_start"
  },
  "job": {
    "description": "Detects unusual spikes in Sentinel incidents by severity",
    "groups": [
      "azure",
      "azure-security-chain",
      "cloudloadgen"
    ],
    "analysis_config": {
      "bucket_span": "15m",
      "detectors": [
        {
          "detector_description": "high_count partitionfield=azure.sentinel.severity",
          "function": "high_count",
          "partition_field_name": "azure.sentinel.severity",
          "detector_index": 0
        }
      ],
      "influencers": [
        "azure.sentinel.severity",
        "source.ip",
        "cloud.region"
      ]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "64mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "azure-load-generator-azure-security-finding-chain",
      "tags": [
        "cloudloadgen"
      ]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-azure-security-sentinel-incident-anomaly",
    "job_id": "azure-security-sentinel-incident-anomaly",
    "indices": [
      "logs-azure.sentinel*"
    ],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "event.kind": "alert"
            }
          },
          {
            "exists": {
              "field": "azure.sentinel.severity"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
