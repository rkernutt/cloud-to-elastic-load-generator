{
  "_meta": {
    "job_id": "azure-security-defender-alert-spike",
    "group": "azure-security-chain",
    "api_job": "PUT _ml/anomaly_detectors/azure-security-defender-alert-spike",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-azure-security-defender-alert-spike",
    "api_open": "POST _ml/anomaly_detectors/azure-security-defender-alert-spike/_open",
    "api_start": "POST _ml/datafeeds/datafeed-azure-security-defender-alert-spike/_start"
  },
  "job": {
    "description": "Detects unusual spikes in Defender alerts by alert type",
    "groups": ["azure", "azure-security-chain", "cloudloadgen"],
    "analysis_config": {
      "bucket_span": "15m",
      "detectors": [
        {
          "detector_description": "high_count partitionfield=azure.defender.alert_type",
          "function": "high_count",
          "partition_field_name": "azure.defender.alert_type",
          "detector_index": 0
        }
      ],
      "influencers": ["azure.defender.alert_type", "source.ip", "cloud.region"]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "64mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "azure-load-generator-azure-security-finding-chain",
      "tags": ["cloudloadgen"]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-azure-security-defender-alert-spike",
    "job_id": "azure-security-defender-alert-spike",
    "indices": ["logs-azure.defender*"],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "event.kind": "alert"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
