{
  "_meta": {
    "pipeline_id": "logs-azure.postgresql-default",
    "dataset": "azure.postgresql",
    "group": "databases",
    "api": "PUT _ingest/pipeline/logs-azure.postgresql-default"
  },
  "description": "Parse JSON from message for azure.postgresql (database-for-postgresql)",
  "processors": [
    {
      "json": {
        "field": "message",
        "target_field": "azure.parsed",
        "ignore_failure": true
      }
    }
  ]
}
