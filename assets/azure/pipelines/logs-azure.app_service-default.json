{
  "_meta": {
    "pipeline_id": "logs-azure.app_service-default",
    "dataset": "azure.app_service",
    "group": "serverless-apps",
    "api": "PUT _ingest/pipeline/logs-azure.app_service-default"
  },
  "description": "Parse JSON from message for azure.app_service (app-service)",
  "processors": [
    {
      "json": {
        "field": "message",
        "target_field": "azure.parsed",
        "ignore_failure": true
      }
    }
  ]
}
