{
  "_meta": {
    "pipeline_id": "logs-azure.defender-default",
    "dataset": "azure.defender",
    "group": "identity-security",
    "api": "PUT _ingest/pipeline/logs-azure.defender-default"
  },
  "description": "Parse JSON from message for azure.defender (defender-for-cloud)",
  "processors": [
    {
      "json": {
        "field": "message",
        "target_field": "azure.parsed",
        "ignore_failure": true
      }
    }
  ]
}
