{
  "_meta": {
    "pipeline_id": "logs-azure.functions-default",
    "dataset": "azure.functions",
    "group": "serverless-apps",
    "api": "PUT _ingest/pipeline/logs-azure.functions-default"
  },
  "description": "Parse JSON from message for azure.functions (functions)",
  "processors": [
    {
      "json": {
        "field": "message",
        "target_field": "azure.parsed",
        "ignore_failure": true
      }
    }
  ]
}
