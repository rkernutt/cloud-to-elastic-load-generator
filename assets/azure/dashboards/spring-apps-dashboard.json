    {
      "type": "lens",
      "uid": "azspr-t1",
      "grid": {
        "x": 0,
        "y": 45,
        "w": 48,
        "h": 12
      },
      "config": {
        "title": "Recent",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.spring_apps* | KEEP `@timestamp`, `azure.spring_apps.resource_name`, operationName, `azure.spring_apps.http_status`, `azure.spring_apps.duration_ms`, event.outcome, correlationId | SORT `@timestamp` DESC | LIMIT 100"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "`@timestamp`",
              "label": "Time"
            },
            {
              "operation": "value",
              "column": "azure.spring_apps.resource_name",
              "label": "Service"
            },
            {
              "operation": "value",
              "column": "operationName",
              "label": "Operation"
            },
            {
              "operation": "value",
              "column": "azure.spring_apps.http_status",
              "label": "HTTP"
            },
            {
              "operation": "value",
              "column": "azure.spring_apps.duration_ms",
              "label": "Ms"
            },
            {
              "operation": "value",
              "column": "event.outcome",
              "label": "Outcome"
            },
            {
              "operation": "value",
              "column": "correlationId",
              "label": "Correlation"
            }
          ],
          "rows": []
        }
      }
    }
