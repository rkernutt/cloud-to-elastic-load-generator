                "type": "esql",
                "query": "FROM logs-azure.spring_apps* | STATS err = SUM(CASE(`azure.spring_apps.http_status` >= 400, 1, 0)) BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
