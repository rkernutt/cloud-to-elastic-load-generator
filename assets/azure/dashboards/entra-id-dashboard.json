          },
          "layers": [
            {
              "type": "bar_horizontal",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-azure.entra_id* | STATS c = COUNT() BY u = `azure.entra_id.user` | SORT c DESC | LIMIT 10"
              },
              "x": {
                "operation": "value",
