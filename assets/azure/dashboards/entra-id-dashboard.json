    {
      "type": "lens",
      "uid": "azent-t1",
      "grid": {
        "x": 0,
        "y": 45,
        "w": 48,
        "h": 12
      },
      "config": {
        "title": "Recent",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-azure.entra_id* | KEEP `@timestamp`, `azure.entra_id.category`, `azure.entra_id.user`, `azure.entra_id.result`, `azure.entra_id.conditional_access`, `azure.entra_id.ip_address`, event.outcome | SORT `@timestamp` DESC | LIMIT 100"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "`@timestamp`",
              "label": "Time"
            },
            {
              "operation": "value",
              "column": "azure.entra_id.category",
              "label": "Category"
            },
            {
              "operation": "value",
              "column": "azure.entra_id.user",
              "label": "User"
            },
            {
              "operation": "value",
              "column": "azure.entra_id.result",
              "label": "Result"
            },
            {
              "operation": "value",
              "column": "azure.entra_id.conditional_access",
              "label": "CA"
            },
            {
              "operation": "value",
              "column": "azure.entra_id.ip_address",
              "label": "IP"
            },
            {
              "operation": "value",
              "column": "event.outcome",
              "label": "Outcome"
            }
          ],
          "rows": []
        }
      }
    }
  ]
