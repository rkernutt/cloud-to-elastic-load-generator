{
  "_meta": {
    "job_id": "gcp-iam-privesc-session-spike",
    "group": "gcp-iam-privesc-chain",
    "api_job": "PUT _ml/anomaly_detectors/gcp-iam-privesc-session-spike",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-gcp-iam-privesc-session-spike",
    "api_open": "POST _ml/anomaly_detectors/gcp-iam-privesc-session-spike/_open",
    "api_start": "POST _ml/datafeeds/datafeed-gcp-iam-privesc-session-spike/_start"
  },
  "job": {
    "description": "Detects spikes in IAM privilege escalation chains",
    "groups": [
      "gcp",
      "gcp-iam-privesc-chain",
      "cloudloadgen"
    ],
    "analysis_config": {
      "bucket_span": "15m",
      "detectors": [
        {
          "detector_description": "high_count partitionfield=user.name",
          "function": "high_count",
          "partition_field_name": "user.name",
          "detector_index": 0
        }
      ],
      "influencers": [
        "user.name",
        "source.ip",
        "gcp.cloud_audit.method_name"
      ]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "64mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "gcp-load-generator-gcp-iam-privesc-chain",
      "tags": [
        "cloudloadgen"
      ]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-gcp-iam-privesc-session-spike",
    "job_id": "gcp-iam-privesc-session-spike",
    "indices": [
      "logs-gcp.audit*"
    ],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "bool": {
              "should": [
                {
                  "wildcard": {
                    "gcp.cloud_audit.method_name": "*ListServiceAccounts*"
                  }
                },
                {
                  "wildcard": {
                    "gcp.cloud_audit.method_name": "*CreateServiceAccountKey*"
                  }
                },
                {
                  "wildcard": {
                    "gcp.cloud_audit.method_name": "*SetIamPolicy*"
                  }
                },
                {
                  "wildcard": {
                    "gcp.cloud_audit.method_name": "*GenerateAccessToken*"
                  }
                }
              ],
              "minimum_should_match": 1
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
