{
  "_meta": {
    "job_id": "gcp-gemini-error-spike",
    "group": "gcp-aiml-extended",
    "api_job": "PUT _ml/anomaly_detectors/gcp-gemini-error-spike",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-gcp-gemini-error-spike",
    "api_open": "POST _ml/anomaly_detectors/gcp-gemini-error-spike/_open",
    "api_start": "POST _ml/datafeeds/datafeed-gcp-gemini-error-spike/_start"
  },
  "job": {
    "description": "Detects spikes in Gemini model inference failures by model",
    "groups": ["gcp", "aiml"],
    "analysis_config": {
      "bucket_span": "15m",
      "detectors": [
        {
          "detector_description": "high_count partitionfield=gcp.gemini.model_id",
          "function": "high_count",
          "partition_field_name": "gcp.gemini.model_id",
          "detector_index": 0
        }
      ],
      "influencers": ["gcp.gemini.model_id", "cloud.region"]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "32mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "gcp-elastic-load-generator"
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-gcp-gemini-error-spike",
    "job_id": "gcp-gemini-error-spike",
    "indices": ["logs-gcp.*"],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "cloud.provider": "gcp"
            }
          },
          {
            "wildcard": {
              "cloud.service.name": "*generativelanguage.googleapis.com*"
            }
          },
          {
            "term": {
              "event.outcome": "failure"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
