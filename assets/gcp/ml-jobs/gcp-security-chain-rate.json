{
  "_meta": {
    "job_id": "gcp-security-chain-rate",
    "group": "gcp-security-chain",
    "api_job": "PUT _ml/anomaly_detectors/gcp-security-chain-rate",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-gcp-security-chain-rate",
    "api_open": "POST _ml/anomaly_detectors/gcp-security-chain-rate/_open",
    "api_start": "POST _ml/datafeeds/datafeed-gcp-security-chain-rate/_start"
  },
  "job": {
    "description": "Detects anomalous rate of finding chains",
    "groups": ["gcp", "gcp-security-chain", "cloudloadgen"],
    "analysis_config": {
      "bucket_span": "30m",
      "detectors": [
        {
          "detector_description": "high_count partitionfield=event.dataset",
          "function": "high_count",
          "partition_field_name": "event.dataset",
          "detector_index": 0
        }
      ],
      "influencers": ["event.dataset", "cloud.account.id"]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "64mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "gcp-load-generator-gcp-security-finding-chain",
      "tags": ["cloudloadgen"]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-gcp-security-chain-rate",
    "job_id": "gcp-security-chain-rate",
    "indices": ["logs-gcp.scc*", "logs-gcp.secops*"],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "bool": {
              "should": [
                {
                  "bool": {
                    "filter": [
                      {
                        "bool": {
                          "should": [
                            {
                              "term": {
                                "event.dataset": "gcp.scc"
                              }
                            },
                            {
                              "term": {
                                "data_stream.dataset": "gcp.scc"
                              }
                            }
                          ],
                          "minimum_should_match": 1
                        }
                      },
                      {
                        "term": {
                          "event.kind": "alert"
                        }
                      }
                    ]
                  }
                },
                {
                  "bool": {
                    "filter": [
                      {
                        "bool": {
                          "should": [
                            {
                              "term": {
                                "event.dataset": "gcp.secops"
                              }
                            },
                            {
                              "term": {
                                "data_stream.dataset": "gcp.secops"
                              }
                            }
                          ],
                          "minimum_should_match": 1
                        }
                      },
                      {
                        "exists": {
                          "field": "gcp.security_operations.action_type"
                        }
                      }
                    ]
                  }
                }
              ],
              "minimum_should_match": 1
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
