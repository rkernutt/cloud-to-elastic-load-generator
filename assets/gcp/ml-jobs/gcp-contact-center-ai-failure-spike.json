{
  "_meta": {
    "job_id": "gcp-contact-center-ai-failure-spike",
    "group": "minimal-coverage",
    "api_job": "PUT _ml/anomaly_detectors/gcp-contact-center-ai-failure-spike",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-gcp-contact-center-ai-failure-spike",
    "api_open": "POST _ml/anomaly_detectors/gcp-contact-center-ai-failure-spike/_open",
    "api_start": "POST _ml/datafeeds/datafeed-gcp-contact-center-ai-failure-spike/_start"
  },
  "job": {
    "description": "Unusual spike in failure events for gcp.ccai",
    "groups": ["gcp", "minimal-coverage"],
    "analysis_config": {
      "bucket_span": "15m",
      "detectors": [
        {
          "detector_description": "high_count partitionfield=cloud.region gcp.ccai",
          "function": "high_count",
          "partition_field_name": "cloud.region",
          "detector_index": 0
        }
      ],
      "influencers": ["cloud.region", "event.outcome"]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "32mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "gcp-load-generator-minimal-coverage"
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-gcp-contact-center-ai-failure-spike",
    "job_id": "gcp-contact-center-ai-failure-spike",
    "indices": ["logs-gcp.*"],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "event.dataset": "gcp.ccai"
            }
          },
          {
            "term": {
              "event.outcome": "failure"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
