{
  "_meta": {
    "job_id": "gcp-cloud-audit-logs-rare-action",
    "group": "gcp-infrastructure",
    "api_job": "PUT _ml/anomaly_detectors/gcp-cloud-audit-logs-rare-action",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-gcp-cloud-audit-logs-rare-action",
    "api_open": "POST _ml/anomaly_detectors/gcp-cloud-audit-logs-rare-action/_open",
    "api_start": "POST _ml/datafeeds/datafeed-gcp-cloud-audit-logs-rare-action/_start"
  },
  "job": {
    "description": "Detects rare Cloud Audit method_name values for user-driven admin activity",
    "groups": ["gcp", "management"],
    "analysis_config": {
      "bucket_span": "60m",
      "detectors": [
        {
          "detector_description": "rare by=gcp.cloud_audit.method_name",
          "function": "rare",
          "by_field_name": "gcp.cloud_audit.method_name",
          "detector_index": 0
        }
      ],
      "influencers": ["gcp.cloud_audit.method_name", "gcp.cloud_audit.service_name", "cloud.region"]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "32mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "gcp-elastic-load-generator"
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-gcp-cloud-audit-logs-rare-action",
    "job_id": "gcp-cloud-audit-logs-rare-action",
    "indices": ["logs-gcp.*"],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "cloud.provider": "gcp"
            }
          },
          {
            "term": {
              "event.dataset": "gcp.cloud_audit"
            }
          },
          {
            "term": {
              "gcp.cloud_audit.caller_type": "USER"
            }
          },
          {
            "exists": {
              "field": "gcp.cloud_audit.method_name"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
