{
  "_meta": {
    "job_id": "gcp-data-pipeline-duration-anomaly",
    "group": "gcp-data-pipeline",
    "api_job": "PUT _ml/anomaly_detectors/gcp-data-pipeline-duration-anomaly",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-gcp-data-pipeline-duration-anomaly",
    "api_open": "POST _ml/anomaly_detectors/gcp-data-pipeline-duration-anomaly/_open",
    "api_start": "POST _ml/datafeeds/datafeed-gcp-data-pipeline-duration-anomaly/_start"
  },
  "job": {
    "description": "Detects unusually slow data pipeline runs",
    "groups": ["gcp", "data-pipeline", "cloudloadgen"],
    "analysis_config": {
      "bucket_span": "15m",
      "detectors": [
        {
          "detector_description": "high_mean(gcp.composer.duration_ms) partitionfield=gcp.composer.dag_id",
          "function": "high_mean",
          "field_name": "gcp.composer.duration_ms",
          "partition_field_name": "gcp.composer.dag_id",
          "detector_index": 0
        }
      ],
      "influencers": ["gcp.composer.dag_id", "cloud.region", "gcp.composer.quality_check"]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "64mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "gcp-load-generator-data-pipeline",
      "tags": ["cloudloadgen"]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-gcp-data-pipeline-duration-anomaly",
    "job_id": "gcp-data-pipeline-duration-anomaly",
    "indices": ["logs-gcp.composer*"],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "gcp.composer.task_id": "dag_complete"
            }
          },
          {
            "exists": {
              "field": "gcp.composer.duration_ms"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
