{
  "_meta": {
    "job_id": "gcp-spanner-failure-spike",
    "group": "gcp-databases",
    "api_job": "PUT _ml/anomaly_detectors/gcp-spanner-failure-spike",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-gcp-spanner-failure-spike",
    "api_open": "POST _ml/anomaly_detectors/gcp-spanner-failure-spike/_open",
    "api_start": "POST _ml/datafeeds/datafeed-gcp-spanner-failure-spike/_start"
  },
  "job": {
    "description": "Spikes in Cloud Spanner failures per database",
    "groups": ["gcp", "databases"],
    "analysis_config": {
      "bucket_span": "15m",
      "detectors": [
        {
          "detector_description": "high_count partitionfield=gcp.cloud_spanner.database",
          "function": "high_count",
          "partition_field_name": "gcp.cloud_spanner.database",
          "detector_index": 0
        }
      ],
      "influencers": ["gcp.cloud_spanner.database", "cloud.region"]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "32mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "gcp-elastic-load-generator"
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-gcp-spanner-failure-spike",
    "job_id": "gcp-spanner-failure-spike",
    "indices": ["logs-gcp.*"],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "cloud.provider": "gcp"
            }
          },
          {
            "wildcard": {
              "cloud.service.name": "*spanner*"
            }
          },
          {
            "term": {
              "event.outcome": "failure"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
