{
  "_meta": {
    "job_id": "gcp-data-exfil-dlp-spike",
    "group": "gcp-data-exfil-chain",
    "api_job": "PUT _ml/anomaly_detectors/gcp-data-exfil-dlp-spike",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-gcp-data-exfil-dlp-spike",
    "api_open": "POST _ml/anomaly_detectors/gcp-data-exfil-dlp-spike/_open",
    "api_start": "POST _ml/datafeeds/datafeed-gcp-data-exfil-dlp-spike/_start"
  },
  "job": {
    "description": "Detects spikes in DLP findings by sensitive info type",
    "groups": ["gcp", "gcp-data-exfil-chain", "cloudloadgen"],
    "analysis_config": {
      "bucket_span": "15m",
      "detectors": [
        {
          "detector_description": "high_count partitionfield=gcp.dlp.info_type",
          "function": "high_count",
          "partition_field_name": "gcp.dlp.info_type",
          "detector_index": 0
        }
      ],
      "influencers": ["gcp.dlp.info_type", "cloud.region", "user.name"]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "32mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "gcp-load-generator-gcp-data-exfil-chain",
      "tags": ["cloudloadgen"]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-gcp-data-exfil-dlp-spike",
    "job_id": "gcp-data-exfil-dlp-spike",
    "indices": ["logs-gcp.dlp*"],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "event.kind": "alert"
            }
          },
          {
            "exists": {
              "field": "gcp.dlp.info_type"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
