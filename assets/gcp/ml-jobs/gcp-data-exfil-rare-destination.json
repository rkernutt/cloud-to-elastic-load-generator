{
  "_meta": {
    "job_id": "gcp-data-exfil-rare-destination",
    "group": "gcp-data-exfil-chain",
    "api_job": "PUT _ml/anomaly_detectors/gcp-data-exfil-rare-destination",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-gcp-data-exfil-rare-destination",
    "api_open": "POST _ml/anomaly_detectors/gcp-data-exfil-rare-destination/_open",
    "api_start": "POST _ml/datafeeds/datafeed-gcp-data-exfil-rare-destination/_start"
  },
  "job": {
    "description": "Detects connections to rare destination IPs during exfil events",
    "groups": [
      "gcp",
      "gcp-data-exfil-chain",
      "cloudloadgen"
    ],
    "analysis_config": {
      "bucket_span": "15m",
      "detectors": [
        {
          "detector_description": "rare by gcp.vpc_flow.dst_ip",
          "function": "rare",
          "by_field_name": "gcp.vpc_flow.dst_ip",
          "detector_index": 0
        }
      ],
      "influencers": [
        "gcp.vpc_flow.dst_ip",
        "source.ip",
        "cloud.region"
      ]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "64mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "gcp-load-generator-gcp-data-exfil-chain",
      "tags": [
        "cloudloadgen"
      ]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-gcp-data-exfil-rare-destination",
    "job_id": "gcp-data-exfil-rare-destination",
    "indices": [
      "logs-gcp.vpcflow*"
    ],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "gcp.vpc_flow.direction": "egress"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
