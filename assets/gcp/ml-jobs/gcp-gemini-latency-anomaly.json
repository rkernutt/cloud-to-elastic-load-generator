{
  "_meta": {
    "job_id": "gcp-gemini-latency-anomaly",
    "group": "gcp-aiml-extended",
    "api_job": "PUT _ml/anomaly_detectors/gcp-gemini-latency-anomaly",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-gcp-gemini-latency-anomaly",
    "api_open": "POST _ml/anomaly_detectors/gcp-gemini-latency-anomaly/_open",
    "api_start": "POST _ml/datafeeds/datafeed-gcp-gemini-latency-anomaly/_start"
  },
  "job": {
    "description": "Detects unusual Gemini model inference latency",
    "groups": [
      "gcp",
      "aiml"
    ],
    "analysis_config": {
      "bucket_span": "15m",
      "detectors": [
        {
          "detector_description": "high_mean(event.duration)",
          "function": "high_mean",
          "field_name": "event.duration",
          "detector_index": 0
        }
      ],
      "influencers": [
        "cloud.region"
      ]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "32mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "gcp-elastic-load-generator"
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-gcp-gemini-latency-anomaly",
    "job_id": "gcp-gemini-latency-anomaly",
    "indices": [
      "logs-gcp.*"
    ],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "cloud.provider": "gcp"
            }
          },
          {
            "wildcard": {
              "cloud.service.name": "*generativelanguage.googleapis.com*"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
