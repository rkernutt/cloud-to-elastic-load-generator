{
  "_meta": {
    "rule_id": "cloudloadgen-gcp-security-secops-high-match",
    "group": "gcp-security-chain",
    "api": "POST /api/alerting/rule"
  },
  "name": "[CloudLoadGen] GCP Security Finding Chain — SecOps High Match Volume",
  "rule_type_id": ".es-query",
  "consumer": "alerts",
  "schedule": {
    "interval": "5m"
  },
  "tags": ["cloudloadgen", "gcp-security-chain"],
  "enabled": false,
  "params": {
    "searchType": "esQuery",
    "timeWindowSize": 15,
    "timeWindowUnit": "m",
    "threshold": [1],
    "thresholdComparator": ">=",
    "size": 100,
    "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"range\":{\"gcp.secops_detection.matched_events_count\":{\"gt\":100}}}]}}}",
    "index": ["logs-gcp.secops*"],
    "timeField": "@timestamp",
    "aggType": "count"
  },
  "actions": [],
  "notify_when": "onActiveAlert",
  "artifacts": {
    "dashboards": [
      {
        "id": "0a71dc79-8982-4254-8619-a414f9266505"
      },
      {
        "id": "96fc6869-45d5-4c50-8597-4353ab61d766"
      }
    ]
  }
}
