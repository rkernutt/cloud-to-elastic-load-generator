{
  "_meta": {
    "rule_id": "cloudloadgen-gcp-exfil-dlp-alert",
    "group": "gcp-data-exfil-chain",
    "api": "POST /api/alerting/rule"
  },
  "name": "[CloudLoadGen] GCP Data Exfil Chain — DLP Finding Alert",
  "rule_type_id": ".es-query",
  "consumer": "alerts",
  "schedule": {
    "interval": "5m"
  },
  "tags": ["cloudloadgen", "gcp-data-exfil-chain"],
  "enabled": false,
  "params": {
    "searchType": "esQuery",
    "timeWindowSize": 15,
    "timeWindowUnit": "m",
    "threshold": [1],
    "thresholdComparator": ">=",
    "size": 100,
    "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"term\":{\"event.kind\":\"alert\"}},{\"bool\":{\"should\":[{\"term\":{\"event.dataset\":\"gcp.dlp\"}},{\"term\":{\"data_stream.dataset\":\"gcp.dlp\"}}],\"minimum_should_match\":1}}]}}}",
    "index": ["logs-gcp.dlp*"],
    "timeField": "@timestamp",
    "aggType": "count"
  },
  "actions": [],
  "notify_when": "onActiveAlert"
}
