{
  "_meta": {
    "rule_id": "cloudloadgen-gcp-exfil-high-egress",
    "group": "gcp-data-exfil-chain",
    "api": "POST /api/alerting/rule"
  },
  "name": "[CloudLoadGen] GCP Data Exfil Chain — VPC High Bytes Sent",
  "rule_type_id": ".es-query",
  "consumer": "alerts",
  "schedule": {
    "interval": "5m"
  },
  "tags": [
    "cloudloadgen",
    "gcp-data-exfil-chain"
  ],
  "enabled": false,
  "params": {
    "searchType": "esQuery",
    "timeWindowSize": 15,
    "timeWindowUnit": "m",
    "threshold": [
      1
    ],
    "thresholdComparator": ">=",
    "size": 100,
    "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"bool\":{\"should\":[{\"term\":{\"event.dataset\":\"gcp.vpcflow\"}},{\"term\":{\"data_stream.dataset\":\"gcp.vpcflow\"}}],\"minimum_should_match\":1}},{\"term\":{\"gcp.vpc_flow.direction\":\"egress\"}},{\"range\":{\"gcp.vpc_flow.bytes_sent\":{\"gt\":52428800}}}]}}}",
    "index": [
      "logs-gcp.vpcflow*"
    ],
    "timeField": "@timestamp",
    "aggType": "count"
  },
  "actions": [],
  "notify_when": "onActiveAlert"
}
