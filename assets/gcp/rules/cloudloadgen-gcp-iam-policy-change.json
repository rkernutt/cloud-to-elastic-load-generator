{
  "_meta": {
    "rule_id": "cloudloadgen-gcp-iam-policy-change",
    "group": "gcp-iam-privesc-chain",
    "api": "POST /api/alerting/rule"
  },
  "name": "[CloudLoadGen] GCP IAM PrivEsc Chain — SetIamPolicy",
  "rule_type_id": ".es-query",
  "consumer": "alerts",
  "schedule": {
    "interval": "5m"
  },
  "tags": ["cloudloadgen", "gcp-iam-privesc-chain"],
  "enabled": false,
  "params": {
    "searchType": "esQuery",
    "timeWindowSize": 15,
    "timeWindowUnit": "m",
    "threshold": [1],
    "thresholdComparator": ">=",
    "size": 100,
    "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"wildcard\":{\"gcp.cloud_audit.method_name\":\"*SetIamPolicy*\"}}]}}}",
    "index": ["logs-gcp.audit*"],
    "timeField": "@timestamp",
    "aggType": "count"
  },
  "actions": [],
  "notify_when": "onActiveAlert"
}
