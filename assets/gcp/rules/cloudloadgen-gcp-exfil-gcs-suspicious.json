{
  "_meta": {
    "rule_id": "cloudloadgen-gcp-exfil-gcs-suspicious",
    "group": "gcp-data-exfil-chain",
    "api": "POST /api/alerting/rule"
  },
  "name": "[CloudLoadGen] GCP Data Exfil Chain — Large GCS Object Get",
  "rule_type_id": ".es-query",
  "consumer": "alerts",
  "schedule": {
    "interval": "5m"
  },
  "tags": ["cloudloadgen", "gcp-data-exfil-chain"],
  "enabled": false,
  "params": {
    "searchType": "esQuery",
    "timeWindowSize": 15,
    "timeWindowUnit": "m",
    "threshold": [1],
    "thresholdComparator": ">=",
    "size": 100,
    "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"bool\":{\"should\":[{\"term\":{\"event.dataset\":\"gcp.gcs\"}},{\"term\":{\"data_stream.dataset\":\"gcp.gcs\"}}],\"minimum_should_match\":1}},{\"term\":{\"gcp.cloud_storage.operation\":\"storage.objects.get\"}},{\"range\":{\"gcp.cloud_storage.object_size\":{\"gt\":52428800}}}]}}}",
    "index": ["logs-gcp.gcs*"],
    "timeField": "@timestamp",
    "aggType": "count"
  },
  "actions": [],
  "notify_when": "onActiveAlert",
  "artifacts": {
    "dashboards": [
      {
        "id": "782929cd-07c9-4274-b7a5-a0cfa7b50c33"
      },
      {
        "id": "133c1666-efed-4948-955e-f7701a798ccf"
      },
      {
        "id": "2d4d7f67-d889-487f-a335-a5dea8ffbd71"
      }
    ]
  }
}
