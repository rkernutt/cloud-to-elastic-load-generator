{
  "_meta": {
    "rule_id": "cloudloadgen-gcp-security-scc-high-severity",
    "group": "gcp-security-chain",
    "api": "POST /api/alerting/rule"
  },
  "name": "[CloudLoadGen] GCP Security Finding Chain — SCC HIGH/CRITICAL",
  "rule_type_id": ".es-query",
  "consumer": "alerts",
  "schedule": {
    "interval": "5m"
  },
  "tags": [
    "cloudloadgen",
    "gcp-security-chain"
  ],
  "enabled": false,
  "params": {
    "searchType": "esQuery",
    "timeWindowSize": 15,
    "timeWindowUnit": "m",
    "threshold": [
      1
    ],
    "thresholdComparator": ">=",
    "size": 100,
    "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"bool\":{\"should\":[{\"term\":{\"gcp.security_command_center.severity\":\"HIGH\"}},{\"term\":{\"gcp.security_command_center.severity\":\"CRITICAL\"}}],\"minimum_should_match\":1}}]}}}",
    "index": [
      "logs-gcp.scc*"
    ],
    "timeField": "@timestamp",
    "aggType": "count"
  },
  "actions": [],
  "notify_when": "onActiveAlert"
}
