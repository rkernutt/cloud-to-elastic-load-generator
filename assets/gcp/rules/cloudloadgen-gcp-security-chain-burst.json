{
  "_meta": {
    "rule_id": "cloudloadgen-gcp-security-chain-burst",
    "group": "gcp-security-chain",
    "api": "POST /api/alerting/rule"
  },
  "name": "[CloudLoadGen] GCP Security Finding Chain — Multi-Stage Chain Burst",
  "rule_type_id": ".es-query",
  "consumer": "alerts",
  "schedule": {
    "interval": "5m"
  },
  "tags": [
    "cloudloadgen",
    "gcp-security-chain"
  ],
  "enabled": false,
  "params": {
    "searchType": "esQuery",
    "timeWindowSize": 15,
    "timeWindowUnit": "m",
    "threshold": [
      2
    ],
    "thresholdComparator": ">",
    "size": 100,
    "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"bool\":{\"should\":[{\"bool\":{\"filter\":[{\"bool\":{\"should\":[{\"term\":{\"event.dataset\":\"gcp.scc\"}},{\"term\":{\"data_stream.dataset\":\"gcp.scc\"}}],\"minimum_should_match\":1}},{\"term\":{\"event.kind\":\"alert\"}}]}},{\"bool\":{\"filter\":[{\"bool\":{\"should\":[{\"term\":{\"event.dataset\":\"gcp.secops\"}},{\"term\":{\"data_stream.dataset\":\"gcp.secops\"}}],\"minimum_should_match\":1}},{\"exists\":{\"field\":\"gcp.security_operations.action_type\"}}]}}],\"minimum_should_match\":1}}]}}}",
    "index": [
      "logs-gcp.scc*",
      "logs-gcp.secops*"
    ],
    "timeField": "@timestamp",
    "aggType": "count"
  },
  "actions": [],
  "notify_when": "onActiveAlert"
}
