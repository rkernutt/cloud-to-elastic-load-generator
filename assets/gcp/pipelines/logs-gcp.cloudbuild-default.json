{
  "_meta": {
    "pipeline_id": "logs-gcp.cloudbuild-default",
    "dataset": "gcp.cloudbuild",
    "group": "devtools",
    "api": "PUT _ingest/pipeline/logs-gcp.cloudbuild-default"
  },
  "description": "Parse JSON from message field for gcp.cloudbuild (service cloud-build)",
  "processors": [
    {
      "json": {
        "field": "message",
        "target_field": "gcp.parsed",
        "ignore_failure": true
      }
    }
  ]
}
