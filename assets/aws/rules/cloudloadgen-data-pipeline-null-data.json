{
  "_meta": {
    "rule_id": "cloudloadgen-data-pipeline-null-data",
    "group": "data-pipeline",
    "api": "POST /api/alerting/rule"
  },
  "name": "[CloudLoadGen] Data Pipeline — Null/Empty Data Detected",
  "rule_type_id": ".es-query",
  "consumer": "alerts",
  "schedule": {
    "interval": "5m"
  },
  "tags": [
    "cloudloadgen",
    "data-pipeline"
  ],
  "enabled": false,
  "params": {
    "searchType": "esQuery",
    "timeWindowSize": 15,
    "timeWindowUnit": "m",
    "threshold": [
      1
    ],
    "thresholdComparator": ">=",
    "size": 100,
    "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"term\":{\"event.dataset\":\"aws.athena\"}},{\"term\":{\"aws.athena.rows_returned\":0}}]}}}",
    "index": [
      "logs-aws.athena*"
    ],
    "timeField": "@timestamp",
    "aggType": "count"
  },
  "actions": [],
  "notify_when": "onActiveAlert"
}
