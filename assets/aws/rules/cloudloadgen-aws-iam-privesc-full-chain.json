{
  "_meta": {
    "rule_id": "cloudloadgen-aws-iam-privesc-full-chain",
    "group": "iam-privesc-chain",
    "api": "POST /api/alerting/rule"
  },
  "name": "[CloudLoadGen] IAM PrivEsc Chain — High Volume of Dangerous IAM Actions",
  "rule_type_id": ".es-query",
  "consumer": "alerts",
  "schedule": {
    "interval": "5m"
  },
  "tags": [
    "cloudloadgen",
    "iam-privesc-chain"
  ],
  "enabled": false,
  "params": {
    "searchType": "esQuery",
    "timeWindowSize": 30,
    "timeWindowUnit": "m",
    "threshold": [
      3
    ],
    "thresholdComparator": ">",
    "size": 100,
    "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"term\":{\"event.dataset\":\"aws.cloudtrail\"}},{\"exists\":{\"field\":\"user.name\"}},{\"bool\":{\"should\":[{\"term\":{\"event.action\":\"CreateAccessKey\"}},{\"bool\":{\"filter\":[{\"term\":{\"event.action\":\"AttachUserPolicy\"}},{\"match_phrase\":{\"aws.cloudtrail.request_parameters\":\"AdministratorAccess\"}}]}},{\"term\":{\"event.action\":\"AssumeRole\"}}],\"minimum_should_match\":1}}]}}}",
    "index": [
      "logs-aws.cloudtrail*"
    ],
    "timeField": "@timestamp",
    "aggType": "count"
  },
  "actions": [],
  "notify_when": "onActiveAlert"
}
