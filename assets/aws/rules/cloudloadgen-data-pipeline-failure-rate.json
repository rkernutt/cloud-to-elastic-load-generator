{
  "_meta": {
    "rule_id": "cloudloadgen-data-pipeline-failure-rate",
    "group": "data-pipeline",
    "api": "POST /api/alerting/rule"
  },
  "name": "[CloudLoadGen] Data Pipeline — High Failure Rate",
  "rule_type_id": ".es-query",
  "consumer": "alerts",
  "schedule": {
    "interval": "5m"
  },
  "tags": ["cloudloadgen", "data-pipeline"],
  "enabled": false,
  "params": {
    "searchType": "esQuery",
    "timeWindowSize": 15,
    "timeWindowUnit": "m",
    "threshold": [3],
    "thresholdComparator": ">",
    "size": 100,
    "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"term\":{\"event.dataset\":\"aws.mwaa\"}},{\"term\":{\"event.outcome\":\"failure\"}}]}}}",
    "index": ["logs-aws.mwaa*"],
    "timeField": "@timestamp",
    "aggType": "count"
  },
  "actions": [],
  "notify_when": "onActiveAlert",
  "artifacts": {
    "dashboards": [
      {
        "id": "63fc2dba-6043-44cb-a4d3-1750171c366e"
      },
      {
        "id": "f2b5c443-2b23-4b54-b2e6-d10c739558da"
      }
    ]
  }
}
