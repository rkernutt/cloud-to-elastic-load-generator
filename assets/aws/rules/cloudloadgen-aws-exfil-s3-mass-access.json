{
  "_meta": {
    "rule_id": "cloudloadgen-aws-exfil-s3-mass-access",
    "group": "data-exfil-chain",
    "api": "POST /api/alerting/rule"
  },
  "name": "[CloudLoadGen] Data Exfil Chain — S3 GetObject With High Additional Event Count",
  "rule_type_id": ".es-query",
  "consumer": "alerts",
  "schedule": {
    "interval": "5m"
  },
  "tags": ["cloudloadgen", "data-exfil-chain"],
  "enabled": false,
  "params": {
    "searchType": "esQuery",
    "timeWindowSize": 15,
    "timeWindowUnit": "m",
    "threshold": [1],
    "thresholdComparator": ">=",
    "size": 100,
    "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"term\":{\"event.dataset\":\"aws.cloudtrail\"}},{\"term\":{\"event.action\":\"GetObject\"}},{\"range\":{\"aws.cloudtrail.additional_event_count\":{\"gt\":100}}}]}}}",
    "index": ["logs-aws.cloudtrail*"],
    "timeField": "@timestamp",
    "aggType": "count"
  },
  "actions": [],
  "notify_when": "onActiveAlert",
  "artifacts": {
    "dashboards": [
      {
        "id": "536bd30f-fb50-40c4-8953-158ca8ff2f51"
      },
      {
        "id": "0874ea51-54b5-4644-b261-b69a324e0248"
      },
      {
        "id": "ed4824f0-38c9-4dc5-9588-58b65ce78b78"
      }
    ]
  }
}
