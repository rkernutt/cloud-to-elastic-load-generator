{
  "_meta": {
    "rule_id": "cloudloadgen-aws-exfil-high-egress",
    "group": "data-exfil-chain",
    "api": "POST /api/alerting/rule"
  },
  "name": "[CloudLoadGen] Data Exfil Chain — VPC Flow High Egress Bytes",
  "rule_type_id": ".es-query",
  "consumer": "alerts",
  "schedule": {
    "interval": "5m"
  },
  "tags": ["cloudloadgen", "data-exfil-chain"],
  "enabled": false,
  "params": {
    "searchType": "esQuery",
    "timeWindowSize": 15,
    "timeWindowUnit": "m",
    "threshold": [1],
    "thresholdComparator": ">=",
    "size": 100,
    "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"term\":{\"event.dataset\":\"aws.vpcflow\"}},{\"term\":{\"network.direction\":\"egress\"}},{\"range\":{\"aws.vpcflow.bytes\":{\"gt\":52428800}}}]}}}",
    "index": ["logs-aws.vpcflow*"],
    "timeField": "@timestamp",
    "aggType": "count"
  },
  "actions": [],
  "notify_when": "onActiveAlert",
  "artifacts": {
    "dashboards": [
      {
        "id": "536bd30f-fb50-40c4-8953-158ca8ff2f51"
      },
      {
        "id": "323fcb99-a898-4dc5-ab33-6136c1848e46"
      }
    ]
  }
}
