{
  "_meta": {
    "rule_id": "cloudloadgen-aws-iam-assume-role-chain",
    "group": "iam-privesc-chain",
    "api": "POST /api/alerting/rule"
  },
  "name": "[CloudLoadGen] IAM PrivEsc Chain — AssumeRole With Privilege-Escalation Tactic",
  "rule_type_id": ".es-query",
  "consumer": "alerts",
  "schedule": {
    "interval": "5m"
  },
  "tags": ["cloudloadgen", "iam-privesc-chain"],
  "enabled": false,
  "params": {
    "searchType": "esQuery",
    "timeWindowSize": 15,
    "timeWindowUnit": "m",
    "threshold": [1],
    "thresholdComparator": ">=",
    "size": 100,
    "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"term\":{\"event.dataset\":\"aws.cloudtrail\"}},{\"term\":{\"event.action\":\"AssumeRole\"}},{\"exists\":{\"field\":\"threat.tactic.name\"}}]}}}",
    "index": ["logs-aws.cloudtrail*"],
    "timeField": "@timestamp",
    "aggType": "count"
  },
  "actions": [],
  "notify_when": "onActiveAlert",
  "artifacts": {
    "dashboards": [
      {
        "id": "8b3125da-2da6-4fdc-b704-c24347e3b5a6"
      },
      {
        "id": "0874ea51-54b5-4644-b261-b69a324e0248"
      }
    ]
  }
}
