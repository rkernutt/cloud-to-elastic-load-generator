{
  "_meta": {
    "rule_id": "cloudloadgen-aws-security-unique-source-ips",
    "group": "security-chain",
    "api": "POST /api/alerting/rule"
  },
  "name": "[CloudLoadGen] Security Finding Chain — Multiple GuardDuty Alerts With Source IP",
  "rule_type_id": ".es-query",
  "consumer": "alerts",
  "schedule": {
    "interval": "5m"
  },
  "tags": [
    "cloudloadgen",
    "security-chain"
  ],
  "enabled": false,
  "params": {
    "searchType": "esQuery",
    "timeWindowSize": 30,
    "timeWindowUnit": "m",
    "threshold": [
      5
    ],
    "thresholdComparator": ">",
    "size": 100,
    "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"term\":{\"event.dataset\":\"aws.guardduty\"}},{\"term\":{\"event.kind\":\"alert\"}},{\"exists\":{\"field\":\"source.ip\"}}]}}}",
    "index": [
      "logs-aws.guardduty*"
    ],
    "timeField": "@timestamp",
    "aggType": "count"
  },
  "actions": [],
  "notify_when": "onActiveAlert"
}
