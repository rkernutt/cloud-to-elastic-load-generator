{
  "_meta": {
    "rule_id": "cloudloadgen-aws-security-high-severity-finding",
    "group": "security-chain",
    "api": "POST /api/alerting/rule"
  },
  "name": "[CloudLoadGen] Security Finding Chain — GuardDuty HIGH/CRITICAL Findings",
  "rule_type_id": ".es-query",
  "consumer": "alerts",
  "schedule": {
    "interval": "5m"
  },
  "tags": ["cloudloadgen", "security-chain"],
  "enabled": false,
  "params": {
    "searchType": "esQuery",
    "timeWindowSize": 15,
    "timeWindowUnit": "m",
    "threshold": [0],
    "thresholdComparator": ">",
    "size": 100,
    "esQuery": "{\"query\":{\"bool\":{\"filter\":[{\"term\":{\"event.dataset\":\"aws.guardduty\"}},{\"bool\":{\"should\":[{\"term\":{\"aws.guardduty.severity.value\":\"High\"}},{\"term\":{\"aws.guardduty.severity.value\":\"Critical\"}}],\"minimum_should_match\":1}}]}}}",
    "index": ["logs-aws.guardduty*"],
    "timeField": "@timestamp",
    "aggType": "count"
  },
  "actions": [],
  "notify_when": "onActiveAlert",
  "artifacts": {
    "dashboards": [
      {
        "id": "5b3080b9-0db3-4c3b-9625-808910425e61"
      },
      {
        "id": "800c7d33-8f8f-43b3-b825-0f4edbddd030"
      }
    ]
  }
}
