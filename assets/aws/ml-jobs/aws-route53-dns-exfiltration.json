{
  "_meta": {
    "job_id": "aws-route53-dns-exfiltration",
    "group": "siem",
    "api_job": "PUT _ml/anomaly_detectors/aws-route53-dns-exfiltration",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-aws-route53-dns-exfiltration",
    "api_open": "POST _ml/anomaly_detectors/aws-route53-dns-exfiltration/_open",
    "api_start": "POST _ml/datafeeds/datafeed-aws-route53-dns-exfiltration/_start"
  },
  "job": {
    "description": "Detects unusually high DNS query volumes per source IP — DNS tunneling or command-and-control traffic encoded as DNS queries",
    "groups": [
      "aws",
      "siem",
      "cloudloadgen"
    ],
    "analysis_config": {
      "bucket_span": "15m",
      "detectors": [
        {
          "detector_description": "high_count over=source.ip",
          "function": "high_count",
          "over_field_name": "source.ip",
          "detector_index": 0
        }
      ],
      "influencers": [
        "source.ip",
        "cloud.account.id",
        "cloud.region"
      ]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "64mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "aws-elastic-load-generator",
      "tags": [
        "cloudloadgen"
      ]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-aws-route53-dns-exfiltration",
    "job_id": "aws-route53-dns-exfiltration",
    "indices": [
      "logs-aws.*"
    ],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "event.dataset": "aws.route53_public_logs"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
