{
  "_meta": {
    "job_id": "aws-vpcflow-high-bytes-tx",
    "group": "security",
    "api_job": "PUT _ml/anomaly_detectors/aws-vpcflow-high-bytes-tx",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-aws-vpcflow-high-bytes-tx",
    "api_open": "POST _ml/anomaly_detectors/aws-vpcflow-high-bytes-tx/_open",
    "api_start": "POST _ml/datafeeds/datafeed-aws-vpcflow-high-bytes-tx/_start"
  },
  "job": {
    "description": "Detects unusual spikes in outbound network bytes from a single source IP (potential data exfiltration)",
    "groups": [
      "aws",
      "security",
      "cloudloadgen"
    ],
    "analysis_config": {
      "bucket_span": "15m",
      "detectors": [
        {
          "detector_description": "high_sum(network.bytes) partitionfield=source.ip",
          "function": "high_sum",
          "field_name": "network.bytes",
          "partition_field_name": "source.ip",
          "detector_index": 0
        }
      ],
      "influencers": [
        "source.ip",
        "destination.port"
      ]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "32mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "aws-elastic-load-generator",
      "tags": [
        "cloudloadgen"
      ]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-aws-vpcflow-high-bytes-tx",
    "job_id": "aws-vpcflow-high-bytes-tx",
    "indices": [
      "logs-aws.*"
    ],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "event.dataset": "aws.vpcflow"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
