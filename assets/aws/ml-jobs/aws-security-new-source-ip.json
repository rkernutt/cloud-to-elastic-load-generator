{
  "_meta": {
    "job_id": "aws-security-new-source-ip",
    "group": "security-chain",
    "api_job": "PUT _ml/anomaly_detectors/aws-security-new-source-ip",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-aws-security-new-source-ip",
    "api_open": "POST _ml/anomaly_detectors/aws-security-new-source-ip/_open",
    "api_start": "POST _ml/datafeeds/datafeed-aws-security-new-source-ip/_start"
  },
  "job": {
    "description": "Detects rare source IPs in security findings",
    "groups": [
      "aws",
      "security-chain",
      "cloudloadgen"
    ],
    "analysis_config": {
      "bucket_span": "15m",
      "detectors": [
        {
          "detector_description": "rare by source.ip",
          "function": "rare",
          "by_field_name": "source.ip",
          "detector_index": 0
        }
      ],
      "influencers": [
        "source.ip",
        "aws.guardduty.type",
        "cloud.region"
      ]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "64mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "aws-load-generator-security-finding-chain",
      "tags": [
        "cloudloadgen"
      ]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-aws-security-new-source-ip",
    "job_id": "aws-security-new-source-ip",
    "indices": [
      "logs-aws.guardduty*"
    ],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "event.kind": "alert"
            }
          },
          {
            "term": {
              "event.dataset": "aws.guardduty"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
