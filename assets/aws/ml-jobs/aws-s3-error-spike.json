{
  "_meta": {
    "job_id": "aws-s3-error-spike",
    "group": "storage",
    "api_job": "PUT _ml/anomaly_detectors/aws-s3-error-spike",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-aws-s3-error-spike",
    "api_open": "POST _ml/anomaly_detectors/aws-s3-error-spike/_open",
    "api_start": "POST _ml/datafeeds/datafeed-aws-s3-error-spike/_start"
  },
  "job": {
    "description": "Detects spikes in S3 client errors (4xx) per bucket",
    "groups": ["aws", "storage", "cloudloadgen"],
    "analysis_config": {
      "bucket_span": "15m",
      "detectors": [
        {
          "detector_description": "High count of S3 4xx client errors by bucket",
          "function": "high_count",
          "partition_field_name": "aws.s3.bucket.name",
          "detector_index": 0
        }
      ],
      "influencers": ["aws.s3.bucket.name", "client.ip"]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "32mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "aws-elastic-load-generator",
      "tags": ["cloudloadgen"]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-aws-s3-error-spike",
    "job_id": "aws-s3-error-spike",
    "indices": ["logs-aws.*"],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "event.dataset": "aws.s3"
            }
          }
        ],
        "must": [
          {
            "range": {
              "aws.s3access.http_status": {
                "gte": 400,
                "lt": 500
              }
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
