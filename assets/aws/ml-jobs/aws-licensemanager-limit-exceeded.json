{
  "_meta": {
    "job_id": "aws-licensemanager-limit-exceeded",
    "group": "aws-ml-extended-services-a",
    "api_job": "PUT _ml/anomaly_detectors/aws-licensemanager-limit-exceeded",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-aws-licensemanager-limit-exceeded",
    "api_open": "POST _ml/anomaly_detectors/aws-licensemanager-limit-exceeded/_open",
    "api_start": "POST _ml/datafeeds/datafeed-aws-licensemanager-limit-exceeded/_start"
  },
  "job": {
    "description": "Detects anomalous counts of License Manager limit exceeded events (license entitlement exhaustion or over-deployment)",
    "groups": ["aws", "aws-ml-extended-services-a", "cloudloadgen"],
    "analysis_config": {
      "bucket_span": "60m",
      "detectors": [
        {
          "detector_description": "count",
          "function": "count",
          "detector_index": 0
        }
      ],
      "influencers": ["cloud.account.id", "cloud.region"]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "16mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "aws-elastic-load-generator",
      "tags": ["cloudloadgen"]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-aws-licensemanager-limit-exceeded",
    "job_id": "aws-licensemanager-limit-exceeded",
    "indices": ["logs-aws.*"],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "event.dataset": "aws.licensemanager"
            }
          },
          {
            "term": {
              "aws.licensemanager.status": "LimitExceeded"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
