{
  "_meta": {
    "job_id": "aws-emr-apm-stage-duration-anomaly",
    "group": "apm-traces",
    "api_job": "PUT _ml/anomaly_detectors/aws-emr-apm-stage-duration-anomaly",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-aws-emr-apm-stage-duration-anomaly",
    "api_open": "POST _ml/anomaly_detectors/aws-emr-apm-stage-duration-anomaly/_open",
    "api_start": "POST _ml/datafeeds/datafeed-aws-emr-apm-stage-duration-anomaly/_start"
  },
  "job": {
    "description": "Detects unusually slow EMR Spark stages — data skew, shuffle bottlenecks, or executor resource contention",
    "groups": ["apm", "traces", "emr", "cloudloadgen"],
    "analysis_config": {
      "bucket_span": "30m",
      "detectors": [
        {
          "detector_description": "high_mean(span.duration.us) partitionfield=labels.spark_stage_id",
          "function": "high_mean",
          "field_name": "span.duration.us",
          "partition_field_name": "labels.spark_stage_id",
          "detector_index": 0
        }
      ],
      "influencers": ["service.name", "labels.spark_stage_id", "labels.emr_cluster_id"]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "32mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "aws-elastic-load-generator",
      "tags": ["cloudloadgen"]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-aws-emr-apm-stage-duration-anomaly",
    "job_id": "aws-emr-apm-stage-duration-anomaly",
    "indices": ["traces-apm-*"],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "processor.event": "span"
            }
          },
          {
            "term": {
              "span.subtype": "spark"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
