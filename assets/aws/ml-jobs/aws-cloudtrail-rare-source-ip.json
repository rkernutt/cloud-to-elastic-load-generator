{
  "_meta": {
    "job_id": "aws-cloudtrail-rare-source-ip",
    "group": "siem",
    "api_job": "PUT _ml/anomaly_detectors/aws-cloudtrail-rare-source-ip",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-aws-cloudtrail-rare-source-ip",
    "api_open": "POST _ml/anomaly_detectors/aws-cloudtrail-rare-source-ip/_open",
    "api_start": "POST _ml/datafeeds/datafeed-aws-cloudtrail-rare-source-ip/_start"
  },
  "job": {
    "description": "Detects API calls from unusual or previously unseen source IPs — geographic anomalies, impossible travel, or compromised credentials in use",
    "groups": [
      "aws",
      "siem",
      "cloudloadgen"
    ],
    "analysis_config": {
      "bucket_span": "60m",
      "detectors": [
        {
          "detector_description": "rare by=source.ip over=user.name",
          "function": "rare",
          "by_field_name": "source.ip",
          "over_field_name": "user.name",
          "detector_index": 0
        }
      ],
      "influencers": [
        "user.name",
        "source.ip",
        "cloud.region"
      ]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "128mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "aws-elastic-load-generator",
      "tags": [
        "cloudloadgen"
      ]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-aws-cloudtrail-rare-source-ip",
    "job_id": "aws-cloudtrail-rare-source-ip",
    "indices": [
      "logs-aws.cloudtrail-*"
    ],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "event.dataset": "aws.cloudtrail"
            }
          },
          {
            "exists": {
              "field": "user.name"
            }
          },
          {
            "exists": {
              "field": "source.ip"
            }
          }
        ],
        "must_not": [
          {
            "term": {
              "source.ip": "AWS Internal"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
