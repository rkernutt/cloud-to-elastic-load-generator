{
  "_meta": {
    "job_id": "aws-cloudfront-error-rate-spike",
    "group": "networking-extended",
    "api_job": "PUT _ml/anomaly_detectors/aws-cloudfront-error-rate-spike",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-aws-cloudfront-error-rate-spike",
    "api_open": "POST _ml/anomaly_detectors/aws-cloudfront-error-rate-spike/_open",
    "api_start": "POST _ml/datafeeds/datafeed-aws-cloudfront-error-rate-spike/_start"
  },
  "job": {
    "description": "Detects unusual CDN error rates in CloudFront — origin failures and availability issues",
    "groups": [
      "aws",
      "networking-extended",
      "cloudloadgen"
    ],
    "analysis_config": {
      "bucket_span": "15m",
      "detectors": [
        {
          "detector_description": "High count of CloudFront 5xx error responses",
          "function": "high_count",
          "detector_index": 0
        }
      ],
      "influencers": [
        "cloud.region",
        "source.ip"
      ]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "16mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "aws-elastic-load-generator",
      "tags": [
        "cloudloadgen"
      ]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-aws-cloudfront-error-rate-spike",
    "job_id": "aws-cloudfront-error-rate-spike",
    "indices": [
      "logs-aws.*"
    ],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "event.dataset": "aws.cloudfront_logs"
            }
          },
          {
            "range": {
              "http.response.status_code": {
                "gte": 500
              }
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
