{
  "_meta": {
    "job_id": "aws-elasticache-latency-spike",
    "group": "databases",
    "api_job": "PUT _ml/anomaly_detectors/aws-elasticache-latency-spike",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-aws-elasticache-latency-spike",
    "api_open": "POST _ml/anomaly_detectors/aws-elasticache-latency-spike/_open",
    "api_start": "POST _ml/datafeeds/datafeed-aws-elasticache-latency-spike/_start"
  },
  "job": {
    "description": "Detects unusual command latency spikes in ElastiCache",
    "groups": [
      "aws",
      "databases",
      "cloudloadgen"
    ],
    "analysis_config": {
      "bucket_span": "15m",
      "detectors": [
        {
          "detector_description": "High mean ElastiCache traffic-based command latency by cluster",
          "function": "high_mean",
          "field_name": "aws.elasticache.metrics.TrafficBasedCmdsLatency.avg",
          "partition_field_name": "aws.elasticache.cluster_id",
          "detector_index": 0
        }
      ],
      "influencers": [
        "aws.elasticache.cluster_id",
        "cloud.region"
      ]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "32mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "aws-elastic-load-generator",
      "tags": [
        "cloudloadgen"
      ]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-aws-elasticache-latency-spike",
    "job_id": "aws-elasticache-latency-spike",
    "indices": [
      "logs-aws.*"
    ],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "event.dataset": "aws.elasticache"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
