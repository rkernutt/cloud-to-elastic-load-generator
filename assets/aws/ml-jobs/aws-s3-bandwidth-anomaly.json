{
  "_meta": {
    "job_id": "aws-s3-bandwidth-anomaly",
    "group": "storage",
    "api_job": "PUT _ml/anomaly_detectors/aws-s3-bandwidth-anomaly",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-aws-s3-bandwidth-anomaly",
    "api_open": "POST _ml/anomaly_detectors/aws-s3-bandwidth-anomaly/_open",
    "api_start": "POST _ml/datafeeds/datafeed-aws-s3-bandwidth-anomaly/_start"
  },
  "job": {
    "description": "Detects unusual data transfer volumes from S3 buckets",
    "groups": [
      "aws",
      "storage",
      "cloudloadgen"
    ],
    "analysis_config": {
      "bucket_span": "15m",
      "detectors": [
        {
          "detector_description": "High sum of bytes sent by S3 bucket",
          "function": "high_sum",
          "field_name": "aws.s3access.bytes_sent",
          "partition_field_name": "aws.s3.bucket.name",
          "detector_index": 0
        }
      ],
      "influencers": [
        "aws.s3.bucket.name",
        "client.ip"
      ]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "32mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "aws-elastic-load-generator",
      "tags": [
        "cloudloadgen"
      ]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-aws-s3-bandwidth-anomaly",
    "job_id": "aws-s3-bandwidth-anomaly",
    "indices": [
      "logs-aws.*"
    ],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "event.dataset": "aws.s3"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
