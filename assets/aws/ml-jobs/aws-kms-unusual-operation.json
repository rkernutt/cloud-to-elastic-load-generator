{
  "_meta": {
    "job_id": "aws-kms-unusual-operation",
    "group": "security-extended",
    "api_job": "PUT _ml/anomaly_detectors/aws-kms-unusual-operation",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-aws-kms-unusual-operation",
    "api_open": "POST _ml/anomaly_detectors/aws-kms-unusual-operation/_open",
    "api_start": "POST _ml/datafeeds/datafeed-aws-kms-unusual-operation/_start"
  },
  "job": {
    "description": "Detects rare/unusual KMS key operations — may indicate credential abuse or unusual access patterns",
    "groups": ["aws", "security-extended", "cloudloadgen"],
    "analysis_config": {
      "bucket_span": "60m",
      "detectors": [
        {
          "detector_description": "rare by=aws.kms.operation partitionfield=cloud.account.id",
          "function": "rare",
          "by_field_name": "aws.kms.operation",
          "partition_field_name": "cloud.account.id",
          "detector_index": 0
        }
      ],
      "influencers": ["aws.kms.operation", "cloud.account.id", "user.name"]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "64mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "aws-elastic-load-generator",
      "tags": ["cloudloadgen"]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-aws-kms-unusual-operation",
    "job_id": "aws-kms-unusual-operation",
    "indices": ["logs-aws.*"],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "event.dataset": "aws.kms"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
