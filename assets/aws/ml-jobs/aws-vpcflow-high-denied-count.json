{
  "_meta": {
    "job_id": "aws-vpcflow-high-denied-count",
    "group": "security",
    "api_job": "PUT _ml/anomaly_detectors/aws-vpcflow-high-denied-count",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-aws-vpcflow-high-denied-count",
    "api_open": "POST _ml/anomaly_detectors/aws-vpcflow-high-denied-count/_open",
    "api_start": "POST _ml/datafeeds/datafeed-aws-vpcflow-high-denied-count/_start"
  },
  "job": {
    "description": "Detects spikes in REJECT/denied traffic from a source IP (reconnaissance or brute force)",
    "groups": ["aws", "security", "cloudloadgen"],
    "analysis_config": {
      "bucket_span": "15m",
      "detectors": [
        {
          "detector_description": "high_count partitionfield=source.ip",
          "function": "high_count",
          "partition_field_name": "source.ip",
          "detector_index": 0
        }
      ],
      "influencers": ["source.ip", "destination.port"]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "32mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "aws-elastic-load-generator",
      "tags": ["cloudloadgen"]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-aws-vpcflow-high-denied-count",
    "job_id": "aws-vpcflow-high-denied-count",
    "indices": ["logs-aws.*"],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "event.dataset": "aws.vpcflow"
            }
          },
          {
            "term": {
              "event.action": "REJECT"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
