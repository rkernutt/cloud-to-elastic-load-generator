{
  "_meta": {
    "job_id": "apm-error-rate-spike",
    "group": "apm-traces",
    "api_job": "PUT _ml/anomaly_detectors/apm-error-rate-spike",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-apm-error-rate-spike",
    "api_open": "POST _ml/anomaly_detectors/apm-error-rate-spike/_open",
    "api_start": "POST _ml/datafeeds/datafeed-apm-error-rate-spike/_start"
  },
  "job": {
    "description": "Detects spikes in transaction error rate per service — deployment failures and upstream dependency issues",
    "groups": ["apm", "traces", "cloudloadgen"],
    "analysis_config": {
      "bucket_span": "15m",
      "detectors": [
        {
          "detector_description": "high_count partitionfield=service.name",
          "function": "high_count",
          "partition_field_name": "service.name",
          "detector_index": 0
        }
      ],
      "influencers": ["service.name", "service.environment", "transaction.name"]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "32mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "aws-elastic-load-generator",
      "tags": ["cloudloadgen"]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-apm-error-rate-spike",
    "job_id": "apm-error-rate-spike",
    "indices": ["traces-apm-*"],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "processor.event": "transaction"
            }
          },
          {
            "term": {
              "event.outcome": "failure"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
