{
  "_meta": {
    "job_id": "aws-entityresolution-job-failure",
    "group": "new-services",
    "api_job": "PUT _ml/anomaly_detectors/aws-entityresolution-job-failure",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-aws-entityresolution-job-failure",
    "api_open": "POST _ml/anomaly_detectors/aws-entityresolution-job-failure/_open",
    "api_start": "POST _ml/datafeeds/datafeed-aws-entityresolution-job-failure/_start"
  },
  "job": {
    "description": "Detects anomalous counts of Entity Resolution job failures (identity graph pipeline issues)",
    "groups": [
      "aws",
      "new-services",
      "cloudloadgen"
    ],
    "analysis_config": {
      "bucket_span": "60m",
      "detectors": [
        {
          "detector_description": "count",
          "function": "count",
          "detector_index": 0
        }
      ],
      "influencers": [
        "cloud.region",
        "cloud.account.id"
      ]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "16mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "aws-elastic-load-generator",
      "tags": [
        "cloudloadgen"
      ]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-aws-entityresolution-job-failure",
    "job_id": "aws-entityresolution-job-failure",
    "indices": [
      "logs-aws.*"
    ],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "event.dataset": "aws.entityresolution"
            }
          },
          {
            "term": {
              "event.outcome": "failure"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
