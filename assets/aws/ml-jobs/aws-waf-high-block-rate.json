{
  "_meta": {
    "job_id": "aws-waf-high-block-rate",
    "group": "security",
    "api_job": "PUT _ml/anomaly_detectors/aws-waf-high-block-rate",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-aws-waf-high-block-rate",
    "api_open": "POST _ml/anomaly_detectors/aws-waf-high-block-rate/_open",
    "api_start": "POST _ml/datafeeds/datafeed-aws-waf-high-block-rate/_start"
  },
  "job": {
    "description": "Detects unusual spikes in WAF block events from a source IP (attack campaigns or bot activity)",
    "groups": [
      "aws",
      "security",
      "cloudloadgen"
    ],
    "analysis_config": {
      "bucket_span": "15m",
      "detectors": [
        {
          "detector_description": "high_count partitionfield=source.ip",
          "function": "high_count",
          "partition_field_name": "source.ip",
          "detector_index": 0
        }
      ],
      "influencers": [
        "source.ip",
        "http.request.method"
      ]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "32mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "aws-elastic-load-generator",
      "tags": [
        "cloudloadgen"
      ]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-aws-waf-high-block-rate",
    "job_id": "aws-waf-high-block-rate",
    "indices": [
      "logs-aws.*"
    ],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "event.dataset": "aws.waf"
            }
          },
          {
            "term": {
              "event.action": "block"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
