{
  "_meta": {
    "job_id": "aws-inspector-critical-vuln-spike",
    "group": "security-extended",
    "api_job": "PUT _ml/anomaly_detectors/aws-inspector-critical-vuln-spike",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-aws-inspector-critical-vuln-spike",
    "api_open": "POST _ml/anomaly_detectors/aws-inspector-critical-vuln-spike/_open",
    "api_start": "POST _ml/datafeeds/datafeed-aws-inspector-critical-vuln-spike/_start"
  },
  "job": {
    "description": "Detects unusual spikes in critical Inspector vulnerability findings per instance",
    "groups": ["aws", "security-extended", "cloudloadgen"],
    "analysis_config": {
      "bucket_span": "15m",
      "detectors": [
        {
          "detector_description": "high_mean(aws.inspector2.metrics.CriticalFindings.sum) partitionfield=cloud.instance.id",
          "function": "high_mean",
          "field_name": "aws.inspector2.metrics.CriticalFindings.sum",
          "partition_field_name": "cloud.instance.id",
          "detector_index": 0
        }
      ],
      "influencers": ["cloud.instance.id", "cloud.region"]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "32mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "aws-elastic-load-generator",
      "tags": ["cloudloadgen"]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-aws-inspector-critical-vuln-spike",
    "job_id": "aws-inspector-critical-vuln-spike",
    "indices": ["logs-aws.*"],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "event.dataset": "aws.inspector2"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
