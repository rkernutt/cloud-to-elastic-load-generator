{
  "_meta": {
    "job_id": "aws-data-exfil-rare-destination",
    "group": "data-exfil-chain",
    "api_job": "PUT _ml/anomaly_detectors/aws-data-exfil-rare-destination",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-aws-data-exfil-rare-destination",
    "api_open": "POST _ml/anomaly_detectors/aws-data-exfil-rare-destination/_open",
    "api_start": "POST _ml/datafeeds/datafeed-aws-data-exfil-rare-destination/_start"
  },
  "job": {
    "description": "Detects connections to rare external IPs during exfil events",
    "groups": ["aws", "data-exfil-chain", "cloudloadgen"],
    "analysis_config": {
      "bucket_span": "15m",
      "detectors": [
        {
          "detector_description": "rare by destination.ip",
          "function": "rare",
          "by_field_name": "destination.ip",
          "detector_index": 0
        }
      ],
      "influencers": ["destination.ip", "source.ip", "cloud.region"]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "64mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "aws-load-generator-data-exfil-chain",
      "tags": ["cloudloadgen"]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-aws-data-exfil-rare-destination",
    "job_id": "aws-data-exfil-rare-destination",
    "indices": ["logs-aws.vpcflow*"],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "network.direction": "egress"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
