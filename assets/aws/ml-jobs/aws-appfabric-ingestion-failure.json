{
  "_meta": {
    "job_id": "aws-appfabric-ingestion-failure",
    "group": "aws-ml-extended-services-a",
    "api_job": "PUT _ml/anomaly_detectors/aws-appfabric-ingestion-failure",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-aws-appfabric-ingestion-failure",
    "api_open": "POST _ml/anomaly_detectors/aws-appfabric-ingestion-failure/_open",
    "api_start": "POST _ml/datafeeds/datafeed-aws-appfabric-ingestion-failure/_start"
  },
  "job": {
    "description": "Detects spikes in AppFabric SaaS audit log ingestion failures per application (data pipeline or connector issues)",
    "groups": ["aws", "aws-ml-extended-services-a", "cloudloadgen"],
    "analysis_config": {
      "bucket_span": "15m",
      "detectors": [
        {
          "detector_description": "high_count by event.outcome=failure partitionfield=aws.appfabric.application",
          "function": "high_count",
          "by_field_name": "event.outcome",
          "partition_field_name": "aws.appfabric.application",
          "detector_index": 0
        }
      ],
      "influencers": ["aws.appfabric.application", "cloud.account.id", "cloud.region"]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "32mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "aws-elastic-load-generator",
      "tags": ["cloudloadgen"]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-aws-appfabric-ingestion-failure",
    "job_id": "aws-appfabric-ingestion-failure",
    "indices": ["logs-aws.*"],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "event.dataset": "aws.appfabric"
            }
          },
          {
            "term": {
              "event.outcome": "failure"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
