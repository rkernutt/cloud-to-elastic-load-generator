{
  "_meta": {
    "job_id": "aws-connect-handle-time-anomaly",
    "group": "media",
    "api_job": "PUT _ml/anomaly_detectors/aws-connect-handle-time-anomaly",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-aws-connect-handle-time-anomaly",
    "api_open": "POST _ml/anomaly_detectors/aws-connect-handle-time-anomaly/_open",
    "api_start": "POST _ml/datafeeds/datafeed-aws-connect-handle-time-anomaly/_start"
  },
  "job": {
    "description": "Detects unusual agent handle time per Connect queue — training gaps, system slowness, or complex call types",
    "groups": ["aws", "media", "cloudloadgen"],
    "analysis_config": {
      "bucket_span": "30m",
      "detectors": [
        {
          "detector_description": "high_mean(event.duration) partitionfield=aws.connect.queue.name",
          "function": "high_mean",
          "field_name": "event.duration",
          "partition_field_name": "aws.connect.queue_name",
          "detector_index": 0
        }
      ],
      "influencers": ["aws.connect.queue_name", "aws.connect.agent_id"]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "32mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "aws-elastic-load-generator",
      "tags": ["cloudloadgen"]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-aws-connect-handle-time-anomaly",
    "job_id": "aws-connect-handle-time-anomaly",
    "indices": ["logs-aws.*"],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "event.dataset": "aws.connect"
            }
          },
          {
            "exists": {
              "field": "event.duration"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
