{
  "_meta": {
    "job_id": "aws-lambda-cold-start-spike",
    "group": "serverless",
    "api_job": "PUT _ml/anomaly_detectors/aws-lambda-cold-start-spike",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-aws-lambda-cold-start-spike",
    "api_open": "POST _ml/anomaly_detectors/aws-lambda-cold-start-spike/_open",
    "api_start": "POST _ml/datafeeds/datafeed-aws-lambda-cold-start-spike/_start"
  },
  "job": {
    "description": "Detects unusual spikes in Lambda cold start (init) events per function — scaling pressure or deployment issues",
    "groups": ["aws", "serverless", "cloudloadgen"],
    "analysis_config": {
      "bucket_span": "15m",
      "detectors": [
        {
          "detector_description": "high_count partitionfield=aws.lambda.function.name",
          "function": "high_count",
          "partition_field_name": "aws.lambda.function.name",
          "detector_index": 0
        }
      ],
      "influencers": ["aws.lambda.function.name", "cloud.region"]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "32mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "aws-elastic-load-generator",
      "tags": ["cloudloadgen"]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-aws-lambda-cold-start-spike",
    "job_id": "aws-lambda-cold-start-spike",
    "indices": ["logs-aws.*"],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "event.dataset": "aws.lambda_logs"
            }
          },
          {
            "term": {
              "aws.lambda.cold_start": true
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
