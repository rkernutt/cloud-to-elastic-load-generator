{
  "_meta": {
    "job_id": "aws-apigateway-throttle-spike",
    "group": "serverless",
    "api_job": "PUT _ml/anomaly_detectors/aws-apigateway-throttle-spike",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-aws-apigateway-throttle-spike",
    "api_open": "POST _ml/anomaly_detectors/aws-apigateway-throttle-spike/_open",
    "api_start": "POST _ml/datafeeds/datafeed-aws-apigateway-throttle-spike/_start"
  },
  "job": {
    "description": "Detects unusual spikes in API Gateway throttled requests (429) — quota exhaustion or abuse",
    "groups": [
      "aws",
      "serverless",
      "cloudloadgen"
    ],
    "analysis_config": {
      "bucket_span": "15m",
      "detectors": [
        {
          "detector_description": "high_count",
          "function": "high_count",
          "detector_index": 0
        }
      ],
      "influencers": [
        "aws.apigateway.stage",
        "cloud.region"
      ]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "16mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "aws-elastic-load-generator",
      "tags": [
        "cloudloadgen"
      ]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-aws-apigateway-throttle-spike",
    "job_id": "aws-apigateway-throttle-spike",
    "indices": [
      "logs-aws.*"
    ],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "event.dataset": "aws.apigateway"
            }
          },
          {
            "term": {
              "http.response.status_code": 429
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
