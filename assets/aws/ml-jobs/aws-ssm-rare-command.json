{
  "_meta": {
    "job_id": "aws-ssm-rare-command",
    "group": "management",
    "api_job": "PUT _ml/anomaly_detectors/aws-ssm-rare-command",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-aws-ssm-rare-command",
    "api_open": "POST _ml/anomaly_detectors/aws-ssm-rare-command/_open",
    "api_start": "POST _ml/datafeeds/datafeed-aws-ssm-rare-command/_start"
  },
  "job": {
    "description": "Detects rare or unusual Systems Manager commands per instance — indicates lateral movement, privilege abuse, or unauthorised admin activity",
    "groups": ["aws", "management", "cloudloadgen"],
    "analysis_config": {
      "bucket_span": "60m",
      "detectors": [
        {
          "detector_description": "rare byfield=event.action partitionfield=cloud.instance.id",
          "function": "rare",
          "by_field_name": "event.action",
          "partition_field_name": "cloud.instance.id",
          "detector_index": 0
        }
      ],
      "influencers": ["event.action", "cloud.instance.id", "user.name"]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "64mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "aws-elastic-load-generator",
      "tags": ["cloudloadgen"]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-aws-ssm-rare-command",
    "job_id": "aws-ssm-rare-command",
    "indices": ["logs-aws.*"],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "event.dataset": "aws.ssm"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
