{
  "_meta": {
    "job_id": "aws-codecatalyst-workflow-failure-spike",
    "group": "new-services",
    "api_job": "PUT _ml/anomaly_detectors/aws-codecatalyst-workflow-failure-spike",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-aws-codecatalyst-workflow-failure-spike",
    "api_open": "POST _ml/anomaly_detectors/aws-codecatalyst-workflow-failure-spike/_open",
    "api_start": "POST _ml/datafeeds/datafeed-aws-codecatalyst-workflow-failure-spike/_start"
  },
  "job": {
    "description": "Detects spikes in CodeCatalyst workflow failures per project (CI/CD pipeline degradation)",
    "groups": ["aws", "new-services", "cloudloadgen"],
    "analysis_config": {
      "bucket_span": "15m",
      "detectors": [
        {
          "detector_description": "high_count partitionfield=aws.codecatalyst.project_name",
          "function": "high_count",
          "partition_field_name": "aws.codecatalyst.project_name",
          "detector_index": 0
        }
      ],
      "influencers": ["aws.codecatalyst.project_name", "cloud.region"]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "32mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "aws-elastic-load-generator",
      "tags": ["cloudloadgen"]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-aws-codecatalyst-workflow-failure-spike",
    "job_id": "aws-codecatalyst-workflow-failure-spike",
    "indices": ["logs-aws.*"],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "event.dataset": "aws.codecatalyst"
            }
          },
          {
            "term": {
              "event.outcome": "failure"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
