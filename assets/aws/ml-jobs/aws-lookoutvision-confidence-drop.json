{
  "_meta": {
    "job_id": "aws-lookoutvision-confidence-drop",
    "group": "aws-ml-edge-ai-supplement",
    "api_job": "PUT _ml/anomaly_detectors/aws-lookoutvision-confidence-drop",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-aws-lookoutvision-confidence-drop",
    "api_open": "POST _ml/anomaly_detectors/aws-lookoutvision-confidence-drop/_open",
    "api_start": "POST _ml/datafeeds/datafeed-aws-lookoutvision-confidence-drop/_start"
  },
  "job": {
    "job_id": "aws-lookoutvision-confidence-drop",
    "description": "Detects drops in model confidence per Lookout for Vision project",
    "groups": [
      "aws",
      "aws-ml-edge-ai-supplement",
      "cloudloadgen"
    ],
    "analysis_config": {
      "bucket_span": "15m",
      "detectors": [
        {
          "detector_description": "low_mean(aws.lookoutvision.confidence) by aws.lookoutvision.project_name",
          "function": "low_mean",
          "field_name": "aws.lookoutvision.confidence",
          "by_field_name": "aws.lookoutvision.project_name"
        }
      ],
      "influencers": [
        "aws.lookoutvision.project_name",
        "aws.lookoutvision.model_version",
        "cloud.account.id"
      ]
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "model_plot_config": {
      "enabled": false
    },
    "analysis_limits": {
      "model_memory_limit": "32mb"
    },
    "allow_lazy_open": true
  },
  "datafeed": {
    "datafeed_id": "datafeed-aws-lookoutvision-confidence-drop",
    "job_id": "aws-lookoutvision-confidence-drop",
    "indices": [
      "logs-aws.lookoutvision*"
    ],
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "event.dataset": "aws.lookoutvision"
            }
          }
        ]
      }
    },
    "scroll_size": 1000,
    "query_delay": "60s"
  }
}
