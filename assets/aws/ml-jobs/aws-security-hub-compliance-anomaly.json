{
  "_meta": {
    "job_id": "aws-security-hub-compliance-anomaly",
    "group": "security-chain",
    "api_job": "PUT _ml/anomaly_detectors/aws-security-hub-compliance-anomaly",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-aws-security-hub-compliance-anomaly",
    "api_open": "POST _ml/anomaly_detectors/aws-security-hub-compliance-anomaly/_open",
    "api_start": "POST _ml/datafeeds/datafeed-aws-security-hub-compliance-anomaly/_start"
  },
  "job": {
    "description": "Detects spikes in compliance failures",
    "groups": ["aws", "security-chain", "cloudloadgen"],
    "analysis_config": {
      "bucket_span": "30m",
      "detectors": [
        {
          "detector_description": "high_count partitionfield=cloud.region",
          "function": "high_count",
          "partition_field_name": "cloud.region",
          "detector_index": 0
        }
      ],
      "influencers": ["cloud.region", "rule.id"]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "32mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "aws-load-generator-security-finding-chain",
      "tags": ["cloudloadgen"]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-aws-security-hub-compliance-anomaly",
    "job_id": "aws-security-hub-compliance-anomaly",
    "indices": ["logs-aws.securityhub_findings*"],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "aws.securityhub_findings.Compliance.Status": "FAILED"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
