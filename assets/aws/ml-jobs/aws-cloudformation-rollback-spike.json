{
  "_meta": {
    "job_id": "aws-cloudformation-rollback-spike",
    "group": "management",
    "api_job": "PUT _ml/anomaly_detectors/aws-cloudformation-rollback-spike",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-aws-cloudformation-rollback-spike",
    "api_open": "POST _ml/anomaly_detectors/aws-cloudformation-rollback-spike/_open",
    "api_start": "POST _ml/datafeeds/datafeed-aws-cloudformation-rollback-spike/_start"
  },
  "job": {
    "description": "Detects unusual CloudFormation stack rollback and failure rates — signals infrastructure deployment instability or repeated bad deploys",
    "groups": ["aws", "management", "cloudloadgen"],
    "analysis_config": {
      "bucket_span": "15m",
      "detectors": [
        {
          "detector_description": "high_count",
          "function": "high_count",
          "detector_index": 0
        }
      ],
      "influencers": ["cloud.region", "cloud.account.id"]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "16mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "aws-elastic-load-generator",
      "tags": ["cloudloadgen"]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-aws-cloudformation-rollback-spike",
    "job_id": "aws-cloudformation-rollback-spike",
    "indices": ["logs-aws.*"],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "event.dataset": "aws.cloudformation"
            }
          }
        ],
        "should": [
          {
            "wildcard": {
              "aws.cloudformation.stack_status": "*ROLLBACK*"
            }
          },
          {
            "wildcard": {
              "aws.cloudformation.stack_status": "*FAILED*"
            }
          }
        ],
        "minimum_should_match": 1
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
