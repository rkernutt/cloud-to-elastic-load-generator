{
  "_meta": {
    "job_id": "aws-athena-data-scanned-spike",
    "group": "analytics",
    "api_job": "PUT _ml/anomaly_detectors/aws-athena-data-scanned-spike",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-aws-athena-data-scanned-spike",
    "api_open": "POST _ml/anomaly_detectors/aws-athena-data-scanned-spike/_open",
    "api_start": "POST _ml/datafeeds/datafeed-aws-athena-data-scanned-spike/_start"
  },
  "job": {
    "description": "Detects unusual data scan volumes — primary cost anomaly signal for Athena",
    "groups": ["aws", "analytics", "cloudloadgen"],
    "analysis_config": {
      "bucket_span": "15m",
      "detectors": [
        {
          "detector_description": "high_sum(aws.athena.data_scanned_bytes) partitionfield=aws.athena.workgroup",
          "function": "high_sum",
          "field_name": "aws.athena.data_scanned_bytes",
          "partition_field_name": "aws.athena.workgroup",
          "detector_index": 0
        }
      ],
      "influencers": ["aws.athena.workgroup", "aws.athena.database"]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "32mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "aws-elastic-load-generator",
      "tags": ["cloudloadgen"]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-aws-athena-data-scanned-spike",
    "job_id": "aws-athena-data-scanned-spike",
    "indices": ["logs-aws.*"],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "event.dataset": "aws.athena"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
