{
  "_meta": {
    "job_id": "aws-drs-replication-lag-anomaly",
    "group": "aws-ml-extended-services-a",
    "api_job": "PUT _ml/anomaly_detectors/aws-drs-replication-lag-anomaly",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-aws-drs-replication-lag-anomaly",
    "api_open": "POST _ml/anomaly_detectors/aws-drs-replication-lag-anomaly/_open",
    "api_start": "POST _ml/datafeeds/datafeed-aws-drs-replication-lag-anomaly/_start"
  },
  "job": {
    "description": "Detects unusually high Elastic Disaster Recovery replication lag per source server (replication pipeline stalling or network degradation)",
    "groups": ["aws", "aws-ml-extended-services-a", "cloudloadgen"],
    "analysis_config": {
      "bucket_span": "15m",
      "detectors": [
        {
          "detector_description": "high_mean(aws.drs.lag_duration_seconds) partitionfield=aws.drs.source_hostname",
          "function": "high_mean",
          "field_name": "aws.drs.lag_duration_seconds",
          "partition_field_name": "aws.drs.source_hostname",
          "detector_index": 0
        }
      ],
      "influencers": ["aws.drs.source_hostname", "cloud.account.id", "cloud.region"]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "32mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "aws-elastic-load-generator",
      "tags": ["cloudloadgen"]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-aws-drs-replication-lag-anomaly",
    "job_id": "aws-drs-replication-lag-anomaly",
    "indices": ["logs-aws.*"],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "event.dataset": "aws.drs"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
