{
  "_meta": {
    "job_id": "aws-cloudwatch-alarm-storm",
    "group": "management",
    "api_job": "PUT _ml/anomaly_detectors/aws-cloudwatch-alarm-storm",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-aws-cloudwatch-alarm-storm",
    "api_open": "POST _ml/anomaly_detectors/aws-cloudwatch-alarm-storm/_open",
    "api_start": "POST _ml/datafeeds/datafeed-aws-cloudwatch-alarm-storm/_start"
  },
  "job": {
    "description": "Detects correlated CloudWatch alarm storms — unusually many alarms firing at once (meta-monitoring for infrastructure-wide incidents)",
    "groups": [
      "aws",
      "management",
      "cloudloadgen"
    ],
    "analysis_config": {
      "bucket_span": "5m",
      "detectors": [
        {
          "detector_description": "high_count",
          "function": "high_count",
          "detector_index": 0
        }
      ],
      "influencers": [
        "cloud.region",
        "cloud.account.id"
      ]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "16mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "aws-elastic-load-generator",
      "tags": [
        "cloudloadgen"
      ]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-aws-cloudwatch-alarm-storm",
    "job_id": "aws-cloudwatch-alarm-storm",
    "indices": [
      "logs-aws.*"
    ],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "event.dataset": "aws.cloudwatch"
            }
          },
          {
            "term": {
              "aws.cloudwatch.alarm_state": "ALARM"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
