{
  "_meta": {
    "job_id": "aws-connect-contact-abandonment-spike",
    "group": "media",
    "api_job": "PUT _ml/anomaly_detectors/aws-connect-contact-abandonment-spike",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-aws-connect-contact-abandonment-spike",
    "api_open": "POST _ml/anomaly_detectors/aws-connect-contact-abandonment-spike/_open",
    "api_start": "POST _ml/datafeeds/datafeed-aws-connect-contact-abandonment-spike/_start"
  },
  "job": {
    "description": "Detects unusual spikes in abandoned contacts per Connect queue — understaffing, outages, or UX problems",
    "groups": [
      "aws",
      "media",
      "cloudloadgen"
    ],
    "analysis_config": {
      "bucket_span": "15m",
      "detectors": [
        {
          "detector_description": "high_count partitionfield=aws.connect.queue.name",
          "function": "high_count",
          "partition_field_name": "aws.connect.queue_name",
          "detector_index": 0
        }
      ],
      "influencers": [
        "aws.connect.queue_name",
        "cloud.region"
      ]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "32mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "aws-elastic-load-generator",
      "tags": [
        "cloudloadgen"
      ]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-aws-connect-contact-abandonment-spike",
    "job_id": "aws-connect-contact-abandonment-spike",
    "indices": [
      "logs-aws.*"
    ],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "event.dataset": "aws.connect"
            }
          },
          {
            "term": {
              "aws.connect.contact.disconnect_reason": "CUSTOMER_DISCONNECT"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
