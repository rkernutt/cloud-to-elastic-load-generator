{
  "_meta": {
    "job_id": "aws-apigateway-logs-latency-anomaly",
    "group": "networking",
    "api_job": "PUT _ml/anomaly_detectors/aws-apigateway-logs-latency-anomaly",
    "api_datafeed": "PUT _ml/datafeeds/datafeed-aws-apigateway-logs-latency-anomaly",
    "api_open": "POST _ml/anomaly_detectors/aws-apigateway-logs-latency-anomaly/_open",
    "api_start": "POST _ml/datafeeds/datafeed-aws-apigateway-logs-latency-anomaly/_start"
  },
  "job": {
    "description": "Detects unusual API Gateway latency per stage",
    "groups": ["aws", "networking", "cloudloadgen"],
    "analysis_config": {
      "bucket_span": "15m",
      "detectors": [
        {
          "detector_description": "High mean API Gateway latency by stage",
          "function": "high_mean",
          "field_name": "aws.apigateway.metrics.Latency.avg",
          "partition_field_name": "aws.apigateway.stage",
          "detector_index": 0
        }
      ],
      "influencers": ["aws.apigateway.stage", "cloud.region"]
    },
    "allow_lazy_open": true,
    "analysis_limits": {
      "model_memory_limit": "32mb"
    },
    "data_description": {
      "time_field": "@timestamp"
    },
    "custom_settings": {
      "created_by": "aws-elastic-load-generator",
      "tags": ["cloudloadgen"]
    }
  },
  "datafeed": {
    "datafeed_id": "datafeed-aws-apigateway-logs-latency-anomaly",
    "job_id": "aws-apigateway-logs-latency-anomaly",
    "indices": ["logs-aws.*"],
    "max_empty_searches": 10,
    "query": {
      "bool": {
        "filter": [
          {
            "term": {
              "event.dataset": "aws.apigateway_logs"
            }
          }
        ]
      }
    },
    "chunking_config": {
      "mode": "auto"
    },
    "query_delay": "60s",
    "delayed_data_check_config": {
      "enabled": true
    }
  }
}
