{
  "_meta": {
    "pipeline_id": "logs-aws.b2bi-default",
    "dataset": "aws.b2bi",
    "group": "analytics",
    "api": "PUT _ingest/pipeline/logs-aws.b2bi-default"
  },
  "description": "Parse AWS B2B Data Interchange EDI transformation log JSON",
  "processors": [
    {
      "json": {
        "field": "message",
