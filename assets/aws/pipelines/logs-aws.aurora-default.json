{
  "_meta": {
    "pipeline_id": "logs-aws.aurora-default",
    "dataset": "aws.aurora",
    "group": "databases",
    "api": "PUT _ingest/pipeline/logs-aws.aurora-default"
  },
  "description": "Parse Amazon Aurora cluster event log JSON",
  "processors": [
    {
      "json": {
        "field": "message",
        "target_field": "aurora.parsed",
        "ignore_failure": true
      }
    },
    {
      "rename": {
        "field": "aurora.parsed.db_instance",
        "target_field": "aurora.instance",
        "ignore_missing": true,
        "ignore_failure": true
      }
    },
    {
      "rename": {
        "field": "aurora.parsed.instance_id",
        "target_field": "aurora.instance",
        "ignore_missing": true,
        "ignore_failure": true
      }
    },
    {
      "rename": {
        "field": "aurora.parsed.query",
        "target_field": "aurora.query",
        "ignore_missing": true,
        "ignore_failure": true
      }
    },
    {
      "rename": {
        "field": "aurora.parsed.operation",
        "target_field": "aurora.operation",
        "ignore_missing": true,
        "ignore_failure": true
      }
    },
    {
      "rename": {
        "field": "aurora.parsed.latency",
        "target_field": "aurora.latency_ms",
        "ignore_missing": true,
        "ignore_failure": true
      }
    },
    {
      "rename": {
        "field": "aurora.parsed.connections",
        "target_field": "aurora.connections",
        "ignore_missing": true,
        "ignore_failure": true
      }
    },
    {
      "rename": {
        "field": "aurora.parsed.user",
        "target_field": "db.user.name",
        "ignore_missing": true,
        "ignore_failure": true
      }
    },
    {
      "rename": {
        "field": "aurora.parsed.statement",
        "target_field": "aurora.statement",
        "ignore_missing": true,
        "ignore_failure": true
      }
    },
    {
      "rename": {
        "field": "aurora.parsed.errorCode",
        "target_field": "error.code",
        "ignore_missing": true,
        "ignore_failure": true
      }
    },
    {
      "rename": {
        "field": "aurora.parsed.error_code",
        "target_field": "error.code",
        "ignore_missing": true,
        "ignore_failure": true
      }
    },
    {
      "rename": {
        "field": "aurora.parsed.errorMessage",
        "target_field": "error.message",
        "ignore_missing": true,
        "ignore_failure": true
      }
    },
    {
      "rename": {
        "field": "aurora.parsed.error_message",
        "target_field": "error.message",
        "ignore_missing": true,
        "ignore_failure": true
      }
    },
    {
      "rename": {
        "field": "aurora.parsed.errorType",
        "target_field": "error.type",
        "ignore_missing": true,
        "ignore_failure": true
      }
    },
    {
      "rename": {
        "field": "aurora.parsed.error_type",
        "target_field": "error.type",
        "ignore_missing": true,
        "ignore_failure": true
      }
    },
    {
      "rename": {
        "field": "aurora.parsed.level",
        "target_field": "log.level",
        "ignore_missing": true,
        "ignore_failure": true
      }
    },
    {
      "rename": {
        "field": "aurora.parsed.logLevel",
        "target_field": "log.level",
        "ignore_missing": true,
        "ignore_failure": true
      }
    },
    {
      "rename": {
        "field": "aurora.parsed.severity",
        "target_field": "log.level",
        "ignore_missing": true,
        "ignore_failure": true
      }
    },
    {
      "lowercase": {
        "field": "log.level",
        "ignore_missing": true,
        "ignore_failure": true
      }
    },
    {
      "set": {
        "field": "event.kind",
        "value": "event",
        "override": false,
        "ignore_failure": true
      }
    },
    {
      "set": {
        "field": "event.category",
        "value": ["database"],
        "override": false,
        "ignore_failure": true
      }
    },
    {
      "set": {
        "field": "event.type",
        "value": ["info"],
        "override": false,
        "ignore_failure": true
      }
    },
    {
      "set": {
        "field": "event.type",
        "value": ["error"],
        "override": true,
        "if": "ctx.event?.outcome == 'failure'",
        "ignore_failure": true
      }
    },
    {
      "script": {
        "lang": "painless",
        "description": "Normalise duration fields to event.duration (nanoseconds)",
        "source": "long nanos = 0L;\n          // Check parsed duration_ms, durationMs, durationSeconds, latency_ms, execution_time_ms\n          def p = ctx['aurora']?.parsed;\n          if (p != null) {\n            if (p.containsKey('duration_ms'))        { nanos = (long)(p.duration_ms * 1000000L); }\n            else if (p.containsKey('durationMs'))     { nanos = (long)(p.durationMs * 1000000L); }\n            else if (p.containsKey('durationSeconds')){ nanos = (long)(p.durationSeconds * 1000000000L); }\n            else if (p.containsKey('latency_ms'))     { nanos = (long)(p.latency_ms * 1000000L); }\n            else if (p.containsKey('execution_time_ms')) { nanos = (long)(p.execution_time_ms * 1000000L); }\n            else if (p.containsKey('elapsed_ms'))     { nanos = (long)(p.elapsed_ms * 1000000L); }\n          }\n          if (nanos > 0 && ctx.event?.duration == null) {\n            if (ctx.event == null) { ctx.event = new HashMap(); }\n            ctx.event.duration = nanos;\n          }",
        "ignore_failure": true
      }
    },
    {
      "geoip": {
        "field": "source.ip",
        "target_field": "source.geo",
        "ignore_missing": true,
        "ignore_failure": true
      }
    },
    {
      "geoip": {
        "field": "client.ip",
        "target_field": "client.geo",
        "ignore_missing": true,
        "ignore_failure": true
      }
    },
    {
      "geoip": {
        "field": "destination.ip",
        "target_field": "destination.geo",
        "ignore_missing": true,
        "ignore_failure": true
      }
    },
    {
      "user_agent": {
        "field": "user_agent.original",
        "target_field": "user_agent",
        "ignore_missing": true,
        "ignore_failure": true
      }
    },
    {
      "append": {
        "field": "related.ip",
        "value": ["{{{source.ip}}}"],
        "allow_duplicates": false,
        "if": "ctx.source?.ip != null",
        "ignore_failure": true
      }
    },
    {
      "append": {
        "field": "related.ip",
        "value": ["{{{destination.ip}}}"],
        "allow_duplicates": false,
        "if": "ctx.destination?.ip != null",
        "ignore_failure": true
      }
    },
    {
      "append": {
        "field": "related.ip",
        "value": ["{{{client.ip}}}"],
        "allow_duplicates": false,
        "if": "ctx.client?.ip != null",
        "ignore_failure": true
      }
    },
    {
      "append": {
        "field": "related.user",
        "value": ["{{{user.name}}}"],
        "allow_duplicates": false,
        "if": "ctx.user?.name != null",
        "ignore_failure": true
      }
    },
    {
      "append": {
        "field": "related.user",
        "value": ["{{{user.email}}}"],
        "allow_duplicates": false,
        "if": "ctx.user?.email != null",
        "ignore_failure": true
      }
    },
    {
      "append": {
        "field": "related.user",
        "value": ["{{{user.id}}}"],
        "allow_duplicates": false,
        "if": "ctx.user?.id != null",
        "ignore_failure": true
      }
    },
    {
      "append": {
        "field": "related.hosts",
        "value": ["{{{host.name}}}"],
        "allow_duplicates": false,
        "if": "ctx.host?.name != null",
        "ignore_failure": true
      }
    },
    {
      "append": {
        "field": "related.hosts",
        "value": ["{{{host.hostname}}}"],
        "allow_duplicates": false,
        "if": "ctx.host?.hostname != null",
        "ignore_failure": true
      }
    },
    {
      "remove": {
        "field": "aurora.parsed",
        "ignore_missing": true,
        "ignore_failure": true
      }
    }
  ],
  "on_failure": [
    {
      "set": {
        "field": "error.message",
        "value": "{{ _ingest.on_failure_message }}"
      }
    },
    {
      "append": {
        "field": "tags",
        "value": ["_ingest_pipeline_failure"]
      }
    },
    {
      "append": {
        "field": "tags",
        "value": ["_logs-aws.aurora-default_failure"]
      }
    }
  ]
}
