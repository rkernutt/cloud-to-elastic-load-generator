{
  "_meta": {
    "pipeline_id": "logs-aws.fsx-default",
    "dataset": "aws.fsx",
    "group": "storage",
    "api": "PUT _ingest/pipeline/logs-aws.fsx-default"
  },
  "description": "Parse Amazon FSx file system ops log JSON",
  "processors": [
    {
      "json": {
        "field": "message",
        "target_field": "fsx.parsed",
        "ignore_failure": true
      }
    }
  ]
}
