{
  "_meta": {
    "pipeline_id": "logs-aws.backup-default",
    "dataset": "aws.backup",
    "group": "storage",
    "api": "PUT _ingest/pipeline/logs-aws.backup-default"
  },
  "description": "Parse AWS Backup job status log JSON",
  "processors": [
    {
      "json": {
        "field": "message",
        "target_field": "backup.parsed",
        "ignore_failure": true
      }
    }
  ]
}
