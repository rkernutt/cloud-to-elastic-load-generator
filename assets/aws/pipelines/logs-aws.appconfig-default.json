{
  "_meta": {
    "pipeline_id": "logs-aws.appconfig-default",
    "dataset": "aws.appconfig",
    "group": "management",
    "api": "PUT _ingest/pipeline/logs-aws.appconfig-default"
  },
  "description": "Parse AWS AppConfig configuration deployment event JSON",
  "processors": [
    {
      "json": {
        "field": "message",
        "target_field": "appconfig.parsed",
        "ignore_failure": true
      }
    }
  ]
}
