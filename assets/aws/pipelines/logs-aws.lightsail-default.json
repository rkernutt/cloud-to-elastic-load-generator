{
  "_meta": {
    "pipeline_id": "logs-aws.lightsail-default",
    "dataset": "aws.lightsail",
    "group": "enduser",
    "api": "PUT _ingest/pipeline/logs-aws.lightsail-default"
  },
  "description": "Parse Amazon Lightsail instance event JSON",
  "processors": [
    {
      "json": {
        "field": "message",
        "target_field": "lightsail.parsed",
        "ignore_failure": true
      }
    }
  ]
}
