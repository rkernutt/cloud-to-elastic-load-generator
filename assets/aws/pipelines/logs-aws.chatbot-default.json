{
  "_meta": {
    "pipeline_id": "logs-aws.chatbot-default",
    "dataset": "aws.chatbot",
    "group": "management",
    "api": "PUT _ingest/pipeline/logs-aws.chatbot-default"
  },
  "description": "Parse AWS Chatbot notification delivery event JSON",
  "processors": [
    {
      "json": {
        "field": "message",
        "target_field": "chatbot.parsed",
        "ignore_failure": true
      }
    }
  ]
}
