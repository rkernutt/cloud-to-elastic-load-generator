{
  "_meta": {
    "pipeline_id": "logs-aws.firehose-default",
    "dataset": "aws.firehose",
    "group": "streaming",
    "api": "PUT _ingest/pipeline/logs-aws.firehose-default"
  },
  "description": "Parse Amazon Data Firehose delivery stream log JSON",
  "processors": [
    {
      "json": {
        "field": "message",
        "target_field": "firehose.parsed",
        "ignore_failure": true
      }
    }
  ]
}
