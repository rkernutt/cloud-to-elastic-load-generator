{
  "_meta": {
    "pipeline_id": "logs-aws.dax-default",
    "dataset": "aws.dax",
    "group": "databases",
    "api": "PUT _ingest/pipeline/logs-aws.dax-default"
  },
  "description": "Parse Amazon DynamoDB Accelerator (DAX) cache hit/miss and operation log JSON",
  "processors": [
    {
      "json": {
        "field": "message",
        "target_field": "dax.parsed",
        "ignore_failure": true
      }
    }
  ]
}
