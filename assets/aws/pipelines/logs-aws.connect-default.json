{
  "_meta": {
    "pipeline_id": "logs-aws.connect-default",
    "dataset": "aws.connect",
    "group": "enduser",
    "api": "PUT _ingest/pipeline/logs-aws.connect-default"
  },
  "description": "Parse Amazon Connect contact centre call log JSON",
  "processors": [
    {
      "json": {
        "field": "message",
        "target_field": "connect.parsed",
        "ignore_failure": true
      }
    }
  ]
}
