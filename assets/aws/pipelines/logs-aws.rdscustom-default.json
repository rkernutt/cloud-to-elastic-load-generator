{
  "_meta": {
    "pipeline_id": "logs-aws.rdscustom-default",
    "dataset": "aws.rdscustom",
    "group": "databases",
    "api": "PUT _ingest/pipeline/logs-aws.rdscustom-default"
  },
  "description": "Parse Amazon RDS Custom for SQL Server/Oracle instance event JSON",
  "processors": [
    {
      "json": {
        "field": "message",
