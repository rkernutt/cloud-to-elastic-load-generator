{
  "_meta": {
    "pipeline_id": "logs-aws.workspaces-default",
    "dataset": "aws.workspaces",
    "group": "enduser",
    "api": "PUT _ingest/pipeline/logs-aws.workspaces-default"
  },
  "description": "Parse Amazon WorkSpaces virtual desktop session JSON",
  "processors": [
    {
      "json": {
        "field": "message",
        "target_field": "workspaces.parsed",
        "ignore_failure": true
      }
    }
  ]
}
