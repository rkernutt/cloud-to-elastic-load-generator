{
  "_meta": {
    "pipeline_id": "logs-aws.kinesisanalytics-default",
    "dataset": "aws.kinesisanalytics",
    "group": "streaming",
    "api": "PUT _ingest/pipeline/logs-aws.kinesisanalytics-default"
  },
  "description": "Parse Amazon Kinesis Data Analytics real-time app log JSON",
  "processors": [
    {
      "json": {
        "field": "message",
        "target_field": "kinesisanalytics.parsed",
        "ignore_failure": true
      }
    }
  ]
}
