{
  "_meta": {
    "pipeline_id": "logs-aws.monitron-default",
    "dataset": "aws.monitron",
    "group": "aiml",
    "api": "PUT _ingest/pipeline/logs-aws.monitron-default"
  },
  "description": "Parse Amazon Monitron vibration and temperature sensor event JSON",
  "processors": [
    {
      "json": {
        "field": "message",
        "target_field": "monitron.parsed",
        "ignore_failure": true
      }
    }
  ]
}
