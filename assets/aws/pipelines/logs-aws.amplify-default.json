{
  "_meta": {
    "pipeline_id": "logs-aws.amplify-default",
    "dataset": "aws.amplify",
    "group": "devtools",
    "api": "PUT _ingest/pipeline/logs-aws.amplify-default"
  },
  "description": "Parse AWS Amplify build & deploy event JSON",
  "processors": [
    {
      "json": {
        "field": "message",
        "target_field": "amplify.parsed",
        "ignore_failure": true
      }
    }
  ]
}
