{
  "_meta": {
    "pipeline_id": "logs-aws.amazonmq-default",
    "dataset": "aws.amazonmq",
    "group": "streaming",
    "api": "PUT _ingest/pipeline/logs-aws.amazonmq-default"
  },
  "description": "Parse Amazon MQ ActiveMQ/RabbitMQ log JSON",
  "processors": [
    {
      "json": {
        "field": "message",
        "target_field": "amazonmq.parsed",
        "ignore_failure": true
      }
    }
  ]
}
