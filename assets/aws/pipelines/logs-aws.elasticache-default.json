{
  "_meta": {
    "pipeline_id": "logs-aws.elasticache-default",
    "dataset": "aws.elasticache",
    "group": "databases",
    "api": "PUT _ingest/pipeline/logs-aws.elasticache-default"
  },
  "description": "Parse Amazon ElastiCache Redis command log JSON",
  "processors": [
    {
      "json": {
        "field": "message",
        "target_field": "elasticache.parsed",
        "ignore_failure": true
      }
    }
  ]
}
