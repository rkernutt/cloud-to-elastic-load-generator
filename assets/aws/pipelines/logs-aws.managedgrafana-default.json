{
  "_meta": {
    "pipeline_id": "logs-aws.managedgrafana-default",
    "dataset": "aws.managedgrafana",
    "group": "management",
    "api": "PUT _ingest/pipeline/logs-aws.managedgrafana-default"
  },
  "description": "Parse Amazon Managed Grafana workspace and alert log JSON",
  "processors": [
    {
      "json": {
        "field": "message",
        "target_field": "managedgrafana.parsed",
        "ignore_failure": true
      }
    }
  ]
}
