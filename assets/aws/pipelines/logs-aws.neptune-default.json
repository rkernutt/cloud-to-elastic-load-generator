{
  "_meta": {
    "pipeline_id": "logs-aws.neptune-default",
    "dataset": "aws.neptune",
    "group": "databases",
    "api": "PUT _ingest/pipeline/logs-aws.neptune-default"
  },
  "description": "Parse Amazon Neptune graph DB query log JSON",
  "processors": [
    {
      "json": {
        "field": "message",
        "target_field": "neptune.parsed",
        "ignore_failure": true
      }
    }
  ]
}
