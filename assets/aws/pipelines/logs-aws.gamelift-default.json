{
  "_meta": {
    "pipeline_id": "logs-aws.gamelift-default",
    "dataset": "aws.gamelift",
    "group": "enduser",
    "api": "PUT _ingest/pipeline/logs-aws.gamelift-default"
  },
  "description": "Parse Amazon GameLift game server & matchmaking JSON",
  "processors": [
    {
      "json": {
        "field": "message",
        "target_field": "gamelift.parsed",
        "ignore_failure": true
      }
    }
  ]
}
