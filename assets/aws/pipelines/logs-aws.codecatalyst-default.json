{
  "_meta": {
    "pipeline_id": "logs-aws.codecatalyst-default",
    "dataset": "aws.codecatalyst",
    "group": "devtools",
    "api": "PUT _ingest/pipeline/logs-aws.codecatalyst-default"
  },
  "description": "Parse Amazon CodeCatalyst workflow run and dev environment log JSON",
  "processors": [
    {
      "json": {
        "field": "message",
        "target_field": "codecatalyst.parsed",
        "ignore_failure": true
      }
    }
  ]
}
