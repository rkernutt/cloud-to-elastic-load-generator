{
  "_meta": {
    "pipeline_id": "logs-aws.qldb-default",
    "dataset": "aws.qldb",
    "group": "databases",
    "api": "PUT _ingest/pipeline/logs-aws.qldb-default"
  },
  "description": "Parse Amazon QLDB ledger transaction log JSON",
  "processors": [
    {
      "json": {
        "field": "message",
