{
  "_meta": {
    "pipeline_id": "logs-aws.apprunner-default",
    "dataset": "aws.apprunner",
    "group": "serverless",
    "api": "PUT _ingest/pipeline/logs-aws.apprunner-default"
  },
  "description": "Parse AWS App Runner container log JSON",
  "processors": [
    {
      "json": {
        "field": "message",
        "target_field": "apprunner.parsed",
        "ignore_failure": true
      }
    }
  ]
}
