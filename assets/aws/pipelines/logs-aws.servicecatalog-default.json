{
  "_meta": {
    "pipeline_id": "logs-aws.servicecatalog-default",
    "dataset": "aws.servicecatalog",
    "group": "management",
    "api": "PUT _ingest/pipeline/logs-aws.servicecatalog-default"
  },
  "description": "Parse AWS Service Catalog provisioning event JSON",
  "processors": [
    {
      "json": {
        "field": "message",
        "target_field": "servicecatalog.parsed",
        "ignore_failure": true
      }
    }
  ]
}
