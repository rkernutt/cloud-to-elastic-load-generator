{
  "_meta": {
    "pipeline_id": "logs-aws.ec2_logs-default",
    "dataset": "aws.ec2_logs",
    "group": "compute",
    "api": "PUT _ingest/pipeline/logs-aws.ec2_logs-default"
  },
  "description": "Parse Amazon EC2 instance log JSON from message field",
  "processors": [
    {
      "json": {
        "field": "message",
        "target_field": "ec2.parsed",
        "ignore_failure": true
      }
    }
  ]
}
