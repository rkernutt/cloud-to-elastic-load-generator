{
  "_meta": {
    "pipeline_id": "logs-aws.codecommit-default",
    "dataset": "aws.codecommit",
    "group": "devtools",
    "api": "PUT _ingest/pipeline/logs-aws.codecommit-default"
  },
  "description": "Parse AWS CodeCommit git push/PR event JSON",
  "processors": [
    {
      "json": {
        "field": "message",
        "target_field": "codecommit.parsed",
        "ignore_failure": true
      }
    }
  ]
}
