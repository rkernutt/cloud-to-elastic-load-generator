{
  "_meta": {
    "pipeline_id": "logs-aws.eventbridge-default",
    "dataset": "aws.eventbridge",
    "group": "streaming",
    "api": "PUT _ingest/pipeline/logs-aws.eventbridge-default"
  },
  "description": "Parse Amazon EventBridge event routing log JSON",
  "processors": [
    {
      "json": {
        "field": "message",
        "target_field": "eventbridge.parsed",
        "ignore_failure": true
      }
    }
  ]
}
