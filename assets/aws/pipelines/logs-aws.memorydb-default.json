{
  "_meta": {
    "pipeline_id": "logs-aws.memorydb-default",
    "dataset": "aws.memorydb",
    "group": "databases",
    "api": "PUT _ingest/pipeline/logs-aws.memorydb-default"
  },
  "description": "Parse Amazon MemoryDB durable Redis log JSON",
  "processors": [
    {
      "json": {
        "field": "message",
        "target_field": "memorydb.parsed",
        "ignore_failure": true
      }
    }
  ]
}
