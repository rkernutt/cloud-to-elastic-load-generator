{
  "_meta": {
    "pipeline_id": "logs-aws.robomaker-default",
    "dataset": "aws.robomaker",
    "group": "devtools",
    "api": "PUT _ingest/pipeline/logs-aws.robomaker-default"
  },
  "description": "Parse AWS RoboMaker simulation and robot application event JSON",
  "processors": [
    {
      "json": {
        "field": "message",
        "target_field": "robomaker.parsed",
        "ignore_failure": true
      }
    }
  ]
}
