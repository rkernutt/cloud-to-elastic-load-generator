{
  "_meta": {
    "pipeline_id": "logs-aws.nova-default",
    "dataset": "aws.nova",
    "group": "aiml",
    "api": "PUT _ingest/pipeline/logs-aws.nova-default"
  },
  "description": "Parse Amazon Nova foundation model invocation log JSON",
  "processors": [
    {
      "json": {
        "field": "message",
        "target_field": "nova.parsed",
        "ignore_failure": true
      }
    }
  ]
}
