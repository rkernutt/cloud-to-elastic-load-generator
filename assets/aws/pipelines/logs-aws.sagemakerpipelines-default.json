{
  "_meta": {
    "pipeline_id": "logs-aws.sagemakerpipelines-default",
    "dataset": "aws.sagemakerpipelines",
    "group": "aiml",
    "api": "PUT _ingest/pipeline/logs-aws.sagemakerpipelines-default"
  },
  "description": "Parse Amazon SageMaker Pipelines workflow execution event JSON",
  "processors": [
    {
      "json": {
        "field": "message",
        "target_field": "sagemakerpipelines.parsed",
        "ignore_failure": true
      }
    }
  ]
}
