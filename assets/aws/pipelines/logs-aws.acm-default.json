{
  "_meta": {
    "pipeline_id": "logs-aws.acm-default",
    "dataset": "aws.acm",
    "group": "security",
    "api": "PUT _ingest/pipeline/logs-aws.acm-default"
  },
  "description": "Parse AWS Certificate Manager (ACM) certificate lifecycle log JSON",
  "processors": [
    {
      "json": {
        "field": "message",
        "target_field": "acm.parsed",
        "ignore_failure": true
      }
    }
  ]
}
