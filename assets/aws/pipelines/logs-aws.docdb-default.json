{
  "_meta": {
    "pipeline_id": "logs-aws.docdb-default",
    "dataset": "aws.docdb",
    "group": "databases",
    "api": "PUT _ingest/pipeline/logs-aws.docdb-default"
  },
  "description": "Parse Amazon DocumentDB MongoDB-compat query log JSON",
  "processors": [
    {
      "json": {
        "field": "message",
        "target_field": "docdb.parsed",
        "ignore_failure": true
      }
    }
  ]
}
