{
  "_meta": {
    "pipeline_id": "logs-aws.appsync-default",
    "dataset": "aws.appsync",
    "group": "serverless",
    "api": "PUT _ingest/pipeline/logs-aws.appsync-default"
  },
  "description": "Parse AWS AppSync GraphQL request log JSON",
  "processors": [
    {
      "json": {
        "field": "message",
        "target_field": "appsync.parsed",
        "ignore_failure": true
      }
    }
  ]
}
