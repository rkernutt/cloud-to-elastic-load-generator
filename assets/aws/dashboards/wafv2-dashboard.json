{
  "title": "AWS WAFv2 — Rules & Blocks",
  "time_range": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "type": "lens",
      "uid": "waf2-k1",
      "grid": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.waf* | STATS Events = COUNT()"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Events"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "waf2-k2",
      "grid": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.waf* | EVAL b = CASE(event.action == \"block\", 1, 0) | STATS m = AVG(b) | EVAL `Blocked %` = ROUND(m * 100, 1)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Blocked %"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "waf2-k3",
      "grid": {
        "x": 24,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.waf* | STATS `Blocked` = SUM(`aws.waf.metrics.BlockedRequests.sum`)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Blocked (sum)"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "waf2-k4",
      "grid": {
        "x": 36,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.waf* | STATS `Allowed` = SUM(`aws.waf.metrics.AllowedRequests.sum`)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Allowed (sum)"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "waf2-d1",
      "grid": {
        "x": 0,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Action",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.waf* | STATS c = COUNT() BY a = event.action | SORT c DESC"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "a"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "waf2-d2",
      "grid": {
        "x": 16,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Terminating rule",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.waf* | STATS c = COUNT() BY r = `aws.waf.terminatingRuleId` | SORT c DESC | LIMIT 10"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "r"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "waf2-d3",
      "grid": {
        "x": 32,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Outcome",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.waf* | STATS c = COUNT() BY o = event.outcome | SORT c DESC"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "o"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "waf2-l1",
      "grid": {
        "x": 0,
        "y": 15,
        "w": 48,
        "h": 10
      },
      "config": {
        "title": "Requests over time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.waf* | STATS c = COUNT() BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
                "column": "b"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "c",
                  "label": "Events"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "waf2-l2",
      "grid": {
        "x": 0,
        "y": 25,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Allowed vs blocked",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.waf* | STATS al = SUM(`aws.waf.metrics.AllowedRequests.sum`), bl = SUM(`aws.waf.metrics.BlockedRequests.sum`) BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
                "column": "b"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "al",
                  "label": "Allowed"
                },
                {
                  "operation": "value",
                  "column": "bl",
                  "label": "Blocked"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "waf2-l3",
      "grid": {
        "x": 24,
        "y": 25,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Counted rules",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.waf* | STATS cnt = SUM(`aws.waf.metrics.CountedRequests.sum`) BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
                "column": "b"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "cnt",
                  "label": "Counted"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "waf2-b1",
      "grid": {
        "x": 0,
        "y": 35,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Top client IPs",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "bar_horizontal",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.waf* | STATS c = COUNT() BY ip = `source.ip` | SORT c DESC | LIMIT 10"
              },
              "x": {
                "operation": "value",
                "column": "ip"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "c",
                  "label": "Requests"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "waf2-t1",
      "grid": {
        "x": 0,
        "y": 45,
        "w": 48,
        "h": 12
      },
      "config": {
        "title": "Recent evaluations",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.waf* | KEEP `@timestamp`, event.action, `aws.waf.terminatingRuleId`, `rule.ruleset`, `source.ip`, `http.request.method`, event.outcome | SORT `@timestamp` DESC | LIMIT 100"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "`@timestamp`",
              "label": "Time"
            },
            {
              "operation": "value",
              "column": "event.action",
              "label": "Action"
            },
            {
              "operation": "value",
              "column": "aws.waf.terminatingRuleId",
              "label": "Rule"
            },
            {
              "operation": "value",
              "column": "rule.ruleset",
              "label": "Ruleset"
            },
            {
              "operation": "value",
              "column": "source.ip",
              "label": "Client"
            },
            {
              "operation": "value",
              "column": "http.request.method",
              "label": "Method"
            },
            {
              "operation": "value",
              "column": "event.outcome",
              "label": "Outcome"
            }
          ],
          "rows": []
        }
      }
    }
  ]
}
