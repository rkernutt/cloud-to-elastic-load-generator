{
  "title": "AWS Inspector — Vulnerabilities",
  "time_range": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "type": "lens",
      "uid": "insp-k1",
      "grid": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.inspector* | STATS Findings = COUNT()"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Findings"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "insp-k2",
      "grid": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.inspector* | STATS Critical = SUM(CASE(`aws.inspector2.severity` == \"CRITICAL\", 1, 0))"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Critical"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "insp-k3",
      "grid": {
        "x": 24,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.inspector* | STATS High = SUM(CASE(`aws.inspector2.severity` == \"HIGH\", 1, 0))"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "High"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "insp-k4",
      "grid": {
        "x": 36,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.inspector* | STATS `Avg CVSS` = ROUND(AVG(`aws.inspector2.severity_score`), 1)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Avg CVSS"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "insp-d1",
      "grid": {
        "x": 0,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Severity",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.inspector* | STATS c = COUNT() BY s = `aws.inspector2.severity` | SORT c DESC"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "s"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "insp-d2",
      "grid": {
        "x": 16,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Finding type",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.inspector* | STATS c = COUNT() BY t = `aws.inspector2.type` | SORT c DESC | LIMIT 8"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "t"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "insp-d3",
      "grid": {
        "x": 32,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Resource type",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.inspector* | STATS c = COUNT() BY r = `aws.inspector2.resource_type` | SORT c DESC"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "r"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "insp-l1",
      "grid": {
        "x": 0,
        "y": 15,
        "w": 48,
        "h": 10
      },
      "config": {
        "title": "Findings over time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.inspector* | STATS c = COUNT() BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
                "column": "b"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "c",
                  "label": "Findings"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "insp-l2",
      "grid": {
        "x": 0,
        "y": 25,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Critical + high trend",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.inspector* | STATS ch = SUM(CASE(`aws.inspector2.severity` IN (\"CRITICAL\", \"HIGH\"), 1, 0)) BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
                "column": "b"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "ch",
                  "label": "Crit+High"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "insp-l3",
      "grid": {
        "x": 24,
        "y": 25,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Covered resources (avg)",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.inspector* | STATS cov = AVG(`aws.inspector2.metrics.CoveredResources.avg`) BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
                "column": "b"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "cov",
                  "label": "Resources"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "insp-b1",
      "grid": {
        "x": 0,
        "y": 35,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Top packages (CVE findings)",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "bar_horizontal",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.inspector* | WHERE `aws.inspector2.type` == \"PACKAGE_VULNERABILITY\" | STATS c = COUNT() BY p = `package.name` | SORT c DESC | LIMIT 10"
              },
              "x": {
                "operation": "value",
                "column": "p"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "c",
                  "label": "Findings"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "insp-t1",
      "grid": {
        "x": 0,
        "y": 45,
        "w": 48,
        "h": 12
      },
      "config": {
        "title": "Recent findings",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.inspector* | KEEP `@timestamp`, `aws.inspector2.severity`, `aws.inspector2.type`, `aws.inspector2.title`, `aws.inspector2.resource_id`, event.outcome | SORT `@timestamp` DESC | LIMIT 100"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "`@timestamp`",
              "label": "Time"
            },
            {
              "operation": "value",
              "column": "aws.inspector2.severity",
              "label": "Severity"
            },
            {
              "operation": "value",
              "column": "aws.inspector2.type",
              "label": "Type"
            },
            {
              "operation": "value",
              "column": "aws.inspector2.title",
              "label": "Title"
            },
            {
              "operation": "value",
              "column": "aws.inspector2.resource_id",
              "label": "Resource"
            },
            {
              "operation": "value",
              "column": "event.outcome",
              "label": "Outcome"
            }
          ],
          "rows": []
        }
      }
    }
  ]
}
