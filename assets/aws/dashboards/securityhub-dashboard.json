{
  "title": "AWS Security Hub — Findings & Compliance",
  "time_range": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "type": "lens",
      "uid": "sh-k1",
      "grid": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.securityhub_findings* | STATS Findings = COUNT()"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Findings"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "sh-k2",
      "grid": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.securityhub_findings* | EVAL f = CASE(`aws.securityhub_findings.Compliance.Status` == \"FAILED\", 1, 0) | STATS m = AVG(f) | EVAL `Failed %` = ROUND(m * 100, 1)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Failed %"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "sh-k3",
      "grid": {
        "x": 24,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.securityhub_findings* | STATS `Crit+High` = SUM(CASE(`aws.securityhub_findings.Severity.Label` == \"CRITICAL\" OR `aws.securityhub_findings.Severity.Label` == \"HIGH\", 1, 0))"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Critical+High"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "sh-k4",
      "grid": {
        "x": 36,
        "y": 0,
        "w": 12,
        "h": 5
      },
      "config": {
        "title": "",
        "attributes": {
          "type": "metric",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.securityhub_findings* | STATS `Controls` = COUNT_DISTINCT(`aws.securityhub_findings.Compliance.SecurityControlId`)"
          },
          "metrics": [
            {
              "type": "primary",
              "operation": "value",
              "column": "Distinct controls"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "sh-d1",
      "grid": {
        "x": 0,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Severity",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.securityhub_findings* | STATS c = COUNT() BY s = `aws.securityhub_findings.Severity.Label` | SORT c DESC"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "s"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "sh-d2",
      "grid": {
        "x": 16,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Compliance",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.securityhub_findings* | STATS c = COUNT() BY z = `aws.securityhub_findings.Compliance.Status` | SORT c DESC"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "z"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "sh-d3",
      "grid": {
        "x": 32,
        "y": 5,
        "w": 16,
        "h": 10
      },
      "config": {
        "title": "Workflow",
        "attributes": {
          "type": "donut",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.securityhub_findings* | STATS c = COUNT() BY w = `aws.securityhub_findings.Workflow.Status` | SORT c DESC | LIMIT 8"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "c"
            }
          ],
          "group_by": [
            {
              "operation": "value",
              "column": "w"
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "sh-l1",
      "grid": {
        "x": 0,
        "y": 15,
        "w": 48,
        "h": 10
      },
      "config": {
        "title": "Findings over time",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.securityhub_findings* | STATS c = COUNT() BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
                "column": "b"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "c",
                  "label": "Events"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "sh-l2",
      "grid": {
        "x": 0,
        "y": 25,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Failed vs passed",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.securityhub_findings* | STATS bad = SUM(CASE(`aws.securityhub_findings.Compliance.Status` == \"FAILED\", 1, 0)), ok = SUM(CASE(`aws.securityhub_findings.Compliance.Status` == \"PASSED\", 1, 0)) BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
                "column": "b"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "bad",
                  "label": "Failed"
                },
                {
                  "operation": "value",
                  "column": "ok",
                  "label": "Passed"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "sh-l3",
      "grid": {
        "x": 24,
        "y": 25,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Normalized severity",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "line",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.securityhub_findings* | STATS sev = AVG(`aws.securityhub_findings.Severity.Normalized`) BY b = BUCKET(`@timestamp`, 75, ?_tstart, ?_tend) | SORT b"
              },
              "x": {
                "operation": "value",
                "column": "b"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "sev",
                  "label": "Avg severity"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "sh-b1",
      "grid": {
        "x": 0,
        "y": 35,
        "w": 24,
        "h": 10
      },
      "config": {
        "title": "Top controls",
        "attributes": {
          "type": "xy",
          "axis": {
            "x": {
              "title": {
                "visible": false
              }
            },
            "left": {
              "title": {
                "visible": false
              }
            }
          },
          "layers": [
            {
              "type": "bar_horizontal",
              "dataset": {
                "type": "esql",
                "query": "FROM logs-aws.securityhub_findings* | STATS c = COUNT() BY ctl = `aws.securityhub_findings.Compliance.SecurityControlId` | SORT c DESC | LIMIT 10"
              },
              "x": {
                "operation": "value",
                "column": "ctl"
              },
              "y": [
                {
                  "operation": "value",
                  "column": "c",
                  "label": "Findings"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "lens",
      "uid": "sh-t1",
      "grid": {
        "x": 0,
        "y": 45,
        "w": 48,
        "h": 12
      },
      "config": {
        "title": "Recent findings",
        "attributes": {
          "type": "datatable",
          "dataset": {
            "type": "esql",
            "query": "FROM logs-aws.securityhub_findings* | KEEP `@timestamp`, `aws.securityhub_findings.Title`, `aws.securityhub_findings.Severity.Label`, `aws.securityhub_findings.Compliance.Status`, `rule.id`, event.outcome | SORT `@timestamp` DESC | LIMIT 100"
          },
          "metrics": [
            {
              "operation": "value",
              "column": "`@timestamp`",
              "label": "Time"
            },
            {
              "operation": "value",
              "column": "aws.securityhub_findings.Title",
              "label": "Title"
            },
            {
              "operation": "value",
              "column": "aws.securityhub_findings.Severity.Label",
              "label": "Severity"
            },
            {
              "operation": "value",
              "column": "aws.securityhub_findings.Compliance.Status",
              "label": "Compliance"
            },
            {
              "operation": "value",
              "column": "rule.id",
              "label": "Control"
            },
            {
              "operation": "value",
              "column": "event.outcome",
              "label": "Outcome"
            }
          ],
          "rows": []
        }
      }
    }
  ]
}
